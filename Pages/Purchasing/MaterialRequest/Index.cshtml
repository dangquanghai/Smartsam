@page
@model SmartSam.Pages.Purchasing.MaterialRequest.IndexModel
@{
    ViewData["Title"] = "Material Request";
    var canAllUsersCondition = (bool?)ViewData["CanShowPcCondition"] ?? false;
    var canStoremanCondition = (bool?)ViewData["CanShowStoreCondition"] ?? false;
    var storeGroupLocked = (bool?)ViewData["StoreGroupLocked"] ?? false;
    var isStoremanMode = string.Equals(Model.Filter.ConditionMode, "storeman", StringComparison.OrdinalIgnoreCase);
    var allUsersDisabledAttr = (!canAllUsersCondition || isStoremanMode) ? "disabled" : null;
    var storemanDisabledAttr = (!canStoremanCondition || !isStoremanMode) ? "disabled" : null;
}

<section class="content">
    <div class="container-fluid">
        <div class="row">

            <!-- SEARCH PANEL (LEFT) -->
            <div class="col-md-2">
                <div class="card card-info mr-search-panel">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-search"></i> Search
                        </h3>
                    </div>

                    <div class="card-body">
                        <form method="get" id="mrSearchForm">
                            <input type="hidden" name="Filter.PageIndex" value="1" />
                            <input type="hidden" name="Filter.PageSize" value="@Model.Filter.PageSize" />

                            <div class="form-group">
                                <label>Store Group</label>
                                <select asp-for="Filter.StoreGroup"
                                        asp-items="Model.StoreGroups"
                                        class="form-control"
                                        disabled="@storeGroupLocked"></select>
                                @if (storeGroupLocked)
                                {
                                    <input type="hidden" asp-for="Filter.StoreGroup" />
                                }
                            </div>

                            <div class="form-group">
                                <label>From Date - To Date</label>
                                <div class="mr-date-range-control">
                                    <input type="text"
                                           id="MrDateRange"
                                           class="form-control form-control-sm"
                                           readonly />
                                </div>
                                <input asp-for="Filter.FromDate" type="hidden" />
                                <input asp-for="Filter.ToDate" type="hidden" />
                            </div>

                            <fieldset class="mr-condition-box @(canAllUsersCondition ? string.Empty : "d-none") mr-condition-group @(isStoremanMode ? "mr-condition-group-disabled" : string.Empty)" data-condition-group="allUsers">
                                <legend class="mr-condition-legend">
                                    <div class="mr-condition-legend-control">
                                        <input type="radio" id="conditionModeAllUsers" name="Filter.ConditionMode" value="allUsers" class="mr-condition-mode-radio" @(!isStoremanMode ? "checked" : null) @(canAllUsersCondition ? null : "disabled") />
                                        <label for="conditionModeAllUsers">Condition for all users</label>
                                    </div>
                                </legend>

                                <div class="mr-condition-grid">
                                    <div class="form-group">
                                        <label>Request No</label>
                                        <input asp-for="Filter.RequestNo" type="text" class="form-control mr-request-no-input" disabled="@allUsersDisabledAttr" />
                                    </div>

                                    <div class="form-group">
                                        <label>Status</label>
                                        <div class="dropdown mr-status-dropdown">
                                            <button class="btn btn-outline-secondary dropdown-toggle text-left w-100" type="button" id="mrStatusDropdownBtn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" disabled="@allUsersDisabledAttr">
                                                Select status
                                            </button>
                                            <div class="dropdown-menu p-2 mr-status-menu" aria-labelledby="mrStatusDropdownBtn">
                                                <div class="mr-status-menu-actions mb-2">
                                                    <button type="button" class="btn btn-sm btn-outline-primary" id="mrStatusSelectAllBtn" disabled="@allUsersDisabledAttr">Select all</button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="mrStatusClearBtn" disabled="@allUsersDisabledAttr">Clear</button>
                                                </div>
                                                @foreach (var status in Model.Statuses)
                                                {
                                                    if (!int.TryParse(status.Value, out var statusValue))
                                                    {
                                                        continue;
                                                    }

                                                    var statusCheckboxId = $"mrStatus_{statusValue}";
                                                    var checkedAttr = Model.Filter.StatusIds.Contains(statusValue) ? "checked" : null;
                                                    <div class="custom-control custom-checkbox mr-status-option">
                                                        <input class="custom-control-input mr-status-checkbox" type="checkbox" id="@statusCheckboxId" name="Filter.StatusIds" value="@statusValue" data-label="@status.Text" @checkedAttr disabled="@allUsersDisabledAttr" />
                                                        <label class="custom-control-label" for="@statusCheckboxId">@status.Text</label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <small class="form-text text-muted mr-status-hint">Leave empty to show all statuses.</small>
                                    </div>

                                    <div class="custom-control custom-checkbox mb-1">
                                        <input asp-for="Filter.BuyGreaterThanZero" class="custom-control-input" disabled="@allUsersDisabledAttr" />
                                        <label asp-for="Filter.BuyGreaterThanZero" class="custom-control-label">Buy &gt; 0</label>
                                    </div>

                                    <div class="custom-control custom-checkbox mb-1">
                                        <input asp-for="Filter.AutoOnly" class="custom-control-input" disabled="@allUsersDisabledAttr" />
                                        <label asp-for="Filter.AutoOnly" class="custom-control-label">Auto</label>
                                    </div>
                                </div>
                            </fieldset>

                            <fieldset class="mr-condition-box @(canStoremanCondition ? string.Empty : "d-none") mr-condition-group @(!isStoremanMode ? "mr-condition-group-disabled" : string.Empty)" data-condition-group="storeman">
                                <legend class="mr-condition-legend">
                                    <div class="mr-condition-legend-control">
                                        <input type="radio" id="conditionModeStoreman" name="Filter.ConditionMode" value="storeman" class="mr-condition-mode-radio" @(isStoremanMode ? "checked" : null) @(canStoremanCondition ? null : "disabled") />
                                        <label for="conditionModeStoreman">Condition for storeman</label>
                                    </div>
                                </legend>

                                <div class="mr-condition-grid mr-condition-grid-store">
                                    <div class="form-group">
                                        <label class="mr-label-red">Item Code</label>
                                        <input asp-for="Filter.ItemCode" class="form-control" disabled="@storemanDisabledAttr" />
                                    </div>

                                    <div class="custom-control custom-checkbox mb-1">
                                        <input asp-for="Filter.IssueLessThanOrder" class="custom-control-input" disabled="@storemanDisabledAttr" />
                                        <label asp-for="Filter.IssueLessThanOrder" class="custom-control-label mr-label-red">Issue &lt; Oder</label>
                                    </div>
                                </div>
                            </fieldset>

                            <button type="submit" class="btn btn-primary btn-block mr-search-submit">
                                <i class="fas fa-search"></i> Search
                            </button>
                            <button type="button" id="btnAdvSearch" class="btn btn-default btn-block mt-2" disabled>
                                ADV Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- RESULT + ACTION (RIGHT) -->
            <div class="col-md-10 mr-result-panel-container" id="mrResultPanelContainer">
                <!-- RESULT GRID -->
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Request</h3>
                        <span class="badge badge-light ml-2" id="total-records-badge">@Model.TotalRecords records</span>
                        <!-- Pagination info trong header (bên phải) -->
                        <div class="card-tools float-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div id="pagination-info" class="d-inline-block mr-2" style="padding-top: 0.3rem;">
                                    <small>No records</small>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                    <!-- Pagination buttons sẽ được thêm bằng JS -->
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered" id="mrTable">
                                <thead class="thead-light">
                                    <tr>
                                        <th></th>
                                        <th>REQUEST_NO</th>
                                        <th>DATE_CREATE</th>
                                        <th>ACCORDINGTO</th>
                                        <th>KPGroupName</th>
                                        <th>MaterialStatusName</th>
                                        <th>PRNO</th>
                                        <th class="d-none">MaterialStatusID</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Rows != null && Model.Rows.Count > 0)
                                    {
                                        for (var rowIndex = 0; rowIndex < Model.Rows.Count; rowIndex++)
                                        {
                                            var r = Model.Rows[rowIndex];
                                            <tr data-id="@r.RequestNo">
                                                <td>
                                                    <input type="radio" name="selectedMr" value="@rowIndex">
                                                </td>
                                                <td style="white-space: nowrap;">
                                                    <a href="javascript:void(0)" class="mr-request-link text-primary font-weight-bold" style="text-decoration: underline;">
                                                        @r.RequestNo
                                                    </a>
                                                </td>
                                                <td>@r.DateCreateDisplay</td>
                                                <td class="vni-font" style="white-space: nowrap;">@r.AccordingTo</td>
                                                <td>@r.KPGroupName</td>
                                                <td>@r.MaterialStatusName</td>
                                                <td>@r.PrNo</td>
                                                <td style="display: none;">@r.MaterialStatusId</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center py-4">No requests found</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ACTION PANEL -->
                <div class="card card-outline card-primary mr-action-panel">
                    <div class="card-footer p-2 text-center">
                        @if (Model.CanCreateAutoMr)
                        {
                            <button type="button" id="btnCreateAuto" class="btn btn-danger btn-sm">CreateAT</button>
                        }
                        @if (Model.CanCreateMr)
                        {
                            <button type="button" id="btnAdd" class="btn btn-success btn-sm">
                                <i class="fas fa-plus"></i> Create MR
                            </button>
                        }
                        <button type="button" id="btnRefresh" class="btn btn-primary btn-sm">RefreshList</button>
                        <button type="button" id="btnClose" class="btn btn-secondary btn-sm">Close</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="modal fade" id="createMrModal" tabindex="-1" role="dialog" aria-labelledby="createMrModalLabel" aria-hidden="true" data-backdrop="static" data-keyboard="false">
        <div class="modal-dialog modal-xl create-mr-modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title" id="createMrModalLabel">ItemList</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body mr-pt-2">
                    <div class="row create-mr-top-row justify-content-center">
                        <div class="col-md-6 create-mr-column create-mr-side-col">
                            <div class="text-danger small font-weight-bold mb-2">
                                You have to fill at least 2 letters for item code or 5 letters in item name before "Search"
                            </div>
                            <div class="form-group mb-1">
                                <label class="mb-1">Item Code</label>
                                <div class="create-mr-input-row create-mr-code-row">
                                    <input type="text" id="createMrItemCode" class="form-control form-control-sm create-mr-text-input vni-font" maxlength="20" />
                                    <div class="custom-control custom-checkbox create-mr-balance-inline">
                                        <input type="checkbox" id="createMrCheckBalance" class="custom-control-input" />
                                        <label class="custom-control-label" for="createMrCheckBalance">Check Balance in Store</label>
                                    </div>
                                    <button type="button" id="createMrSearchBtn" class="btn btn-sm btn-primary create-mr-inline-btn">Search</button>
                                </div>
                            </div>
                            <div class="form-group mb-0">
                                <label class="mb-1">Item Name</label>
                                <input type="text" id="createMrItemName" class="form-control form-control-sm create-mr-text-input vni-font" maxlength="150" />
                            </div>
                        </div>
                        <div class="col-md-1 create-mr-middle-col"></div>
                        <div class="col-md-5 create-mr-column create-mr-side-col">
                            <form id="createMrSubmitForm" method="post" asp-page-handler="CreateMr" class="d-none">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="CreateDescription" id="createMrDescriptionInput" />
                                <input type="hidden" name="CreateLinesJson" id="createMrLinesJsonInput" />
                                <input type="hidden" name="CreateStoreGroup" id="createMrStoreGroupInput" />
                            </form>
                            <div class="form-group mb-0">
                                <div class="mr-create-desc-wrap">
                                    <label class="mb-1">Descriptions:</label>
                                    <div class="create-mr-input-row create-mr-input-row-top">
                                        <textarea id="createMrDescription" class="form-control form-control-sm create-mr-text-input create-mr-desc-textarea vni-font" rows="5" required></textarea>
                                        <button type="submit" form="createMrSubmitForm" class="btn btn-sm btn-primary create-mr-inline-btn" id="createMrConfirmBtn">CreateMR</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row create-mr-bottom-row justify-content-center">
                        <div class="col-md-6 create-mr-column create-mr-side-col">
                            <label class="mb-1 mr-item-selected-label">Search Results</label>
                            <div class="table-responsive border create-mr-table-wrap">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width:28px"></th>
                                            <th style="width:120px">ItemCode</th>
                                            <th>Item Name</th>
                                            <th style="width:70px">Uni</th>
                                            <th style="width:60px">In.S</th>
                                            <th style="width:76px">Order</th>
                                        </tr>
                                    </thead>
                                    <tbody id="createMrSearchResultBody">
                                        <tr><td colspan="6" class="text-center text-muted">No data</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="col-md-1 d-flex align-items-center justify-content-center py-3 create-mr-middle-col">
                            <div class="d-flex flex-column">
                                <button type="button" id="createMrMoveRightBtn" class="btn btn-outline-primary btn-sm mb-2">&gt;</button>
                                <button type="button" id="createMrMoveLeftBtn" class="btn btn-outline-secondary btn-sm">&lt;</button>
                            </div>
                        </div>
                        <div class="col-md-5 create-mr-column create-mr-side-col">
                            <label class="mb-1 mr-item-selected-label">Item Selected</label>
                            <div class="table-responsive border create-mr-table-wrap">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width:28px"></th>
                                            <th style="width:120px">ItemCode</th>
                                            <th>Item Name</th>
                                            <th style="width:70px">Uni</th>
                                            <th style="width:76px">Order</th>
                                        </tr>
                                    </thead>
                                    <tbody id="createMrSelectedBody">
                                        <tr><td colspan="5" class="text-center text-muted">No selected item</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            <small class="text-danger d-none mt-1" id="createMrValidation"></small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.CanCreateAutoMr)
{
    <div class="modal fade" id="createAutoMrModal" tabindex="-1" role="dialog" aria-labelledby="createAutoMrModalLabel" aria-hidden="true" data-backdrop="static" data-keyboard="false">
        <div class="modal-dialog create-auto-modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title" id="createAutoMrModalLabel">Generate MR</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pt-2 pb-1">
                    <form id="createAutoMrForm" method="post" asp-page-handler="CreateAuto">
                        @Html.AntiForgeryToken()
                        <div class="form-row">
                            <div class="form-group col-md-4 mb-2">
                                <label class="mb-1">Request No:</label>
                                <input type="text"
                                       class="form-control form-control-sm"
                                       value="@(Model.CreateAutoRequestNoPreview.HasValue ? Model.CreateAutoRequestNoPreview.Value.ToString() : "(auto)")"
                                       readonly />
                            </div>
                            <div class="form-group col-md-8 mb-2">
                                <label class="mb-1">Store Group:</label>
                                <select id="createAutoStoreGroup"
                                        name="CreateAutoStoreGroup"
                                        class="form-control form-control-sm"
                                        disabled="@storeGroupLocked">
                                    @foreach (var option in Model.StoreGroups)
                                    {
                                        <option value="@option.Value">@option.Text</option>
                                    }
                                </select>
                                @if (storeGroupLocked)
                                {
                                        <input type="hidden" name="CreateAutoStoreGroup" value="@Model.Filter.StoreGroup" />
                                }
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-4 mb-2">
                                <label class="mb-1">Date Create:</label>
                                <input type="date"
                                       name="CreateAutoDateCreate"
                                       class="form-control form-control-sm"
                                       value="@(Model.CreateAutoDateCreate.HasValue ? Model.CreateAutoDateCreate.Value.ToString("yyyy-MM-dd") : string.Empty)" />
                            </div>
                            <div class="form-group col-md-8 mb-2">
                                <label class="mb-1">According:</label>
                                <textarea name="CreateAutoDescription"
                                          id="createAutoDescription"
                                          class="form-control form-control-sm vni-font create-auto-according"
                                          rows="2">@((Model.CreateAutoDescription ?? string.Empty))</textarea>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-12 mb-0">
                                <label class="mb-1">From Date - To Date:</label>
                                <div class="mr-date-range-control create-auto-date-range-control">
                                    <input type="text"
                                           id="CreateAutoDateRange"
                                           class="form-control form-control-sm"
                                           readonly />
                                </div>
                                <input type="hidden"
                                       name="CreateAutoFromDate"
                                       value="@(Model.CreateAutoFromDate.HasValue ? Model.CreateAutoFromDate.Value.ToString("yyyy-MM-dd") : string.Empty)" />
                                <input type="hidden"
                                       name="CreateAutoToDate"
                                       value="@(Model.CreateAutoToDate.HasValue ? Model.CreateAutoToDate.Value.ToString("yyyy-MM-dd") : string.Empty)" />
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer create-auto-modal-footer">
                    <button type="submit" form="createAutoMrForm" class="btn btn-sm btn-primary">Generate</button>
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/Purchasing/MaterialRequest/index.css" asp-append-version="true" />
}

@section Scripts {
    @Html.AntiForgeryToken()
    <script src="~/js/Purchasing/MaterialRequest/index.js" asp-append-version="true"></script>
}
