@page
@model SmartSam.Pages.Purchasing.ApproveSupplierAnnualy.IndexModel
@{
    ViewData["Title"] = "Approve Supplier";

    Func<int, string> navUrl = (supplierId) => Url.Page("./Index", new
    {
        DeptId = Model.DeptId,
        PageIndex = Model.PageIndex,
        PageSize = Model.PageSize,
        CurrentSupplierId = supplierId
    }) ?? "#";

    var editAll = Model.CanEditAllSupplierFields;
    var commentOnly = Model.CanEditCommentOnly;
}

<section class="content">
    <div class="container-fluid">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            var alertClass = Model.MessageType switch
            {
                "success" => "alert-success",
                "warning" => "alert-warning",
                "error" => "alert-danger",
                _ => "alert-info"
            };
            <div class="alert @alertClass alert-dismissible fade show mb-2" role="alert">
                @Model.Message
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
        }

        <div class="card card-primary card-outline mb-2">
            <div class="card-header p-2 d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0">Approve Supplier</h3>
            </div>
            <div class="card-body p-2">
                @if (Model.CurrentSupplierDetail is null)
                {
                    <div class="text-muted">No supplier found for current scope.</div>
                }
                else
                {
                    <form method="post" id="approveSupplierForm">
                        <input type="hidden" asp-for="DeptId" />
                        <input type="hidden" asp-for="PageIndex" />
                        <input type="hidden" asp-for="PageSize" />
                        <input type="hidden" asp-for="CurrentSupplierId" />
                        <input type="hidden" asp-for="EditSupplier.SupplierID" />

                        <table class="table table-sm table-borderless approve-form-table mb-2">
                            <colgroup>
                                <col class="approve-col-label" />
                                <col class="approve-col-input" />
                                <col class="approve-col-label" />
                                <col class="approve-col-input" />
                                <col class="approve-col-label" />
                                <col class="approve-col-input" />
                                <col class="approve-col-label-sm" />
                                <col class="approve-col-check" />
                            </colgroup>
                            <tbody>
                                <tr>
                                    <th>Supplier Code</th>
                                    <td>
                                        <input asp-for="EditSupplier.SupplierCode" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th>Supplier Name</th>
                                    <td>
                                        <input asp-for="EditSupplier.SupplierName" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th>Address</th>
                                    <td>
                                        <input asp-for="EditSupplier.Address" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th class="text-right">IsNew</th>
                                    <td class="text-center isnew-cell">
                                        <input asp-for="EditSupplier.IsNew" type="checkbox" disabled="@(editAll ? null : "disabled")" />
                                    </td>
                                </tr>
                                <tr>
                                    <th>Phone</th>
                                    <td>
                                        <input asp-for="EditSupplier.Phone" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th>Fax</th>
                                    <td>
                                        <input asp-for="EditSupplier.Fax" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th>Certificate</th>
                                    <td>
                                        <input asp-for="EditSupplier.Certificate" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th class="text-right">Document</th>
                                    <td class="text-center isnew-cell">
                                        <input asp-for="EditSupplier.Document" type="checkbox" disabled="@(editAll ? null : "disabled")" />
                                    </td>
                                </tr>
                                <tr>
                                    <th>Business</th>
                                    <td colspan="7">
                                        <input asp-for="EditSupplier.Business" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                </tr>
                                <tr>
                                    <th>Contact</th>
                                    <td>
                                        <input asp-for="EditSupplier.Contact" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th>Position</th>
                                    <td>
                                        <input asp-for="EditSupplier.Position" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th>Mobile</th>
                                    <td>
                                        <input asp-for="EditSupplier.Mobile" class="form-control form-control-sm" readonly="@(editAll ? null : "readonly")" />
                                    </td>
                                    <th></th>
                                    <td></td>
                                </tr>
                                <tr>
                                    <th>Service</th>
                                    <td colspan="7">
                                        <textarea asp-for="EditSupplier.Service" class="form-control form-control-sm" rows="2" readonly="@(editAll ? null : "readonly")"></textarea>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Comment</th>
                                    <td colspan="7">
                                        <div class="d-flex align-items-start">
                                            <textarea asp-for="EditSupplier.Comment" class="form-control form-control-sm mr-2" rows="2" readonly="@((editAll || commentOnly) ? null : "readonly")"></textarea>
                                            <button
                                                type="submit"
                                                formaction="?handler=SaveMoreComment"
                                                class="btn btn-sm btn-secondary text-nowrap"
                                                disabled="@(!Model.CanEditComment ? "disabled" : null)">
                                                More Comment
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="d-flex align-items-center mb-2 module-action-bar">
                            <div class="d-flex align-items-center flex-wrap">
                                @if (Model.HasFirstSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-1" href="@navUrl(Model.FirstSupplierId!.Value)">&lt;&lt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-1" disabled>&lt;&lt;</button>
                                }

                                @if (Model.HasPrevSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-1" href="@navUrl(Model.PrevSupplierId!.Value)">&lt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-1" disabled>&lt;</button>
                                }

                                @if (Model.HasNextSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-1" href="@navUrl(Model.NextSupplierId!.Value)">&gt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-1" disabled>&gt;</button>
                                }

                                @if (Model.HasLastSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-3" href="@navUrl(Model.LastSupplierId!.Value)">&gt;&gt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-3" disabled>&gt;&gt;</button>
                                }

                                <button
                                    type="button"
                                    class="btn btn-sm btn-action-add mr-2"
                                    disabled="@(!Model.CanApproveByLevel ? "disabled" : null)"
                                    data-confirm-handler="Approve"
                                    data-confirm-title="Approve Confirmation"
                                    data-confirm-message="Are you sure you want to approve this supplier?"
                                    data-confirm-kind="primary">
                                    <i class="fas fa-check mr-1"></i>Approve Supplier
                                </button>
                                <button
                                    type="button"
                                    class="btn btn-sm btn-action-copy mr-2"
                                    disabled="@(!Model.CanDisapproveByLevel ? "disabled" : null)"
                                    data-confirm-handler="Disapprove"
                                    data-confirm-title="Disapprove Confirmation"
                                    data-confirm-message="Are you sure you want to disapprove this supplier?"
                                    data-confirm-kind="primary">
                                    <i class="fas fa-ban mr-1"></i>DisApprove Supplier
                                </button>
                                <a class="btn btn-sm btn-action-close mr-3" href="/Purchasing/Supplier/Index"><i class="fas fa-times mr-1"></i>Close</a>
                                <span class="text-danger font-weight-bold mr-3">@(string.IsNullOrWhiteSpace(Model.CurrentSupplierDetail?.SupplierStatusName) ? "N/A" : Model.CurrentSupplierDetail!.SupplierStatusName)</span>
                            </div>

                            <div class="d-flex align-items-center ml-auto">
                                <span class="text-primary font-weight-bold mr-3">@Model.CurrentSupplierPosition/@Model.CurrentPageSupplierCount Suppliers</span>
                                <input asp-for="GoToOrder" type="number" min="1" max="@Model.CurrentPageSupplierCount" class="form-control form-control-sm mr-2" style="width:80px" />
                                <button type="submit" formaction="?handler=GoTo" class="btn btn-sm btn-action-close goto-btn-compact"><i class="fas fa-share-square mr-1"></i>Go to</button>
                            </div>
                        </div>
                    </form>
                }
            </div>
        </div>

        <div class="modal fade" id="actionConfirmModal" tabindex="-1" role="dialog" aria-labelledby="actionConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header" id="actionConfirmModalHeader">
                        <h5 class="modal-title" id="actionConfirmModalLabel">Confirmation</h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body" id="actionConfirmModalBody"></div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary btn-sm" id="actionConfirmModalSubmitBtn">Confirm</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card card-secondary card-outline">
            <div class="card-header p-2">
                <h3 class="card-title">Purchase Order Information</h3>
            </div>
            <div class="card-body p-2">
                <div class="font-weight-bold">CountPO:3, Total Cost:376666 VND</div>
                <table class="table table-bordered table-sm mt-2 mb-0">
                    <thead>
                        <tr>
                            <th style="width:30%">Index Name</th>
                            <th style="width:30%">Sub Index</th>
                            <th style="width:20%">The Time</th>
                            <th style="width:20%">Point</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Delivery Time</td><td>Meet requirement</td><td>2</td><td>4</td></tr>
                        <tr><td>Goods Quality</td><td>Very Good</td><td>2</td><td>4</td></tr>
                        <tr><td>Supply Goods Quantity as per P.O</td><td>Always inadequate</td><td>2</td><td>4</td></tr>
                        <tr><td>Price</td><td>The same price with other subcontractors</td><td>4</td><td>3</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/Purchasing/ApproveSupplierAnnualy/index.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Purchasing/ApproveSupplierAnnualy/index.js" asp-append-version="true"></script>
}
