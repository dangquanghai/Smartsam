@page
@model SmartSam.Pages.Purchasing.PurchaseOrder.PurchaseOrderDetailModel
@{
    ViewData["Title"] = "Purchase Order Detail";
}

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <strong><i class="fas fa-check-circle"></i></strong> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        }

        <form method="post" id="purchaseOrderDetailForm">
            <input asp-for="Mode" type="hidden" />
            <input asp-for="Header.Id" type="hidden" />
            <input asp-for="DetailsJson" type="hidden" id="DetailsJson" />
            <input asp-for="ReturnUrl" type="hidden" />

            <div class="card card-primary card-outline">
                <div class="card-header py-2">
                    <h3 class="card-title">Purchase Order Detail</h3>
                </div>
                <div class="card-body pb-2">
                    <div class="purchase-order-header-layout">
                        <div class="purchase-order-header-left">
                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">PO. No.<span class="text-danger">*</span></label></div>
                                <div class="col-4">
                                    <input asp-for="Header.PONo" id="PONo" class="form-control form-control-sm" readonly />
                                </div>
                                <div class="col-2 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Order Date</label></div>
                                <div class="col-4">
                                    <input asp-for="Header.PODate" id="PODate" type="date" class="form-control form-control-sm" readonly="@Model.IsViewMode" />
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">PR No</label></div>
                                <div class="col-4">
                                    <select asp-for="Header.PRID" asp-items="Model.PrOptions" id="PRID" class="form-control form-control-sm" disabled="@Model.IsViewMode" style="width: 100%;">
                                        <option value="">-- Select PR --</option>
                                    </select>
                                </div>
                                <div class="col-2 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Currency</label></div>
                                <div class="col-4">
                                    <select asp-for="Header.Currency" asp-items="Model.CurrencyOptions" class="form-control form-control-sm" disabled="@Model.IsViewMode">
                                    </select>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">Supplier</label></div>
                                <div class="col-4">
                                    <select asp-for="Header.SupplierID" id="SupplierID" class="form-control form-control-sm" disabled="@Model.IsViewMode" style="width: 100%;">
                                        <option value="">-- Type supplier code or name --</option>
                                        @if (Model.Header.SupplierID.HasValue && !string.IsNullOrWhiteSpace(Model.CurrentSupplierText))
                                        {
                                            <option value="@Model.Header.SupplierID" selected>@Model.CurrentSupplierText</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-2 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Ass. Level</label></div>
                                <div class="col-4">
                                    <select asp-for="Header.AssessLevel" asp-items="Model.AssessLevelOptions" class="form-control form-control-sm" disabled="@Model.IsViewMode">
                                        <option value="">-- Select Assess Level --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">ExRate</label></div>
                                <div class="col-4">
                                    <input asp-for="Header.ExRate" id="ExRate" class="form-control form-control-sm text-right" readonly="@Model.IsViewMode" />
                                </div>
                                <div class="col-2 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Status</label></div>
                                <div class="col-4">
                                    <select asp-for="Header.StatusId" asp-items="Model.StatusOptions" class="form-control form-control-sm" disabled>
                                    </select>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-start mb-2">
                                <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">Note</label></div>
                                <div class="col-10">
                                    <textarea asp-for="Header.Note"
                                              id="Note"
                                              rows="2"
                                              maxlength="100"
                                              oninput="if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);"
                                              class="form-control form-control-sm vni-font"
                                              readonly="@Model.IsViewMode"></textarea>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-start mb-0">
                                <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">Subject</label></div>
                                <div class="col-10">
                                    <input asp-for="Header.Remark" id="Remark" maxlength="100" class="form-control form-control-sm vni-font" readonly="@Model.IsViewMode" />
                                </div>
                            </div>
                        </div>

                        <div class="purchase-order-header-right">
                            <div class="purchase-order-header-field mb-2">
                                <label class="col-form-label-sm mt-1 mb-0">Terms &amp; Condition</label>
                                <div>
                                    <textarea asp-for="Header.POTerms" id="POTerms" rows="6" class="form-control form-control-sm vni-font" readonly="@Model.IsViewMode"></textarea>
                                </div>
                            </div>

                            <div class="purchase-order-vat-grid">
                                <div class="purchase-order-vat-label">
                                    <label class="col-form-label-sm mb-0">%VAT</label>
                                </div>
                                <div class="purchase-order-vat-value purchase-order-vat-value-sm">
                                    <input asp-for="Header.PerVAT" id="PerVAT" class="form-control form-control-sm text-right" readonly="@Model.IsViewMode" />
                                </div>
                                <div class="purchase-order-vat-label purchase-order-vat-label-secondary">
                                    <label class="col-form-label-sm mb-0">Before VAT</label>
                                </div>
                                <div class="purchase-order-vat-value">
                                    <input asp-for="Header.BeforeVAT" id="BeforeVAT" class="form-control form-control-sm text-right" readonly />
                                </div>

                                <div></div>
                                <div></div>
                                <div class="purchase-order-vat-label purchase-order-vat-label-secondary">
                                    <label class="col-form-label-sm mb-0">VAT</label>
                                </div>
                                <div class="purchase-order-vat-value">
                                    <input asp-for="Header.VAT" id="VAT" class="form-control form-control-sm text-right" readonly />
                                </div>

                                <div></div>
                                <div></div>
                                <div class="purchase-order-vat-label purchase-order-vat-label-secondary">
                                    <label class="col-form-label-sm mb-0">After VAT</label>
                                </div>
                                <div class="purchase-order-vat-value">
                                    <input asp-for="Header.AfterVAT" id="AfterVAT" class="form-control form-control-sm text-right" readonly />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="purchase-order-action-bar">
                        @if (Model.CanSave)
                        {
                            <button type="submit" class="btn btn-sm btn-success mr-2" id="btnSave">
                                <i class="fas fa-save"></i> Save
                            </button>
                        }
                        @if (Model.CanPurchaserApprove)
                        {
                            <button type="button" class="btn btn-sm btn-success mr-2" id="btnPurchaserApprove">
                                <i class="fas fa-check"></i> Purchaser Approve
                            </button>
                        }
                        @if (Model.CanEvaluate)
                        {
                            <button type="button" class="btn btn-sm btn-primary mr-2" id="btnEvaluate">
                                <i class="fas fa-star"></i> @(Model.CanEditEvaluate ? "Evaluate" : "Evaluate View")
                            </button>
                        }
                        @if (Model.CanApprove)
                        {
                            <button type="button" class="btn btn-sm btn-info mr-2" id="btnApprove">
                                <i class="fas fa-check"></i> Approve
                            </button>
                        }
                        @if (Model.CanBackToProcessing)
                        {
                            <button type="button" class="btn btn-sm btn-warning mr-2" id="btnBackToProcessingDetail">
                                <i class="fas fa-undo"></i> Back to Processing
                            </button>
                        }
                        <button type="button" class="btn btn-sm btn-secondary mr-2" id="btnCalculateTotal">
                            <i class="fas fa-calculator"></i> CalSum
                        </button>
                        @if (Model.Header.Id > 0)
                        {
                            <button type="button" class="btn btn-sm btn-primary mr-2" id="btnOpenPurchaseOrderReport">
                                <i class="fas fa-file-pdf"></i> Report
                            </button>
                        }
                        @if (Model.Header.Id > 0)
                        {
                            <button type="button" class="btn btn-sm btn-secondary mr-2" id="btnOpenPurchaseOrderAttachments">
                                <i class="fas fa-paperclip"></i> Attached Files
                            </button>
                        }
                        <a href="@Model.BackToListUrl" class="btn btn-sm btn-default">
                            <i class="fas fa-arrow-left"></i> Back to list
                        </a>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover mb-0 po-wide-table" id="purchaseOrderDetailTable">
                            <colgroup>
                                <col style="width: 28px;" />
                                <col style="width: 110px;" />
                                <col style="min-width: 260px;" />
                                <col style="width: 80px;" />
                                <col style="width: 90px;" />
                                <col style="width: 100px;" />
                                <col style="width: 120px;" />
                                <col style="width: 70px;" />
                                <col style="width: 190px;" />
                                <col style="width: 90px;" />
                                <col style="width: 100px;" />
                                <col style="width: 110px;" />
                            </colgroup>
                            <thead class="thead-light">
                                <tr>
                                    <th style="width: 50px;" class="text-center">@(Model.CanSave ? "" : "STT")</th>
                                    <th style="width: 110px;">Item Code</th>
                                    <th style="min-width: 260px;">Item Name</th>
                                    <th style="width: 80px;">Unit</th>
                                    <th style="width: 100px;" class="text-center">Qty</th>
                                    <th style="width: 100px;" class="text-center">U.Price</th>
                                    <th style="width: 100px;" class="text-center">PO Amount</th>
                                    <th style="width: 100px;">Dept</th>
                                    <th style="width: 190px;">Note</th>
                                    <th style="width: 100px;" class="text-center">Rec Qty</th>
                                    <th style="width: 100px;" class="text-center">Rec Amount</th>
                                    <th style="width: 110px;" class="text-center">Rec Date</th>
                                </tr>
                            </thead>
                            <tbody id="purchaseOrderDetailRows">
                                <tr id="purchaseOrderDetailEmptyRow">
                                    <td colspan="12" class="text-center text-muted">No detail rows</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer py-2">
                    @if (Model.CanSave)
                    {
                        <button type="button" class="btn btn-sm btn-success mr-2" id="btnAddDetail">
                            <i class="fas fa-plus"></i> Add Detail
                        </button>
                    }
                    <span class="float-right">Total Record(s): <span id="purchaseOrderDetailCount">0</span></span>
                </div>
            </div>
        </form>

        <form method="post" asp-page-handler="Evaluate" id="poEvaluateForm">
            <input type="hidden" name="Header.Id" value="@Model.Header.Id" />
            <input type="hidden" name="Mode" value="@Model.Mode" />
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            <input type="hidden" name="EstimatePoint" id="EvaluateEstimatePointInput" />
        </form>

        <form method="post" asp-page-handler="PurchaserApprove" id="poPurchaserApproveForm">
            <input type="hidden" name="Header.Id" value="@Model.Header.Id" />
            <input type="hidden" name="Mode" value="@Model.Mode" />
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        </form>

        <form method="post" asp-page-handler="Approve" id="poApproveForm">
            <input type="hidden" name="Header.Id" value="@Model.Header.Id" />
            <input type="hidden" name="Mode" value="@Model.Mode" />
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        </form>

        <form method="post" asp-page-handler="BackToProcessing" id="poBackToProcessingForm">
            <input type="hidden" name="Header.Id" value="@Model.Header.Id" />
            <input type="hidden" name="Mode" value="@Model.Mode" />
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            <input type="hidden" name="ConvertReason" id="ConvertReasonInput" />
        </form>

        @if (Model.CanSave)
        {
            <div class="modal fade" id="purchaseOrderAddDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-dialog modal-xl purchase-order-adddetail-modal-dialog" role="document">
                    <div class="modal-content">
                        <div class="modal-header py-2">
                            <h5 class="modal-title">Select Items From PR</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body pb-2">
                            <div class="text-danger small mb-2 d-none" id="purchaseOrderAddDetailError"></div>
                            <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover mb-0 po-wide-table" id="purchaseOrderPrLineTable">
                            <colgroup>
                                <col style="width: 50px;" />
                                <col style="width: 110px;" />
                                <col style="min-width: 190px;" />
                                <col style="width: 80px;" />
                                <col style="width: 90px;" />
                                <col style="width: 100px;" />
                                <col style="width: 180px;" />
                                <col style="width: 180px;" />
                            </colgroup>
                            <thead class="thead-light">
                                <tr>
                                    <th style="width: 50px;" class="text-center">
                                        <input type="checkbox" id="purchaseOrderPrCheckAll" />
                                    </th>
                                            <th style="width: 110px;">Item Code</th>
                                            <th style="min-width: 190px;">Item Name</th>
                                            <th style="width: 80px;">Unit</th>
                                            <th style="width: 90px;" class="text-center">Qty</th>
                                            <th style="width: 100px;" class="text-center">U.Price</th>
                                            <th style="width: 180px;">Remark</th>
                                            <th style="width: 180px;">Supplier</th>
                                        </tr>
                                    </thead>
                                    <tbody id="purchaseOrderPrLineRows">
                                        <tr>
                                            <td colspan="8" class="text-center text-muted">Please select PR first.</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer py-2">
                            <button type="button" class="btn btn-sm btn-primary" id="btnConfirmAddDetail" disabled>
                                Add
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="modal fade" id="purchaseOrderEvaluateModal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog purchase-order-evaluate-modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h5 class="modal-title">@(Model.CanEditEvaluate ? "Evaluate Purchase Order" : "Evaluate View")</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body purchase-order-evaluate-body">
                        <fieldset class="purchase-order-evaluate-fieldset">
                            <legend>Price</legend>
                            <div class="purchase-order-evaluate-options">
                            @foreach (var option in Model.EvaluateOptions)
                            {
                                var radioId = $"estimatePoint{option.EstimatePoint}";
                                <div class="custom-control custom-radio purchase-order-evaluate-option">
                                    <input class="custom-control-input" type="radio" id="@radioId" name="estimatePointOption" value="@option.EstimatePoint" @(Model.CurrentEstimatePoint == option.EstimatePoint ? "checked" : null) @(!Model.CanEditEvaluate ? "disabled" : null) />
                                    <label class="custom-control-label" for="@radioId">@option.DisplayText</label>
                                </div>
                            }
                            </div>
                        </fieldset>
                        @if (Model.CanEditEvaluate)
                        {
                            <div class="custom-control custom-checkbox purchase-order-evaluate-confirm">
                                <input type="checkbox" class="custom-control-input" id="confirmEstimateCheck" />
                                <label class="custom-control-label" for="confirmEstimateCheck">You make sure with your estimate</label>
                            </div>
                        }
                    </div>
                    <div class="modal-footer py-2 purchase-order-evaluate-footer">
                        @if (Model.CanEditEvaluate)
                        {
                            <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-sm btn-primary" id="btnConfirmEvaluate">OK</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Close</button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="purchaseOrderConvertModal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h5 class="modal-title">Reason to convert PO</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <textarea class="form-control form-control-sm vni-font" id="ConvertReasonText" rows="5"></textarea>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-warning" id="btnConfirmBackToProcessing">Convert</button>
                        <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="purchaseOrderReportPreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog modal-xl purchase-order-report-modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h5 class="modal-title">Purchase Order Report Preview</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body p-0 purchase-order-report-preview-body">
                        <div class="text-center text-muted py-4" id="purchaseOrderReportPreviewLoading">
                            <i class="fas fa-spinner fa-spin mr-1"></i> Loading report...
                        </div>
                        <iframe id="purchaseOrderReportPreviewFrame" class="purchase-order-report-preview-frame" title="Purchase Order Report Preview"></iframe>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-primary" id="btnExportPurchaseOrderReportPdf">
                            <i class="fas fa-file-pdf"></i> Export PDF
                        </button>
                        <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Header.Id > 0)
        {
            <div class="modal fade" id="purchaseOrderAttachmentModal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header py-2">
                            <h5 class="modal-title">Attached Files</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body pb-2">
                            @if (Model.AttachmentList.Count == 0)
                            {
                                <div class="text-muted small mb-3">No attached files.</div>
                            }
                            else
                            {
                                <form method="post" action="@Url.Page("./PurchaseOrderDetail", "DeleteAttachments", new { id = Model.Header.Id, mode = Model.Mode, returnUrl = Model.ReturnUrl })" id="poDeleteAttachmentsForm" class="purchase-order-attachment-delete-form">
                                    @Html.AntiForgeryToken()
                                    <input asp-for="Header.Id" type="hidden" />
                                    <input asp-for="Mode" type="hidden" />
                                    <input asp-for="ReturnUrl" type="hidden" />
                                    <div class="table-responsive mb-3 purchase-order-attachment-table-wrap">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead class="thead-light">
                                                <tr>
                                                    @if (Model.CanManageAttachments)
                                                    {
                                                        <th style="width:50px;" class="text-center"></th>
                                                    }
                                                    <th>File</th>
                                                    <th style="width:160px;">Modified Date</th>
                                                    <th style="width:120px;">Size</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var attachment in Model.AttachmentList)
                                                {
                                                    <tr>
                                                        @if (Model.CanManageAttachments)
                                                        {
                                                            <td class="text-center">
                                                                <input type="checkbox" name="SelectedAttachmentFileNames" value="@attachment.FileName" class="po-attachment-selector" />
                                                            </td>
                                                        }
                                                        <td>
                                                            <a asp-page="./PurchaseOrderDetail"
                                                               asp-page-handler="DownloadAttachment"
                                                               asp-route-id="@Model.Header.Id"
                                                               asp-route-fileName="@attachment.FileName">@attachment.FileName</a>
                                                        </td>
                                                        <td>@attachment.ModifiedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                                        <td>@attachment.SizeText</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </form>
                            }

                            @if (Model.CanManageAttachments)
                            {
                                <form method="post" enctype="multipart/form-data" action="@Url.Page("./PurchaseOrderDetail", "UploadAttachment", new { id = Model.Header.Id, mode = Model.Mode, returnUrl = Model.ReturnUrl })" id="poUploadAttachmentsForm">
                                    @Html.AntiForgeryToken()
                                    <input asp-for="Header.Id" type="hidden" />
                                    <input asp-for="Mode" type="hidden" />
                                    <input asp-for="ReturnUrl" type="hidden" />
                                    <div class="form-group mb-0">
                                        <label class="mb-1">Attached Files <span class="purchase-order-attachment-note">Allowed: @Model.AllowedAttachmentExtensionsText | Max size: @Model.MaxAttachmentSizeMb MB</span></label>
                                        <input type="file" name="AttachmentUploads" class="form-control-file" id="purchaseOrderAttachmentUpload" accept="@Model.AllowedAttachmentExtensionsText" multiple />
                                        <div id="purchaseOrderAttachmentError" class="text-danger small mt-1" style="display:none;"></div>
                                        <div class="mt-2">
                                            <button type="submit" class="btn btn-sm btn-action-add border" id="btnPurchaseOrderAttachmentUpload">
                                                <i class="fas fa-upload"></i> Upload
                                            </button>
                                            @if (Model.AttachmentList.Count > 0)
                                            {
                                                <button type="submit" class="btn btn-sm btn-action-disapprove border ml-2" id="btnPurchaseOrderAttachmentDelete" form="poDeleteAttachmentsForm" formnovalidate disabled>
                                                    <i class="fas fa-trash"></i> Delete Files
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/Purchasing/PurchaseOrder/detail.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.purchaseOrderDetailPage = {
