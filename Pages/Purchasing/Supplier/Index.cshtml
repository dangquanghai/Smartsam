@page
@model SmartSam.Pages.Purchasing.Supplier.IndexModel
@{
    @* Tracking comment: keep Supplier index file marked as touched for current work. *@
    ViewData["Title"] = "Suppliers";
}

<section class="content">
    <div class="container-fluid">
        @if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
        {
            <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.FlashMessageType) ? "info" : Model.FlashMessageType) alert-dismissible fade show mb-3" role="alert">
                <strong><i class="fas fa-check-circle"></i> Notification:</strong> @Model.FlashMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        <div id="supplierAjaxMessageHost" class="mb-3 d-none"></div>

        <div class="row">
            <!-- SEARCH PANEL (LEFT) -->
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-search"></i> Search
                        </h3>
                    </div>

                    <div class="card-body">
                        <form method="get" id="supplierSearchForm">
                            <input type="hidden" id="PageIndex" name="PageIndex" value="@Model.PageIndex" />
                            <input type="hidden" id="PageSize" name="PageSize" value="@(Model.PageSize > 0 ? Model.PageSize : Model.DefaultPageSize)" />
                            <!-- Row 1 -->
                            <div class="form-group">
                                <div class="custom-control custom-radio">
                                    <input class="custom-control-input" type="radio" id="viewCurrent" name="ViewMode" value="current" @(Model.ViewMode == "current" ? "checked" : "")>
                                    <label class="custom-control-label" for="viewCurrent">Current List</label>
                                </div>
                                <div class="custom-control custom-radio mt-1">
                                    <input class="custom-control-input" type="radio" id="viewByYear" name="ViewMode" value="byyear" @(Model.ViewMode == "byyear" ? "checked" : "")>
                                    <label class="custom-control-label" for="viewByYear">By Year</label>
                                </div>
                            </div>

                            <!-- Row 2 -->
                            <div class="form-group collapse" id="yearGroup">
                                <label>Year</label>
                                <input class="form-control" asp-for="Year" type="number" min="2000" max="2100" />
                            </div>

                            <!-- Row 3 -->
                            <div class="form-group">
                                <label>Department</label>
                                <select asp-for="DeptId"
                                        asp-items="Model.Departments"
                                        id="DeptId"
                                        class="form-control"
                                        style="width:100%">
                                </select>
                            </div>

                            <!-- Row 4 -->
                            <div class="form-group">
                                <label>Business</label>
                                <input asp-for="Business" class="form-control vni-font" />
                            </div>

                            <!-- Row 5 -->
                            <div class="form-group">
                                <label>Supplier Code</label>
                                <input asp-for="SupplierCode" class="form-control" />
                            </div>

                            <!-- Row 6 -->
                            <div class="form-group">
                                <label>Contact Person</label>
                                <input asp-for="Contact" class="form-control vni-font" />
                            </div>

                            <!-- Row 7 -->
                            <div class="form-group">
                                <label>Supplier Name</label>
                                <input asp-for="SupplierName" class="form-control vni-font" />
                            </div>

                            <!-- Row 8 -->
                            <div class="form-group">
                                <label>Status</label>
                                <select asp-for="StatusId" asp-items="Model.Statuses" class="form-control"></select>
                            </div>

                            <!-- Row 9 -->
                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input asp-for="IsNew" class="custom-control-input" />
                                    <label asp-for="IsNew" class="custom-control-label">New</label>
                                </div>
                            </div>

                            <!-- Row 10 -->
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

	        <!-- RESULT + ACTION (RIGHT) -->
	        <div class="col-md-10" id="supplierResultPanelContainer">
	            <!-- RESULT GRID -->
	            <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Suppliers</h3>
                        <span class="badge badge-light ml-2" id="total-records-badge">@Model.TotalRecords records</span>
                        <!-- Pagination info trong header (bên phải) -->
                        <div class="card-tools float-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div id="pagination-info" class="d-inline-block mr-2" style="padding-top: 0.3rem;">
                                    <small>No records</small>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                    <!-- Pagination buttons render by JS -->
                                </ul>
                            </nav>
                        </div>
                    </div>

	                    <div class="card-body p-0">
	                        <div class="table-responsive">
	                            <table class="table table-hover table-bordered text-nowrap" id="supplierTable">
	                                <thead class="thead-light">
	                                    <tr>
	                                        <th></th>
	                                        <th>Supplier Code</th>
	                                        <th>Supplier Name</th>
	                                        <th>Address</th>
	                                        <th>Phone</th>
	                                        <th>Mobile</th>
	                                        <th>Fax</th>
	                                        <th>Contact</th>
	                                        <th>Position</th>
	                                        <th>Business</th>
	                                        <th>Status</th>
	                                        <th class="d-none">Supplier Status ID</th> <!-- Header cho cột ẩn -->
	                                        <th>Dept</th>
	                                    </tr>
	                                </thead>
	                                <tbody>
	                                    @for (var supplierRowIndex = 0; supplierRowIndex < Model.Rows.Count; supplierRowIndex++)
	                                    {
	                                        var s = Model.Rows[supplierRowIndex];
	                                        <tr data-id="@s.SupplierID" data-supplier-id="@s.SupplierID" data-index="@supplierRowIndex">
	                                            <td>
	                                                <input type="radio" name="selectedSupplier">
	                                            </td>
	                                            <td style="white-space: nowrap;">
	                                                <a href="javascript:void(0)" class="supplier-link text-bold" style="text-decoration: underline;">
	                                                    @s.SupplierCode
	                                                </a>
	                                            </td>
	                                            <td class="vni-font" style="white-space: nowrap;">@s.SupplierName</td>
	                                            <td class="vni-font" style="white-space: nowrap;">@s.Address</td>
	                                            <td>@s.Phone</td>
	                                            <td>@s.Mobile</td>
	                                            <td>@s.Fax</td>
	                                            <td class="vni-font" style="white-space: nowrap;">@s.Contact</td>
	                                            <td>@s.Position</td>
	                                            <td class="vni-font" style="white-space: nowrap;">@s.Business</td>
	                                            <td>@s.SupplierStatusName</td>
	                                            <td style="display: none;">@s.Status</td> <!-- Cột ẩn chứa SupplierStatus -->
	                                            <td>@s.DeptCode</td>
	                                        </tr>
	                                    }
	                                </tbody>
	                            </table>
	                        </div>
	                    </div>
		                </div>
                <!-- ACTION PANEL -->
                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center">
                        @if (Model.PagePerm.HasPermission(3))
                        {
                            <button id="btnAdd" type="button" class="btn btn-success btn-sm">
                                <i class="fas fa-plus"></i> Add New
                            </button>
                        }
                        @* Nút Copy/Submit mặc định tắt; JS sẽ bật theo dòng được chọn và trạng thái hợp lệ. *@
                        <button id="btnCopy" type="button" class="btn btn-primary btn-sm d-none">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                        @* Excel luôn hiển thị; handler vẫn kiểm tra quyền khi gọi trực tiếp. *@
                        <button id="btnExcel" type="button" class="btn btn-secondary btn-sm">
                            <i class="fas fa-file-export"></i> Excel
                        </button>
                        <a href="/Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-times"></i> Close
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="copyYearModal" tabindex="-1" role="dialog" aria-labelledby="copyYearModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 460px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="copyYearModalLabel">Copy Supplier List</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body py-3">
                <form id="copyYearForm" method="post" asp-page-handler="CopyYear">
                    <input type="hidden" asp-for="SelectedSupplierIdsCsv" id="copySelectedSupplierIdsCsvInput" />
                    <div class="form-group mb-3">
                        <div class="d-flex align-items-center">
                            <label class="mb-0 mr-3" style="min-width: 84px;">Copy Year</label>
                            <div>
                                <input id="copyYearInput" asp-for="CopyYear" type="number" min="2000" max="@(DateTime.Today.Year - 1)" class="form-control form-control-sm" style="width: 110px;" />
                                <div id="copyYearValidation" class="invalid-feedback d-none">Enter a valid year.</div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center justify-content-between flex-wrap">
                        <div class="custom-control custom-checkbox mb-2 mb-sm-0 mr-3">
                            <input asp-for="ConfirmCopy" class="custom-control-input" />
                            <label asp-for="ConfirmCopy" class="custom-control-label font-weight-normal">Copy selected suppliers to this year?</label>
                        </div>
                        <div class="d-flex align-items-center">
                            <button type="button" class="btn btn-default btn-sm mr-2" data-dismiss="modal">Cancel</button>
                            <button id="copyYearSubmitBtn" type="submit" form="copyYearForm" class="btn btn-warning btn-sm" disabled>Copy</button>
                        </div>
                    </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Purchasing/Supplier/index.css" asp-append-version="true" />
}

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        const defaultPageSize = @Model.DefaultPageSize;
    </script>
    <script src="~/js/Purchasing/Supplier/index.js" asp-append-version="true"></script>
}
