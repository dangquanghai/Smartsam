@page
@model SmartSam.Pages.Purchasing.ApproveSupplierNew.ApproveSupplierNewDetailModel
@{
    ViewData["Title"] = "Approve Supplier New";

    Func<int, string> navUrl = (supplierId) => Url.Page("./Index", new
    {
        CurrentSupplierId = supplierId
    }) ?? "#";

    var editAll = Model.CanEditAllSupplierFields;
    var commentOnly = Model.CanEditCommentOnly;
}

<section class="content">
    <div class="container-fluid">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            var alertClass = Model.MessageType switch
            {
                "success" => "alert-success",
                "warning" => "alert-warning",
                "error" => "alert-danger",
                _ => "alert-info"
            };
            <div class="alert @alertClass alert-dismissible fade show mb-2" role="alert">
                @Model.Message
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
        }

        <div class="card card-primary card-outline mb-2">
            <div class="card-header p-2 d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0">Approve Supplier New</h3>
            </div>
            <div class="card-body p-2">
                @if (Model.CurrentSupplierDetail is null)
                {
                    <div class="text-muted">No supplier found for current scope.</div>
                }
                else
                {
                    <form method="post" id="approveSupplierForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <input type="hidden" asp-for="CurrentSupplierId" />
                        <input type="hidden" asp-for="EditSupplier.SupplierID" />

                        <div class="mb-2">
                            <div class="row no-gutters align-items-start mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Supplier Code<span class="required-mark">*</span></label></div>
                                <div class="col-2 pr-3">
                                    <input asp-for="EditSupplier.SupplierCode" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" required="@(editAll ? "required" : null)" />
                                    <span asp-validation-for="EditSupplier.SupplierCode" class="text-danger small"></span>
                                </div>
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Supplier Name<span class="required-mark">*</span></label></div>
                                <div class="col-8">
                                    <input asp-for="EditSupplier.SupplierName" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" required="@(editAll ? "required" : null)" />
                                    <span asp-validation-for="EditSupplier.SupplierName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Business</label></div>
                                <div class="col-8 pr-3">
                                    <input asp-for="EditSupplier.Business" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">IsNew</label></div>
                                <div class="col-2 d-flex align-items-center">
                                    <input asp-for="EditSupplier.IsNew" type="checkbox" disabled="@(editAll ? null : "disabled")" />
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Certificate</label></div>
                                <div class="col-8 pr-3">
                                    <input asp-for="EditSupplier.Certificate" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Document</label></div>
                                <div class="col-2 d-flex align-items-center">
                                    <input asp-for="EditSupplier.Document" type="checkbox" disabled="@(editAll ? null : "disabled")" />
                                </div>
                            </div>

                            <div class="row no-gutters align-items-start mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mt-1">Address<span class="required-mark">*</span></label></div>
                                <div class="col-11">
                                    <textarea asp-for="EditSupplier.Address" class="form-control form-control-sm vni-font" rows="2" readonly="@(editAll ? null : "readonly")" required="@(editAll ? "required" : null)"></textarea>
                                    <span asp-validation-for="EditSupplier.Address" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Phone</label></div>
                                <div class="col-3 pr-3">
                                    <input asp-for="EditSupplier.Phone" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Fax</label></div>
                                <div class="col-3 pr-3">
                                    <input asp-for="EditSupplier.Fax" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Mobile</label></div>
                                <div class="col-3">
                                    <input asp-for="EditSupplier.Mobile" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                            </div>

                            <div class="row no-gutters align-items-center mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Contact</label></div>
                                <div class="col-5 pr-3">
                                    <input asp-for="EditSupplier.Contact" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mb-0">Position</label></div>
                                <div class="col-5">
                                    <input asp-for="EditSupplier.Position" class="form-control form-control-sm vni-font" readonly="@(editAll ? null : "readonly")" />
                                </div>
                            </div>

                            <div class="row no-gutters align-items-start mb-2">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mt-1">Service</label></div>
                                <div class="col-11">
                                    <textarea asp-for="EditSupplier.Service" class="form-control form-control-sm vni-font" rows="2" readonly="@(editAll ? null : "readonly")"></textarea>
                                </div>
                            </div>

                            <div class="row no-gutters align-items-start mb-0">
                                <div class="col-1 text-left pr-2"><label class="col-form-label-sm mt-1">Comment</label></div>
                                <div class="col-11">
                                    <div class="d-flex align-items-start">
                                        <textarea asp-for="EditSupplier.Comment" class="form-control form-control-sm vni-font mr-2" rows="2" readonly="@((editAll || commentOnly) ? null : "readonly")"></textarea>
                                        <button
                                            type="submit"
                                            formaction="?handler=SaveMoreComment"
                                            class="btn btn-sm btn-secondary text-nowrap"
                                            disabled="@(!Model.CanEditComment ? "disabled" : null)">
                                            More Comment
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-2 module-action-bar">
                            <div class="d-flex align-items-center flex-wrap">
                                @if (Model.HasFirstSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-1" href="@navUrl(Model.FirstSupplierId!.Value)">&lt;&lt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-1" disabled>&lt;&lt;</button>
                                }

                                @if (Model.HasPrevSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-1" href="@navUrl(Model.PrevSupplierId!.Value)">&lt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-1" disabled>&lt;</button>
                                }

                                @if (Model.HasNextSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-1" href="@navUrl(Model.NextSupplierId!.Value)">&gt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-1" disabled>&gt;</button>
                                }

                                @if (Model.HasLastSupplier)
                                {
                                    <a class="btn btn-sm btn-action-close nav-mini-btn mr-3" href="@navUrl(Model.LastSupplierId!.Value)">&gt;&gt;</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-action-close nav-mini-btn mr-3" disabled>&gt;&gt;</button>
                                }

                                <button
                                    type="button"
                                    class="btn btn-sm btn-action-add mr-2"
                                    disabled="@(!Model.CanApproveByLevel ? "disabled" : null)"
                                    data-confirm-handler="Approve"
                                    data-confirm-title="Approve Confirmation"
                                    data-confirm-message="Are you sure you want to approve this supplier?"
                                    data-confirm-kind="primary">
                                    <i class="fas fa-check mr-1"></i>Approve Supplier
                                </button>
                                <button
                                    type="button"
                                    class="btn btn-sm btn-action-copy mr-2"
                                    disabled="@(!Model.CanDisapproveByLevel ? "disabled" : null)"
                                    data-confirm-handler="Disapprove"
                                    data-confirm-title="Disapprove Confirmation"
                                    data-confirm-message="Are you sure you want to disapprove this supplier?"
                                    data-confirm-kind="primary">
                                    <i class="fas fa-ban mr-1"></i>DisApprove Supplier
                                </button>
                                <a class="btn btn-sm btn-action-close mr-3" href="/Purchasing/Supplier/Index"><i class="fas fa-times mr-1"></i>Close</a>
                                <span class="text-danger font-weight-bold mr-3">@(string.IsNullOrWhiteSpace(Model.CurrentSupplierDetail?.SupplierStatusName) ? "N/A" : Model.CurrentSupplierDetail!.SupplierStatusName)</span>
                            </div>

                            <div class="d-flex align-items-center ml-auto">
                                <span class="text-primary font-weight-bold mr-3">@Model.CurrentSupplierPosition/@Model.CurrentPageSupplierCount Suppliers</span>
                                <input asp-for="GoToOrder" type="number" min="1" max="@Model.CurrentPageSupplierCount" class="form-control form-control-sm mr-2" style="width:80px" />
                                <button type="submit" formaction="?handler=GoTo" class="btn btn-sm btn-action-close goto-btn-compact"><i class="fas fa-share-square mr-1"></i>Go to</button>
                            </div>
                        </div>
                    </form>
                }
            </div>
        </div>

        <div class="modal fade" id="actionConfirmModal" tabindex="-1" role="dialog" aria-labelledby="actionConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header" id="actionConfirmModalHeader">
                        <h5 class="modal-title" id="actionConfirmModalLabel">Confirmation</h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body" id="actionConfirmModalBody"></div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary btn-sm" id="actionConfirmModalSubmitBtn">Confirm</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card card-secondary card-outline mt-2">
            <div class="card-header p-2">
                <h3 class="card-title">Warranty Service</h3>
            </div>
            <div class="card-body p-2">
                <table class="table table-bordered table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="width:20%">TheDate</th>
                            <th style="width:45%">Comment</th>
                            <th style="width:15%">ThePoint</th>
                            <th style="width:20%">WarrantyOrService</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SupplierServiceRows.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">No service data.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var row in Model.SupplierServiceRows)
                            {
                                <tr>
                                    <td>@(row.TheDate.HasValue ? row.TheDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                                    <td>@(string.IsNullOrWhiteSpace(row.Comment) ? "-" : row.Comment)</td>
                                    <td>@(row.ThePoint.HasValue ? row.ThePoint.Value.ToString() : "-")</td>
                                    <td>@(row.WarrantyOrService.HasValue ? row.WarrantyOrService.Value.ToString() : "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Purchasing/ApproveSupplierNew/ApproveSupplierNewDetail.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Purchasing/ApproveSupplierNew/ApproveSupplierNewDetail.js" asp-append-version="true"></script>
}
