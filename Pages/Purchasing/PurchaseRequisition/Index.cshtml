@page
@model SmartSam.Pages.Purchasing.PurchaseRequisition.IndexModel
@{
    ViewData["Title"] = "Purchase Requisition";
    var currentPage = Model.Filter.Page <= 0 ? 1 : Model.Filter.Page;
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
    var pageItems = new List<int?>();
    for (var p = 1; p <= totalPages; p++)
    {
        if (p == 1 || p == totalPages || (p >= currentPage - 2 && p <= currentPage + 2))
        {
            pageItems.Add(p);
        }
        else if (pageItems.Count == 0 || pageItems[^1].HasValue)
        {
            pageItems.Add(null);
        }
    }
    Func<int, string> pageUrl = (page) => Url.Page("./Index", new
    {
        RequestNo = Model.Filter.RequestNo,
        StatusId = Model.Filter.StatusId,
        Description = Model.Filter.Description,
        UseDateRange = Model.Filter.UseDateRange,
        FromDate = Model.Filter.UseDateRange ? Model.Filter.FromDate?.ToString("yyyy-MM-dd") : null,
        ToDate = Model.Filter.UseDateRange && Model.Filter.FromDate.HasValue ? Model.Filter.ToDate?.ToString("yyyy-MM-dd") : null,
        PageNumber = page,
        PageSize = Model.Filter.PageSize
    }) ?? "#";
}

<section class="content">
    <div class="container-fluid">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            var alertClass = Model.MessageType switch
            {
                "success" => "alert-success",
                "warning" => "alert-warning",
                "error" => "alert-danger",
                _ => "alert-info"
            };
            <div class="alert @alertClass alert-dismissible fade show mb-2" role="alert">
                @Model.Message
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
        }

        <div class="row">
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-search"></i> Search</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="prqSearchForm">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                            <input type="hidden" name="PageNumber" value="1" />
                            <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />

                            <div class="form-group mb-2">
                                <label>Request No.</label>
                                <input id="Filter_RequestNo" name="RequestNo" value="@Model.Filter.RequestNo" class="form-control form-control-sm vni-font" />
                            </div>

                            <div class="form-group mb-2">
                                <label>Status</label>
                                <select id="Filter_StatusId" name="StatusId" class="form-control form-control-sm">
                                    @foreach (var status in Model.StatusList)
                                    {
                                        var isSelectedStatus = string.IsNullOrWhiteSpace(status.Value)
                                            ? !Model.Filter.StatusId.HasValue
                                            : Model.Filter.StatusId?.ToString() == status.Value;
                                        <option value="@status.Value" selected="@(isSelectedStatus ? "selected" : null)">@status.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group mb-2">
                                <label>Description</label>
                                <input id="Filter_Description" name="Description" value="@Model.Filter.Description" class="form-control form-control-sm vni-font" />
                            </div>

                            <div class="form-group mb-1">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" id="Filter_UseDateRange" name="UseDateRange" value="true" class="custom-control-input" checked="@(Model.Filter.UseDateRange ? "checked" : null)" />
                                    <label for="Filter_UseDateRange" class="custom-control-label">Use Date Range</label>
                                </div>
                            </div>

                            <div class="form-group mb-2">
                                <label>From Date</label>
                                <input id="Filter_FromDate" name="FromDate" value="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))" type="date" class="form-control form-control-sm" />
                            </div>

                            <div class="form-group mb-3">
                                <label>To Date</label>
                                <input id="Filter_ToDate" name="ToDate" value="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" type="date" class="form-control form-control-sm" />
                            </div>

                            <button type="submit" class="btn btn-primary btn-block btn-sm border mb-2">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-10">
                <div class="card card-primary">
                    <div class="card-header prq-table-header">
                        <div class="prq-table-header-left">
                            <h3 class="card-title">Purchase Requisitions</h3>
                            <span class="badge badge-light ml-2" id="total-records-badge">@Model.TotalRecords records</span>
                        </div>
                        <div class="prq-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div id="pagination-info" class="d-inline-block mr-2 prq-pagination-info">
                                    @if (Model.TotalRecords == 0)
                                    {
                                        <small>No records</small>
                                    }
                                    else
                                    {
                                        <small>Showing @Model.PageStart to @Model.PageEnd of @Model.TotalRecords entries</small>
                                    }
                                </div>
                                <div class="prq-page-size-form d-inline-flex mr-2">
                                    <label class="mb-0 prq-page-size-label" for="prqPageSize">Show</label>
                                    <select id="prqPageSize" class="form-control form-control-sm prq-page-size-select">
                                        <option value="10" selected="@(Model.Filter.PageSize == 10 ? "selected" : null)">10</option>
                                        <option value="20" selected="@(Model.Filter.PageSize == 20 ? "selected" : null)">20</option>
                                        <option value="50" selected="@(Model.Filter.PageSize == 50 ? "selected" : null)">50</option>
                                        <option value="100" selected="@(Model.Filter.PageSize == 100 ? "selected" : null)">100</option>
                                        <option value="200" selected="@(Model.Filter.PageSize == 200 ? "selected" : null)">200</option>
                                    </select>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasPreviousPage ? pageUrl(currentPage - 1) : "#")">Prev</a>
                                    </li>
                                    @foreach (var pageItem in pageItems)
                                    {
                                        if (pageItem.HasValue)
                                        {
                                            <li class="page-item @(pageItem.Value == currentPage ? "active" : "")">
                                                <a class="page-link prq-pager-link" href="@pageUrl(pageItem.Value)">@pageItem.Value</a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                    }
                                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasNextPage ? pageUrl(currentPage + 1) : "#")">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive prq-table-wrap">
                            <table class="table table-hover table-bordered mb-0 text-nowrap prq-table" id="prqTable">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 32px;"></th>
                                        <th style="width: 120px;">No.</th>
                                        <th style="width: 120px;">Date</th>
                                        <th>Description</th>
                                        <th style="width: 100px;">Status</th>
                                        <th style="width: 90px;">Purchaser</th>
                                        <th style="width: 90px;">Chief_A</th>
                                        <th style="width: 90px;">G.Director</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Rows.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center text-muted">No data</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var row in Model.Rows)
                                        {
                                            <tr class="prq-row" data-prid="@row.Id" data-request-no="@row.RequestNo" data-can-edit="@(Model.CanEditRow(row.StatusId) ? "true" : "false")" data-can-approve="@(Model.CanApproveRow(row) ? "true" : "false")" data-can-view-detail="@(Model.CanViewDetailRow(row.StatusId) ? "true" : "false")">
                                                <td>
                                                    <input type="radio" class="prq-selector" name="selectedPurchaseRequisition" aria-label="Select row" />
                                                </td>
                                                <td>
                                                    @if (Model.CanEditRow(row.StatusId) || Model.CanApproveRow(row) || Model.CanViewDetailRow(row.StatusId))
                                                    {
                                                        var accessMode = Model.GetAccessMode(row);
                                                        var linkClass = accessMode == "view" ? "prq-row-link prq-row-link-view text-bold" : "prq-row-link text-bold";
                                                        <a href="@Url.Page("./PurchaseRequisitionDetail", new { id = row.Id, mode = accessMode })" class="@linkClass" data-id="@row.Id">@row.RequestNo</a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-bold">@row.RequestNo</span>
                                                    }
                                                </td>
                                                <td>@row.RequestDate.ToString("dd/MM/yyyy")</td>
                                                <td class="prq-description-column">
                                                    <div class="prq-description-cell">
                                                        @if (Model.NeedCollapseDescription(row.Description))
                                                        {
                                                            <span class="prq-description-preview vni-font">@Model.GetDescriptionPreview(row.Description)</span>
                                                            <button type="button" class="prq-read-more">Read more</button>
                                                            <span class="prq-description-full d-none vni-font">@row.Description</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="prq-description-full vni-font">@row.Description</span>
                                                        }
                                                    </div>
                                                </td>
                                                <td>@row.StatusName</td>
                                                <td>@row.PurchaserCode</td>
                                                <td>@row.ChiefACode</td>
                                                <td>@row.GDirectorCode</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center module-action-bar prq-action-bar">
                        @if (Model.CanAddAt)
                        {
                            <button type="button" id="prqAddAtBtn" class="btn btn-sm btn-action-copy border mx-1 my-1"><i class="fas fa-file-signature"></i> Add AT</button>
                        }
                        @if (Model.CanAddNew)
                        {
                            <a asp-page="./PurchaseRequisitionDetail" asp-route-mode="add" class="btn btn-sm btn-action-add border mx-1 my-1"><i class="fas fa-plus"></i> Add New</a>
                        }
                        @if (Model.CanViewDetailRequisition)
                        {
                            <button type="button" id="btnViewPrDetail" class="btn btn-sm btn-action-close border mx-1 my-1">
                                <i class="fas fa-list"></i> View Detail
                            </button>
                        }
                        <button type="button" id="btnExportExcel" class="btn btn-sm btn-action-export border mx-1 my-1"><i class="fas fa-file-excel"></i> Export Excel</button>
                        @* <button type="button" id="btnDisapproval" class="btn btn-sm btn-action-copy border mx-1 my-1" disabled><i class="fas fa-ban"></i> Disapproval</button> *@
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="prqAddAtModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <form method="post" enctype="multipart/form-data" asp-page="./Index" asp-page-handler="AddAt" id="prqAddAtForm">
                <div class="modal-header py-2">
                    <h5 class="modal-title font-weight-bold">Gen PR</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pb-2">
                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                    <input asp-for="AddAtDetailsJson" type="hidden" id="AddAtDetailsJson" />
                    <input asp-for="AddAtRequestNo" type="hidden" id="AddAtRequestNo" />
                    <input asp-for="AddAtRequestDate" type="hidden" id="AddAtRequestDate" />
                    <input asp-for="AddAtCurrencyId" type="hidden" id="AddAtCurrencyId" />
                    <input type="hidden" name="RequestNo" value="@Model.Filter.RequestNo" />
                    <input type="hidden" name="StatusId" value="@Model.Filter.StatusId" />
                    <input type="hidden" name="Description" value="@Model.Filter.Description" />
                    <input type="hidden" name="UseDateRange" value="@Model.Filter.UseDateRange" />
                    <input type="hidden" name="FromDate" value="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="ToDate" value="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" />
                    <input type="hidden" name="PageNumber" value="@Model.Filter.Page" />
                    <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label class="mb-1">No.</label>
                            <input id="prqAddAtRequestNoDisplay" class="form-control form-control-sm vni-font" readonly />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="mb-1">Date</label>
                            <input id="prqAddAtRequestDateDisplay" class="form-control form-control-sm" readonly />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="mb-1">Currency</label>
                            <select id="prqAddAtCurrencySelect" class="form-control form-control-sm"></select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label class="mb-1">Description<span class="required-mark">*</span></label>
                            <textarea asp-for="AddAtDescription" id="prqAddAtDescription" rows="2" class="form-control form-control-sm vni-font" maxlength="500"></textarea>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-12">
                            <label class="mb-1">Attached Files <span class="prq-add-at-file-note">Allowed: @Model.AllowedAttachmentExtensionsText | Max size: @Model.MaxAttachmentSizeMb MB</span></label>
                            <input asp-for="AddAtAttachments" type="file" id="prqAddAtAttachments" class="form-control form-control-sm prq-add-at-file-input" accept="@Model.AllowedAttachmentExtensionsText" multiple />
                            <div id="prqAddAtAttachmentError" class="prq-add-at-file-error d-none"></div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <button type="submit" class="btn btn-sm btn-action-save border mr-2">
                            <i class="fas fa-check"></i> Save
                        </button>
                        <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">
                            <i class="fas fa-times"></i> Close
                        </button>
                    </div>

                    <div class="table-responsive prq-add-at-table-wrap">
                        <table class="table table-sm table-bordered table-hover mb-0 text-nowrap">
                            <thead class="thead-light">
                                <tr>
                                    <th style="width:70px;">Check</th>
                                    <th style="width:110px;">RequestNo</th>
                                    <th style="width:140px;">Item Code</th>
                                    <th>Item Name</th>
                                    <th style="width:90px;" class="prq-center">BUY</th>
                                    <th style="width:110px;" class="prq-center prq-sugbuy-header">SugBuy</th>
                                    <th style="width:80px;" class="prq-center">Unit</th>
                                    <th style="width:100px;" class="prq-center">U.Price</th>
                                    <th style="width:220px;">Specification</th>
                                    <th style="width:260px;">Note</th>
                                </tr>
                            </thead>
                            <tbody id="prqAddAtDetailRows">
                                <tr id="prqAddAtDetailEmptyRow">
                                    <td colspan="10" class="text-center text-muted">No MR rows</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="prqViewDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Purchase Requisition Detail</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body pb-2">
                <div class="row prq-view-detail-filter-row mb-2 align-items-end">
                    <div style="width: 97px;">
                        <strong class="prq-detail-label">Request No.</strong>
                    </div>
                    <div class="col-md-2">
                        <input type="text" class="form-control form-control-sm vni-font" id="prqViewDetailRequestNo" />
                    </div>
                    <div style="width: 97px;">
                        <strong class="prq-detail-label">Description</strong>
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control form-control-sm vni-font" id="prqViewDetailDescription" />
                    </div>
                    <div class="form-check prq-view-detail-check">
                        <input style="margin-bottom: 5px;" type="checkbox" class="form-check-input" id="prqViewDetailUseDateRange" />
                    </div>
                    <div>
                        <strong class="prq-detail-label">From</strong>
                    </div>
                    <div class="col-md-2">
                        <div class="d-flex align-items-center prq-view-detail-inline-date">
                            <input type="date" class="form-control form-control-sm" id="prqViewDetailFromDate" disabled />
                        </div>
                    </div>
                    <div>
                        <strong class="prq-detail-label">To</strong>
                    </div>
                    <div class="col-md-2">
                        <input type="date" class="form-control form-control-sm" id="prqViewDetailToDate" disabled />
                    </div>
                    @* <div class="col-lg-2 col-md-12 d-flex align-items-end justify-content-lg-end prq-view-detail-filter-actions"> *@
                </div>

                <div class="row prq-view-detail-filter-row mb-2 align-items-end">
                    <div style="width: 97px;">
                        <strong class="prq-detail-label">Rec Qty.</strong>
                    </div>
                    <div class="col-md-2">
                        <div class="input-group input-group-sm">
                            <div class="input-group-prepend">
                                <select class="form-control form-control-sm" id="prqViewDetailRecQtyOperator">
                                    <option value="=">=</option>
                                    <option value=">">&gt;</option>
                                    <option value=">=">&gt;=</option>
                                    <option value="<">&lt;</option>
                                    <option value="<=">&lt;=</option>
                                </select>
                            </div>
                            <input type="text" class="form-control form-control-sm" id="prqViewDetailRecQty" inputmode="decimal" />
                        </div>
                    </div>
                    <div style="width: 97px;">
                        <strong class="prq-detail-label">Item Code</strong>
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control form-control-sm" id="prqViewDetailItemCode" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-sm btn-action-save border mr-2" id="btnPrqViewDetailSearch">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>

                <div class="table-responsive prq-view-detail-table-wrap">
                    <table class="table table-sm table-bordered table-hover mb-0 text-nowrap" id="prqViewDetailTable">
                        <thead class="thead-light">
                            <tr>
                                <th style="width:120px;">Req No.</th>
                                <th style="width:110px;">Req Date</th>
                                <th style="width:260px;">Description</th>
                                <th>Item Code / Name</th>
                                <th style="width:100px;" class="prq-center">PR Qty.</th>
                                <th style="width:100px;" class="prq-center">Rec Qty.</th>
                            </tr>
                        </thead>
                        <tbody id="prqViewDetailRows">
                            <tr id="prqViewDetailEmptyRow">
                                <td colspan="6" class="text-center text-muted">No detail rows</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2 flex-wrap prq-view-detail-paging">
                    <div id="prqViewDetailPaginationInfo" class="prq-pagination-info">
                        <small>No records</small>
                    </div>
                    <div class="d-flex align-items-center flex-wrap mt-2 mt-md-0">
                        <div class="prq-page-size-form d-inline-flex mr-2">
                            <label class="mb-0 prq-view-detail-page-size-label" for="prqViewDetailPageSize">Show</label>
                            <select id="prqViewDetailPageSize" class="form-control form-control-sm prq-page-size-select">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                                <option value="200">200</option>
                            </select>
                        </div>
                        <ul class="pagination pagination-sm mb-0 d-inline-flex" id="prqViewDetailPagination"></ul>
                    </div>
                </div>

                <div class="d-flex justify-content-start align-items-center mt-2 flex-wrap">
                    <button type="button" class="btn btn-sm btn-action-export border mr-2" id="btnPrqViewDetailReport">
                        <i class="fas fa-file-pdf"></i> Report
                    </button>
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="prqDangerModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white py-2">
                <h5 class="modal-title">Thông báo lỗi</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="prqDangerModalMessage" class="text-danger"></div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Purchasing/PurchaseRequisition/index.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.purchaseRequisitionPage = {
            canEdit: @(Model.CanEditRequisition ? "true" : "false"),
            canViewDetail: @(Model.CanViewDetailRequisition ? "true" : "false"),
            canAddAt: @(Model.CanAddAt ? "true" : "false"),
            canDisapproval: @(Model.PagePerm.HasPermission(6) ? "true" : "false"),
            detailUrlBase: '@Url.Page("./PurchaseRequisitionDetail")',
            viewDetailEndpoint: '@Url.Page("./Index", "ViewDetailRows")',
            viewDetailReportEndpoint: '@Url.Page("./Index", "ViewDetailReport")',
            allowedAttachmentExtensions: '@Model.AllowedAttachmentExtensionsText',
            maxAttachmentSizeMb: @Model.MaxAttachmentSizeMb
        };
    </script>
    <script src="~/js/Purchasing/PurchaseRequisition/index.js" asp-append-version="true"></script>
}
