@page "{id?}"
@model SmartSam.Pages.Purchasing.PurchaseRequisition.PurchaseRequisitionDetailModel
@{
    ViewData["Title"] = "Purchase Requisition Detail";
    var alertClass = (Model.MessageType ?? "info").ToLowerInvariant() switch
    {
        "success" => "alert-success",
        "warning" => "alert-warning",
        "error" => "alert-danger",
        _ => "alert-info"
    };
}

<section class="content">
    <div class="container-fluid">
        <form method="post" id="prqDetailForm">
            <input asp-for="Mode" type="hidden" />
            <input asp-for="Requisition.Id" type="hidden" />
            <input asp-for="DetailsJson" type="hidden" id="DetailsJson" />
            <input asp-for="SelectedDetailId" type="hidden" id="SelectedDetailId" />

            <div class="card card-primary card-outline">
                <div class="card-header py-2">
                    <h3 class="card-title prq-detail-title">Purchase Requisition Detail</h3>
                </div>
                <div class="card-body pb-2">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                    @if (!string.IsNullOrWhiteSpace(Model.Message))
                    {
                        <div class="alert @alertClass mb-2 py-2">@Model.Message</div>
                    }

                    <div class="row prq-detail-form-row mb-3">
                        <div class="col-lg-3 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">No.<span class="required-mark">*</span></label>
                            <input asp-for="Requisition.RequestNo" class="form-control form-control-sm vni-font" readonly />
                            <span asp-validation-for="Requisition.RequestNo" class="text-danger small"></span>
                        </div>
                        <div class="col-lg-3 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Date<span class="required-mark">*</span></label>
                            <input asp-for="Requisition.RequestDate" type="date" class="form-control form-control-sm" readonly />
                        </div>
                        <div class="col-lg-3 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Status</label>
                            <select asp-for="Requisition.Status" asp-items="Model.StatusList" class="form-control form-control-sm" disabled></select>
                        </div>
                        <div class="col-lg-3 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Currency<span class="required-mark">*</span></label>
                            <select asp-for="Requisition.Currency" id="prqCurrencySelect" class="form-control form-control-sm" disabled="@Model.IsViewMode">
                                <option value="1">VND</option>
                            </select>
                        </div>
                    </div>
                    <div class="row prq-detail-form-row mb-3">
                        <div class="col-lg-12 col-md-12 prq-detail-form-col">
                            <label class="prq-detail-label">Description<span class="required-mark">*</span></label>
                            <textarea asp-for="Requisition.Description" rows="3" class="form-control form-control-sm vni-font" readonly="@(Model.IsViewMode ? "readonly" : null)"></textarea>
                            <span asp-validation-for="Requisition.Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-2 prq-toolbar-top">
                        @if (Model.CanSave)
                        {
                            <button type="submit" class="btn btn-sm btn-action-save border mr-2">
                                <i class="fas fa-save"></i> Save
                            </button>
                        }
                        @if (Model.CanApproveWorkflow)
                        {
                            <button type="submit" class="btn btn-sm btn-action-approve border mr-2" formaction="@Url.Page("./PurchaseRequisitionDetail", "Approve", new { id = Model.Requisition.Id, mode = Model.Mode })" formnovalidate>
                                <i class="fas fa-check"></i> Approve
                            </button>
                        }
                        @if (Model.CanDisapproveWorkflow)
                        {
                            <button type="submit" class="btn btn-sm btn-action-disapprove border mr-2" formaction="@Url.Page("./PurchaseRequisitionDetail", "Disapprove", new { id = Model.Requisition.Id, mode = Model.Mode })" formnovalidate>
                                <i class="fas fa-ban"></i> Disapprove
                            </button>
                        }
                        <a asp-page="./Index" class="btn btn-sm btn-action-close border mr-2">
                            <i class="fas fa-times"></i> Close
                        </a>
                        @if (Model.CanResetToNew)
                        {
                            <button type="submit" class="btn btn-sm btn-action-secondary border" formaction="@Url.Page("./PurchaseRequisitionDetail", "CstNew", new { id = Model.Requisition.Id, mode = Model.Mode })" formnovalidate>
                                <i class="fas fa-undo"></i> CST New
                            </button>
                        }
                        <label>Total Amount: <span id="prqTotalAmount">@Model.TotalAmount.ToString("#,##0.###")</span> <span id="prqTotalAmountCurrency">VND</span></label>
                    </div>

                    <div class="table-responsive prq-detail-table-wrap">
                        <table class="table table-sm table-bordered table-hover mb-0 text-nowrap" id="prqDetailTable">
                            <thead class="thead-light">
                                <tr>
                                    <th style="width:40px;" class="prq-center"></th>
                                    <th style="width:140px;">Item Code</th>
                                    <th>Item Name</th>
                                    <th style="width:80px;" class="prq-center">Unit</th>
                                    <th style="width:90px;" class="prq-center">QtyFromM</th>
                                    <th style="width:90px;" class="prq-center">QtyPur</th>
                                    <th style="width:100px;" class="prq-center">U.Price</th>
                                    <th style="width:120px;" class="prq-center">Amount</th>
                                    <th style="width:220px;" class="prq-center">Remark</th>
                                    <th style="width:180px;">Supplier</th>
                                    @if (Model.CanSave)
                                    {
                                        <th style="width:60px;"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody id="prqDetailRows">
                                <tr id="prqDetailEmptyRow">
                                    <td colspan="@(Model.CanSave ? 11 : 10)" class="text-center text-muted">No detail rows</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-2 d-flex align-items-center flex-wrap">
                        @if (Model.CanSave)
                        {
                            <button type="button" class="btn btn-sm btn-action-add border mr-2 mb-2" data-toggle="modal" data-target="#prqAddDetailModal">
                                <i class="fas fa-plus"></i> Add Detail
                            </button>
                        }
                        @if (Model.CanMoveToMr)
                        {
                            <button type="submit" id="btnToMr" class="btn btn-sm btn-action-secondary border mr-2 mb-2" formaction="@Url.Page("./PurchaseRequisitionDetail", "ToMr", new { id = Model.Requisition.Id, mode = Model.Mode })" formnovalidate disabled>
                                <i class="fas fa-reply"></i> To MR
                            </button>
                        }
                        @if (Model.Requisition.Id > 0)
                        {
                            <button type="button" class="btn btn-sm btn-action-secondary border mr-2 mb-2" data-toggle="modal" data-target="#prqAttachmentModal">
                                <i class="fas fa-paperclip"></i> Attached Files
                            </button>
                        }
                        <div class="ml-auto mb-2 prq-detail-record-total">Total Record(s): <span id="prqDetailRecordCount">0</span></div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@if (Model.CanSave)
{
    <div class="modal fade" id="prqAddDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title">Add Detail</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pb-2">
                    <div id="detailAddError" class="text-danger small mb-2" style="display:none;"></div>
                    <div class="table-responsive prq-add-at-table-wrap prq-add-detail-table-wrap">
                        <table class="table table-sm table-bordered table-hover mb-0 text-nowrap" id="prqAddDetailTable">
                            <thead class="thead-light">
                                <tr>
                                    <th style="width:70px;">Check</th>
                                    <th style="width:110px;">RequestNo</th>
                                    <th style="width:140px;">Item Code</th>
                                    <th>Item Name</th>
                                    <th style="width:90px;" class="prq-center">BUY</th>
                                    <th style="width:110px;" class="prq-center">SugBuy<span class="required-mark">*</span></th>
                                    <th style="width:90px;" class="prq-center">Unit</th>
                                    <th style="width:100px;" class="prq-center">U.Price</th>
                                    <th style="width:180px;">Specification</th>
                                    <th style="width:210px;">Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ItemList)
                                {
                                    <tr data-add-detail-row="1"
                                        data-item-id="@item.Id"
                                        data-item-code="@item.ItemCode"
                                        data-item-name="@item.ItemName"
                                        data-request-no="@item.RequestNo"
                                        data-buy="@item.Buy"
                                        data-unit="@item.Unit"
                                        data-unit-price="@item.UnitPrice"
                                        data-specification="@item.Specification"
                                        data-note="@item.Note"
                                        data-mr-detail-id="@item.MrDetailId">
                                        <td class="prq-center">
                                            <input type="checkbox" class="prq-add-detail-check" />
                                        </td>
                                        <td>@item.RequestNo</td>
                                        <td>@item.ItemCode</td>
                                        <td>@item.ItemName</td>
                                        <td class="prq-center">@item.Buy.ToString("0.###")</td>
                                        <td class="prq-center">
                                            <input type="text" inputmode="decimal" class="form-control form-control-sm prq-add-detail-subqty" value="@item.Buy.ToString("0.###")" />
                                        </td>
                                        <td class="prq-center">@item.Unit</td>
                                        <td class="prq-center">@item.UnitPrice.ToString("0.###")</td>
                                        <td class="prq-add-at-text-cell prq-add-detail-specification"></td>
                                        <td class="prq-add-at-text-cell prq-add-detail-note"></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-action-add border mr-2" id="btnAddDetailConfirm">
                        <i class="fas fa-plus"></i> Add
                    </button>
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.Requisition.Id > 0)
{
    <div class="modal fade" id="prqAttachmentModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title">Attached Files</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pb-2">
                    @if (Model.AttachmentList.Count == 0)
                    {
                        <div class="text-muted small mb-3">No attached files.</div>
                    }
                    else
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>File</th>
                                        <th style="width:160px;">Upload Date</th>
                                        <th style="width:120px;">User</th>
                                        <th style="width:90px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var attachment in Model.AttachmentList)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-page="./PurchaseRequisitionDetail" asp-page-handler="DownloadAttachment" asp-route-id="@Model.Requisition.Id" asp-route-docId="@attachment.DocId">@attachment.FilePath</a>
                                            </td>
                                            <td>@attachment.UploadDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@attachment.UserCode</td>
                                            <td class="text-center">
                                                @if (Model.CanManageAttachments)
                                                {
                                                    <form method="post" action="@Url.Page("./PurchaseRequisitionDetail", "DeleteAttachment", new { id = Model.Requisition.Id, mode = Model.Mode, docId = attachment.DocId })">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-action-disapprove border px-2" formnovalidate>
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (Model.CanManageAttachments)
                    {
                        <form method="post" enctype="multipart/form-data" action="@Url.Page("./PurchaseRequisitionDetail", "UploadAttachment", new { id = Model.Requisition.Id, mode = Model.Mode })">
                            @Html.AntiForgeryToken()
                            <input asp-for="Requisition.Id" type="hidden" />
                            <input asp-for="Mode" type="hidden" />
                            <div class="form-group mb-0">
                                <label class="mb-1">Attached Files <span class="prq-attachment-note">Allowed: @Model.AllowedAttachmentExtensionsText | Max size: @Model.MaxAttachmentSizeMb MB</span></label>
                                <input asp-for="AttachmentUpload" type="file" class="form-control-file prq-attachment-input" id="detailAttachmentUpload" accept="@Model.AllowedAttachmentExtensionsText" />
                                <div id="detailAttachmentError" class="text-danger small mt-1" style="display:none;"></div>
                                <div class="mt-2">
                                    <button type="submit" class="btn btn-sm btn-action-add border" id="btnDetailAttachmentUpload">
                                        <i class="fas fa-upload"></i> Upload
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Purchasing/PurchaseRequisition/PurchaseRequisitionDetail.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.purchaseRequisitionDetailPage = {
            canSave: @(Model.CanSave ? "true" : "false"),
            canMoveToMr: @(Model.CanMoveToMr ? "true" : "false"),
            canSelectDetail: @(Model.CanMoveToMr ? "true" : "false"),
            allowedAttachmentExtensions: "@Model.AllowedAttachmentExtensionsText",
            maxAttachmentSizeMb: @Model.MaxAttachmentSizeMb
        };
    </script>
    <script src="~/js/Purchasing/PurchaseRequisition/PurchaseRequisitionDetail.js" asp-append-version="true"></script>
}
