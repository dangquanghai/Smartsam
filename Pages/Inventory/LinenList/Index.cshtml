@page
@model SmartSam.Pages.Inventory.LinenList.IndexModel
@{
    ViewData["Title"] = "Linen List - Price";

    string FormatNumberText(string value)
    {
        var raw = (value ?? string.Empty).Trim().Replace(",", string.Empty);
        return decimal.TryParse(raw, out var number)
            ? number.ToString("#,##0")
            : value ?? string.Empty;
    }
}
<section class="content">
    <div class="container-fluid">
        <div class="row linen-list-layout-row">

            <!-- SEARCH PANEL (LEFT) -->
            <div class="col-md-2 linen-list-search-column">
                <div class="card card-info linen-list-search-panel">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-search"></i> Search
                        </h3>
                    </div>

                    <div class="card-body">
                        <form method="get" id="linenListSearchForm">
                            <div class="form-group">
                                <label for="Filter_LinenCode">Linen Code</label>
                                <input type="text" class="form-control form-control-sm" id="Filter_LinenCode" asp-for="Filter.LinenCode" />
                            </div>

                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" id="Filter_IsLinen" checked>
                                    <label class="custom-control-label" for="Filter_IsLinen">Is Linen</label>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" id="Filter_IsUniform">
                                    <label class="custom-control-label" for="Filter_IsUniform">Is Uniform</label>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" id="Filter_IsRegular">
                                    <label class="custom-control-label" for="Filter_IsRegular">Is regular</label>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" id="Filter_IsService">
                                    <label class="custom-control-label" for="Filter_IsService">Is Service</label>
                                </div>
                            </div>

                            <button class="btn btn-primary btn-block btn-sm">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- RESULT + ACTION (RIGHT) -->
            <div class="col-md-10 linen-list-result-column" id="linenListResultPanelContainer">
                <!-- RESULT GRID -->
                <div class="card card-primary">
                    <div class="card-header linen-list-table-header">
                        <div class="linen-list-table-header-left">
                            <h3 class="card-title">Linen list</h3>
                            <span class="badge badge-light ml-2" id="total-records-badge">0 records</span>
                        </div>
                        <div class="linen-list-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div id="pagination-info" class="d-inline-block mr-2 linen-list-table-paging-info">
                                    <small>No records</small>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered mb-0 text-nowrap" id="linenListTable">
                                <colgroup>
                                    <col style="width: 32px;" />
                                    <col style="width: 220px;" />
                                    <col style="width: 90px;" />
                                    <col style="width: 90px;" />
                                    <col style="width: 180px;" />
                                    <col style="width: 90px;" />
                                    <col style="width: 90px;" />
                                </colgroup>
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 32px;"></th>
                                        <th style="width: 220px;">LinnenCode</th>
                                        <th style="width: 90px;" class="text-center">IsLinen</th>
                                        <th style="width: 90px;" class="text-center">IsUniform</th>
                                        <th style="width: 180px;">Price (EcoWash HCMC)</th>
                                        <th style="width: 90px;" class="text-center">Regular</th>
                                        <th style="width: 90px;" class="text-center">IsOrder</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.Rows)
                                    {
                                        <tr data-id="@row.ID">
                                            <td style="width:32px;">
                                                <input type="radio" name="selectedLinen">
                                            </td>
                                            <td style="white-space: nowrap;">
                                                <a href="javascript:void(0)" class="linen-code-link text-bold" style="text-decoration: underline;">
                                                    @row.LinnenCode
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox" disabled checked="@row.IsLinen" />
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox" disabled checked="@row.IsUniform" />
                                            </td>
                                            <td>@FormatNumberText(row.EcoWashHcmc)</td>
                                            <td class="text-center">
                                                <input type="checkbox" disabled checked="@row.Regular" />
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox" disabled checked="@row.IsOrder" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- ACTION PANEL -->
                <div class="card card-outline card-primary linen-list-action-panel">
                    <div class="card-footer p-2 text-center">
                        @if (Model.PagePerm.HasPermission(2))
                        {
                            <button class="btn btn-success btn-sm" id="btnAdd">
                                <i class="fas fa-plus"></i> Add
                            </button>
                        }

                        <button class="btn btn-primary btn-sm d-none" id="btnEdit">
                            <i class="fas fa-edit"></i> Edit
                        </button>

                        <button class="btn btn-outline-success btn-sm" id="btnExportExcel" type="button">
                            <i class="fas fa-file-excel"></i> Excell
                        </button>

                        <a class="btn btn-secondary btn-sm" href="/">
                            <i class="fas fa-times"></i> Close
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/Inventory/LinenList/index.css" asp-append-version="true" />
}

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        const defaultPageSize = @Model.DefaultPageSize;
        window.linenListPage = {
            detailUrl: '/Inventory/LinenList/LinenListDetail',
            exportUrlBase: '/Inventory/LinenList/Index?handler=ExportExcel',
            canUpdate: @(Model.PagePerm.HasPermission(2) ? "true" : "false")
        };
    </script>
    <script src="~/js/Inventory/LinenList/index.js" asp-append-version="true"></script>
}
