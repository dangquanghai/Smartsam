@section Scripts {
    <script>
        window.linenDeliveryPage = {
            isView: @Model.IsViewMode.ToString().ToLowerInvariant(),
            deliveryType: @(Model.Header.DeliveryType?.ToString() ?? "null"),
            supplierId: @(Model.Header.SupplierID?.ToString() ?? "null"),
            noteId: @(Model.Header.NoteID?.ToString() ?? "null"),
            deliveryId: @Model.Header.DeliveryID,
            isSpecialLaundry: @Model.Header.IsSpecialLaundry.ToString().ToLowerInvariant(),
            canToBill: @Model.CanToBill.ToString().ToLowerInvariant(),
            pantryNoteDetailUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("/Inventory/LinnenNoteDaily/LinnenNoteDailyDetail", new { mode = "view", popup = true }))),
            pantryNotePrintPreviewUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("/Inventory/LinnenNoteDaily/LinnenNoteDailyDetail", "PrintPreview"))),
            billDetailUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("/Cus/DailyServiceBill/DailyServiceBillDetail"))),
            printPreviewUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("./LinenDeliveryDetail", "PrintPreview", new { id = Model.Header.DeliveryID }))),
            reportPdfUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("/Inventory/LinenReport/Index", "Pdf", new { reportType = "delivery", descriptionId = Model.Header.DeliveryID, lockedReportType = "delivery", popup = true }))),
            rowTemplateOptions: {
                locations: @Html.Raw(Model.LocationOptionsJson),
                linens: @Html.Raw(Model.LinenOptionsJson)
            }
        };
    </script>
    <script src="~/js/Inventory/LinenDelivery/LinenDeliveryDetail.js" asp-append-version="true"></script>
}
