@page
@model SmartSam.Pages.Inventory.LinenDelivery.LinenDeliveryDetailModel
@{
    ViewData["Title"] = "Linen Delivery Detail";
    var isView = Model.IsViewMode;
    var reportLinenCodes = Model.Details
        .Select(x => (x.LinenCode ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
}

@section Styles {
    <style>
        .linen-delivery-header label {
            font-size: 12px;
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linen-delivery-header .form-control-sm,
        .linen-delivery-header .custom-select-sm {
            height: 28px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .linen-delivery-header-checks {
            display: flex;
            align-items: center;
            min-height: 28px;
            gap: 0.75rem;
        }

        .linen-delivery-header-checks .custom-control {
            display: flex;
            align-items: center;
            min-height: 28px;
            margin-bottom: 0;
        }

        .linen-delivery-header-checks .custom-control-label {
            display: inline-flex;
            align-items: center;
            min-height: 28px;
            line-height: 1.2;
        }

        .linen-delivery-header-checks .custom-control-label::before,
        .linen-delivery-header-checks .custom-control-label::after {
            top: 50%;
            transform: translateY(-50%);
        }

        .linen-delivery-grid th,
        .linen-delivery-grid td {
            vertical-align: middle !important;
        }

        #linenDeliveryDetailTable tbody > tr > td:first-of-type,
        #linenDeliveryDetailTable tbody > tr > th:first-of-type,
        #linenDeliveryDetailTable tfoot > tr > td:first-of-type,
        #linenDeliveryDetailTable tfoot > tr > th:first-of-type,
        #linenDeliveryDetailTable thead > tr > td:first-of-type,
        #linenDeliveryDetailTable thead > tr > th:first-of-type {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .linen-delivery-grid .form-control-sm,
        .linen-delivery-grid .custom-select-sm {
            min-width: 50px;
        }

        .linen-delivery-grid .ld-location,
        .linen-delivery-grid .ld-linen {
            min-width: 160px;
        }

        .linen-delivery-note-cell {
            padding: 0.3rem !important;
        }

        .linen-delivery-action-cell {
            width: 28px;
            padding: 0 !important;
            vertical-align: middle;
        }

        .linen-delivery-action-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
        }

        .linen-delivery-action-wrap .js-remove-row {
            margin: 0;
        }

        .linen-delivery-bill-table th,
        .linen-delivery-bill-table td {
            vertical-align: middle !important;
        }

        .linen-delivery-report-modal-dialog {
            max-width: 94%;
        }

        .linen-delivery-report-toolbar {
            border-bottom: 1px solid #d7d7d7;
            background: #f8f9fa;
        }

        .linen-delivery-report-toolbar .form-control-sm,
        .linen-delivery-report-toolbar .custom-select-sm {
            height: 28px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .linen-delivery-report-toolbar label {
            font-size: 12px;
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linen-delivery-report-choice {
            display: inline-flex;
            align-items: center;
            margin-right: 10px;
            margin-bottom: 4px;
            font-size: 12px;
        }

        .linen-delivery-report-choice input {
            margin-right: 4px;
        }

        .linen-delivery-report-chart {
            display: inline-flex;
            align-items: center;
            margin-bottom: 4px;
            font-size: 12px;
        }

        .linen-delivery-report-chart .custom-control-label {
            padding-top: 1px;
        }

        .linen-delivery-report-preview-wrap {
            min-height: 420px;
            background: #fff;
        }

        .linen-delivery-report-preview-table {
            min-width: 980px;
            border-collapse: collapse;
        }

        .linen-delivery-report-preview-table th,
        .linen-delivery-report-preview-table td {
            border: 1px solid #cfcfcf !important;
            padding: 3px 4px !important;
            font-size: 12px;
            vertical-align: middle !important;
        }

        .linen-delivery-report-preview-table thead th {
            background: #eef2f7;
            text-align: center;
        }

        .linen-delivery-report-preview-meta {
            font-size: 12px;
            color: #495057;
        }
    </style>
}

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2" asp-validation-summary="All"></div>
        }

        <form method="post" id="linenDeliveryDetailForm">
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="DetailsJson" id="DetailsJson" />

            <div class="card card-primary card-outline">
                <div class="card-body p-2 linen-delivery-header">
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="form-group row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label col-form-label-sm">Delivery ID</label>
                                <div class="col-sm-4">
                                    <input asp-for="Header.DeliveryID" class="form-control form-control-sm" readonly />
                                </div>
                                <label class="col-sm-1 col-form-label col-form-label-sm">Date</label>
                                <div class="col-sm-4">
                                    <input asp-for="Header.DeliveryDate" type="date" class="form-control form-control-sm" readonly="@isView" />
                                </div>
                            </div>

                            <div class="form-group row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label col-form-label-sm">Description</label>
                                <div class="col-sm-9">
                                    <input asp-for="Header.Description" class="form-control form-control-sm vni-font" maxlength="100" readonly="@isView" />
                                </div>
                            </div>

                            <div class="form-group row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label col-form-label-sm">Type(*)</label>
                                <div class="col-sm-5">
                                    <select asp-for="Header.DeliveryType"
                                            asp-items="Model.DeliveryTypeOptions"
                                            class="form-control form-control-sm vni-font"
                                            id="Header_DeliveryType"
                                            disabled="@Model.IsTypeLocked">
                                    </select>
                                    @if (Model.IsTypeLocked)
                                    {
                                        <input type="hidden" asp-for="Header.DeliveryType" />
                                    }
                                </div>
                                <div class="col-sm-4 linen-delivery-header-checks">
                                    <div class="custom-control custom-checkbox d-inline-block mr-3">
                                        <input asp-for="Header.Closed" class="custom-control-input" disabled="@isView" />
                                        <label asp-for="Header.Closed" class="custom-control-label">Close</label>
                                    </div>
                                    <div class="custom-control custom-checkbox d-inline-block">
                                        <input asp-for="Header.IsRent" class="custom-control-input" disabled="@isView" />
                                        <label asp-for="Header.IsRent" class="custom-control-label">Rent</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <div class="form-group row mb-2 align-items-center linen-delivery-note-wrap">
                                <label class="col-sm-3 col-form-label col-form-label-sm">Pantry Linen(*)</label>
                                <div class="col-sm-6">
                                    <select asp-for="Header.NoteID"
                                            asp-items="Model.PantryNoteOptions"
                                            class="form-control form-control-sm vni-font"
                                            id="Header_NoteID"
                                            disabled="@Model.IsPantryNoteLocked">
                                    </select>
                                    @if (Model.IsPantryNoteLocked)
                                    {
                                        <input type="hidden" asp-for="Header.NoteID" />
                                    }
                                </div>
                                <div class="col-sm-3">
                                    @if (Model.Header.NoteID.HasValue && Model.Header.NoteID.Value > 0)
                                    {
                                        <a class="btn btn-info btn-sm btn-block"
                                           href="/Inventory/LinnenNoteDaily/LinnenNoteDailyDetail?id=@Model.Header.NoteID.Value&mode=view">
                                            View
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-info btn-sm btn-block" disabled>View</button>
                                    }
                                </div>
                            </div>

                            <div class="form-group row mb-2 align-items-center linen-delivery-supplier-wrap">
                                <label class="col-sm-3 col-form-label col-form-label-sm">Supplier(*)</label>
                                <div class="col-sm-9">
                                    <select asp-for="Header.SupplierID"
                                            asp-items="Model.SupplierOptions"
                                            class="form-control form-control-sm vni-font"
                                            id="Header_SupplierID"
                                            disabled="@isView">
                                    </select>
                                </div>
                            </div>

                            <div class="form-group row mb-0 align-items-center linen-delivery-special-wrap">
                                <label class="col-sm-3 col-form-label col-form-label-sm">Special Laundry</label>
                                <div class="col-sm-9 linen-delivery-header-checks">
                                    <div class="custom-control custom-checkbox d-inline-block">
                                        <input asp-for="Header.IsSpecialLaundry" class="custom-control-input" disabled="@Model.IsSpecialLocked" />
                                        <label asp-for="Header.IsSpecialLaundry" class="custom-control-label">
                                            <span class="sr-only">Special Laundry</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-primary">
                <div class="card-header py-2">
                    <h3 class="card-title">Detail</h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0 linen-delivery-grid" id="linenDeliveryDetailTable">
                            <colgroup>
                                <col style="width: 28px;" />
                                <col style="min-width: 160px;" />
                                <col style="min-width: 160px;" />
                                <col style="width: 70px;" />
                                <col style="width: 70px;" />
                                <col style="width: 50px;" />
                                <col style="width: 110px;" />
                                <col style="width: 120px;" />
                                <col style="min-width: 180px;" />
                            </colgroup>
                            <thead class="thead-light">
                                <tr>
                                    <th class="linen-delivery-action-cell"></th>
                                    <th>Location</th>
                                    <th>Linen</th>
                                    <th style="width: 70px;">Express</th>
                                    <th style="width: 70px;">Child</th>
                                    <th style="width: 50px;">Qty</th>
                                    <th style="width: 110px;">Price</th>
                                    <th style="width: 120px;">Amount</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Details.Count == 0)
                                {
                                    <tr class="linen-delivery-empty-row">
                                        <td colspan="9" class="text-center text-muted py-3">No detail rows</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var row in Model.Details)
                                    {
                                        <tr class="linen-delivery-detail-row"
                                            data-id="@row.ID"
                                            data-delivery-id="@row.DeliveryID"
                                            data-location="@row.Location"
                                            data-linen-code="@row.LinenCode"
                                            data-no-need-bill="@row.NoNeedBill.ToString().ToLowerInvariant()">
                                            <td class="linen-delivery-action-cell">
                                                @if (!isView)
                                                {
                                                    <div class="linen-delivery-action-wrap">
                                                        <button type="button" class="btn btn-xs btn-outline-danger border js-remove-row" title="Remove">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm ld-location vni-font" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.LocationOptions)
                                                    {
                                                        if (option.Value == Convert.ToString(row.LocationID))
                                                        {
                                                            <option value="@option.Value" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm ld-linen vni-font" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.LinenOptions)
                                                    {
                                                        var price = option.Group?.Name ?? string.Empty;
                                                        if (option.Value == Convert.ToString(row.LinnenID))
                                                        {
                                                            <option value="@option.Value" data-price="@price" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value" data-price="@price">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center"><input type="checkbox" class="ld-express" @(row.Express ? "checked" : null) @(isView ? "disabled" : null) /></td>
                                            <td class="text-center"><input type="checkbox" class="ld-child" @(row.IsChild ? "checked" : null) @(isView ? "disabled" : null) /></td>
                                            <td><input type="number" step="0.01" min="0" class="form-control form-control-sm text-right ld-quantity" value="@row.Quantity.ToString("0.##")" @(isView ? "readonly" : null) /></td>
                                            <td><input type="number" step="0.01" class="form-control form-control-sm text-right ld-price" value="@row.Price.ToString("0.##")" @(isView ? "readonly" : null) /></td>
                                            <td><input type="number" step="0.01" class="form-control form-control-sm text-right ld-amount" value="@row.Amount.ToString("0.##")" readonly /></td>
                                            <td class="linen-delivery-note-cell"><input type="text" maxlength="100" class="form-control form-control-sm ld-note vni-font" value="@row.Note" @(isView ? "readonly" : null) /></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer p-2 text-center">
                    @if (Model.CanSave)
                    {
                        <button type="button" class="btn btn-success btn-sm mr-1" id="btnAddDetailRow">
                            <i class="fas fa-plus"></i> Add Detail
                        </button>
                        <button type="submit" class="btn btn-primary btn-sm mr-1">
                            <i class="fas fa-save"></i> Save
                        </button>
                    }
                    <button type="button" class="btn btn-info btn-sm mr-1" id="btnPrintLinenDeliveryDetail">
                        <i class="fas fa-print"></i> Print
                    </button>
                    <button type="button"
                            class="btn btn-warning btn-sm mr-1"
                            id="btnToBill"
                            @(Model.CanToBill ? null : "disabled")>
                        <i class="fas fa-file-invoice-dollar"></i> To Bill
                    </button>
                    <a class="btn btn-secondary btn-sm" href="/Inventory/LinenDelivery">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </a>
                </div>
            </div>
        </form>
    </div>
</section>

<div class="modal fade" id="linenDeliveryReportModal" tabindex="-1" role="dialog" aria-labelledby="linenDeliveryReportModalLabel" aria-hidden="true">
    <div class="modal-dialog linen-delivery-report-modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linenDeliveryReportModalLabel">Linen - Report</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0">
                <div class="p-2 linen-delivery-report-toolbar">
                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-2">
                        <div class="d-flex flex-wrap align-items-center">
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="pantry" disabled />Pantry-Linen</label>
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="delivery" checked />Delivery</label>
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="receive" disabled />Receive</label>
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="laundry-record" disabled />Laundry Record</label>
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="not-receive" disabled />Not Receive</label>
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="laundry-balance" disabled />Laundry.U. Balance</label>
                            <label class="linen-delivery-report-choice"><input type="radio" name="linenDeliveryReportType" value="apmt-balance" disabled />Apmt Balance</label>
                        </div>
                        <div class="linen-delivery-report-chart">
                            <div class="custom-control custom-checkbox mb-0">
                                <input type="checkbox" class="custom-control-input" id="linenDeliveryReportChart" disabled />
                                <label class="custom-control-label" for="linenDeliveryReportChart">Chart</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-row align-items-center">
                        <div class="col-md-4 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">Des</label>
                                <select class="form-control form-control-sm vni-font" id="linenDeliveryReportDescription">
                                    <option value="@Model.Header.DeliveryID">@Model.Header.Description</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">Linnen</label>
                                <select class="form-control form-control-sm vni-font" id="linenDeliveryReportLinenCode">
                                    <option value="">ALL</option>
                                    @foreach (var linenCode in reportLinenCodes)
                                    {
                                        <option value="@linenCode">@linenCode</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">From</label>
                                <input type="date" class="form-control form-control-sm" id="linenDeliveryReportFromDate" value="@Model.Header.DeliveryDate.ToString("yyyy-MM-dd")" readonly />
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">To</label>
                                <input type="date" class="form-control form-control-sm" id="linenDeliveryReportToDate" value="@Model.Header.DeliveryDate.ToString("yyyy-MM-dd")" readonly />
                            </div>
                        </div>
                        <div class="col-md-1 mb-2">
                            <button type="button" class="btn btn-sm btn-primary btn-block" id="btnPreviewLinenDeliveryReport">Preview</button>
                        </div>
                    </div>
                </div>

                <div class="px-2 pt-2 linen-delivery-report-preview-meta" id="linenDeliveryReportPreviewMeta">
                    Delivery: @Model.Header.Description
                </div>
                <div class="p-2 linen-delivery-report-preview-wrap">
                    <div class="table-responsive" id="linenDeliveryReportPreviewContainer">
                        <div class="text-center text-muted py-5">Click Preview to load report data.</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="linenDeliveryBillModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Linen Delivery Bill</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger d-none py-2 mb-3" id="linenDeliveryBillError"></div>

                <div id="linenDeliveryBillCreatePanel">
                    <div class="form-row align-items-end">
                        <div class="form-group col-md-4 mb-2">
                            <label class="mb-1">Bill Date</label>
                            <input type="date" class="form-control form-control-sm" id="linenDeliveryBillDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="form-group col-md-3 mb-2">
                            <button type="button" class="btn btn-primary btn-sm" id="btnCreateLinenDeliveryBill">
                                <i class="fas fa-save"></i> Create Bill
                            </button>
                        </div>
                    </div>
                </div>

                <div id="linenDeliveryBillListWrap" class="mt-2 d-none">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0 linen-delivery-bill-table">
                            <thead class="thead-light">
                                <tr>
                                    <th class="text-left" style="width: 90px;">Bill ID</th>
                                    <th style="width: 120px;">Bill Date</th>
                                    <th style="width: 110px;">Apartment</th>
                                    <th>Customer</th>
                                    <th style="width: 120px;">USD Amount</th>
                                    <th style="width: 100px;">Status</th>
                                </tr>
                            </thead>
                            <tbody id="linenDeliveryBillTableBody">
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-3">No bills</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.linenDeliveryPage = {
            isView: @Model.IsViewMode.ToString().ToLowerInvariant(),
            deliveryType: @(Model.Header.DeliveryType?.ToString() ?? "null"),
            supplierId: @(Model.Header.SupplierID?.ToString() ?? "null"),
            deliveryId: @Model.Header.DeliveryID,
            isSpecialLaundry: @Model.Header.IsSpecialLaundry.ToString().ToLowerInvariant(),
            canToBill: @Model.CanToBill.ToString().ToLowerInvariant(),
            printPreviewUrl: '@Url.Page("./LinenDeliveryDetail", "PrintPreview", new { id = Model.Header.DeliveryID })',
            reportPageUrl: '@Url.Page("/Inventory/LinenReport/Index")',
            rowTemplateOptions: {
                locations: @Html.Raw(Model.LocationOptionsJson),
                linens: @Html.Raw(Model.LinenOptionsJson)
            }
        };
    </script>
    <script src="~/js/Inventory/LinenDelivery/LinenDeliveryDetail.js" asp-append-version="true"></script>
}
