@page
@model SmartSam.Pages.Inventory.LinenDelivery.LinenDeliveryDetailModel
@{
    ViewData["Title"] = "Linen Delivery Detail";
    var isView = Model.IsViewMode;
    var indexUrl = string.IsNullOrWhiteSpace(Model.RedirectUrl) ? "/Inventory/LinenDelivery" : Model.RedirectUrl;
    var reportLinenCodes = Model.Details
        .Select(x => (x.LinenCode ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
}

@section Styles {
    <style>
        .linen-delivery-header label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linen-delivery-header .form-control-sm,
        .linen-delivery-header .custom-select-sm {
            height: 28px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .linen-delivery-header-checks {
            display: flex;
            align-items: center;
            min-height: 28px;
            gap: 0.75rem;
        }

        .linen-delivery-header-checks .custom-control {
            display: flex;
            align-items: center;
            min-height: 28px;
            margin-bottom: 0;
        }

        .linen-delivery-header-checks .custom-control-label {
            display: inline-flex;
            align-items: center;
            min-height: 28px;
            line-height: 1.2;
        }

        .linen-delivery-header-checks .custom-control-label::before,
        .linen-delivery-header-checks .custom-control-label::after {
            top: 50%;
            transform: translateY(-50%);
        }
        .linen-delivery-header-vb {
            display: grid;
            grid-template-columns: minmax(122px, 0.7fr) minmax(132px, 0.8fr) minmax(160px, 1fr) minmax(240px, 1.45fr) 92px 82px 92px;
            gap: 0.4rem 0.75rem;
            align-items: center;
        }

        .linen-delivery-header-vb .ld-inline-field {
            display: grid;
            grid-template-columns: max-content minmax(0, 1fr);
            gap: 0.35rem;
            align-items: center;
            min-width: 0;
        }

        .linen-delivery-header-vb .linen-delivery-supplier-wrap .ld-inline-field,
        .linen-delivery-header-vb .linen-delivery-note-wrap .ld-inline-field {
            grid-template-columns: 100px minmax(0, 1fr);
        }

        .linen-delivery-header-vb .ld-field-supplier {
            grid-column: 4;
            grid-row: 2;
        }

        .linen-delivery-header-vb .ld-field-lock {
            grid-column: 5;
            grid-row: 1;
        }

        .linen-delivery-header-vb .ld-field-note-view {
            grid-column: 6;
            grid-row: 1;
        }

        .linen-delivery-header-vb .ld-field-description {
            grid-column: 1 / span 3;
            grid-row: 2;
        }

        .linen-delivery-header-vb .ld-field-pantry {
            grid-column: 4;
            grid-row: 1;
        }

        .linen-delivery-header-vb .ld-field-rent {
            grid-column: 5;
            grid-row: 2;
        }

        .linen-delivery-header-vb .ld-field-save {
            grid-column: 7;
            grid-row: 2;
        }

        .linen-delivery-header-vb .ld-field-special {
            grid-column: 4 / span 2;
            grid-row: 3;
        }

        .linen-delivery-header-vb.ld-layout-supplier .ld-field-supplier,
        .linen-delivery-header-vb.ld-layout-special .ld-field-supplier {
            grid-row: 1;
        }

        .linen-delivery-header-vb.ld-layout-supplier .ld-field-rent {
            grid-column: 6;
            grid-row: 1;
        }

        .linen-delivery-header-vb.ld-layout-special .ld-field-rent {
