<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2" asp-validation-summary="All"></div>
        }

        <form method="post" id="linenDeliveryDetailForm">
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="DetailsJson" id="DetailsJson" />
            <input type="hidden" asp-for="RedirectUrl" id="RedirectUrl" />

            <div class="card card-primary card-outline">
                <div class="card-header py-2">
                    <h3 class="card-title">Linen Delivery Detail</h3>
                </div>
                <div class="card-body linen-delivery-header">
                    <div class="linen-delivery-header-vb">
                        <div class="ld-inline-field">
                            <label class="ld-header-label">Delivery ID</label>
                            <input asp-for="Header.DeliveryID" class="form-control form-control-sm" readonly />
                        </div>

                        <div class="ld-inline-field">
                            <label class="ld-header-label">Date</label>
                            <input asp-for="Header.DeliveryDate" type="date" class="form-control form-control-sm" readonly="@isView" />
                        </div>

                        <div class="ld-inline-field">
                            <label class="ld-header-label">Type(*)</label>
                            <select asp-for="Header.DeliveryType"
                                    asp-items="Model.DeliveryTypeOptions"
                                    class="form-control form-control-sm vni-font"
                                    id="Header_DeliveryType"
                                    disabled="@Model.IsTypeLocked">
                            </select>
                            @if (Model.IsTypeLocked)
                            {
                                <input type="hidden" asp-for="Header.DeliveryType" />
                            }
                        </div>

                        <div class="linen-delivery-supplier-wrap ld-field-supplier">
                            <div class="ld-inline-field">
                                <label class="ld-header-label">Supplier(*)</label>
                                <select asp-for="Header.SupplierID"
                                        asp-items="Model.SupplierOptions"
                                        class="form-control form-control-sm vni-font"
                                        id="Header_SupplierID"
                                        disabled="@isView">
                                </select>
                            </div>
                        </div>

                        <div class="ld-check-field ld-field-lock">
                            <span class="ld-header-label">Lock</span>
                            <div class="custom-control custom-checkbox">
                                <input asp-for="Header.Closed" class="custom-control-input" disabled="@isView" />
                                <label asp-for="Header.Closed" class="custom-control-label"><span class="sr-only">Lock</span></label>
                            </div>
                        </div>

                        <div class="ld-action-cell linen-delivery-note-wrap ld-field-note-view">
                            @if (Model.Header.NoteID.HasValue && Model.Header.NoteID.Value > 0)
                            {
                                <button type="button"
                                        class="btn btn-info btn-sm js-view-pantry-note"
                                        data-note-id="@Model.Header.NoteID.Value">
                                    View
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-info btn-sm js-view-pantry-note" disabled>View</button>
                            }
                        </div>

                        <div class="ld-inline-field ld-field-description">
                            <label class="ld-header-label">Description</label>
                            <input asp-for="Header.Description" class="form-control form-control-sm vni-font" maxlength="100" readonly="@isView" />
                        </div>

                        <div class="linen-delivery-note-wrap ld-field-pantry">
                            <div class="ld-inline-field">
                                <label class="ld-header-label">Pantry-Linen(*)</label>
                                <select asp-for="Header.NoteID"
                                        asp-items="Model.PantryNoteOptions"
                                        class="form-control form-control-sm vni-font"
                                        id="Header_NoteID"
                                        disabled="@Model.IsPantryNoteLocked">
                                </select>
                                @if (Model.IsPantryNoteLocked)
                                {
                                    <input type="hidden" asp-for="Header.NoteID" />
                                }
                            </div>
                        </div>

                        <div class="ld-check-field ld-field-rent">
                            <span class="ld-header-label">Is Rent</span>
                            <div class="custom-control custom-checkbox">
                                <input asp-for="Header.IsRent" class="custom-control-input" disabled="@isView" />
                                <label asp-for="Header.IsRent" class="custom-control-label"><span class="sr-only">Is Rent</span></label>
                            </div>
                        </div>

                        <div class="ld-action-cell ld-field-save">
                            @if (Model.CanSave)
                            {
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="fas fa-save"></i> Save
                                </button>
                            }
                        </div>

                        <div class="linen-delivery-special-wrap ld-field-special">
                            <div class="ld-check-field">
                                <span class="ld-header-label">Special Laundry</span>
                                <div class="custom-control custom-checkbox">
                                    <input asp-for="Header.IsSpecialLaundry" class="custom-control-input" disabled="@Model.IsSpecialLocked" />
                                    <label asp-for="Header.IsSpecialLaundry" class="custom-control-label"><span class="sr-only">Special Laundry</span></label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0 linen-delivery-grid" id="linenDeliveryDetailTable">
                            <colgroup>
                                <col style="width: 36px;" />
                                <col style="min-width: 160px;" />
                                <col style="min-width: 160px;" />
                                <col style="width: 70px;" />
                                <col style="width: 70px;" />
                                <col style="width: 80px;" />
                                <col style="width: 110px;" />
                                <col style="width: 120px;" />
                                <col style="min-width: 180px;" />
                            </colgroup>
                            <thead class="thead-light">
                                <tr>
                                    <th class="linen-delivery-action-cell text-center">@(isView ? "STT" : string.Empty)</th>
                                    <th>Location</th>
                                    <th>Linen</th>
                                    <th style="width: 70px;">Express</th>
                                    <th style="width: 70px;">Child</th>
                                    <th style="width: 80px;">Qty</th>
                                    <th style="width: 110px;">Price</th>
                                    <th style="width: 120px;">Amount</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Details.Count == 0)
                                {
                                    <tr class="linen-delivery-empty-row">
                                        <td colspan="9" class="text-center text-muted py-3">No detail rows</td>
                                    </tr>
                                }
                                else
                                {
                                    var rowIndex = 0;
                                    foreach (var row in Model.Details)
                                    {
                                        rowIndex++;
                                        <tr class="linen-delivery-detail-row"
                                            data-id="@row.ID"
                                            data-delivery-id="@row.DeliveryID"
                                            data-location="@row.Location"
                                            data-linen-code="@row.LinenCode"
                                            data-no-need-bill="@row.NoNeedBill.ToString().ToLowerInvariant()">
                                            <td class="linen-delivery-action-cell">
                                                @if (!isView)
                                                {
                                                    <div class="linen-delivery-action-wrap">
                                                        <button type="button" class="btn btn-xs btn-outline-danger border js-remove-row" title="Remove">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="linen-delivery-action-wrap">
                                                        @rowIndex
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm ld-location vni-font" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.LocationOptions)
                                                    {
                                                        if (option.Value == Convert.ToString(row.LocationID))
                                                        {
                                                            <option value="@option.Value" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm ld-linen vni-font" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.LinenOptions)
                                                    {
                                                        var price = option.Group?.Name ?? string.Empty;
                                                        if (option.Value == Convert.ToString(row.LinnenID))
                                                        {
                                                            <option value="@option.Value" data-price="@price" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value" data-price="@price">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center"><input type="checkbox" class="ld-express" @(row.Express ? "checked" : null) @(isView ? "disabled" : null) /></td>
                                            <td class="text-center"><input type="checkbox" class="ld-child" @(row.IsChild ? "checked" : null) @(isView ? "disabled" : null) /></td>
                                            <td><input type="text" inputmode="decimal" class="form-control form-control-sm text-right ld-quantity" value="@row.Quantity.ToString("#,0.##", System.Globalization.CultureInfo.InvariantCulture)" @(isView ? "readonly" : null) /></td>
                                            <td><input type="text" inputmode="decimal" class="form-control form-control-sm text-right ld-price" value="@row.Price.ToString("#,0.##", System.Globalization.CultureInfo.InvariantCulture)" @(isView ? "readonly" : null) /></td>
                                            <td><input type="text" inputmode="decimal" class="form-control form-control-sm text-right ld-amount" value="@row.Amount.ToString("#,0.##", System.Globalization.CultureInfo.InvariantCulture)" readonly /></td>
                                            <td class="linen-delivery-note-cell"><input type="text" maxlength="100" class="form-control form-control-sm ld-note vni-font" value="@row.Note" @(isView ? "readonly" : null) /></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer py-2 text-center">
                    @if (Model.CanSave)
                    {
                        <button type="button" class="btn btn-sm btn-success mr-2" id="btnAddDetailRow">
                            <i class="fas fa-plus"></i> Add Detail
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-info mr-2" id="btnPrintLinenDeliveryDetail">
                        <i class="fas fa-print"></i> Print
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-warning mr-2"
                            id="btnToBill"
                            @(Model.CanToBill ? null : "disabled")>
                        <i class="fas fa-file-invoice-dollar"></i> To Bill
                    </button>
                    <button type="button" class="btn btn-sm btn-default" id="btnCloseLinenDeliveryDetail" data-index-url="@indexUrl">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

