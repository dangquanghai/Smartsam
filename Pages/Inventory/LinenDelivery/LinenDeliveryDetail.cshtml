                                <select class="form-control form-control-sm vni-font" id="linenDeliveryReportLinenCode">
                                    <option value="">All</option>
                                    @foreach (var linenCode in reportLinenCodes)
                                    {
                                        <option value="@linenCode">@linenCode</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-8">
                            <div class="linen-delivery-report-inline-field">
                                <label class="linen-delivery-report-inline-label">From - To</label>
                                <input type="date"
                                       class="form-control form-control-sm"
                                       value="@Model.Header.DeliveryDate.ToString("yyyy-MM-dd")"
                                       disabled />
                                <input type="date"
                                       class="form-control form-control-sm"
                                       value="@Model.Header.DeliveryDate.ToString("yyyy-MM-dd")"
                                       disabled />
                            </div>
                        </div>
                        <div class="col-lg-1 col-md-4">
                            <button type="button" class="btn btn-sm btn-secondary btn-block" id="btnPreviewLinenDeliveryReport">Preview</button>
                        </div>
                    </div>
                </div>
                <div class="linen-delivery-report-status" id="linenDeliveryReportMeta">Delivery | @Model.Header.Description</div>
                <div class="linen-delivery-report-canvas">
                    <div id="linenDeliveryReportLoading" class="linen-delivery-report-loading">Loading PDF preview...</div>
                    <iframe id="linenDeliveryReportFrame"
