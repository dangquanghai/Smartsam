@page
@model SmartSam.Pages.Inventory.LinenReceiving.IndexModel
@{
    ViewData["Title"] = "Linen Receiving";
}

<section class="content">
    <div class="container-fluid">
        <div class="row linen-receiving-layout-row">
            <div class="col-md-2 linen-receiving-search-column">
                <div class="card card-info linen-receiving-search-panel">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-search"></i> Search</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="linenReceivingSearchForm">
                            @Html.AntiForgeryToken()

                            <div class="form-group">
                                <label>From Date - To Date</label>
                                <div class="linen-receiving-date-range-control">
                                    <input type="text"
                                           id="LinenReceivingDateRange"
                                           class="form-control form-control-sm"
                                           readonly />
                                </div>
                                <input asp-for="Filter.FromDate" type="hidden" />
                                <input asp-for="Filter.ToDate" type="hidden" />
                            </div>

                            <div class="form-group">
                                <label>Receive No</label>
                                <input asp-for="Filter.ReceiveId" class="form-control form-control-sm" inputmode="numeric" />
                            </div>

                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input asp-for="Filter.IsLocked" class="custom-control-input" />
                                    <label asp-for="Filter.IsLocked" class="custom-control-label">Lock</label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-block btn-sm">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-10 linen-receiving-result-column" id="linenReceivingResultPanelContainer">
                <div class="card card-primary">
                    <div class="card-header linen-receiving-table-header">
                        <div class="linen-receiving-table-header-left">
                            <h3 class="card-title">Linen Receiving</h3>
                            <span class="badge badge-light ml-2" id="total-records-badge">0 records</span>
                        </div>
                        <div class="linen-receiving-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div id="pagination-info" class="d-inline-block mr-2 linen-receiving-table-paging-info">
                                    <small>No records</small>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered mb-0 text-nowrap" id="linenReceivingTable">
                                <colgroup>
                                    <col style="width: 32px;" />
                                    <col style="width: 110px;" />
                                    <col style="width: 120px;" />
                                    <col />
                                    <col style="width: 420px;" />
                                </colgroup>
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 32px;"></th>
                                        <th style="width: 110px;">ID</th>
                                        <th style="width: 120px;">Date</th>
                                        <th>Description</th>
                                        <th>DeliveryInfor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">No data</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card card-outline card-primary linen-receiving-action-panel">
                    <div class="card-footer p-2 text-center">
                        @if (Model.CanAdd)
                        {
                            <button class="btn btn-success btn-sm" id="btnAdd" type="button">
                                <i class="fas fa-plus"></i> Add
                            </button>
                            <button class="btn btn-danger btn-sm" id="btnDelete" type="button" disabled>
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        }
                        <button class="btn btn-info btn-sm" id="btnPrint" type="button" disabled>
                            <i class="fas fa-print"></i> Print
                        </button>
                        <a class="btn btn-secondary btn-sm" href="/">
                            <i class="fas fa-times"></i> Close
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/Inventory/LinenReceiving/index.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        var defaultPageSize = @Model.DefaultPageSize;
    </script>
    <script src="~/js/Inventory/LinenReceiving/index.js" asp-append-version="true"></script>
}
