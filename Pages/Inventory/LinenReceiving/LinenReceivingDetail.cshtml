@page
@model SmartSam.Pages.Inventory.LinenReceiving.LinenReceivingDetailModel
@{
    ViewData["Title"] = "Linen Receiving Detail";
    var isView = Model.IsViewMode;
    var reportLinenCodes = Model.Details
        .Select(x => (x.LinenCode ?? string.Empty).Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
}

@section Styles {
    <style>
        .linen-receiving-header label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linen-receiving-header .form-control-sm,
        .linen-receiving-header .custom-select-sm {
            height: 28px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .linen-receiving-header-checks {
            display: flex;
            align-items: center;
            min-height: 28px;
            gap: 0.75rem;
        }

        .linen-receiving-header-checks .custom-control {
            display: flex;
            align-items: center;
            min-height: 28px;
            margin-bottom: 0;
        }

        .linen-receiving-header-checks .custom-control-label {
            display: inline-flex;
            align-items: center;
            min-height: 28px;
            line-height: 1.2;
        }

        .linen-receiving-header-checks .custom-control-label::before,
        .linen-receiving-header-checks .custom-control-label::after {
            top: 50%;
            transform: translateY(-50%);
        }

        .linen-receiving-header-layout {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
        }

        .linen-receiving-header-left {
            flex: 0 0 58%;
            max-width: 58%;
        }

        .linen-receiving-header-right {
            flex: 1 1 42%;
            max-width: 42%;
        }

        .linen-receiving-header .form-group {
            margin-left: 0;
            margin-right: 0;
        }

        .linen-receiving-header .lr-label-main,
        .linen-receiving-header .lr-label-sub {
            text-align: left;
            padding-right: 0.5rem;
        }

        .linen-receiving-header .lr-label-main {
            flex: 0 0 22%;
            max-width: 22%;
        }

        .linen-receiving-header .lr-field-main {
            flex: 0 0 78%;
            max-width: 78%;
        }

        .linen-receiving-header .lr-label-sub {
            flex: 0 0 18%;
            max-width: 18%;
            padding-left: 1.5rem;
        }

        .linen-receiving-header .lr-field-sub {
            flex: 0 0 24%;
            max-width: 24%;
        }

        .linen-receiving-header .lr-note-select {
            flex: 0 0 53%;
            max-width: 53%;
        }

        .linen-receiving-header .lr-note-view {
            flex: 0 0 25%;
            max-width: 25%;
        }

        .linen-receiving-header .lr-note-view .btn {
            width: 92px;
            min-width: 78px;
            height: 28px;
            padding-top: 2px;
            padding-bottom: 2px;
            text-align: center;
        }

        .linen-receiving-header .lr-special-field {
            flex: 0 0 78%;
            max-width: 78%;
        }


        .linen-receiving-grid th,
        .linen-receiving-grid td {
            vertical-align: middle !important;
        }

        #linenReceivingDetailTable tbody > tr > td:first-of-type,
        #linenReceivingDetailTable tbody > tr > th:first-of-type,
        #linenReceivingDetailTable tfoot > tr > td:first-of-type,
        #linenReceivingDetailTable tfoot > tr > th:first-of-type,
        #linenReceivingDetailTable thead > tr > td:first-of-type,
        #linenReceivingDetailTable thead > tr > th:first-of-type {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        #linenReceivingDetailTable .select2-container {
            width: 100% !important;
        }

        #linenReceivingDetailTable .select2-container--default .select2-selection--single {
            height: 31px;
            min-height: 31px;
            border: 1px solid #ced4da;
            border-radius: 0.2rem;
        }

        #linenReceivingDetailTable .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 29px;
            padding-left: 0.5rem;
            padding-right: 1.5rem;
        }

        #linenReceivingDetailTable .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 29px;
        }

        .linen-receiving-grid .form-control-sm,
        .linen-receiving-grid .custom-select-sm {
            min-width: 50px;
        }

        .linen-receiving-grid .lr-location,
        .linen-receiving-grid .lr-linen {
            min-width: 160px;
        }

        .linen-receiving-action-cell {
            width: 36px;
            padding: 0 !important;
            vertical-align: middle;
        }

        .linen-receiving-action-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            font-weight: 600;
        }

        .linen-receiving-note-cell {
            padding: 0.3rem !important;
        }

        .linen-receiving-report-modal-dialog {
            max-width: 90vw;
            width: 90vw;
            margin: 0.5rem auto;
        }

        .linen-receiving-report-modal-dialog .modal-content {
            height: 88vh;
            max-height: 88vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: 0;
        }

        .linen-receiving-delivery-detail-modal-dialog {
            max-width: 90vw;
            width: 90vw;
            margin: 0.5rem auto;
        }

        .linen-receiving-delivery-detail-modal-dialog .modal-content {
            height: 90vh;
            max-height: 90vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: 0;
        }

        #linenReceivingDeliveryDetailModal.fade .modal-dialog {
            opacity: 0;
            transform: translate(0, 0) scaleY(0.04);
            transform-origin: center center;
            transition: transform 0.22s ease-out, opacity 0.14s ease-out;
        }

        #linenReceivingDeliveryDetailModal.show .modal-dialog {
            opacity: 1;
            transform: translate(0, 0) scaleY(1);
        }

        #linenReceivingDeliveryDetailModal .modal-content {
            transform-origin: center center;
        }

        @@media (prefers-reduced-motion: reduce) {
            #linenReceivingDeliveryDetailModal.fade .modal-dialog,
            #linenReceivingDeliveryDetailModal.show .modal-dialog {
                opacity: 1;
                transform: none;
                transition: none;
            }
        }

        .linen-receiving-delivery-detail-body {
            flex: 1 1 auto;
            min-height: 0;
            padding: 0;
        }

        .linen-receiving-delivery-detail-frame {
            display: block;
            width: 100%;
            height: 100%;
            min-height: 0;
            border: 0;
            background: #fff;
        }

        .linen-receiving-report-body {
            flex: 1 1 auto;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        .linen-receiving-report-toolbar {
            background: #efefef;
            border-bottom: 1px solid #b8b8b8;
            padding: 0.5rem 0.65rem 0.35rem;
            flex: 0 0 auto;
        }

        .linen-receiving-report-mode-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem 1rem;
            margin-bottom: 0.4rem;
        }

        .linen-receiving-report-modes {
            display: flex;
            flex-wrap: wrap;
            gap: 0.2rem 0.9rem;
        }

        .linen-receiving-report-mode-item,
        .linen-receiving-report-inline-field,
        .linen-receiving-report-chart,
        .linen-receiving-report-chart .custom-control,
        .linen-receiving-report-chart .custom-control-label {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
        }

        .linen-receiving-report-mode-item {
            gap: 0.2rem;
            font-size: 12px;
        }

        .linen-receiving-report-mode-item input {
            margin: 0;
        }

        .linen-receiving-report-mode-item input:checked + span {
            color: #198754;
            font-weight: 700;
            background: #e8f5ee;
            border: 1px solid #198754;
            border-radius: 3px;
            padding: 1px 4px;
        }

        .linen-receiving-report-mode-item:has(input:checked) {
            color: #198754;
        }

        .linen-receiving-report-toolbar label {
            margin-bottom: 0;
            white-space: nowrap;
            font-weight: 400;
        }

        .linen-receiving-report-toolbar .form-control-sm {
            height: 26px;
            padding-top: 1px;
            padding-bottom: 1px;
            border-radius: 0;
            font-size: 12px;
        }

        .linen-receiving-report-inline-field {
            gap: 0.45rem;
        }

        .linen-receiving-report-inline-field .form-control {
            flex: 1 1 auto;
            min-width: 0;
        }

        .linen-receiving-report-status {
            padding: 0.35rem 0.75rem 0;
            color: #4a5560;
            min-height: 22px;
            font-size: 12px;
            flex: 0 0 auto;
        }

        .linen-receiving-report-canvas {
            background: #b8b8b8;
            padding: 1rem;
            flex: 1 1 auto;
            min-height: 0;
            overflow: auto;
        }

        .linen-receiving-report-iframe {
            display: block;
            width: 100%;
            height: 100%;
            min-height: 0;
            border: 1px solid #8c8c8c;
            background: #fff;
        }

        .linen-receiving-report-loading {
            display: none;
            padding: 1rem;
            text-align: center;
            color: #6c757d;
            background: #f8f9fa;
            margin-bottom: 0.5rem;
            flex: 0 0 auto;
        }

        @@media (max-width: 991.98px) {
            .linen-receiving-header-layout {
                display: block;
            }

            .linen-receiving-header-left,
            .linen-receiving-header-right {
                max-width: 100%;
                flex-basis: 100%;
            }

            .linen-receiving-header .lr-label-main,
            .linen-receiving-header .lr-field-main,
            .linen-receiving-header .lr-label-sub,
            .linen-receiving-header .lr-field-sub,
            .linen-receiving-header .lr-note-select,
            .linen-receiving-header .lr-note-view,
            .linen-receiving-header .lr-special-field {
                flex: 0 0 100%;
                max-width: 100%;
                padding-left: 0;
            }

            .linen-receiving-header .lr-label-sub {
                padding-top: 0.25rem;
            }
        }
    </style>
}

<section class="content vni-font">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2 js-auto-dismiss-alert" role="alert" data-timeout="10000">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2" asp-validation-summary="All"></div>
        }

        <form method="post" id="linenReceivingDetailForm">
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="DetailsJson" id="DetailsJson" />

            <div class="card card-primary card-outline">
                <div class="card-header py-2">
                    <h3 class="card-title">Linen Receiving Detail</h3>
                </div>
                <div class="card-body pb-2 linen-receiving-header">
                    <div class="linen-receiving-header-layout">
                        <div class="linen-receiving-header-left">
                            <div class="form-group row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label col-form-label-sm lr-label-main">Receive ID</label>
                                <div class="col-sm-4 lr-field-sub">
                                    <input asp-for="Header.ReceiveID" class="form-control form-control-sm" readonly />
                                </div>
                                <label class="col-sm-1 col-form-label col-form-label-sm lr-label-sub">Date</label>
                                <div class="col-sm-4 lr-field-sub">
                                    <input asp-for="Header.ReceiveDate" type="date" class="form-control form-control-sm" readonly="@isView" />
                                </div>
                            </div>

                            <div class="form-group row mb-2 align-items-center">
                                <label class="col-sm-3 col-form-label col-form-label-sm lr-label-main">Description</label>
                                <div class="col-sm-9 lr-field-main">
                                    <input asp-for="Header.Description" class="form-control form-control-sm vni-font" maxlength="100" readonly="@isView" />
                                </div>
                            </div>
                        </div>

                        <div class="linen-receiving-header-right">
                            <div class="form-group row mb-2 align-items-center linen-receiving-delivery-wrap">
                                <label class="col-sm-3 col-form-label col-form-label-sm lr-label-main">Delivery(*)</label>
                                <div class="col-sm-6 lr-note-select">
                                    <select asp-for="Header.SendID"
                                            asp-items="Model.DeliveryOptions"
                                            class="form-control form-control-sm vni-font"
                                            id="Header_SendID"
                                            disabled="@Model.IsDeliveryLocked">
                                    </select>
                                    @if (Model.IsDeliveryLocked)
                                    {
                                        <input type="hidden" asp-for="Header.SendID" />
                                    }
                                </div>
                                <div class="col-sm-3 lr-note-view">
                                    <button type="button"
                                            class="btn btn-info btn-sm js-view-delivery-detail"
                                            id="btnViewLinenReceivingDelivery"
                                            data-delivery-url="@(Model.Header.SendID.HasValue && Model.Header.SendID.Value > 0 ? Url.Page("/Inventory/LinenDelivery/LinenDeliveryDetail", new { id = Model.Header.SendID.Value, mode = "view", popup = true }) : string.Empty)"
                                            data-delivery-url-template="@Url.Page("/Inventory/LinenDelivery/LinenDeliveryDetail", new { id = "__DELIVERY_ID__", mode = "view", popup = true })"
                                            disabled="@(!Model.Header.SendID.HasValue || Model.Header.SendID.Value <= 0)">
                                        View
                                    </button>
                                </div>
                            </div>

                            <div class="form-group row mb-0 align-items-center linen-receiving-options-wrap">
                                <label class="col-sm-3 col-form-label col-form-label-sm lr-label-main">Options</label>
                                <div class="col-sm-6 linen-receiving-header-checks lr-note-select">
                                    <div class="custom-control custom-checkbox d-inline-block mr-3">
                                        <input asp-for="Header.IsRent" class="custom-control-input" disabled="@isView" />
                                        <label asp-for="Header.IsRent" class="custom-control-label">Rent</label>
                                    </div>
                                    <div class="custom-control custom-checkbox d-inline-block">
                                        <input asp-for="Header.IsLocked" class="custom-control-input" disabled="@isView" />
                                        <label asp-for="Header.IsLocked" class="custom-control-label">Lock</label>
                                    </div>
                                </div>
                                <div class="col-sm-3 lr-note-view">
                                    @if (Model.CanSave)
                                    {
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <i class="fas fa-save"></i> Save
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0 linen-receiving-grid" id="linenReceivingDetailTable">
                            <colgroup>
                                <col style="width: 36px;" />
                                <col style="min-width: 180px;" />
                                <col style="min-width: 160px;" />
                                <col style="min-width: 160px;" />
                                <col style="width: 70px;" />
                                <col style="width: 70px;" />
                                <col style="width: 80px;" />
                                <col style="width: 110px;" />
                                <col style="width: 120px;" />
                                <col style="min-width: 180px;" />
                            </colgroup>
                            <thead class="thead-light">
                                <tr>
                                    <th class="linen-receiving-action-cell text-center">@(isView ? "#" : string.Empty)</th>
                                    <th>Delivery</th>
                                    <th>Location</th>
                                    <th>Linen</th>
                                    <th style="width: 70px;">Express</th>
                                    <th style="width: 70px;">Child</th>
                                    <th style="width: 80px;">Qty</th>
                                    <th style="width: 110px;">Price</th>
                                    <th style="width: 120px;">Amount</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Details.Count == 0)
                                {
                                    <tr class="linen-receiving-empty-row">
                                        <td colspan="10" class="text-center text-muted py-3">No detail rows</td>
                                    </tr>
                                }
                                else
                                {
                                    var rowIndex = 0;
                                    foreach (var row in Model.Details)
                                    {
                                        rowIndex++;
                                        var rowSendId = row.SendID ?? Model.Header.SendID;
                                        <tr class="linen-receiving-detail-row" data-id="@row.ID">
                                            <td class="linen-receiving-action-cell">
                                                @if (!isView)
                                                {
                                                    <div class="linen-receiving-action-wrap">
                                                        <button type="button" class="btn btn-xs btn-outline-danger border js-remove-row" title="Remove">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="linen-receiving-action-wrap">
                                                        @rowIndex
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm lr-delivery vni-font" data-delivery-loaded="false" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.DeliveryOptions)
                                                    {
                                                        if (option.Value == Convert.ToString(rowSendId))
                                                        {
                                                            <option value="@option.Value" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm lr-location select2 vni-font" data-placeholder="-- Select --" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.LocationOptions)
                                                    {
                                                        if (option.Value == Convert.ToString(row.LocationID))
                                                        {
                                                            <option value="@option.Value" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-control form-control-sm lr-linen vni-font" @(isView ? "disabled" : null)>
                                                    @foreach (var option in Model.LinenOptions)
                                                    {
                                                        var price = option.Group?.Name ?? string.Empty;
                                                        if (option.Value == Convert.ToString(row.LinnenID))
                                                        {
                                                            <option value="@option.Value" data-price="@price" selected>@option.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@option.Value" data-price="@price">@option.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center"><input type="checkbox" class="lr-express" @(row.Express ? "checked" : null) @(isView ? "disabled" : null) /></td>
                                            <td class="text-center"><input type="checkbox" class="lr-child" @(row.IsChild ? "checked" : null) @(isView ? "disabled" : null) /></td>
                                            <td><input type="text" inputmode="decimal" class="form-control form-control-sm text-right lr-quantity" value="@row.Quantity.ToString("#,0", System.Globalization.CultureInfo.InvariantCulture)" @(isView ? "readonly" : null) /></td>
                                            <td><input type="text" inputmode="decimal" class="form-control form-control-sm text-right lr-price" value="@row.Price.ToString("#,0", System.Globalization.CultureInfo.InvariantCulture)" @(isView ? "readonly" : null) /></td>
                                            <td><input type="text" inputmode="decimal" class="form-control form-control-sm text-right lr-amount" value="@row.Amount.ToString("#,0", System.Globalization.CultureInfo.InvariantCulture)" readonly /></td>
                                            <td class="linen-receiving-note-cell"><input type="text" maxlength="100" class="form-control form-control-sm lr-note vni-font" value="@row.Note" @(isView ? "readonly" : null) /></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer py-2 text-center">
                    @if (Model.CanSave)
                    {
                        <button type="button" class="btn btn-sm btn-success mr-2" id="btnAddDetailRow">
                            <i class="fas fa-plus"></i> Add Detail
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-info mr-2" id="btnPrintLinenReceivingDetail">
                        <i class="fas fa-print"></i> Print
                    </button>
                    <a class="btn btn-sm btn-default" href="@Model.BackUrl">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </a>
                </div>
            </div>
        </form>
    </div>
</section>

<div class="modal fade" id="linenReceivingReportModal" tabindex="-1" role="dialog" aria-labelledby="linenReceivingReportModalLabel" aria-hidden="true">
    <div class="modal-dialog linen-receiving-report-modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linenReceivingReportModalLabel">Linen - Report</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0 linen-receiving-report-body">
                <div class="linen-receiving-report-toolbar">
                    <div class="linen-receiving-report-mode-row">
                        <div class="linen-receiving-report-modes">
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="pantry" disabled /><span>Pantry-Linen</span></label>
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="delivery" disabled /><span>Delivery</span></label>
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="receive" checked disabled /><span>Receive</span></label>
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="laundry-record" disabled /><span>Laudry Record</span></label>
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="not-receive" disabled /><span>Not Receive</span></label>
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="laundry-balance" disabled /><span>Laundry.U. Balance</span></label>
                            <label class="linen-receiving-report-mode-item"><input type="radio" name="linenReceivingReportType" value="apmt-balance" disabled /><span>Apmt Balance</span></label>
                        </div>
                        <div class="linen-receiving-report-chart">
                            <div class="custom-control custom-checkbox mb-0">
                                <input type="checkbox" class="custom-control-input" id="linenReceivingReportChart" disabled />
                                <label class="custom-control-label" for="linenReceivingReportChart">Chart</label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-4 col-md-6">
                            <div class="linen-receiving-report-inline-field">
                                <label for="linenReceivingReportDescription" class="linen-receiving-report-inline-label">Des</label>
                                <select class="form-control form-control-sm vni-font" id="linenReceivingReportDescription" disabled>
                                    <option value="@Model.Header.ReceiveID">@Model.Header.Description</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="linen-receiving-report-inline-field">
                                <label for="linenReceivingReportLinenCode" class="linen-receiving-report-inline-label">Linnen</label>
                                <select class="form-control form-control-sm vni-font" id="linenReceivingReportLinenCode">
                                    <option value="">All</option>
                                    @foreach (var linenCode in reportLinenCodes)
                                    {
                                        <option value="@linenCode">@linenCode</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-8">
                            <div class="linen-receiving-report-inline-field">
                                <label class="linen-receiving-report-inline-label">From - To</label>
                                <input type="date" class="form-control form-control-sm" value="@Model.Header.ReceiveDate.ToString("yyyy-MM-dd")" disabled />
                                <input type="date" class="form-control form-control-sm" value="@Model.Header.ReceiveDate.ToString("yyyy-MM-dd")" disabled />
                            </div>
                        </div>
                        <div class="col-lg-1 col-md-4">
                            <button type="button" class="btn btn-sm btn-secondary btn-block" id="btnPreviewLinenReceivingReport">Preview</button>
                        </div>
                    </div>
                </div>
                <div class="linen-receiving-report-status" id="linenReceivingReportMeta">Receive | @Model.Header.Description</div>
                <div class="linen-receiving-report-canvas">
                    <div id="linenReceivingReportLoading" class="linen-receiving-report-loading">Loading PDF preview...</div>
                    <iframe id="linenReceivingReportFrame" class="linen-receiving-report-iframe" title="Linen Receiving Report"></iframe>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="linenReceivingDeliveryDetailModal" tabindex="-1" role="dialog" aria-labelledby="linenReceivingDeliveryDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog linen-receiving-delivery-detail-modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linenReceivingDeliveryDetailModalLabel">Linen Delivery Detail</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body linen-receiving-delivery-detail-body">
                <iframe id="linenReceivingDeliveryDetailFrame"
                        class="linen-receiving-delivery-detail-frame"
                        title="Linen Delivery Detail"></iframe>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        window.linenReceivingPage = {
            isView: @Model.IsViewMode.ToString().ToLowerInvariant(),
            receiveId: @Model.Header.ReceiveID,
            sendId: @(Model.Header.SendID?.ToString() ?? "null"),
            reportPdfUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("/Inventory/LinenReport/Index", "Pdf", new { reportType = "receive", descriptionId = Model.Header.ReceiveID, lockedReportType = "receive", popup = true }))),
            rowTemplateOptions: {
                deliveries: @Html.Raw(Model.DeliveryOptionsJson),
                locations: @Html.Raw(Model.LocationOptionsJson),
                linens: @Html.Raw(Model.LinenOptionsJson)
            }
        };
    </script>
    <script src="~/js/Inventory/LinenReceiving/LinenReceivingDetail.js" asp-append-version="true"></script>
}
