@page
@model SmartSam.Pages.Inventory.InventoryReceived.IndexModel
@{
    ViewData["Title"] = "Item Received List";
    var currentPage = Model.Filter.Page <= 0 ? 1 : Model.Filter.Page;
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
    var pageItems = new List<int?>();
    for (var p = 1; p <= totalPages; p++)
    {
        if (p == 1 || p == totalPages || (p >= currentPage - 2 && p <= currentPage + 2)) pageItems.Add(p);
        else if (pageItems.Count == 0 || pageItems[^1].HasValue) pageItems.Add(null);
    }
    Func<int, string> pageUrl = page => Url.Page("./Index", new
    {
        FlowNo = Model.Filter.FlowNo,
        PONo = Model.Filter.PONo,
        ToStoreId = Model.Filter.ToStoreId,
        RecTypeId = Model.Filter.RecTypeId,
        StatusId = Model.Filter.StatusId,
        FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"),
        ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"),
        Page = page,
        PageSize = Model.Filter.PageSize
    }) ?? "#";
}

<section class="content vni-font inventory-received-page">
    <div class="container-fluid">
        <form method="post" asp-page-handler="Delete" id="receiveDeleteForm">
            <input type="hidden" name="id" id="deleteFlowId" />
            <input type="hidden" name="Filter.FlowNo" value="@Model.Filter.FlowNo" />
            <input type="hidden" name="Filter.PONo" value="@Model.Filter.PONo" />
            <input type="hidden" name="Filter.ToStoreId" value="@Model.Filter.ToStoreId" />
            <input type="hidden" name="Filter.RecTypeId" value="@Model.Filter.RecTypeId" />
            <input type="hidden" name="Filter.StatusId" value="@Model.Filter.StatusId" />
            <input type="hidden" name="Filter.FromDate" value="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="Filter.ToDate" value="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="Filter.Page" value="@Model.Filter.Page" />
            <input type="hidden" name="Filter.PageSize" value="@Model.Filter.PageSize" />
        </form>
        <div class="row">
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header"><h3 class="card-title"><i class="fas fa-search"></i> Search</h3></div>
                    <div class="card-body">
                        <form method="get">
                            <input type="hidden" name="Page" value="1" />
                            <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />
                            <div class="form-group mb-2"><label>Doc No.</label><input asp-for="Filter.FlowNo" name="FlowNo" class="form-control form-control-sm vni-font" /></div>
                            <div class="form-group mb-2"><label>PO No.</label><input asp-for="Filter.PONo" name="PONo" class="form-control form-control-sm vni-font" /></div>
                            <div class="form-group mb-2"><label>From</label><input asp-for="Filter.FromDate" name="FromDate" type="date" class="form-control form-control-sm" /></div>
                            <div class="form-group mb-2"><label>To</label><input asp-for="Filter.ToDate" name="ToDate" type="date" class="form-control form-control-sm" /></div>
                            <div class="form-group mb-2"><label>Rec. Type</label><select asp-for="Filter.RecTypeId" name="RecTypeId" asp-items="Model.ReceiveTypes" class="form-control form-control-sm select2 vni-font"></select></div>
                            <div class="form-group mb-2"><label>Status</label><select asp-for="Filter.StatusId" name="StatusId" asp-items="Model.Statuses" class="form-control form-control-sm select2 vni-font"></select></div>
                            <div class="form-group mb-2"><label>To St House</label><select asp-for="Filter.ToStoreId" name="ToStoreId" asp-items="Model.Stores" class="form-control form-control-sm select2 vni-font"></select></div>
                            <button type="submit" class="btn btn-primary btn-block btn-sm border mb-2"><i class="fas fa-search"></i> Search</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-10">
                <div class="card card-primary">
                    <div class="card-header prq-table-header">
                        <div class="prq-table-header-left">
                            <h3 class="card-title">Item Received List</h3>
                            <span class="badge badge-light ml-2">@Model.TotalRecords records</span>
                        </div>
                        <div class="prq-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div class="d-inline-block mr-2 prq-pagination-info">
                                    @if (Model.TotalRecords == 0)
                                    {
                                        <small>No records</small>
                                    }
                                    else
                                    {
                                        <small>Showing @Model.PageStart to @Model.PageEnd of @Model.TotalRecords entries</small>
                                    }
                                </div>
                                <div class="prq-page-size-form d-inline-flex mr-2">
                                    <label class="mb-0 prq-page-size-label" for="receivePageSize">Show</label>
                                    <select id="receivePageSize" class="form-control form-control-sm prq-page-size-select">
                                        @foreach (var pageSizeOption in Model.PageSizeOptions)
                                        {
                                            <option value="@pageSizeOption" selected="@(Model.Filter.PageSize == pageSizeOption ? "selected" : null)">@pageSizeOption</option>
                                        }
                                    </select>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasPreviousPage ? pageUrl(currentPage - 1) : "#")">Prev</a>
                                    </li>
                                    @foreach (var pageItem in pageItems)
                                    {
                                        if (pageItem.HasValue)
                                        {
                                            <li class="page-item @(pageItem.Value == currentPage ? "active" : "")">
                                                <a class="page-link prq-pager-link" href="@pageUrl(pageItem.Value)">@pageItem.Value</a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                        }
                                    }
                                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasNextPage ? pageUrl(currentPage + 1) : "#")">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive prq-table-wrap">
                        <table class="table table-hover table-bordered mb-0 text-nowrap prq-table" id="receiveTable">
                            <thead class="thead-light">
                                <tr>
                                    <th style="width:32px;"></th>
                                    <th style="width:150px;">Doc No.</th>
                                    <th style="width:120px;">Received Date</th>
                                    <th>Status</th>
                                    <th style="width:210px;">StoreName</th>
                                    <th style="width:140px;">PO.No</th>
                                    <th style="width:260px;">Rec. Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Rows.Count == 0)
                                {
                                    <tr><td colspan="7" class="text-center text-muted py-3">No item received found.</td></tr>
                                }
                                else
                                {
                                    foreach (var row in Model.Rows)
                                    {
                                        <tr class="receive-row" data-flowid="@row.FlowID" data-statusid="@row.StatusID" data-view-url="@Url.Page("./InventoryReceivedDetail", new { id = row.FlowID, mode = "view" })" data-edit-url="@Url.Page("./InventoryReceivedDetail", new { id = row.FlowID, mode = "edit" })" data-approved-url="@Url.Page("./InventoryReceivedDetail", new { id = row.FlowID, mode = "approved" })">
                                            <td><input type="radio" class="receive-selector" name="selectedInventoryReceived" aria-label="Select row" /></td>
                                            <td>
                                                @if (Model.PagePerm.HasPermission(2) || Model.PagePerm.HasPermission(4) || Model.PagePerm.HasPermission(5))
                                                {
                                                    var accessMode = Model.PagePerm.HasPermission(4) ? "edit" : (Model.PagePerm.HasPermission(5) ? "approved" : "view");
                                                    <a href="@Url.Page("./InventoryReceivedDetail", new { id = row.FlowID, mode = accessMode })" class="prq-row-link prq-row-link-request-no text-bold">@row.FlowNo</a>
                                                }
                                                else
                                                {
                                                    <span class="prq-row-link-request-no text-bold">@row.FlowNo</span>
                                                }
                                            </td>
                                            <td>@row.FlowDate.ToString("dd/MM/yyyy")</td>
                                            <td>@row.StatusName</td>
                                            <td>@row.StoreName</td>
                                            <td>@row.PONo</td>
                                            <td>@row.SupplierName</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>

                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center module-action-bar prq-action-bar">
                        @if (Model.PagePerm.HasPermission(3))
                        {
                            <a asp-page="./InventoryReceivedDetail" asp-route-mode="add" class="btn btn-sm btn-action-add border mx-1 my-1"><i class="fas fa-plus"></i> Add</a>
                        }
                        @if (Model.PagePerm.HasPermission(4))
                        {
                            <button type="button" id="btnDeleteReceived" class="btn btn-sm btn-danger border mx-1 my-1" disabled><i class="fas fa-trash"></i> Delete</button>
                        }
                        @if (Model.PagePerm.HasPermission(2))
                        {
                            <button type="button" class="btn btn-sm btn-action-close border mx-1 my-1" data-toggle="modal" data-target="#receiveSearchDetailModal"><i class="fas fa-search-plus"></i> Search Detail</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade vni-font" id="receiveSearchDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 96vw; width: 96vw;" role="document">
        <div class="modal-content">
            <div class="modal-header py-2"><h5 class="modal-title">Search Detail</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body">
                <div class="form-row align-items-end mb-2">
                    <div class="col-md-5"><label>Item Code / Item Name / Doc No.</label><input id="receiveDetailKeyword" class="form-control form-control-sm vni-font" /></div>
                    <div class="col-md-1"><button id="btnReceiveDetailSearch" type="button" class="btn btn-sm btn-primary btn-block"><i class="fas fa-search"></i> Search</button></div>
                </div>
                <div class="table-responsive receive-detail-table-wrap">
                    <table class="table table-sm table-bordered table-hover mb-1 text-nowrap receive-detail-table">
                        <thead class="thead-light"><tr><th>Item Code</th><th>Item Name</th><th>Doc No.</th><th>Date</th><th class="text-right">Act. Qty</th><th class="text-right">Price</th><th class="text-right">Amount</th></tr></thead>
                        <tbody id="receiveDetailRows"><tr><td colspan="7" class="text-center text-muted">Enter keyword then search.</td></tr></tbody>
                    </table>
                </div>
                <div class="prq-table-header-right mt-2">
                    <nav aria-label="Search detail paging">
                        <div class="d-inline-block mr-2 prq-pagination-info">
                            <small id="receiveDetailPagingInfo">No records</small>
                        </div>
                        <div class="prq-page-size-form d-inline-flex mr-2">
                            <label class="mb-0 prq-page-size-label" for="receiveDetailPageSize">Show</label>
                            <select id="receiveDetailPageSize" class="form-control form-control-sm prq-page-size-select">
                                @foreach (var pageSizeOption in Model.PageSizeOptions)
                                {
                                    <option value="@pageSizeOption" selected="@(pageSizeOption == 10 ? "selected" : null)">@pageSizeOption</option>
                                }
                            </select>
                        </div>
                        <ul class="pagination pagination-sm mb-0 d-inline-flex" id="receiveDetailPagination"></ul>
                    </nav>
                </div>
            </div>
            <div class="modal-footer py-2"><button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button></div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="receiveDeleteConfirmModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger py-2">
                <h5 class="modal-title text-white">Confirm Delete</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="receiveDeleteConfirmText">Do you want to delete this Doc no.?</div>
            <div class="modal-footer py-2">
                <button type="button" id="btnConfirmDeleteReceived" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Delete</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Purchasing/PurchaseRequisition/index.css" asp-append-version="true" />
    <style>
        #receiveTable tbody tr.receive-row {
            cursor: pointer;
        }
        body.inventory-received-search-modal-open .select2-container { z-index: 1040 !important; }
        #receiveSearchDetailModal { z-index: 2050; }
        #receiveSearchDetailModal .modal-dialog { z-index: 2051; }
        #receiveSearchDetailModal .modal-content { z-index: 2052; }
        #receiveSearchDetailModal .select2-container { z-index: 2060 !important; }
        #receiveSearchDetailModal .select2-dropdown { z-index: 2061 !important; }
        #receiveDeleteConfirmModal { z-index: 2050; }
        #receiveDeleteConfirmModal .modal-dialog { z-index: 2051; }
        #receiveDeleteConfirmModal .modal-content { z-index: 2052; }
        .receive-detail-table-wrap { overflow-x: auto; }
        .receive-detail-table { min-width: 1100px; }
        .receive-detail-table th,
        .receive-detail-table td { white-space: nowrap; }
    </style>
}

@section Scripts {
    <script>
        (function () {
            const $searchDetailModal = $('#receiveSearchDetailModal');
            const $deleteConfirmModal = $('#receiveDeleteConfirmModal');
            let receiveDetailState = { page: 1, pageSize: 10, totalPages: 1, totalRecords: 0, keyword: '' };

            if ($.fn.select2) {
                $('select').select2({ width: '100%' });
            }

            function destroyBackgroundSelect2() {
                $('select.select2').each(function () {
                    const $select = $(this);
                    if ($select.closest('.modal').length > 0) return;
                    if ($select.data('select2')) {
                        $select.select2('close');
                        $select.select2('destroy');
                    }
                });
                $('body').addClass('inventory-received-search-modal-open');
            }

            function initBackgroundSelect2() {
                $('select.select2').each(function () {
                    const $select = $(this);
                    if ($select.closest('.modal').length > 0) return;
                    if (!$select.data('select2')) {
                        $select.select2({ width: '100%' });
                    }
                });
                $('body').removeClass('inventory-received-search-modal-open');
            }

            function buildPagerItems(currentPage, totalPages) {
                const items = [];
                if (totalPages <= 0) return items;
                items.push({ text: 'Prev', page: Math.max(1, currentPage - 1), disabled: currentPage <= 1, active: false });
                const pages = [];
                pages.push(1);
                for (let page = currentPage - 1; page <= currentPage + 1; page++) {
                    if (page > 1 && page < totalPages) pages.push(page);
                }
                if (totalPages > 1) pages.push(totalPages);
                const uniquePages = [...new Set(pages)].sort((a, b) => a - b);
                let prevPage = 0;
                uniquePages.forEach(page => {
                    if (prevPage && page - prevPage > 1) {
                        items.push({ text: '...', page: null, disabled: true, active: false });
                    }
                    items.push({ text: String(page), page, disabled: false, active: page === currentPage });
                    prevPage = page;
                });
                items.push({ text: 'Next', page: Math.min(totalPages, currentPage + 1), disabled: currentPage >= totalPages, active: false });
                return items;
            }

            function renderReceiveDetailPagination() {
                const start = receiveDetailState.totalRecords === 0 ? 0 : ((receiveDetailState.page - 1) * receiveDetailState.pageSize) + 1;
                const end = receiveDetailState.totalRecords === 0 ? 0 : Math.min(receiveDetailState.page * receiveDetailState.pageSize, receiveDetailState.totalRecords);
                $('#receiveDetailPagingInfo').text(receiveDetailState.totalRecords === 0
                    ? 'No records'
                    : `Showing ${start} to ${end} of ${receiveDetailState.totalRecords} entries`);

                const $pagination = $('#receiveDetailPagination');
                $pagination.empty();
                buildPagerItems(receiveDetailState.page, receiveDetailState.totalPages).forEach(item => {
                    const disabledClass = item.disabled ? ' disabled' : '';
                    const activeClass = item.active ? ' active' : '';
                    const href = item.disabled || item.page === null ? '#' : `#page-${item.page}`;
                    if (item.page === null) {
                        $pagination.append('<li class="page-item disabled"><span class="page-link">...</span></li>');
                    } else {
                        $pagination.append(`<li class="page-item${disabledClass}${activeClass}"><a class="page-link prq-pager-link receive-detail-page-link" data-page="${item.page}" href="${href}">${item.text}</a></li>`);
                    }
                });
            }

            $('#receivePageSize').on('change', function () {
                const url = new URL(window.location.href);
                url.searchParams.set('PageSize', this.value);
                url.searchParams.set('Page', '1');
                window.location.href = url.toString();
            });

            function getSelectedRow() {
                const row = document.querySelector('#receiveTable tbody tr.receive-row input.receive-selector:checked');
                return row ? row.closest('tr.receive-row') : null;
            }

            function syncDeleteButtonState() {
                const row = getSelectedRow();
                if (!row) {
                    $('#btnDeleteReceived').prop('disabled', true);
                    return;
                }
                const statusId = Number(row.getAttribute('data-statusid') || 0);
                $('#btnDeleteReceived').prop('disabled', statusId > 1);
            }

            $(document).on('click', '#receiveTable tbody tr.receive-row', function (e) {
                if (!$(e.target).is('a')) {
                    const $radio = $(this).find('input.receive-selector');
                    const wasChecked = $radio.prop('checked');
                    $('input.receive-selector').prop('checked', false);
                    if (!wasChecked) {
                        $radio.prop('checked', true);
                    }
                    syncDeleteButtonState();
                }
            });

            $('#btnDeleteReceived').on('click', function () {
                const row = getSelectedRow();
                if (!row) {
                    return;
                }

                const flowId = row.getAttribute('data-flowid');
                const flowNo = row.querySelector('td:nth-child(2) a, td:nth-child(2)')?.textContent?.trim() || '';
                $('#deleteFlowId').val(flowId);
                $('#receiveDeleteConfirmText').text(`Do you want to delete this Doc no. '${flowNo}' ?`);
                $('#receiveDeleteConfirmModal').modal('show');
            });

            $('#btnConfirmDeleteReceived').on('click', function () {
                $('#receiveDeleteConfirmModal').modal('hide');
                $('#receiveDeleteForm').trigger('submit');
            });

            syncDeleteButtonState();

            async function loadDetail(page) {
                receiveDetailState.keyword = $('#receiveDetailKeyword').val() || '';
                receiveDetailState.page = page || 1;
                receiveDetailState.pageSize = Number($('#receiveDetailPageSize').val() || 10);
                const url = `?handler=SearchDetail&keyword=${encodeURIComponent(receiveDetailState.keyword)}&pageNumber=${receiveDetailState.page}&pageSize=${receiveDetailState.pageSize}`;
                const response = await fetch(url);
                const data = await response.json();
                const $rows = $('#receiveDetailRows');
                $rows.empty();
                if (!data.rows || data.rows.length === 0) {
                    $rows.append('<tr><td colspan="7" class="text-center text-muted">No detail found.</td></tr>');
                } else {
                    data.rows.forEach(r => {
                        $rows.append(`<tr><td>${r.itemCode}</td><td class="tcvn3-font">${r.itemName}</td><td><a href="./InventoryReceived/InventoryReceivedDetail?id=${r.flowId}&mode=view">${r.flowNo}</a></td><td>${r.flowDate}</td><td class="text-right">${Number(r.actQty).toLocaleString()}</td><td class="text-right">${Number(r.unitPrice).toLocaleString()}</td><td class="text-right">${Number(r.amount).toLocaleString()}</td></tr>`);
                    });
                }
                receiveDetailState.page = data.pageNumber || 1;
                receiveDetailState.pageSize = data.pageSize || receiveDetailState.pageSize;
                receiveDetailState.totalPages = data.totalPages || 1;
                receiveDetailState.totalRecords = data.totalRecords || 0;
                renderReceiveDetailPagination();
            }
            $('#btnReceiveDetailSearch').on('click', function () { loadDetail(1); });
            $('#receiveDetailKeyword').on('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    loadDetail(1);
                }
            });
            $('#receiveDetailPageSize').on('change', function () { loadDetail(1); });
            $(document).on('click', '.receive-detail-page-link', function (e) {
                e.preventDefault();
                const page = Number($(this).data('page') || 0);
                if (page > 0 && page !== receiveDetailState.page) {
                    loadDetail(page);
                }
            });

            $searchDetailModal.add($deleteConfirmModal).on('show.bs.modal', function () {
                destroyBackgroundSelect2();
            });

            $searchDetailModal.on('shown.bs.modal', function () {
                loadDetail(1);
            });

            $searchDetailModal.add($deleteConfirmModal).on('hidden.bs.modal', function () {
                if (!$('#receiveSearchDetailModal').hasClass('show') && !$('#receiveDeleteConfirmModal').hasClass('show')) {
                    initBackgroundSelect2();
                }
            });

            $(document).on('select2:opening', 'select.select2', function (e) {
                const isModalOpen = $('#receiveSearchDetailModal.show').length > 0 || $('#receiveDeleteConfirmModal.show').length > 0;
                const isInsideModal = $(this).closest('#receiveSearchDetailModal.show, #receiveDeleteConfirmModal.show').length > 0;
                if (isModalOpen && !isInsideModal) {
                    e.preventDefault();
                    return false;
                }
            });
        })();
    </script>
}
