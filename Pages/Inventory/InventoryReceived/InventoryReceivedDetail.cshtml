            function formatBytes(bytes) {
                const value = Number(bytes || 0);
                if (value < 1024) return `${value} B`;
                if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
                return `${(value / (1024 * 1024)).toFixed(2)} MB`;
            }

            function formatDateTimeDdMmYyyyHm(date) {
                const d = date instanceof Date ? date : new Date(date);
                const dd = String(d.getDate()).padStart(2, '0');
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const yyyy = d.getFullYear();
                const hh = String(d.getHours()).padStart(2, '0');
                const min = String(d.getMinutes()).padStart(2, '0');
                return `${dd}/${mm}/${yyyy} ${hh}:${min}`;
            }

            function attachmentKey(file) {
                return `${file.name || ''}__${file.size || 0}__${file.lastModified || 0}`;
            }

            function syncAttachmentInputFromStaging() {
                const dt = new DataTransfer();
                stagedAttachments.forEach(file => dt.items.add(file));
                const input = document.getElementById('detailAttachmentUpload');
                if (!input) {
                    return;
                }
                input.files = dt.files;
            }

            function renderAttachmentStaging() {
                const $body = $('#attachmentListBody');
                $body.empty();
                const canEdit = @Model.CanEditVoucherBusiness.ToString().ToLowerInvariant();

                existingAttachments.filter(file => !deletedAttachmentDocIds.includes(Number(file.docId))).forEach(file => {
                    const deleteAction = canEdit
                        ? `<button type="button" class="btn btn-xs btn-danger btn-remove-existing-attachment" data-docid="${file.docId}"><i class="fas fa-trash"></i></button>`
                        : '';
                    $body.append(`<tr>
                        <td class="text-center">${deleteAction}</td>
                        <td><a href="${file.downloadUrl}">${file.filePath || ''}</a></td>
                        <td>${file.uploadDate || ''}</td>
                        <td>${file.employeeCode || ''}</td>
                    </tr>`);
                });

                pendingAttachments.forEach((file, index) => {
                    const removeAction = canEdit
                        ? `<button type="button" class="btn btn-xs btn-danger btn-remove-pending-attachment" data-index="${index}"><i class="fas fa-trash"></i></button>`
                        : '';
                    const nowText = formatDateTimeDdMmYyyyHm(new Date());
                    const displayUser = (currentEmployeeCode || currentUserName || 'Current User');
                    $body.append(`<tr>
                        <td class="text-center">${removeAction}</td>
                        <td>${file.name || ''}</td>
                        <td>${nowText}</td>
                        <td>${displayUser}</td>
                    </tr>`);
                });

                const visibleExistingCount = existingAttachments.filter(file => !deletedAttachmentDocIds.includes(Number(file.docId))).length;
                $('#attachmentCountText').text(visibleExistingCount + pendingAttachments.length);
                if (visibleExistingCount === 0 && pendingAttachments.length === 0) {
                    $body.append('<tr><td colspan="4" class="text-center text-muted py-3">No files selected</td></tr>');
                    return;
                }
            }

            function syncDeletedAttachmentDocIds() {
                $('#DeletedAttachmentDocIdsJson').val(JSON.stringify(deletedAttachmentDocIds));
