                    const actQty = Number(d.actQty ?? d.ActQty ?? 0);
                    const unitPrice = Number(d.unitPrice ?? d.UnitPrice ?? 0);
                    const amount = Number(d.amount ?? d.Amount ?? 0);
                    const locationId = Number(d.locationId ?? d.LocationId ?? 0);
