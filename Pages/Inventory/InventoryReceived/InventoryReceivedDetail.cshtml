            function destroyBackgroundSelect2() {
                $('#inventoryReceivedDetailForm select.select2').each(function () {
                    const $select = $(this);
                    if ($select.closest('.modal').length > 0) {
                        return;
                    }

                    if ($select.data('select2')) {
                        $select.select2('close');
                        $select.select2('destroy');
                    }
                });

                $('body').addClass('inventory-received-modal-open');
            }

            function initBackgroundSelect2() {
                $('#inventoryReceivedDetailForm select.select2').each(function () {
                    const $select = $(this);
                    if ($select.closest('.modal').length > 0) {
                        return;
                    }

                    if (!$select.data('select2')) {
                        $select.select2({ width: '100%' });
                    }
                });

                $('body').removeClass('inventory-received-modal-open');
            }

            function initModalSelect2($modal) {
                $modal.find('select.select2').each(function () {
                    const $select = $(this);

                    if ($select.data('select2')) {
                        $select.select2('destroy');
                    }

                    const config = {
                        width: '100%',
                        dropdownParent: $modal
                    };

                    if ($select.attr('id') === 'detailItemId' || $select.attr('id') === 'manualAddItemId') {
                        config.templateResult = function (state) {
                            if (!state.id) return state.text;
                            const text = state.text || '';
                            const idx = text.indexOf(' - ');
                            if (idx < 0) {
                                return $('<span></span>').text(text);
                            }
                            const code = text.substring(0, idx);
                            const name = text.substring(idx + 3);
                            const $result = $('<span><span class="item-code"></span> - <span class="tcvn3-font item-name"></span></span>');
                            $result.find('.item-code').text(code);
                            $result.find('.item-name').text(name);
                            return $result;
                        };

                        config.templateSelection = function (state) {
                            if (!state.id) return state.text;
                            const text = state.text || '';
                            const idx = text.indexOf(' - ');
                            if (idx < 0) {
                                return $('<span class="tcvn3-font"></span>').text(text);
                            }
                            const code = text.substring(0, idx);
                            const name = text.substring(idx + 3);
                            const $result = $('<span><span class="item-code"></span> - <span class="tcvn3-font item-name"></span></span>');
                            $result.find('.item-code').text(code);
                            $result.find('.item-name').text(name);
                            return $result;
                        };

                        config.escapeMarkup = function (markup) { return markup; };
                    }

                    $select.select2(config);
                });
            }

            const inventoryReceivedModalSelector = '#receivedAddDetailModal, #detailResetWarningModal, #prqAttachmentModal, #confirmInventoryReceivedModal, #receiveFromIssueModal';

            $('.modal').filter(inventoryReceivedModalSelector).on('show.bs.modal', function () {
                const $modal = $(this);
                destroyBackgroundSelect2();
                if ($modal.is('#confirmInventoryReceivedModal')) {
                    $('body').addClass('inventory-received-confirm-open');
                }
                initModalSelect2($modal);
            });

            $('.modal').filter(inventoryReceivedModalSelector).on('hidden.bs.modal', function () {
                if ($(this).is('#confirmInventoryReceivedModal')) {
                    $('body').removeClass('inventory-received-confirm-open');
                }
                if ($('.modal.show').filter(inventoryReceivedModalSelector).length === 0) {
                    initBackgroundSelect2();
                }
            });

            $(document).on('select2:opening', 'select.select2', function (e) {
                const isModalOpen = $('.modal.show').filter(inventoryReceivedModalSelector).length > 0;
                const isInsideModal = $(this).closest('.modal.show').filter(inventoryReceivedModalSelector).length > 0;
                if (isModalOpen && !isInsideModal) {
                    e.preventDefault();
                    return false;
                }
            });

            $('#btnConfirmVoucherAction').on('click', function () {
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                if (mode === 'add') {
                    isSubmittingConfirmAfterSave = true;
                    $('#confirmInventoryReceivedModal').modal('hide');
                    $('#inventoryReceivedDetailForm').attr('action', '?handler=SaveAndConfirm');
                    $('#inventoryReceivedDetailForm').trigger('submit');
                    return;
                }

                $('#confirmInventoryReceivedForm').trigger('submit');
            });

            $('#confirmInventoryReceivedModal').on('hidden.bs.modal', function () {
                if (isSubmittingConfirmAfterSave) {
                    return;
                }
                $('#ConfirmAfterSave').val('false');
                $('#inventoryReceivedDetailForm').attr('action', '');
            });

            $('#btnOpenAddDetail').on('click', function () {
                $('#btnConfirmResetDetails').show();
                const openModal = function () {
                    if (isPoFlow()) {
                        $('#addDetailPoPanel').removeClass('d-none');
                        $('#addDetailManualPanel').addClass('d-none');
                        resetAddDetailModalInputs();
                    } else {
                        $('#addDetailPoPanel').addClass('d-none');
                        $('#addDetailManualPanel').removeClass('d-none');
                        renderManualAddDetailOptions();
                        syncManualItemInfo();
                    }
                    $('#receivedAddDetailModal').modal('show');
                };

                if (isPoFlow()) {
                    reloadDetailItemsByPo().then(openModal);
                } else {
                    openModal();
                }
            });

            $('#Header_POID').on('change', function () {
                reloadDetailItemsByPo();
            });

            $('#btnAddDetailConfirm').on('click', function () {
                if (!isPoFlow()) {
                    showAddDetailModalValidation('');
                    clearManualAddFieldErrors();
                    const itemId = Number($('#manualAddItemId').val() || 0);
                    const item = itemCatalog.find(x => Number(x.id) === itemId);
                    if (!item) {
                        showAddDetailModalValidation('Please select item.');
                        return;
                    }

                    const docQty = parseNumber($('#manualAddDocQty').val());
                    const actQty = parseNumber($('#manualAddActQty').val());
                    const unitPrice = parseNumber($('#manualAddUnitPrice').val());
                    const locationIdRaw = $('#manualAddLocationId').val();
                    const location = locationCatalog.find(x => x.id === locationIdRaw);

                    if (actQty <= 0) {
                        setManualAddFieldError('#manualAddActQty', '#manualAddActQtyError', 'Act. Qty must be greater than 0.');
                        showAddDetailModalValidation(`Item '${item.itemCode || ''}' must have Act. Qty > 0.`);
                        return;
                    }
                    if (docQty < actQty) {
                        setManualAddFieldError('#manualAddDocQty', '#manualAddDocQtyError', 'Doc. Qty must be greater than or equal Act. Qty.');
                        setManualAddFieldError('#manualAddActQty', '#manualAddActQtyError', 'Act. Qty must be less than or equal Doc. Qty.');
                        showAddDetailModalValidation(`Item '${item.itemCode || ''}' Doc. Qty must be greater than or equal Act. Qty.`);
                        return;
                    }
                    if (unitPrice <= 0) {
                        setManualAddFieldError('#manualAddUnitPrice', '#manualAddUnitPriceError', 'Price must be greater than 0.');
                        showAddDetailModalValidation(`Item '${item.itemCode || ''}' must have Price > 0.`);
                        return;
                    }

                    details.push({
                        itemId: Number(item.id),
                        chekingID: null,
                        chekingDTID: null,
                        mrDetailID: null,
                        itemCode: item.itemCode || '',
                        itemName: item.itemName || '',
                        unit: item.unit || '',
                        docQty: docQty,
                        actQty: actQty,
                        unitPrice: unitPrice,
                        amount: actQty * unitPrice,
                        locationId: locationIdRaw ? Number(locationIdRaw) : null,
                        locationName: location?.text || ''
                    });

                    renderRows();
                    $('#receivedAddDetailModal').modal('hide');
                    return;
                }

                const checked = $('.add-detail-check:checked');
                if (checked.length === 0) {
                    return;
                }

                showClientValidation('');
                showAddDetailModalValidation('');
                clearPoAddFieldErrors();
                let errorMessage = '';

                checked.each(function () {
                    if (errorMessage) return;
                    const itemId = Number($(this).data('itemid'));
                    const item = itemCatalog.find(x => Number(x.id) === itemId);
                    if (!item) return;

                    const docQty = parseNumber($(`.add-docqty[data-itemid='${itemId}']`).val());
                    const actQty = parseNumber($(`.add-actqty[data-itemid='${itemId}']`).val());
                    const unitPrice = parseNumber($(`.add-unitprice[data-itemid='${itemId}']`).val());
                    const maxQty = getAvailableQty(item);
                    if (actQty <= 0) {
                        errorMessage = `Item '${item.itemCode || ''}' must have Act. Qty > 0.`;
                        setPoAddFieldError(itemId, 'add-actqty', 'Act. Qty must be greater than 0.');
                        return;
                    }
                    if (actQty > maxQty) {
                        errorMessage = `Item '${item.itemCode || ''}' Act. Qty exceeds remaining qty (${formatNumber(maxQty)}).`;
                        setPoAddFieldError(itemId, 'add-actqty', `Act. Qty exceeds remaining qty (${formatNumber(maxQty)}).`);
                        return;
                    }
                    if (docQty < actQty) {
                        errorMessage = `Item '${item.itemCode || ''}' Doc. Qty must be greater than or equal Act. Qty.`;
                        setPoAddFieldError(itemId, 'add-docqty', 'Doc. Qty must be greater than or equal Act. Qty.');
                        setPoAddFieldError(itemId, 'add-actqty', 'Act. Qty must be less than or equal Doc. Qty.');
                        return;
                    }
                    if (unitPrice <= 0) {
                        errorMessage = `Item '${item.itemCode || ''}' must have Price > 0.`;
                        setPoAddFieldError(itemId, 'add-unitprice', 'Price must be greater than 0.');
                        return;
                    }
                    if ($('#Header_POID').val() && (!item.checkingDtId || !item.mrDetailId)) {
                        errorMessage = `Item '${item.itemCode || ''}' is missing source link.`;
                        return;
                    }
                    const locationIdRaw = $(`.add-location[data-itemid='${itemId}']`).val();
                    const location = locationCatalog.find(x => x.id === locationIdRaw);

                    details.push({
                        itemId: Number(item.id),
                        chekingID: item.checkingId ? Number(item.checkingId) : null,
                        chekingDTID: item.checkingDtId ? Number(item.checkingDtId) : null,
                        mrDetailID: item.mrDetailId ? Number(item.mrDetailId) : null,
                        itemCode: item.itemCode || '',
                        itemName: item.itemName || '',
                        unit: item.unit || '',
                        docQty: docQty,
                        actQty: actQty,
                        unitPrice: unitPrice,
                        amount: actQty * unitPrice,
                        locationId: locationIdRaw ? Number(locationIdRaw) : null,
                        locationName: location?.text || ''
                    });
                });

                if (errorMessage) {
                    showAddDetailModalValidation(errorMessage);
                    return;
                }

                renderRows();
                $('#receivedAddDetailModal').modal('hide');
            });

            $(document).on('input change', '.add-actqty, .add-docqty', function () {
                const itemId = Number($(this).data('itemid'));
                const item = itemCatalog.find(x => Number(x.id) === itemId);
                if (!item) return;
                const actQty = parseNumber($(`.add-actqty[data-itemid='${itemId}']`).val());
                const docQty = parseNumber($(`.add-docqty[data-itemid='${itemId}']`).val());
                const maxQty = getAvailableQty(item);
                if (actQty > maxQty || actQty <= 0 || docQty < actQty) {
                    $(this).addClass('is-invalid');
                } else {
                    $(`.add-actqty[data-itemid='${itemId}'], .add-docqty[data-itemid='${itemId}']`).removeClass('is-invalid');
                    showClientValidation('');
                }
            });

            $(document).on('change', '.add-detail-check', function () {
                $('#btnAddDetailConfirm').prop('disabled', $('.add-detail-check:checked').length === 0);
                syncAddDetailCheckAll();
            });

            $(document).on('change', '#manualAddItemId', function () {
                syncManualItemInfo();
            });

            $('#checkAllAddDetail').on('change', function () {
                const checked = $(this).is(':checked');
                $('.add-detail-check').prop('checked', checked);
                $('#btnAddDetailConfirm').prop('disabled', $('.add-detail-check:checked').length === 0);
                syncAddDetailCheckAll();
            });

            $(document).on('input change', '.detail-docqty, .detail-actqty, .detail-unitprice, .detail-location', function () {
                const idx = Number($(this).data('index'));
                const row = details[idx];
                if (!row) return;

                row.docQty = parseNumber($(`.detail-docqty[data-index='${idx}']`).val());
                row.actQty = parseNumber($(`.detail-actqty[data-index='${idx}']`).val());
                const source = itemCatalog.find(x => detailKey(x) === detailKey(row));
                const maxQty = source ? Number(source.remainingQty || 0) : null;
                if (maxQty !== null && row.actQty > maxQty) {
                    row.actQty = Math.max(0, maxQty);
                    $(`.detail-actqty[data-index='${idx}']`).val(formatNumber(row.actQty));
                    showClientValidation(`Item '${row.itemCode || ''}' Act. Qty exceeds remaining qty (${formatNumber(maxQty)}).`);
                } else if (row.actQty <= 0) {
                    showClientValidation(`Item '${row.itemCode || ''}' must have Act. Qty > 0.`);
                } else if (row.docQty < row.actQty) {
                    showClientValidation(`Item '${row.itemCode || ''}' Doc. Qty must be greater than or equal Act. Qty.`);
                } else {
                    showClientValidation('');
                }
                row.unitPrice = parseNumber($(`.detail-unitprice[data-index='${idx}']`).val());
                row.amount = row.actQty * row.unitPrice;

                const locationIdRaw = $(`.detail-location[data-index='${idx}']`).val();
                const location = locationCatalog.find(x => x.id === locationIdRaw);
                row.locationId = locationIdRaw ? Number(locationIdRaw) : null;
                row.locationName = location?.text || '';

                $(`.detail-amount[data-index='${idx}']`).text(formatNumber(row.amount));
                syncDetailsJson();
            });

            $(document).on('focus', '.number-format', function () {
                $(this).val(parseNumber($(this).val()));
            });

            $(document).on('blur', '.number-format', function () {
                $(this).val(formatNumber(parseNumber($(this).val())));
            });

            $(document).on('click', '.btn-delete-detail', function () {
                details.splice(Number($(this).data('index')), 1);
                renderRows();
            });

            $('#detailAttachmentUpload').on('change', function () {
                const files = Array.from(this.files || []);
                if (files.length === 0) return;
                const existingKeys = new Set(pendingAttachments.map(attachmentKey));
                files.forEach(file => {
                    const key = attachmentKey(file);
                    if (!existingKeys.has(key)) {
                        pendingAttachments.push(file);
                        existingKeys.add(key);
                    }
                });
                stagedAttachments = [...pendingAttachments];
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
                this.value = '';
            });

            $(document).on('click', '.btn-remove-pending-attachment', function () {
                const idx = Number($(this).data('index'));
                pendingAttachments.splice(idx, 1);
                stagedAttachments = [...pendingAttachments];
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
            });

            $(document).on('click', '.btn-remove-existing-attachment', function () {
                const docId = Number($(this).data('docid'));
                if (docId > 0 && !deletedAttachmentDocIds.includes(docId)) {
                    deletedAttachmentDocIds.push(docId);
                    syncDeletedAttachmentDocIds();
                    renderAttachmentStaging();
                }
            });

            $('#btnAttachmentAgree').on('click', function () {
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
            });

            $('#prqAttachmentModal').on('show.bs.modal', function () {
                renderAttachmentStaging();
            });

            $('#prqAttachmentModal').on('hidden.bs.modal', function () {
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
            });

            $('#Header_POID').on('focus', function () { pendingOldValue = $(this).val(); });

            $('#btnOpenReceiveFromIssue').on('click', function () {
                if ($(this).prop('disabled')) {
                    return;
                }
                if (Number($('#Header_FlowSubType').val() || 0) !== 6) {
                    showClientValidation('Receive From Inventory Issue is only available for Receive From Company Main Store.');
                    return;
                }

                showIssueReceiveValidation('');
                loadIssueReceiveList().then(function () {
                    if (selectedIssueFlowId > 0) {
                        loadIssueReceiveDetails(selectedIssueFlowId);
                    } else {
                        issueReceiveDetails = [];
                        renderIssueReceiveDetails();
                    }
                    $('#receiveFromIssueModal').modal('show');
                });
            });

            $('#btnSearchIssueReceive').on('click', function () {
                selectedIssueFlowId = 0;
                issueReceiveDetails = [];
                renderIssueReceiveDetails();
                loadIssueReceiveList();
            });

            $(document).on('change', '.issue-receive-select', function () {
                selectedIssueFlowId = Number($(this).val() || 0);
                $('#btnReceiveFromIssueOk').prop('disabled', selectedIssueFlowId <= 0);
                showIssueReceiveValidation('');
                loadIssueReceiveDetails(selectedIssueFlowId);
            });

            $(document).on('click', '#issueReceiveRowsBody .issue-receive-row', function (e) {
                if ($(e.target).is('.issue-receive-select')) {
                    return;
                }

                const flowId = Number($(this).data('flow-id') || 0);
                if (!flowId) {
                    return;
                }

                $(this).find('.issue-receive-select').prop('checked', true).trigger('change');
            });

            $('#btnReceiveFromIssueOk').on('click', function () {
                if (selectedIssueFlowId <= 0) {
                    showIssueReceiveValidation('Please select issue voucher.');
                    return;
                }
                if (!issueReceiveDetails.length) {
                    showIssueReceiveValidation('Selected issue voucher has no details.');
                    return;
                }

                details = issueReceiveDetails.map(x => ({
                    itemId: Number(x.itemId || 0),
                    chekingID: null,
                    chekingDTID: null,
                    mrDetailID: null,
                    itemCode: x.itemCode || '',
                    itemName: x.itemName || '',
                    unit: x.unit || '',
                    docQty: Number(x.docQty || 0),
                    actQty: Number(x.actQty || 0),
                    unitPrice: Number(x.unitPrice || 0),
                    amount: Number(x.amount || 0),
                    locationId: null,
                    locationName: ''
                }));

                $('#SelectedIssueFlowId').val(selectedIssueFlowId);
                $('#Header_POID').val('').trigger('change.select2');
                renderRows();
                $('#receiveFromIssueModal').modal('hide');
            });
            $('#Header_POID').on('change', function () {
                if (details.length === 0) { pendingOldValue = $(this).val(); return; }
                pendingField = this;
                pendingAction = 'po-change';
                $('#btnConfirmResetDetails').show();
                $('#detailResetWarningModal .modal-body').text('Changing this header field will reset the current detail list. Do you want to continue?');
                $('#detailResetWarningModal').modal('show');
            });

            $('#btnConfirmResetDetails').on('click', function () {
                if (pendingField) {
                    clearDetails();
                    if (pendingAction === 'flow-subtype-change') {
                        applyFieldRuleByFlowSubType();
                        reloadReceiveContext();
                    } else {
                        pendingOldValue = $(pendingField).val();
                    }
                    pendingField = null;
                    pendingAction = '';
                }
                $('#detailResetWarningModal').modal('hide');
            });

            $('#detailResetWarningModal').on('hidden.bs.modal', function () {
                if (pendingField) {
                    $(pendingField).val(pendingOldValue).trigger('change.select2');
                    pendingField = null;
                    pendingAction = '';
                }
                $('#btnConfirmResetDetails').show();
            });

            $('#Header_FlowSubType').on('change', function () {
                if (details.length > 0) {
                    pendingField = this;
                    pendingOldValue = $(this).data('old') || '';
                    pendingAction = 'flow-subtype-change';
                    $('#btnConfirmResetDetails').show();
                    $('#detailResetWarningModal .modal-body').text('Changing Received Type will reset PO No and current detail list. Do you want to continue?');
                    $('#detailResetWarningModal').modal('show');
                    return;
                }
                $(this).data('old', $(this).val());
                applyFieldRuleByFlowSubType();
                reloadReceiveContext();
            });

            $('#Header_FlowSubType').on('focus', function () {
                $(this).data('old', $(this).val());
            });

            initSelect2();
            applyFieldRuleByFlowSubType();
            syncAttachmentInputFromStaging();
            syncDeletedAttachmentDocIds();
            renderRows();
        })();
    </script>
}



