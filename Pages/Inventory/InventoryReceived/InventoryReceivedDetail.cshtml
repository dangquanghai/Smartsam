@page
@using System.Text.Json
@model SmartSam.Pages.Inventory.InventoryReceived.InventoryReceivedDetailModel
@{
    ViewData["Title"] = "Item Received Detail";
    var initialDetailsJson = JsonSerializer.Serialize(Model.Details, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    var alertClass = (Model.MessageType ?? "info").ToLowerInvariant() switch
    {
        "success" => "alert-success",
        "warning" => "alert-warning",
        "error" => "alert-danger",
        _ => "alert-info"
    };
}

<section class="content vni-font">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header py-2">
                <h3 class="card-title prq-detail-title">Item Received Detail</h3>
            </div>

            <form method="post" enctype="multipart/form-data" id="inventoryReceivedDetailForm" class="mb-0">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="mode" value="@Model.Mode" />
                <input asp-for="DetailsJson" type="hidden" id="DetailsJson" />
                <input asp-for="SelectedIssueFlowId" type="hidden" id="SelectedIssueFlowId" />
                <input asp-for="DeletedAttachmentDocIdsJson" type="hidden" id="DeletedAttachmentDocIdsJson" />
                <input asp-for="ConfirmAfterSave" type="hidden" id="ConfirmAfterSave" value="false" />
                @if (Model.IsEditMode)
                {
                    <input type="hidden" asp-for="Header.POID" />
                }

                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.Message))
                    {
                        <div class="alert @alertClass mb-2 py-2">@Model.Message</div>
                    }
                    <div id="clientValidationAlert" class="alert alert-danger mb-2 py-2 d-none"></div>

                    <div class="row prq-detail-form-row mb-3">
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Doc No.<span class="required-mark">*</span></label>
                            <input asp-for="Header.FlowNo" class="form-control form-control-sm vni-font" readonly="@(Model.IsAddMode && Model.CanEditVoucherBusiness ? null : "readonly")" />
                            <span asp-validation-for="Header.FlowNo" class="text-danger small"></span>
                        </div>
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Received Date</label>
                            <input asp-for="Header.FlowDate" type="date" class="form-control form-control-sm" readonly="@(Model.CanEditVoucherBusiness ? null : "readonly")" />
                        </div>
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Received Type<span class="required-mark">*</span></label>
                            <select asp-for="Header.FlowSubType" asp-items="Model.ReceiveTypes" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select>
                            <span asp-validation-for="Header.FlowSubType" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row prq-detail-form-row mb-3">
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Enter To<span class="required-mark">*</span></label>
                            <select asp-for="Header.ToStore" asp-items="Model.Stores" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select>
                            <span asp-validation-for="Header.ToStore" class="text-danger small"></span>
                        </div>
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">According To</label>
                            <input asp-for="Header.According" class="form-control form-control-sm vni-font" readonly="@(Model.CanEditVoucherBusiness ? null : "readonly")" />
                        </div>
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">PO No.</label>
                            <div class="d-flex align-items-start">
                                <select asp-for="Header.POID" asp-items="Model.PONos" class="form-control form-control-sm select2 detail-context-field" disabled="@(Model.CanEditVoucherBusiness && Model.IsAddMode ? null : "disabled")"></select>
                                <button type="button" id="btnOpenAttachmentModal" class="btn btn-sm btn-action-secondary border ml-2 mb-2 text-nowrap" data-toggle="modal" data-target="#prqAttachmentModal">
                                    <i class="fas fa-paperclip"></i> Attached Files (<span id="attachmentCountText">@Model.AttachmentList.Count</span>)
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="row prq-detail-form-row mb-3">
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Move to Company Store<span id="moveToCompanyStoreRequiredMark" class="required-mark d-none">*</span></label>
                            <select asp-for="Header.MoveToCPNStore" asp-items="Model.MoveToCPNStores" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")">
                                <option value="">--- Select ---</option>
                            </select>
                            <span asp-validation-for="Header.MoveToCPNStore" class="text-danger small"></span>
                        </div>
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Return Department</label>
                            <select asp-for="Header.RetDept" asp-items="Model.Departments" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select>
                        </div>
                        <div class="col-lg-4 col-md-6 prq-detail-form-col">
                            <label class="prq-detail-label">Return Location</label>
                            <select asp-for="Header.RetAssetLocation" asp-items="Model.Locations" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select>
                        </div>
                        <input type="hidden" asp-for="Header.StatusID" />
                        <input type="hidden" asp-for="Header.StatusName" />
                    </div>

                    <div class="row prq-detail-form-row mb-3">
                        <div class="col-12 prq-detail-form-col">
                            <label class="prq-detail-label">Reason</label>
                            <input asp-for="Header.Reason" class="form-control form-control-sm vni-font" readonly="@(Model.CanEditVoucherBusiness ? null : "readonly")" />
                        </div>
                    </div>

                    <div class="row prq-detail-form-row mb-3 align-items-end">
                        <div class="col-12 prq-detail-form-col d-flex justify-content-start align-items-center">
                            @if (Model.CanEditVoucherBusiness)
                            {
                                <button type="button" id="btnOpenAddDetail" class="btn btn-sm btn-action-close border"><i class="fas fa-plus"></i> Add Detail</button>
                            }
                            <span class="ml-3 font-weight-bold">Status: <span id="statusTextStrong" class="font-weight-bold">@Model.Header.StatusName</span></span>
                        </div>
                    </div>

                    <div class="row prq-detail-form-row mb-0">
                        <div class="col-12 prq-detail-form-col">
                            <div class="table-responsive prq-table-wrap border rounded-sm inventory-received-detail-scroll inventory-received-detail-scroll-x">
                                <table class="table table-hover table-bordered mb-0 text-nowrap prq-table inventory-received-main-table">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width:70px;" class="text-center">Action</th>
                                            <th style="width:220px;">Item Code</th>
                                            <th style="min-width:360px;">Item Name</th>
                                            <th style="width:90px;">Unit</th>
                                            <th class="text-right" style="width:100px;">Doc. Qty</th>
                                            <th class="text-right" style="width:100px;">Act. Qty</th>
                                            <th class="text-right" style="width:110px;">Price</th>
                                            <th class="text-right" style="width:120px; min-width:120px; max-width:120px;">Amount</th>
                                            <th style="width:260px;">Location</th>
                                        </tr>
                                    </thead>
                                    <tbody id="detailRowsBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer p-2 text-left module-action-bar prq-action-bar">
                    @if (Model.CanEditVoucherBusiness)
                    {
                        <button type="submit" class="btn btn-sm btn-action-save btn-success border mx-1 my-1"><i class="fas fa-save"></i> Save</button>
                    }
                    @if ((Model.IsAddMode && Model.CanEditVoucherBusiness) || Model.CanConfirmVoucherBusiness)
                    {
                        <button type="button" id="btnOpenConfirmVoucher" class="btn btn-sm btn-success border mx-1 my-1" data-toggle="modal" data-target="#confirmInventoryReceivedModal"><i class="fas fa-check"></i> Confirm</button>
                    }
                    @if ((Model.IsAddMode || Model.IsEditMode) && Model.CanEditVoucherBusiness)
                    {
                        <button type="button" id="btnOpenReceiveFromIssue" class="btn btn-sm btn-info border mx-1 my-1" disabled><i class="fas fa-exchange-alt"></i> Receive From Inventory Issue</button>
                    }
                    <a class="btn btn-sm btn-action-close border mx-1 my-1" asp-page="./Index"><i class="fas fa-arrow-left"></i> Back to List</a>
                </div>
            </form>

            @if (Model.Id.HasValue && Model.PagePerm.HasPermission(5))
            {
                <form method="post" asp-page-handler="Confirm" id="confirmInventoryReceivedForm" class="d-none">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="mode" value="@Model.Mode" />
                </form>
            }
        </div>
    </div>
</section>

<div class="modal fade vni-font" id="confirmInventoryReceivedModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-primary">
            <div class="modal-header bg-primary py-2">
                <h5 class="modal-title text-white">Confirm Voucher</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                Are you sure you want to confirm this inventory received voucher?
            </div>
            <div class="modal-footer py-2 justify-content-end">
                <button type="button" id="btnConfirmVoucherAction" class="btn btn-sm btn-primary"><i class="fas fa-check"></i> Confirm</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="receivedAddDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-xl-down modal-xl" style="max-width: 96vw;" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Add Detail</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body pb-2">
                <div id="addDetailModalValidationAlert" class="alert alert-danger mb-2 py-2 d-none"></div>
                <div id="addDetailManualPanel" class="d-none">
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="prq-detail-label">Item</label>
                            <select id="manualAddItemId" class="form-control form-control-sm select2"></select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="prq-detail-label">Unit</label>
                            <input type="text" id="manualAddUnit" class="form-control form-control-sm" readonly />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="prq-detail-label">Location</label>
                            <select id="manualAddLocationId" class="form-control form-control-sm select2"></select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="prq-detail-label">Doc. Qty</label>
                            <input type="text" id="manualAddDocQty" class="form-control form-control-sm text-right number-format" value="0" />
                            <small id="manualAddDocQtyError" class="text-danger d-none"></small>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="prq-detail-label">Act. Qty</label>
                            <input type="text" id="manualAddActQty" class="form-control form-control-sm text-right number-format" value="0" />
                            <small id="manualAddActQtyError" class="text-danger d-none"></small>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="prq-detail-label">Price</label>
                            <input type="text" id="manualAddUnitPrice" class="form-control form-control-sm text-right number-format" value="0" />
                            <small id="manualAddUnitPriceError" class="text-danger d-none"></small>
                        </div>
                    </div>
                </div>
                <div id="addDetailPoPanel" class="table-responsive inventory-received-add-detail-scroll">
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead>
                            <tr>
                                <th style="width:45px;" class="text-center"><input type="checkbox" id="checkAllAddDetail" /></th>
                                <th style="width:220px;">Item Code</th>
                                <th style="min-width:360px;">Item Name</th>
                                <th style="width:90px;">Unit</th>
                                <th style="width:130px;" class="text-right">Doc. Qty</th>
                                <th style="width:130px;" class="text-right">Act. Qty</th>
                                <th style="width:110px;" class="text-right">Price</th>
                                <th style="width:160px;">Location</th>
                            </tr>
                        </thead>
                        <tbody id="addDetailRowsBody">
                            <tr><td colspan="8" class="text-center text-muted py-3">No data</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" id="btnAddDetailConfirm" class="btn btn-sm btn-primary" disabled><i class="fas fa-save"></i> Add</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="detailResetWarningModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning py-2">
                <h5 class="modal-title text-dark">Warning</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">Changing this header field will reset the current detail list. Do you want to continue?</div>
            <div class="modal-footer py-2">
                <button type="button" id="btnConfirmResetDetails" class="btn btn-sm btn-warning">Continue</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="receiveFromIssueModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document" style="max-width: 96vw;">
        <div class="modal-content">
            <div class="modal-header py-2 bg-info">
                <h5 class="modal-title text-white">Receive From Inventory Issue</h5>
                <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body pb-2">
                <div id="receiveFromIssueAlert" class="alert alert-danger mb-2 py-2 d-none"></div>
                <div class="form-row align-items-end mb-2">
                    <div class="col-md-3">
                        <label class="prq-detail-label">From Date</label>
                        <input type="date" id="issueFromDate" class="form-control form-control-sm" value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-3">
                        <label class="prq-detail-label">To Date</label>
                        <input type="date" id="issueToDate" class="form-control form-control-sm" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" id="btnSearchIssueReceive" class="btn btn-sm btn-primary"><i class="fas fa-search"></i> Search</button>
                    </div>
                </div>
                <div class="table-responsive inventory-received-add-detail-scroll mb-3">
                    <table class="table table-bordered table-hover table-sm mb-0 text-nowrap">
                        <thead>
                            <tr>
                                <th style="width:45px;" class="text-center"></th>
                                <th style="width:150px;">Doc No.</th>
                                <th style="width:120px;">Issue Date</th>
                                <th style="min-width:220px;">According</th>
                                <th style="min-width:180px;">Issue as St.House</th>
                                <th style="min-width:180px;">Received Department</th>
                                <th style="min-width:180px;">Received Location</th>
                            </tr>
                        </thead>
                        <tbody id="issueReceiveRowsBody">
                            <tr><td colspan="7" class="text-center text-muted py-3">No data</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="table-responsive inventory-received-add-detail-scroll">
                    <table class="table table-bordered table-hover table-sm mb-0 text-nowrap">
                        <thead>
                            <tr>
                                <th style="width:220px;">Item Code</th>
                                <th style="min-width:360px;">Item Name</th>
                                <th style="width:90px;">Unit</th>
                                <th style="width:110px;" class="text-right">Doc. Qty</th>
                                <th style="width:110px;" class="text-right">Act. Qty</th>
                                <th style="width:110px;" class="text-right">Price</th>
                                <th style="width:120px;" class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="issueReceiveDetailRowsBody">
                            <tr><td colspan="7" class="text-center text-muted py-3">No data</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" id="btnReceiveFromIssueOk" class="btn btn-sm btn-primary" disabled><i class="fas fa-check"></i> OK</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="prqAttachmentModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl attachment-modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Attached Files</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                @if (Model.CanEditVoucherBusiness)
                {
                <div class="form-group mb-2">
                    <label class="mb-1">Attached Files <span class="prq-attachment-note">Allowed: @Model.AllowedAttachmentExtensionsText | Max size: @Model.MaxAttachmentSizeMb MB</span></label>
                    <input asp-for="AttachmentUploads" type="file" form="inventoryReceivedDetailForm" class="form-control-file" id="detailAttachmentUpload" accept="@Model.AllowedAttachmentExtensionsText" multiple />
                    <div id="detailAttachmentError" class="text-danger small mt-1" style="display:none;"></div>
                </div>
                }
                <div class="table-responsive attachment-list-scroll-x">
                    <table class="table table-bordered table-sm mb-0 text-nowrap">
                        <thead>
                            <tr>
                                <th style="width:70px;" class="text-center">Action</th>
                                <th>File Name</th>
                                <th style="width:190px; min-width:190px;">Date created</th>
                                <th style="width:140px; min-width:140px;">User</th>
                            </tr>
                        </thead>
                        <tbody id="attachmentListBody">
                            <tr><td colspan="4" class="text-center text-muted py-3">No files selected</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer py-2">
                @if (Model.CanEditVoucherBusiness)
                {
                    <button type="button" class="btn btn-sm btn-action-save border" id="btnAttachmentAgree" data-dismiss="modal">Agree</button>
                }
                else
                {
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Purchasing/PurchaseRequisition/index.css" asp-append-version="true" />
    <style>
        .select2-results__group { font-weight: 700; color: #212529; }
        .select2-container--default .select2-results__option[aria-disabled=true] { color: #6c757d; }
        body.inventory-received-modal-open > .select2-container { z-index: 1035 !important; }
        #inventoryReceivedDetailForm .modal .select2-container { z-index: 1080 !important; }
        #inventoryReceivedDetailForm .modal .select2-dropdown { z-index: 1081 !important; }
        #receiveFromIssueModal { z-index: 1075 !important; }
        #receiveFromIssueModal .modal-dialog { z-index: 1076 !important; }
        #prqAttachmentModal { z-index: 1060 !important; }
        #confirmInventoryReceivedModal { z-index: 1070 !important; }
        #confirmInventoryReceivedModal .modal-dialog { z-index: 1071 !important; }
        .modal-backdrop { z-index: 1040; }
        body.inventory-received-confirm-open .select2-container { z-index: 1035 !important; }
        .inventory-received-detail-scroll { max-height: 500px; overflow-y: auto; }
        .inventory-received-detail-scroll-x { overflow-x: auto; }
        .inventory-received-add-detail-scroll { max-height: calc(100vh - 220px); overflow-y: auto; }
        .inventory-received-detail-scroll thead th,
        .inventory-received-add-detail-scroll thead th { position: sticky; top: 0; z-index: 2; background: #f8f9fa; }
        .inventory-received-main-table { min-width: 1650px; }
        .inventory-received-detail-scroll .table,
        .inventory-received-add-detail-scroll .table { table-layout: auto; }
        .inventory-received-add-detail-scroll td:nth-child(2),
        .inventory-received-add-detail-scroll td:nth-child(3),
        .inventory-received-add-detail-scroll th:nth-child(2),
        .inventory-received-add-detail-scroll th:nth-child(3),
        .inventory-received-detail-scroll td:nth-child(2),
        .inventory-received-detail-scroll td:nth-child(3),
        .inventory-received-detail-scroll th:nth-child(2),
        .inventory-received-detail-scroll th:nth-child(3) { white-space: nowrap; }
        .inventory-received-detail-scroll .detail-docqty,
        .inventory-received-detail-scroll .detail-actqty,
        .inventory-received-add-detail-scroll .add-docqty,
        .inventory-received-add-detail-scroll .add-actqty { width: 100px; min-width: 100px; max-width: 100px; }
        .inventory-received-detail-scroll .detail-unitprice,
        .inventory-received-add-detail-scroll .add-unitprice { width: 110px; min-width: 110px; max-width: 110px; }
        .inventory-received-detail-scroll .detail-location { min-width: 230px; white-space: nowrap; }
        .inventory-received-detail-scroll td:first-child { text-align: center; vertical-align: middle; }
        .attachment-list-scroll-x { overflow-x: auto; }
        .attachment-modal-dialog { max-width: 1100px; }
    </style>
}

@section Scripts {
    <script>
        (function () {
            const itemCatalog = @Html.Raw(JsonSerializer.Serialize(Model.ItemCatalog.Select(x => new {
                id = x.ItemId.ToString(),
                checkingId = x.ChekingID,
                checkingDtId = x.ChekingDTID,
                mrDetailId = x.MRDetailID,
                itemCode = x.ItemCode,
                itemName = x.ItemName,
                unit = x.Unit,
                remainingQty = x.RemainingQty,
                price = x.Price
            })));
            const locationCatalog = @Html.Raw(JsonSerializer.Serialize(Model.Locations.Where(x => !string.IsNullOrWhiteSpace(x.Value)).Select(x => new { id = x.Value, text = x.Text })));
            const existingAttachments = @Html.Raw(JsonSerializer.Serialize(Model.AttachmentList.Select(x => new {
                docId = x.DocId,
                filePath = x.FilePath,
                uploadDate = x.UploadDate?.ToString("dd/MM/yyyy HH:mm") ?? "",
                employeeCode = x.EmployeeCode,
                downloadUrl = Url.Page("./InventoryReceivedDetail", "DownloadAttachment", new { id = Model.Id, docId = x.DocId }),
                deleteUrl = Url.Page("./InventoryReceivedDetail", "DeleteAttachment", new { id = Model.Id, docId = x.DocId })
            })));
