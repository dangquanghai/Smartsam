                const s = String(v).replace(/,/g, '').trim();
                const n = Number(s);
                return isNaN(n) ? 0 : n;
            }
            function formatNumber(v) {
                return Number(v || 0).toLocaleString(undefined, { maximumFractionDigits: 0 });
            }
            function syncAddDetailCheckAll() {
