            function initSelect2() {
                if (!$.fn.select2) return;
                const $modal = $addDetailModal;
                $('select.select2').not($modal.find('select.select2')).select2({ width: '100%' });
                $modal.find('select.select2').select2({ width: '100%', dropdownParent: $modal });
            }

            function reloadReceiveContext() {
                const flowSubType = $('#Header_FlowSubType').val() || '';
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                const url = `?handler=ReceiveContext&flowSubType=${encodeURIComponent(flowSubType)}`;

                return fetch(url, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : null)
                    .then(data => {
                        if (!data) return;
                        $('#Header_StatusID').val(data.statusId || '');
                        $('#Header_StatusName').val(data.statusName || '');
                        $('#statusTextStrong').text(data.statusName || '');
                        if (mode === 'add' && data.flowNo) {
                            $('#Header_FlowNo').val(data.flowNo);
                        } else if (mode === 'add' && !flowSubType) {
                            $('#Header_FlowNo').val('');
                        }
                    })
                    .catch(() => {
                        $('#Header_StatusName').val('');
                    });
            }

            function setFieldEnabled($field, enabled, clearWhenDisabled) {
                if (!$field || $field.length === 0) return;
                const tagName = ($field.prop('tagName') || '').toLowerCase();
                if (tagName === 'select') {
                    if (!enabled && clearWhenDisabled) {
                        $field.val('').trigger('change.select2');
                    }
                    $field.prop('disabled', !enabled).trigger('change.select2');
                    return;
                }

                if (!enabled && clearWhenDisabled) {
                    $field.val('');
                }
                $field.prop('readonly', !enabled);
            }

            function syncReceiveFromIssueButton() {
                const flowSubType = Number($('#Header_FlowSubType').val() || 0);
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                const canEditBusiness = @Model.CanEditVoucherBusiness.ToString().ToLowerInvariant();
                const canUseReceiveFromIssue = canEditBusiness && (mode === 'add' || mode === 'edit') && flowSubType === 6;
                $('#btnOpenReceiveFromIssue').prop('disabled', !canUseReceiveFromIssue);
            }

            function applyFieldRuleByFlowSubType() {
                const flowSubType = Number($('#Header_FlowSubType').val() || 0);
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                const isView = mode === 'view';
                const isEdit = mode === 'edit';
                const canEditBusiness = @Model.CanEditVoucherBusiness.ToString().ToLowerInvariant();
                const $po = $('#Header_POID');
                const $files = $('#btnOpenAttachmentModal');
                const $moveToCompanyStore = $('#Header_MoveToCPNStore');
                const $retDept = $('#Header_RetDept');
                const $retLocation = $('#Header_RetAssetLocation');
                const $reason = $('#Header_Reason');

                const canEditHeader = !isView && canEditBusiness;
                syncReceiveFromIssueButton();

                if (!canEditHeader) {
                    $('#moveToCompanyStoreRequiredMark').addClass('d-none');
                    setFieldEnabled($po, false, false);
                    $files.prop('disabled', true);
                    setFieldEnabled($moveToCompanyStore, false, false);
                    setFieldEnabled($retDept, false, false);
                    setFieldEnabled($retLocation, false, false);
                    setFieldEnabled($reason, false, false);
                    return;
                }

                if (flowSubType <= 0) {
                    $('#moveToCompanyStoreRequiredMark').addClass('d-none');
                    setFieldEnabled($po, false, true);
                    $files.prop('disabled', true);
                    setFieldEnabled($moveToCompanyStore, false, true);
                    setFieldEnabled($retDept, false, true);
                    setFieldEnabled($retLocation, false, true);
                    setFieldEnabled($reason, false, true);
                    return;
                }

                if (flowSubType === 1) {
                    $('#moveToCompanyStoreRequiredMark').addClass('d-none');
                    setFieldEnabled($po, !isEdit, false);
                    $files.prop('disabled', false);
                    setFieldEnabled($moveToCompanyStore, false, true);
                    setFieldEnabled($retDept, true, false);
                    setFieldEnabled($retLocation, true, false);
                    setFieldEnabled($reason, true, false);
                    return;
                }

                if (flowSubType !== 6) {
                    $('#moveToCompanyStoreRequiredMark').removeClass('d-none');
                    setFieldEnabled($po, false, true);
                    $files.prop('disabled', true);
                    setFieldEnabled($moveToCompanyStore, true, false);
                    setFieldEnabled($retDept, false, true);
                    setFieldEnabled($retLocation, false, true);
                    setFieldEnabled($reason, true, false);
                    return;
                }

                $('#moveToCompanyStoreRequiredMark').addClass('d-none');
                setFieldEnabled($po, false, true);
                $files.prop('disabled', true);
                setFieldEnabled($moveToCompanyStore, false, true);
                setFieldEnabled($retDept, false, true);
                setFieldEnabled($retLocation, false, true);
                setFieldEnabled($reason, true, false);
            }

            function syncDetailsJson() {
