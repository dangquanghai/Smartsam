@page
@model SmartSam.Pages.Inventory.InventoryTransfer.IndexModel
@{
    ViewData["Title"] = "Item Transfer List";
    var currentPage = Model.Filter.Page <= 0 ? 1 : Model.Filter.Page;
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
    var pageItems = new List<int?>();
    for (var p = 1; p <= totalPages; p++)
    {
        if (p == 1 || p == totalPages || (p >= currentPage - 2 && p <= currentPage + 2)) pageItems.Add(p);
        else if (pageItems.Count == 0 || pageItems[^1].HasValue) pageItems.Add(null);
    }
    Func<int, string> pageUrl = page => Url.Page("./Index", new
    {
        FlowNo = Model.Filter.FlowNo,
        According = Model.Filter.According,
        FromStoreId = Model.Filter.FromStoreId,
        ToStoreId = Model.Filter.ToStoreId,
        FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"),
        ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"),
        Page = page,
        PageSize = Model.Filter.PageSize
    }) ?? "#";
}
<section class="content vni-font inventory-received-page">
    <div class="container-fluid">
        <form method="post" asp-page-handler="Delete" id="transferDeleteForm">
            <input type="hidden" name="id" id="deleteFlowId" />
            <input type="hidden" name="Filter.FlowNo" value="@Model.Filter.FlowNo" />
            <input type="hidden" name="Filter.According" value="@Model.Filter.According" />
            <input type="hidden" name="Filter.FromStoreId" value="@Model.Filter.FromStoreId" />
            <input type="hidden" name="Filter.ToStoreId" value="@Model.Filter.ToStoreId" />
            <input type="hidden" name="Filter.FromDate" value="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="Filter.ToDate" value="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="Filter.Page" value="@Model.Filter.Page" />
            <input type="hidden" name="Filter.PageSize" value="@Model.Filter.PageSize" />
        </form>

        <div class="row">
            <div class="col-md-2">
                <div class="card card-info"><div class="card-header"><h3 class="card-title"><i class="fas fa-search"></i> Search</h3></div><div class="card-body">
                    <form method="get">
                        <input type="hidden" name="Page" value="1" />
                        <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />
                        <div class="form-group mb-2"><label>Doc No.</label><input asp-for="Filter.FlowNo" class="form-control form-control-sm vni-font" /></div>
                        <div class="form-group mb-2"><label>According</label><input asp-for="Filter.According" class="form-control form-control-sm vni-font" /></div>
                        <div class="form-group mb-2"><label>From</label><input asp-for="Filter.FromDate" type="date" class="form-control form-control-sm" /></div>
                        <div class="form-group mb-2"><label>To</label><input asp-for="Filter.ToDate" type="date" class="form-control form-control-sm" /></div>
                        <div class="form-group mb-2"><label>Issue at St.House</label><select asp-for="Filter.FromStoreId" asp-items="Model.Stores" class="form-control form-control-sm select2 vni-font"></select></div>
                        <div class="form-group mb-2"><label>Enter to St.House</label><select asp-for="Filter.ToStoreId" asp-items="Model.Stores" class="form-control form-control-sm select2 vni-font"></select></div>
                        <button type="submit" class="btn btn-primary btn-block btn-sm border mb-2"><i class="fas fa-search"></i> Search</button>
                    </form>
                </div></div>
            </div>
            <div class="col-md-10">
                <div class="card card-primary">
                    <div class="card-header prq-table-header">
                        <div class="prq-table-header-left">
                            <h3 class="card-title">Item Transfer List</h3>
                            <span class="badge badge-light ml-2">@Model.TotalRecords records</span>
                        </div>
                        <div class="prq-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div class="d-inline-block mr-2 prq-pagination-info">
                                    @if (Model.TotalRecords == 0)
                                    {
                                        <small>No records</small>
                                    }
                                    else
                                    {
                                        <small>Showing @Model.PageStart to @Model.PageEnd of @Model.TotalRecords entries</small>
                                    }
                                </div>
                                <div class="prq-page-size-form d-inline-flex mr-2">
                                    <label class="mb-0 prq-page-size-label" for="transferPageSize">Show</label>
                                    <select id="transferPageSize" class="form-control form-control-sm prq-page-size-select">
                                        @foreach (var pageSizeOption in Model.PageSizeOptions)
                                        {
                                            <option value="@pageSizeOption" selected="@(Model.Filter.PageSize == pageSizeOption ? "selected" : null)">@pageSizeOption</option>
                                        }
                                    </select>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasPreviousPage ? pageUrl(currentPage - 1) : "#")">Prev</a>
                                    </li>
                                    @foreach (var pageItem in pageItems)
                                    {
                                        if (pageItem.HasValue)
                                        {
                                            <li class="page-item @(pageItem.Value == currentPage ? "active" : "")">
                                                <a class="page-link prq-pager-link" href="@pageUrl(pageItem.Value)">@pageItem.Value</a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                        }
                                    }
                                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasNextPage ? pageUrl(currentPage + 1) : "#")">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                    <div class="card-body p-0"><div class="table-responsive prq-table-wrap"><table class="table table-hover table-bordered mb-0 text-nowrap prq-table" id="transferTable"><thead class="thead-light"><tr><th style="width:32px;"></th><th>Doc No.</th><th>Transfer Date</th><th>According</th><th>Issue at St.House</th><th>Enter to St.House</th></tr></thead><tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted py-3">No item transfer found.</td></tr>
                    }
                    else
                    {
                        foreach (var row in Model.Rows)
                        {
                            <tr class="transfer-row" data-flowid="@row.FlowID">
                                <td><input type="radio" class="transfer-selector" name="selectedTransfer" /></td>
                                <td>
                                    @if (Model.PagePerm.HasPermission(2) || Model.PagePerm.HasPermission(4))
                                    {
                                        var accessMode = Model.PagePerm.HasPermission(4) ? "edit" : "view";
                                        <a href="@Url.Page("./InventoryTransferDetail", new { id = row.FlowID, mode = accessMode })" class="prq-row-link prq-row-link-request-no text-bold">@row.FlowNo</a>
                                    }
                                    else
                                    {
                                        <span class="prq-row-link-request-no text-bold">@row.FlowNo</span>
                                    }
                                </td>
                                <td>@row.FlowDate.ToString("dd/MM/yyyy")</td>
                                <td>@row.According</td>
                                <td>@row.FromStoreName</td>
                                <td>@row.ToStoreName</td>
                            </tr>
                        }
                    }
                    </tbody></table></div></div>
                </div>
                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center module-action-bar prq-action-bar">
                        @if (Model.PagePerm.HasPermission(3))
                        {
                            <a asp-page="./InventoryTransferDetail" asp-route-mode="add" class="btn btn-sm btn-success border mx-1 my-1"><i class="fas fa-plus"></i> Add</a>
                        }
                        @if (Model.PagePerm.HasPermission(5))
                        {
                            <button type="button" id="btnDeleteTransfer" class="btn btn-sm btn-danger border mx-1 my-1" disabled><i class="fas fa-trash"></i> Delete</button>
                        }
                        @if (Model.PagePerm.HasPermission(2))
                        {
                            <button type="button" id="btnExportTransfer" class="btn btn-sm btn-primary border mx-1 my-1" disabled><i class="fas fa-file-excel"></i> Export Excel</button>
                            <button type="button" class="btn btn-sm btn-action-close border mx-1 my-1" data-toggle="modal" data-target="#transferSearchDetailModal"><i class="fas fa-search-plus"></i> Search Detail</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade vni-font" id="transferDeleteConfirmModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document"><div class="modal-content"><div class="modal-header bg-danger py-2"><h5 class="modal-title text-white">Confirm Delete</h5><button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button></div><div class="modal-body" id="transferDeleteConfirmText">Do you want to delete this Doc no.?</div><div class="modal-footer py-2"><button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Cancel</button><button type="button" id="btnConfirmDeleteTransfer" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Delete</button></div></div></div>
</div>


<div class="modal fade vni-font" id="transferSearchDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 96vw; width: 96vw;" role="document">
        <div class="modal-content">
            <div class="modal-header py-2"><h5 class="modal-title">Search Detail</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body">
                <div class="form-row align-items-end mb-2">
                    <div class="col-md-5"><label>Item Code / Item Name / Doc No.</label><input id="transferDetailKeyword" class="form-control form-control-sm vni-font" /></div>
                    <div class="col-md-1"><button id="btnTransferDetailSearch" type="button" class="btn btn-sm btn-primary btn-block"><i class="fas fa-search"></i> Search</button></div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered table-hover mb-1 text-nowrap">
                        <thead class="thead-light"><tr><th>Item Code</th><th>Item Name</th><th>Doc No.</th><th>Date</th><th class="text-right">Act. Qty</th><th class="text-right">Price</th><th class="text-right">Amount</th></tr></thead>
                        <tbody id="transferDetailRows"><tr><td colspan="7" class="text-center text-muted">Enter keyword then search.</td></tr></tbody>
                    </table>
                </div>
                <div class="prq-table-header-right mt-2">
                    <nav aria-label="Search detail paging">
                        <div class="d-inline-block mr-2 prq-pagination-info"><small id="transferDetailPagingInfo">No records</small></div>
                        <div class="prq-page-size-form d-inline-flex mr-2">
                            <label class="mb-0 prq-page-size-label" for="transferDetailPageSize">Show</label>
                            <select id="transferDetailPageSize" class="form-control form-control-sm prq-page-size-select select2">
                                @foreach (var pageSizeOption in Model.PageSizeOptions)
                                {
                                    <option value="@pageSizeOption" selected="@(pageSizeOption == 10 ? "selected" : null)">@pageSizeOption</option>
                                }
                            </select>
                        </div>
                        <ul class="pagination pagination-sm mb-0 d-inline-flex" id="transferDetailPagination"></ul>
                    </nav>
                </div>
            </div>
            <div class="modal-footer py-2"><button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function(){
    function initBackgroundSelect2(){ if(!$.fn.select2) return; $('select.select2').each(function(){ const el=$(this); const parent = el.closest('#transferSearchDetailModal').length ? $('#transferSearchDetailModal') : null; if(el.data('select2')) el.select2('destroy'); el.select2(parent ? { width:'100%', dropdownParent: parent } : { width:'100%' }); }); }
    function destroyBackgroundSelect2(){ $('select.select2').each(function(){ const el=$(this); if(el.data('select2')) el.select2('destroy'); }); }
    initBackgroundSelect2();
    setTimeout(initBackgroundSelect2, 0);
    const transferDetailState = { page: 1, pageSize: 10, totalPages: 1, totalRecords: 0, keyword: '' };
    const transferDetailPageUrl = '@Url.Page("./InventoryTransferDetail")';
    const transferExportUrl = '@Url.Page("./Index", new { handler = "Export" })';

    function getSelectedRow(){ return $('.transfer-selector:checked').closest('.transfer-row'); }
    function syncButtonState(){ const hasRow = getSelectedRow().length > 0; $('#btnDeleteTransfer,#btnExportTransfer').prop('disabled', !hasRow); }
    $(document).on('click', '#transferTable tbody tr.transfer-row', function(e){
        if ($(e.target).closest('a').length) return;
        const $row = $(this);
        const wasSelected = $row.hasClass('table-active');
        $('#transferTable tbody tr.transfer-row').removeClass('table-active');
        $('.transfer-selector').prop('checked', false);
        if (!wasSelected) {
            $row.addClass('table-active');
            $row.find('.transfer-selector').prop('checked', true);
        }
        syncButtonState();
    });

    $('#btnDeleteTransfer').on('click', function(){ const row=getSelectedRow(); if(row.length===0) return; const flowNo=row.find('td').eq(1).text().trim(); $('#transferDeleteConfirmText').text(`Do you want to delete this Doc no. '${flowNo}' ?`); $('#deleteFlowId').val(row.data('flowid')); $('#transferDeleteConfirmModal').modal('show'); });
    $('#btnConfirmDeleteTransfer').on('click', function(){ $('#transferDeleteConfirmModal').modal('hide'); $('#transferDeleteForm').trigger('submit'); });
    $('#btnExportTransfer').on('click', function(){ const row=getSelectedRow(); if(row.length===0) return; window.open(`${transferExportUrl}&id=${row.data('flowid')}`, '_blank'); });

    function renderTransferDetailPagination(){
        const page = transferDetailState.page;
        const totalPages = transferDetailState.totalPages || 1;
        const totalRecords = transferDetailState.totalRecords || 0;
        const start = totalRecords === 0 ? 0 : ((page - 1) * transferDetailState.pageSize) + 1;
        const end = totalRecords === 0 ? 0 : Math.min(page * transferDetailState.pageSize, totalRecords);
        $('#transferDetailPagingInfo').text(`Showing ${start}-${end} of ${totalRecords}`);
        const $pager = $('#transferDetailPagination').empty();
        const add = (p, text, disabled, active) => $pager.append(`<li class="page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}"><a class="page-link transfer-detail-page-link" href="#" data-page="${p}">${text}</a></li>`);
        add(Math.max(1, page - 1), 'Prev', page <= 1, false);
        for(let p=1;p<=totalPages;p++){ if(p===1 || p===totalPages || (p>=page-2 && p<=page+2)) add(p, p, false, p===page); }
        add(Math.min(totalPages, page + 1), 'Next', page >= totalPages, false);
    }

    async function loadTransferDetail(page){
        transferDetailState.keyword = $('#transferDetailKeyword').val() || '';
        transferDetailState.page = page || 1;
        transferDetailState.pageSize = Number($('#transferDetailPageSize').val() || 10);
        const url = `?handler=SearchDetail&keyword=${encodeURIComponent(transferDetailState.keyword)}&pageNumber=${transferDetailState.page}&pageSize=${transferDetailState.pageSize}`;
        const response = await fetch(url);
        const data = await response.json();
        const $rows = $('#transferDetailRows').empty();
        if(!data.rows || data.rows.length === 0){
            $rows.append('<tr><td colspan="7" class="text-center text-muted">No detail found.</td></tr>');
        } else {
            data.rows.forEach(r => $rows.append(`<tr><td>${r.itemCode}</td><td class="tcvn3-font">${r.itemName}</td><td><a href="./InventoryTransfer/InventoryTransferDetail?id=${r.flowId}&mode=view">${r.flowNo}</a></td><td>${r.flowDate}</td><td class="text-right">${Number(r.actQty).toLocaleString()}</td><td class="text-right">${Number(r.unitPrice).toLocaleString()}</td><td class="text-right">${Number(r.amount).toLocaleString()}</td></tr>`));
        }
        transferDetailState.page = data.pageNumber || 1;
        transferDetailState.pageSize = data.pageSize || transferDetailState.pageSize;
        transferDetailState.totalPages = data.totalPages || 1;
        transferDetailState.totalRecords = data.totalRecords || 0;
        renderTransferDetailPagination();
    }

    $('#transferSearchDetailModal').on('show.bs.modal', function(){ destroyBackgroundSelect2(); });
    $('#transferSearchDetailModal').on('shown.bs.modal', function(){ loadTransferDetail(1); });
    $('#transferSearchDetailModal').on('hidden.bs.modal', function(){ initBackgroundSelect2(); });
    $('#btnTransferDetailSearch').on('click', function(){ loadTransferDetail(1); });
    $('#transferDetailKeyword').on('keydown', function(e){ if(e.key === 'Enter'){ e.preventDefault(); loadTransferDetail(1); } });
    $('#transferDetailPageSize').on('change', function(){ loadTransferDetail(1); });
    $(document).on('click', '.transfer-detail-page-link', function(e){ e.preventDefault(); const page = Number($(this).data('page') || 0); if(page > 0) loadTransferDetail(page); });

    $("#transferPageSize").on("change", function(){ const u = new URL(window.location.href); u.searchParams.set("Page", "1"); u.searchParams.set("PageSize", $(this).val()); window.location = u.toString(); });
    syncButtonState();
});
</script>
}











@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Purchasing/PurchaseRequisition/index.css" asp-append-version="true" />
    <style>
        #transferTable tbody tr.transfer-row { cursor: pointer; }
    </style>
}
