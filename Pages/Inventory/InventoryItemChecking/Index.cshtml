@page
@model SmartSam.Pages.Inventory.ItemChecking.IndexModel
@{
    ViewData["Title"] = "Inventory Item Checking";
    var currentPage = Model.Filter.Page <= 0 ? 1 : Model.Filter.Page;
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
    var pageItems = new List<int?>();
    for (var p = 1; p <= totalPages; p++)
    {
        if (p == 1 || p == totalPages || (p >= currentPage - 2 && p <= currentPage + 2))
        {
            pageItems.Add(p);
        }
        else if (pageItems.Count == 0 || pageItems[^1].HasValue)
        {
            pageItems.Add(null);
        }
    }
    Func<int, string> pageUrl = page => Url.Page("./Index", new Dictionary<string, object?>
    {
        ["Filter.DeptId"] = Model.Filter.DeptId,
        ["Filter.CheckingId"] = Model.Filter.CheckingId,
        ["Filter.StatusId"] = Model.Filter.StatusId,
        ["Filter.UseCheckedDate"] = Model.Filter.UseCheckedDate,
        ["Filter.CheckedFrom"] = Model.Filter.CheckedFrom?.ToString("yyyy-MM-dd"),
        ["Filter.CheckedTo"] = Model.Filter.CheckedTo?.ToString("yyyy-MM-dd"),
        ["Filter.UseApprovedDate"] = Model.Filter.UseApprovedDate,
        ["Filter.ApprovedFrom"] = Model.Filter.ApprovedFrom?.ToString("yyyy-MM-dd"),
        ["Filter.ApprovedTo"] = Model.Filter.ApprovedTo?.ToString("yyyy-MM-dd"),
        ["Filter.LateChecking"] = Model.Filter.LateChecking,
        ["Filter.Page"] = page,
        ["Filter.PageSize"] = Model.Filter.PageSize
    }) ?? "#";
}

<section class="content vni-font inventory-item-checking-page">
    <div class="container-fluid">
        @if (!string.IsNullOrWhiteSpace(Model.AlertMessage))
        {
            var alertClass = Model.AlertType switch
            {
                "success" => "alert-success",
                "warning" => "alert-warning",
                "error" => "alert-danger",
                _ => "alert-info"
            };
            <div class="alert @alertClass alert-dismissible fade show mb-2" role="alert">
                @Model.AlertMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
        }
        <div class="row">
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header"><h3 class="card-title"><i class="fas fa-search"></i> Search</h3></div>
                    <div class="card-body">
                        <form method="get" id="inventoryItemCheckingSearchForm">
                            <input type="hidden" name="Filter.Page" value="1" />
                            <input type="hidden" name="Filter.PageSize" value="@Model.Filter.PageSize" />
                            <div class="form-group mb-2">
                                <label>Department</label>
                                @if (Model.CanChangeDepartmentFilter)
                                {
                                    <select asp-for="Filter.DeptId" asp-items="Model.Departments" class="form-control form-control-sm select2 vni-font" data-placeholder="--- All ---"></select>
                                }
                                else
                                {
                                    <input type="hidden" asp-for="Filter.DeptId" />
                                    <select asp-for="Filter.DeptId" asp-items="Model.Departments" class="form-control form-control-sm select2 vni-font" data-placeholder="--- All ---" disabled></select>
                                }
                            </div>
                            <div class="form-group mb-2"><label>Checking Id</label><input asp-for="Filter.CheckingId" type="number" min="1" class="form-control form-control-sm" /></div>
                            <div class="form-group mb-2"><label>Status</label><select asp-for="Filter.StatusId" asp-items="Model.Statuses" class="form-control form-control-sm select2 vni-font" data-placeholder="--- All ---"></select></div>
                            <div class="form-group mb-1"><div class="custom-control custom-checkbox"><input asp-for="Filter.UseCheckedDate" class="custom-control-input" /><label asp-for="Filter.UseCheckedDate" class="custom-control-label">Checked Date</label></div></div>
                            <div class="form-group mb-2"><label>From</label><input id="CheckedFromDateDisplay" type="text" class="form-control form-control-sm app-date-picker" value="@Model.Filter.CheckedFrom?.ToString("dd/MM/yyyy")" data-hidden-target="#CheckedFromDateHidden" autocomplete="off" readonly /><input id="CheckedFromDateHidden" name="Filter.CheckedFrom" type="hidden" value="@Model.Filter.CheckedFrom?.ToString("yyyy-MM-dd")" /></div>
                            <div class="form-group mb-2"><label>To</label><input id="CheckedToDateDisplay" type="text" class="form-control form-control-sm app-date-picker" value="@Model.Filter.CheckedTo?.ToString("dd/MM/yyyy")" data-hidden-target="#CheckedToDateHidden" autocomplete="off" readonly /><input id="CheckedToDateHidden" name="Filter.CheckedTo" type="hidden" value="@Model.Filter.CheckedTo?.ToString("yyyy-MM-dd")" /></div>
                            <div class="form-group mb-1"><div class="custom-control custom-checkbox"><input asp-for="Filter.UseApprovedDate" class="custom-control-input" /><label asp-for="Filter.UseApprovedDate" class="custom-control-label">Approved Date</label></div></div>
                            <div class="form-group mb-2"><label>From</label><input id="ApprovedFromDateDisplay" type="text" class="form-control form-control-sm app-date-picker" value="@Model.Filter.ApprovedFrom?.ToString("dd/MM/yyyy")" data-hidden-target="#ApprovedFromDateHidden" autocomplete="off" readonly /><input id="ApprovedFromDateHidden" name="Filter.ApprovedFrom" type="hidden" value="@Model.Filter.ApprovedFrom?.ToString("yyyy-MM-dd")" /></div>
                            <div class="form-group mb-2"><label>To</label><input id="ApprovedToDateDisplay" type="text" class="form-control form-control-sm app-date-picker" value="@Model.Filter.ApprovedTo?.ToString("dd/MM/yyyy")" data-hidden-target="#ApprovedToDateHidden" autocomplete="off" readonly /><input id="ApprovedToDateHidden" name="Filter.ApprovedTo" type="hidden" value="@Model.Filter.ApprovedTo?.ToString("yyyy-MM-dd")" /></div>
                            <div class="form-group mb-2"><div class="custom-control custom-checkbox"><input asp-for="Filter.LateChecking" class="custom-control-input" /><label asp-for="Filter.LateChecking" class="custom-control-label">Late Checking</label></div></div>
                            <button type="submit" class="btn btn-sm btn-primary btn-block"><i class="fas fa-search"></i> Search</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-10">
                <div class="card card-primary inventory-item-checking-list-card">
                    <div class="card-header p-2 inventory-item-checking-list-header vni-font">
                        <div class="d-flex justify-content-between align-items-center flex-wrap">
                            <div class="inventory-item-checking-title">
                                Inventory Item Checking
                                <span class="badge badge-light ml-1">@Model.TotalRecords records</span>
                            </div>
                            <div class="d-flex align-items-center inventory-item-checking-header-tools app-paging-white">
                                <span class="small mr-3">Showing @Model.PageStart to @Model.PageEnd of @Model.TotalRecords entries</span>
                                <label class="mb-0 mr-2 small font-weight-bold">Show</label>
                                <select id="inventoryItemCheckingPageSize" class="form-control form-control-sm inventory-item-checking-page-size mr-2">
                                    @foreach (var pageSizeOption in Model.PageSizeOptions)
                                    {
                                        <option value="@pageSizeOption" selected="@(Model.Filter.PageSize == pageSizeOption ? "selected" : null)">@pageSizeOption</option>
                                    }
                                </select>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasPreviousPage ? pageUrl(currentPage - 1) : "#")">Prev</a>
                                    </li>
                                    @foreach (var pageItem in pageItems)
                                    {
                                        if (pageItem.HasValue)
                                        {
                                            <li class="page-item @(pageItem.Value == currentPage ? "active" : "")">
                                                <a class="page-link prq-pager-link" href="@pageUrl(pageItem.Value)">@pageItem.Value</a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                        }
                                    }
                                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                        <a class="page-link prq-pager-link" href="@(Model.HasNextPage ? pageUrl(currentPage + 1) : "#")">Next</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive inventory-item-checking-table-wrap">
                            <table class="table table-hover table-bordered mb-0 text-nowrap inventory-item-checking-table vni-font" id="itemCheckingTable">
                                <thead class="thead-light"><tr><th style="width:120px;">Checking Id</th><th style="width:180px;">PO No</th><th style="width:180px;">Status</th><th style="width:220px;">Checked By</th><th style="width:200px;">Checked Date</th><th style="width:230px;">Approved By</th><th style="width:210px;">Approved Date</th><th>Receiving NO</th></tr></thead>
                                <tbody>
                                @if (Model.Rows.Count == 0)
                                { <tr><td colspan="7" class="text-center text-muted">No data</td></tr> }
                                else
                                {
                                    foreach (var row in Model.Rows)
                                    {
                                        var statusBadgeClass = row.StatusId switch
                                        {
                                            1 => "badge-info",
                                            2 => "badge-primary",
                                            3 => "badge-success",
                                            4 => "badge-warning",
                                            5 => "badge-danger",
                                            _ => "badge-secondary"
                                        };
                                        var detailMode = Model.CanEditRow(row.StatusId) ? "edit" : (Model.CanApproveRow(row.StatusId) ? "approved" : (Model.CanView ? "view" : string.Empty));
                                        var detailUrl = string.IsNullOrEmpty(detailMode) ? string.Empty : (Url.Page("./ItemCheckingDetail", new { id = row.CheckingId, mode = detailMode }) ?? "#");
                                        <tr class="inventory-item-checking-row" data-id="@row.CheckingId" data-status-id="@row.StatusId"><td>@if (!string.IsNullOrEmpty(detailMode)) { <a href="@detailUrl" class="inventory-item-checking-po-link font-weight-bold">@row.CheckingId</a> } else { <span class="font-weight-bold">@row.CheckingId</span> }</td><td>@row.PONo</td><td><span class="badge @statusBadgeClass">@row.StatusName</span></td><td>@row.CheckedBy</td><td>@(row.CheckedDate?.ToString("dd/MM/yyyy"))</td><td>@row.ApprovedBy</td><td>@(row.ApprovedDate?.ToString("dd/MM/yyyy"))</td><td>@row.ReceiveNo</td></tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card card-outline card-primary inventory-item-checking-action-card">
                    <div class="card-footer p-2 text-center module-action-bar ip-action-bar inventory-item-checking-action-bar vni-font">
                        @if (Model.CanAdd)
                        {
                            <button type="button" id="iicAddBtn" class="btn btn-sm btn-action-add border mx-1 my-1">
                                <i class="fas fa-plus"></i> Add
                            </button>
                        }
                        <button type="button" id="btnExportExcel" class="btn btn-sm btn-action-export border mx-1 my-1">
                            <i class="fas fa-file-excel"></i> Export Excel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.inventoryItemCheckingPage = {
            detailUrlBase: '@Url.Page("./ItemCheckingDetail")',
            exportUrl: '@Url.Page("./Index", "ExportExcel")'
        };
    </script>
    <script src="~/adminlte/plugins/jquery-ui/jquery-ui.min.js" asp-append-version="true"></script>
    <script src="~/js/common/app-datepicker.js" asp-append-version="true"></script>
    <script src="~/js/Inventory/InventoryItemChecking/index.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/adminlte/plugins/jquery-ui/jquery-ui.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/common/app-datepicker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Inventory/InventoryItemChecking/index.css" asp-append-version="true" />
}



