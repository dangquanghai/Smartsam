@page
@model SmartSam.Pages.Inventory.LinnenNoteDaily.LinnenNoteDailyDetailModel
@{
    ViewData["Title"] = "Pantry Linen Detail";
    var isView = Model.IsViewMode;
    var isBeginReadonly = isView || !Model.Header.Start;
    var linenHeaders = Model.Details
        .GroupBy(x => x.LinenCode)
        .Select(x => x.First())
        .ToList();
    var pantryGroups = Model.Details
        .GroupBy(x => new { x.Pentry, x.PentryName })
        .ToList();
    string FormatQty(int value) => value == 0 ? string.Empty : value.ToString();
    string LinenTitle(string code)
    {
        return code switch
        {
            "BATH-MAT" => "Bath mat",
            "PILLOW-CASE" => "Pillow case",
            "D-COVER-S" => "D Cover S",
            "SHEET-K" => "Sheet K",
            "D-COVER-K" => "D Cover K",
            "K-CLOTH" => "K Cloth",
            "D-CLOTH" => "D Cloth",
            _ => code.Replace("-", " ")
        };
    }
}

@section Styles {
    <style>
        .linnen-note-vb-header .form-control-sm {
            height: 24px;
            padding: 1px 4px;
        }

        .linnen-note-vb-header label {
            font-size: 12px;
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linnen-note-matrix {
            border-collapse: collapse;
            min-width: 1560px;
        }

        .linnen-note-matrix th,
        .linnen-note-matrix td {
            border: 1px solid #777 !important;
            padding: 1px 2px !important;
            vertical-align: middle !important;
        }

        .linnen-note-matrix .ln-pantry-title {
            width: 48px;
            background: #ff9b38;
            color: #000;
            font-weight: 700;
            text-align: center;
        }

        .linnen-note-matrix .ln-linen-title {
            background: #5b5de0;
            color: #fff;
            font-weight: 700;
            text-align: center;
            white-space: nowrap;
        }

        .linnen-note-matrix .ln-sub-title {
            background: #cdc8ff;
            color: #1c1c7a;
            font-weight: 400;
            text-align: center;
            width: 32px;
        }

        .linnen-note-matrix .ln-pantry-cell {
            background: #ff6f72;
            color: #000;
            text-align: center;
            font-weight: 700;
            width: 42px;
        }

        .linnen-note-matrix .ln-time-cell {
            color: #000;
            text-align: center;
            width: 24px;
        }

        .linnen-note-matrix .ln-time-am {
            background: #fff2a8;
        }

        .linnen-note-matrix .ln-time-pm {
            background: #ffc7d1;
        }

        .linnen-note-matrix .ln-qty-cell-be {
            background: #f7d7b6;
        }

        .linnen-note-matrix .ln-qty-cell-de,
        .linnen-note-matrix .ln-qty-cell-re {
            background: #fff;
        }

        .linnen-note-matrix .ln-qty {
            width: 31px;
            height: 22px;
            border: 0;
            border-radius: 0;
            padding: 0 2px;
            font-size: 12px;
            background: transparent;
        }

        .linnen-note-matrix .ln-qty:read-only {
            background: transparent;
        }

        .linnen-note-legend {
            color: #001ad8;
            font-size: 12px;
        }

        .linnen-note-check {
            display: inline-flex;
            align-items: center;
            height: 24px;
            line-height: 24px;
        }

        .linnen-note-check input[type="checkbox"] {
            margin: 0 4px 0 0;
        }

        .linnen-note-check label {
            margin: 0;
            line-height: 24px;
        }

        .linnen-report-modal-dialog {
            max-width: 94%;
        }

        .linnen-report-toolbar {
            border-bottom: 1px solid #d7d7d7;
            background: #f8f9fa;
        }

        .linnen-report-toolbar .form-control-sm,
        .linnen-report-toolbar .custom-select-sm {
            height: 28px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .linnen-report-toolbar label {
            font-size: 12px;
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linnen-report-choice {
            display: inline-flex;
            align-items: center;
            margin-right: 10px;
            margin-bottom: 4px;
            font-size: 12px;
        }

        .linnen-report-choice input {
            margin-right: 4px;
        }

        .linnen-report-chart {
            display: inline-flex;
            align-items: center;
            margin-bottom: 4px;
            font-size: 12px;
        }

        .linnen-report-chart .custom-control-label {
            padding-top: 1px;
        }

        .linnen-report-preview-wrap {
            min-height: 420px;
            background: #fff;
        }

        .linnen-report-preview-table {
            min-width: 1560px;
            border-collapse: collapse;
        }

        .linnen-report-preview-table th,
        .linnen-report-preview-table td {
            border: 1px solid #cfcfcf !important;
            padding: 3px 4px !important;
            font-size: 12px;
            vertical-align: middle !important;
            white-space: nowrap;
        }

        .linnen-report-preview-table thead th {
            background: #eef2f7;
            text-align: center;
        }

        .linnen-report-preview-table .ln-report-pantry {
            background: #fff4df;
            font-weight: 700;
        }

        .linnen-report-preview-table .ln-report-time {
            text-align: center;
            width: 32px;
            font-weight: 700;
        }

        .linnen-report-preview-meta {
            font-size: 12px;
            color: #495057;
        }
    </style>
}

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2" asp-validation-summary="All"></div>
        }

        <form method="post" id="linnenNoteDetailForm">
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="Header.Id" />
            <input type="hidden" asp-for="DetailsJson" id="DetailsJson" />
            <input type="hidden" asp-for="ReturnToIndex" id="ReturnToIndex" />
            <input type="hidden" asp-for="RedirectUrl" id="RedirectUrl" />

            <div class="card card-primary card-outline">
                <div class="card-body p-2 linnen-note-vb-header">
                    <div class="d-flex align-items-center">
                        <label class="mr-1">Note No</label>
                        <input asp-for="Header.Id" class="form-control form-control-sm mr-2" style="width: 55px;" readonly />
                        <label class="mr-1">Date</label>
                        <input asp-for="Header.DateCreate" type="date" class="form-control form-control-sm mr-2" style="width: 135px;" readonly="@isView" />
                        <label class="mr-1">Description</label>
                        <input asp-for="Header.Description" class="form-control form-control-sm mr-2" style="width: 300px;" maxlength="100" readonly="@isView" />
                        <div class="linnen-note-check mr-3">
                            <input asp-for="Header.IsRent" disabled="@isView" />
                            <label asp-for="Header.IsRent">Is Rent</label>
                        </div>
                        <div class="linnen-note-check">
                            <input asp-for="Header.IsClose" disabled />
                            <label asp-for="Header.IsClose">Close</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-primary">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0 linnen-note-matrix" id="linnenNoteDetailsTable">
                            <thead>
                                <tr>
                                    <th colspan="2" rowspan="2" class="ln-pantry-title">Pantry<br />No</th>
                                    @foreach (var linen in linenHeaders)
                                    {
                                        <th colspan="3" class="ln-linen-title">@LinenTitle(linen.LinenCode)</th>
                                    }
                                </tr>
                                <tr>
                                    @foreach (var linen in linenHeaders)
                                    {
                                        <th class="ln-sub-title">Be</th>
                                        <th class="ln-sub-title">De</th>
                                        <th class="ln-sub-title">Re</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Details.Count == 0)
                                {
                                    <tr>
                                        <td colspan="35" class="text-center text-muted py-3">No detail rows</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var pantry in pantryGroups)
                                    {
                                        for (var timeSection = 1; timeSection <= 2; timeSection++)
                                        {
                                            <tr>
                                                @if (timeSection == 1)
                                                {
                                                    <td rowspan="2" class="ln-pantry-cell">@pantry.Key.PentryName</td>
                                                }
                                                <td class="ln-time-cell @(timeSection == 1 ? "ln-time-am" : "ln-time-pm")">@(timeSection == 1 ? "A" : "P")</td>
                                                @foreach (var linen in linenHeaders)
                                                {
                                                    var row = pantry.FirstOrDefault(x => x.TimeSection == timeSection && x.LinenCode == linen.LinenCode);
                                                    if (row == null)
                                                    {
                                                        <td class="ln-qty-cell-be"></td>
                                                        <td class="ln-qty-cell-de"></td>
                                                        <td class="ln-qty-cell-re"></td>
                                                    }
                                                    else
                                                    {
                                                        <td class="ln-qty-cell-be">
                                                            <span class="linnen-note-detail-record d-none"
                                                                  data-id="@row.Id"
                                                                  data-header-id="@row.HeaderId"
                                                                  data-pentry="@row.Pentry"
                                                                  data-pentry-name="@row.PentryName"
                                                                  data-time-section="@row.TimeSection"
                                                                  data-linen-code="@row.LinenCode"
                                                                  data-linen-name="@row.LinenName"></span>
                                                            <input type="text" inputmode="numeric" class="form-control form-control-sm text-right ln-qty" data-detail-id="@row.Id" data-field="be" value="@FormatQty(row.Be)" readonly="@isBeginReadonly" />
                                                        </td>
                                                        <td class="ln-qty-cell-de"><input type="text" inputmode="numeric" class="form-control form-control-sm text-right ln-qty" data-detail-id="@row.Id" data-field="de" value="@FormatQty(row.De)" readonly="@isView" /></td>
                                                        <td class="ln-qty-cell-re"><input type="text" inputmode="numeric" class="form-control form-control-sm text-right ln-qty" data-detail-id="@row.Id" data-field="re" value="@FormatQty(row.Re)" readonly="@isView" /></td>
                                                    }
                                                }
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer p-2 text-center">
                    <div class="linnen-note-legend text-left mb-2">Be : Begin Quantity, De : Delivery Quantity, Re : Receive Quantity , A : AM , P : PM</div>
                    @if (Model.CanSave)
                    {
                        <button type="submit" class="btn btn-sm btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-secondary" id="btnPrintLinnenNoteDetail">
                        <i class="fas fa-print"></i> Print
                    </button>
                    <button type="button" class="btn btn-sm btn-default" id="btnCloseLinnenNoteDetail" data-index-url="@Url.Page("./Index")">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<div class="modal fade" id="linnenReportModal" tabindex="-1" role="dialog" aria-labelledby="linnenReportModalLabel" aria-hidden="true">
    <div class="modal-dialog linnen-report-modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linnenReportModalLabel">Linen - Report</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0">
                <div class="p-2 linnen-report-toolbar">
                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-2">
                        <div class="d-flex flex-wrap align-items-center">
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="pantry" checked />Pantry-Linen</label>
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="delivery" disabled />Delivery</label>
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="receive" disabled />Receive</label>
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="laundry-record" disabled />Laundry Record</label>
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="not-receive" disabled />Not Receive</label>
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="laundry-balance" disabled />Laundry.U. Balance</label>
                            <label class="linnen-report-choice"><input type="radio" name="linnenReportType" value="apmt-balance" disabled />Apmt Balance</label>
                        </div>
                        <div class="linnen-report-chart">
                            <div class="custom-control custom-checkbox mb-0">
                                <input type="checkbox" class="custom-control-input" id="linnenReportChart" disabled />
                                <label class="custom-control-label" for="linnenReportChart">Chart</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-row align-items-center">
                        <div class="col-md-4 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">Des</label>
                                <select class="form-control form-control-sm" id="linnenReportDescription">
                                    <option value="@Model.Header.Id">@Model.Header.Description</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">Linnen</label>
                                <select class="form-control form-control-sm" id="linnenReportLinenCode">
                                    <option value="">ALL</option>
                                    @foreach (var linen in linenHeaders)
                                    {
                                        <option value="@linen.LinenCode">@LinenTitle(linen.LinenCode)</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">From</label>
                                <input type="date" class="form-control form-control-sm" id="linnenReportFromDate" value="@Model.Header.DateCreate.ToString("yyyy-MM-dd")" readonly />
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="d-flex align-items-center">
                                <label class="mr-2">To</label>
                                <input type="date" class="form-control form-control-sm" id="linnenReportToDate" value="@Model.Header.DateCreate.ToString("yyyy-MM-dd")" readonly />
                            </div>
                        </div>
                        <div class="col-md-1 mb-2">
                            <button type="button" class="btn btn-sm btn-primary btn-block" id="btnPreviewLinnenReport">Preview</button>
                        </div>
                    </div>
                </div>

                <div class="px-2 pt-2 linnen-report-preview-meta" id="linnenReportPreviewMeta">
                    Note: @Model.Header.Description
                </div>
                <div class="p-2 linnen-report-preview-wrap">
                    <div class="table-responsive" id="linnenReportPreviewContainer">
                        <div class="text-center text-muted py-5">Click Preview to load report data.</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="linnenNoteUnsavedModal" tabindex="-1" role="dialog" aria-labelledby="linnenNoteUnsavedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linnenNoteUnsavedModalLabel">Unsaved Changes</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body py-3">
                Data has changed. Do you want to save before leaving?
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-primary btn-sm" id="btnUnsavedSave">Save</button>
                <button type="button" class="btn btn-secondary btn-sm" id="btnUnsavedDiscard">Don't Save</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="btnUnsavedCancel" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.linnenNoteDailyDetail = {
            isView: @(isView ? "true" : "false"),
            indexUrl: "@Url.Page("./Index")",
            printPreviewUrl: "@Url.Page("./LinnenNoteDailyDetail", "PrintPreview", new { id = Model.Header.Id })",
            reportPageUrl: "@Url.Page("/Inventory/LinenReport/Index")"
        };
    </script>
    <script src="~/js/Inventory/LinnenNoteDaily/LinnenNoteDailyDetail.js" asp-append-version="true"></script>
}
