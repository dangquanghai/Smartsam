@page
@model SmartSam.Pages.Inventory.LinnenNoteDaily.LinnenNoteDailyDetailModel
@{
    ViewData["Title"] = "Pantry Linen Detail";
    var isView = Model.IsViewMode;
    var isPopup = Model.IsPopup;
    var isBeginReadonly = isView || !Model.Header.Start;
    var detailLookup = Model.Details
        .GroupBy(x => $"{x.Pentry}|{x.TimeSection}|{x.LinenCode}", StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);
    string FormatQty(int value) => value == 0 ? string.Empty : value.ToString();

    SmartSam.Pages.Inventory.LinnenNoteDaily.LinnenNoteDailyDetailRow? FindDetail(int pentryId, int timeSection, string linenCode)
    {
        var key = $"{pentryId}|{timeSection}|{linenCode}";
        if (detailLookup.TryGetValue(key, out var row))
        {
            return row;
        }

        return null;
    }
}

@section Styles {
    <style>
        .linnen-note-vb-header .form-control-sm {
            height: 24px;
            padding: 1px 4px;
        }

        .linnen-note-vb-header label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        .linnen-note-matrix {
            border-collapse: collapse;
            min-width: 1560px;
        }

        .linnen-note-matrix th,
        .linnen-note-matrix td {
            border: 1px solid #777 !important;
            padding: 1px 2px !important;
            vertical-align: middle !important;
        }

        .linnen-note-matrix .ln-pantry-title {
            width: 48px;
            background: #ff9b38;
            color: #000;
            font-weight: 700;
            text-align: center;
        }

        .linnen-note-matrix .ln-linen-title {
            background: #5b5de0;
            color: #fff;
            font-weight: 700;
            text-align: center;
            white-space: nowrap;
        }

        .linnen-note-matrix .ln-sub-title {
            background: #cdc8ff;
            color: #1c1c7a;
            font-weight: 400;
            text-align: center;
            width: 32px;
        }

        .linnen-note-matrix .ln-pantry-cell {
            background: #ff6f72;
            color: #000;
            text-align: center;
            font-weight: 700;
            width: 42px;
        }

        .linnen-note-matrix .ln-time-cell {
            color: #000;
            text-align: center;
            width: 24px;
        }

        .linnen-note-matrix .ln-time-am {
            background: #fff2a8;
        }

        .linnen-note-matrix .ln-time-pm {
            background: #ffc7d1;
        }

        .linnen-note-matrix .ln-qty-cell-be {
            background: #f7d7b6;
        }

        .linnen-note-matrix .ln-qty-cell-de,
        .linnen-note-matrix .ln-qty-cell-re {
