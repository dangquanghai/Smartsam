        .linnen-note-legend {
            color: #001ad8;
            font-size: 12px;
        }

        .linnen-note-check {
            display: inline-flex;
            align-items: center;
            height: 24px;
            line-height: 24px;
        }

        .linnen-note-check input[type="checkbox"] {
            margin: 0 4px 0 0;
        }

        .linnen-note-check label {
            margin: 0;
            line-height: 24px;
        }

        .linnen-report-modal-dialog {
            max-width: 90vw;
            width: 90vw;
            margin: 0.5rem auto;
        }

        .linnen-report-modal-dialog .modal-content {
            height: 88vh;
            max-height: 88vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: 0;
        }

        .linnen-report-body {
            flex: 1 1 auto;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        .linnen-report-toolbar {
            background: #efefef;
            border-bottom: 1px solid #b8b8b8;
            padding: 0.5rem 0.65rem 0.35rem;
            flex: 0 0 auto;
        }

        .linnen-report-toolbar .form-control-sm,
        .linnen-report-toolbar .custom-select-sm,
        .linnen-report-toolbar .input-group-text {
            height: 26px;
            padding-top: 1px;
            padding-bottom: 1px;
            border-radius: 0;
            font-size: 12px;
        }

        .linnen-report-toolbar label {
            margin-bottom: 0;
            white-space: nowrap;
            font-weight: 400;
        }

        .linnen-report-mode-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem 1rem;
            margin-bottom: 0.4rem;
        }

        .linnen-report-modes {
            display: flex;
            flex-wrap: wrap;
            gap: 0.2rem 0.9rem;
        }

        .linnen-report-mode-item {
            display: inline-flex;
            align-items: center;
            gap: 0.2rem;
            font-size: 12px;
        }

        .linnen-report-mode-item input {
            margin: 0;
        }

        .linnen-report-chart {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
        }

        .linnen-report-chart .custom-control {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
            padding-left: 1.45rem;
        }

        .linnen-report-chart .custom-control-label {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
            line-height: 26px;
        }

        .linnen-report-chart .custom-control-label::before,
        .linnen-report-chart .custom-control-label::after {
            top: 0.15rem;
        }

        .linnen-report-inline-field {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            min-height: 26px;
        }

        .linnen-report-inline-label {
            margin-bottom: 0;
            white-space: nowrap;
            font-weight: 400;
            line-height: 26px;
        }

        .linnen-report-inline-field .form-control {
            flex: 1 1 auto;
            min-width: 0;
        }

        .linnen-report-status {
            padding: 0.35rem 0.75rem 0;
            color: #4a5560;
            min-height: 22px;
            font-size: 12px;
            flex: 0 0 auto;
        }

        .linnen-report-canvas {
            background: #b8b8b8;
            padding: 1rem;
            flex: 1 1 auto;
            min-height: 0;
            overflow: auto;
        }

        .linnen-report-iframe {
            display: block;
            width: 100%;
            height: 100%;
            min-height: 0;
            border: 1px solid #8c8c8c;
            background: #fff;
        }

        .linnen-report-loading {
            display: none;
            padding: 1rem;
            text-align: center;
            color: #6c757d;
            background: #f8f9fa;
            margin-bottom: 0.5rem;
            flex: 0 0 auto;
        }

        .linnen-note-popup-body .main-header,
        .linnen-note-popup-body .main-sidebar,
        .linnen-note-popup-body .main-footer,
        .linnen-note-popup-body .content-header {
            display: none !important;
        }

        .linnen-note-popup-body .content-wrapper {
            margin-left: 0 !important;
            padding: 0 !important;
            min-height: 100vh !important;
        }

        .linnen-note-popup-body .content-wrapper > .content,
        .linnen-note-popup-body .content-wrapper > .content > .container-fluid {
            padding: 0 !important;
            margin: 0 !important;
        }

        .linnen-note-popup .container-fluid {
            padding: 0 !important;
        }

        .linnen-note-popup .card {
            margin-bottom: 0;
            border-radius: 0;
        }

        .linnen-note-popup .linnen-note-detail-footer {
            display: none;
        }
    </style>
}

<section class="content @(isPopup ? "linnen-note-popup" : string.Empty)">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2 js-auto-dismiss-alert" role="alert" data-timeout="20000">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 js-auto-dismiss-alert" asp-validation-summary="All" data-timeout="20000"></div>
        }

        <form method="post" id="linnenNoteDetailForm">
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="Header.Id" />
            <input type="hidden" asp-for="DetailsJson" id="DetailsJson" />
            <input type="hidden" asp-for="ReturnToIndex" id="ReturnToIndex" />
            <input type="hidden" asp-for="RedirectUrl" id="RedirectUrl" />
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="card card-primary card-outline">
                <div class="card-body p-2 linnen-note-vb-header">
                    <div class="d-flex align-items-center">
                        <label class="mr-1">Note No</label>
                        <input asp-for="Header.Id" class="form-control form-control-sm mr-2" style="width: 55px;" readonly />
                        <label class="mr-1">Date</label>
                        <input asp-for="Header.DateCreate" type="date" class="form-control form-control-sm mr-2" style="width: 135px;" readonly="@isView" />
                        <label class="mr-1">Description</label>
                        <input asp-for="Header.Description" class="form-control form-control-sm mr-2" style="width: 300px;" maxlength="100" readonly="@isView" />
                        <div class="linnen-note-check mr-3">
                            <input asp-for="Header.IsRent" disabled="@isView" />
                            <label asp-for="Header.IsRent">Is Rent</label>
                        </div>
                        <div class="linnen-note-check">
                            <input asp-for="Header.IsClose" disabled />
                            <label asp-for="Header.IsClose">Close</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-primary">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0 linnen-note-matrix" id="linnenNoteDetailsTable">
                            <thead>
                                <tr>
                                    <th colspan="2" rowspan="2" class="ln-pantry-title">Pantry<br />No</th>
                                    @foreach (var linen in Model.DetailColumns)
                                    {
                                        <th colspan="3" class="ln-linen-title">@linen.Title</th>
                                    }
                                </tr>
                                <tr>
                                    @foreach (var linen in Model.DetailColumns)
                                    {
                                        <th class="ln-sub-title">Be</th>
                                        <th class="ln-sub-title">De</th>
                                        <th class="ln-sub-title">Re</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pantry in Model.DetailPantries)
                                {
                                    for (var timeSection = 1; timeSection <= 2; timeSection++)
                                    {
                                        <tr>
                                            @if (timeSection == 1)
                                            {
                                                <td rowspan="2" class="ln-pantry-cell">@pantry.DisplayName</td>
                                            }
                                            <td class="ln-time-cell @(timeSection == 1 ? "ln-time-am" : "ln-time-pm")">@(timeSection == 1 ? "A" : "P")</td>
                                            @foreach (var linen in Model.DetailColumns)
                                            {
                                                var row = FindDetail(pantry.PentryId, timeSection, linen.Code);
                                                if (row == null)
                                                {
                                                    <td class="ln-qty-cell-be"></td>
                                                    <td class="ln-qty-cell-de"></td>
                                                    <td class="ln-qty-cell-re"></td>
                                                }
                                                else
                                                {
                                                    <td class="ln-qty-cell-be">
                                                        <span class="linnen-note-detail-record d-none"
                                                              data-id="@row.Id"
                                                              data-header-id="@row.HeaderId"
                                                              data-pentry="@row.Pentry"
                                                              data-pentry-name="@row.PentryName"
                                                              data-time-section="@row.TimeSection"
                                                              data-linen-code="@row.LinenCode"
                                                              data-linen-name="@row.LinenName"></span>
                                                        <input type="text" inputmode="numeric" class="form-control form-control-sm text-right ln-qty" data-detail-id="@row.Id" data-field="be" data-nav-column="@($"{linen.Code}|be")" value="@FormatQty(row.Be)" readonly="@isBeginReadonly" />
                                                    </td>
                                                    <td class="ln-qty-cell-de"><input type="text" inputmode="numeric" class="form-control form-control-sm text-right ln-qty" data-detail-id="@row.Id" data-field="de" data-nav-column="@($"{linen.Code}|de")" value="@FormatQty(row.De)" readonly="@isView" /></td>
                                                    <td class="ln-qty-cell-re"><input type="text" inputmode="numeric" class="form-control form-control-sm text-right ln-qty" data-detail-id="@row.Id" data-field="re" data-nav-column="@($"{linen.Code}|re")" value="@FormatQty(row.Re)" readonly="@isView" /></td>
                                                }
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer p-2 text-center linnen-note-detail-footer">
                    <div class="linnen-note-legend text-left mb-2">Be : Begin Quantity, De : Delivery Quantity, Re : Receive Quantity , A : AM , P : PM</div>
                    @if (Model.CanSave)
                    {
                        <button type="submit" class="btn btn-sm btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-secondary" id="btnPrintLinnenNoteDetail">
                        <i class="fas fa-print"></i> Print
                    </button>
                    <button type="button" class="btn btn-sm btn-default" id="btnCloseLinnenNoteDetail" data-index-url="@(string.IsNullOrWhiteSpace(Model.ReturnUrl) ? Url.Page("./Index") : Model.ReturnUrl)">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<div class="modal fade" id="linnenReportModal" tabindex="-1" role="dialog" aria-labelledby="linnenReportModalLabel" aria-hidden="true">
    <div class="modal-dialog linnen-report-modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linnenReportModalLabel">Linen - Report</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0 linnen-report-body">
                <div class="linnen-report-toolbar">
                    <div class="linnen-report-mode-row">
                        <div class="linnen-report-modes">
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="pantry" checked disabled />
                                <span>Pantry-Linen</span>
                            </label>
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="delivery" disabled />
                                <span>Delivery</span>
                            </label>
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="receive" disabled />
                                <span>Receive</span>
                            </label>
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="laundry-record" disabled />
                                <span>Laudry Record</span>
                            </label>
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="not-receive" disabled />
                                <span>Not Receive</span>
                            </label>
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="laundry-balance" disabled />
                                <span>Laundry.U. Balance</span>
                            </label>
                            <label class="linnen-report-mode-item">
                                <input type="radio" name="linnenNoteReportType" value="apmt-balance" disabled />
                                <span>Apmt Balance</span>
                            </label>
                        </div>
                        <div class="linnen-report-chart">
                            <div class="custom-control custom-checkbox mb-0">
                                <input type="checkbox" class="custom-control-input" id="linnenNoteReportChart" disabled />
                                <label class="custom-control-label" for="linnenNoteReportChart">Chart</label>
                            </div>
                        </div>
                    </div>

                    <div class="row linen-report-filter-row">
                        <div class="col-lg-4 col-md-6">
                            <div class="linnen-report-inline-field">
                                <label for="linnenNoteReportDescription" class="linnen-report-inline-label">Des</label>
                                <select class="form-control form-control-sm vni-font"
                                        id="linnenNoteReportDescription"
                                        disabled>
                                    <option value="@Model.Header.Id">@Model.Header.Description</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="linnen-report-inline-field">
                                <label for="linnenNoteReportLinenCode" class="linnen-report-inline-label">Linnen</label>
                                <select class="form-control form-control-sm vni-font"
                                        id="linnenNoteReportLinenCode">
                                    <option value="">All</option>
                                    @foreach (var linen in Model.DetailColumns)
                                    {
                                        <option value="@linen.Code">@linen.Code</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4">
                            <div class="linnen-report-inline-field">
                                <label class="linnen-report-inline-label">From</label>
                                <input type="date"
                                       class="form-control form-control-sm"
                                       value="@Model.Header.DateCreate.ToString("yyyy-MM-dd")"
                                       disabled />
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4">
                            <div class="linnen-report-inline-field">
                                <label class="linnen-report-inline-label">To</label>
                                <input type="date"
                                       class="form-control form-control-sm"
                                       value="@Model.Header.DateCreate.ToString("yyyy-MM-dd")"
                                       disabled />
                            </div>
                        </div>
                        <div class="col-lg-1 col-md-4">
                            <button type="button" class="btn btn-sm btn-secondary btn-block" id="btnPreviewLinnenNoteReport">Preview</button>
                        </div>
                    </div>
                </div>

                <div class="linnen-report-status" id="linnenReportMeta">Pantry-Linen | @Model.Header.Description</div>
                <div class="linnen-report-canvas">
                    <div id="linnenReportLoading" class="linnen-report-loading">Loading PDF preview...</div>
                    <iframe id="linnenReportFrame"
                            class="linnen-report-iframe"
                            title="Linen Report"></iframe>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="linnenNoteUnsavedModal" tabindex="-1" role="dialog" aria-labelledby="linnenNoteUnsavedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="linnenNoteUnsavedModalLabel">Unsaved Changes</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body py-3">
                Data has changed. Do you want to save before leaving?
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-primary btn-sm" id="btnUnsavedSave">Save</button>
                <button type="button" class="btn btn-secondary btn-sm" id="btnUnsavedDiscard">Don't Save</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="btnUnsavedCancel" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.linnenNoteDailyDetail = {
            isView: @(isView ? "true" : "false"),
            isPopup: @(isPopup ? "true" : "false"),
            indexUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(string.IsNullOrWhiteSpace(Model.ReturnUrl) ? Url.Page("./Index") : Model.ReturnUrl)),
            printPreviewUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("./LinnenNoteDailyDetail", "PrintPreview", new { id = Model.Header.Id }))),
            reportPdfUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Page("./LinnenNoteDailyDetail", "ReportPdf", new { id = Model.Header.Id, download = false })))
        };
    </script>
    <script src="~/js/Inventory/LinnenNoteDaily/LinnenNoteDailyDetail.js" asp-append-version="true"></script>
}
