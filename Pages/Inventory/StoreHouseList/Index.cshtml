@page
@model SmartSam.Pages.Inventory.StoreHouseList.IndexModel
@{
    ViewData["Title"] = "Store-House List";
    var currentPage = Model.Filter.Page <= 0 ? 1 : Model.Filter.Page;
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
    var pageItems = new List<int?>();

    for (var p = 1; p <= totalPages; p++)
    {
        if (p == 1 || p == totalPages || (p >= currentPage - 2 && p <= currentPage + 2))
        {
            pageItems.Add(p);
        }
        else if (pageItems.Count == 0 || pageItems[^1].HasValue)
        {
            pageItems.Add(null);
        }
    }

    Func<int, string> pageUrl = (page) => Url.Page("./Index", new
    {
        GroupName = Model.Filter.GroupName,
        DepartmentId = Model.Filter.DepartmentId,
        AdminGroup = Model.Filter.AdminGroup,
        PageNumber = page,
        PageSize = Model.Filter.PageSize
    }) ?? "#";
}

<section class="content vni-font">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-search"></i> Search</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="storeHouseSearchForm">
                            <input type="hidden" name="PageNumber" value="1" />
                            <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />

                            <div class="form-group mb-2">
                                <label>Group Name</label>
                                <input id="Filter_GroupName" name="GroupName" value="@Model.Filter.GroupName" class="form-control form-control-sm vni-font" />
                            </div>

                            <div class="form-group mb-2">
                                <label>Department</label>
                                <select id="Filter_DepartmentId" name="DepartmentId" class="form-control form-control-sm select2 vni-font" data-placeholder="--- All ---">
                                    @foreach (var department in Model.DepartmentList)
                                    {
                                        var selectedDepartment = string.IsNullOrWhiteSpace(department.Value)
                                            ? !Model.Filter.DepartmentId.HasValue
                                            : Model.Filter.DepartmentId?.ToString() == department.Value;
                                        <option value="@department.Value" selected="@(selectedDepartment ? "selected" : null)">@department.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label>Admin Group</label>
                                <select id="Filter_AdminGroup" name="AdminGroup" class="form-control form-control-sm">
                                    <option value="" selected="@(!Model.Filter.AdminGroup.HasValue ? "selected" : null)">--- All ---</option>
                                    <option value="0" selected="@(Model.Filter.AdminGroup == 0 ? "selected" : null)">No</option>
                                    <option value="1" selected="@(Model.Filter.AdminGroup == 1 ? "selected" : null)">Yes</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-block btn-sm border mb-2">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-10">
                <div class="card card-primary">
                    <div class="card-header shl-table-header">
                        <div class="shl-table-header-left">
                            <h3 class="card-title">Store-House Groups</h3>
                            <span class="badge badge-light ml-2">@Model.TotalRecords records</span>
                        </div>
                        <div class="shl-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div class="d-inline-block mr-2 shl-pagination-info">
                                    @if (Model.TotalRecords == 0)
                                    {
                                        <small>No records</small>
                                    }
                                    else
                                    {
                                        <small>Showing @Model.PageStart to @Model.PageEnd of @Model.TotalRecords entries</small>
                                    }
                                </div>
                                <div class="shl-page-size-form d-inline-flex mr-2">
                                    <label class="mb-0 shl-page-size-label" for="storeHousePageSize">Show</label>
                                    <select id="storeHousePageSize" class="form-control form-control-sm shl-page-size-select">
                                        @foreach (var pageSizeOption in Model.PageSizeOptions)
                                        {
                                            <option value="@pageSizeOption" selected="@(Model.Filter.PageSize == pageSizeOption ? "selected" : null)">@pageSizeOption</option>
                                        }
                                    </select>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex">
                                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link shl-pager-link" href="@(Model.HasPreviousPage ? pageUrl(currentPage - 1) : "#")">Prev</a>
                                    </li>
                                    @foreach (var pageItem in pageItems)
                                    {
                                        if (pageItem.HasValue)
                                        {
                                            <li class="page-item @(pageItem.Value == currentPage ? "active" : "")">
                                                <a class="page-link shl-pager-link" href="@pageUrl(pageItem.Value)">@pageItem.Value</a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                        }
                                    }
                                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                        <a class="page-link shl-pager-link" href="@(Model.HasNextPage ? pageUrl(currentPage + 1) : "#")">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive shl-table-wrap">
                            <table class="table table-hover table-bordered mb-0 text-nowrap shl-table" id="storeHouseTable">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 32px;"></th>
                                        <th class="shl-col-group">Group Name</th>
                                        <th class="shl-col-department">Department</th>
                                        <th style="width: 120px;" class="shl-center">Admin Group</th>
                                        <th style="width: 95px;" class="shl-center">Stores</th>
                                        <th style="width: 95px;" class="shl-center">Members</th>
                                        <th style="width: 95px;" class="shl-center">Items</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Rows.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">No data</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var row in Model.Rows)
                                        {
                                            <tr class="shl-row" data-group-id="@row.KPGroupID">
                                                <td>
                                                    <input type="radio" class="shl-selector" name="selectedStoreHouseGroup" aria-label="Select row" />
                                                </td>
                                                <td class="shl-col-group">
                                                    <span class="shl-ellipsis vni-font" title="@row.KPGroupName">@row.KPGroupName</span>
                                                </td>
                                                <td class="shl-col-department">
                                                    <span class="shl-ellipsis vni-font" title="@row.DeptName">@row.DeptName</span>
                                                </td>
                                                <td class="shl-center">
                                                    <span class="badge @(row.IsAdminGroup ? "badge-warning" : "badge-secondary")">@(row.IsAdminGroup ? "Yes" : "No")</span>
                                                </td>
                                                <td class="shl-center">@row.StoreCount</td>
                                                <td class="shl-center">@row.MemberCount</td>
                                                <td class="shl-center">@row.ItemCount</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center module-action-bar shl-action-bar">
                        <a href="@Url.Page("./Index", "ExportExcel", new {
                               GroupName = Model.Filter.GroupName,
                               DepartmentId = Model.Filter.DepartmentId,
                               AdminGroup = Model.Filter.AdminGroup
                           })"
                           class="btn btn-sm btn-action-export border mx-1 my-1">
                            <i class="fas fa-file-excel"></i> Export Excel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Inventory/StoreHouseList/index.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Inventory/StoreHouseList/index.js" asp-append-version="true"></script>
}
