                        <thead class="thead-light"><tr><th style="width:40px;" class="text-center"><input type="checkbox" id="mrCheckAll" class="align-middle" /></th><th>Item Code</th><th>Item Name</th><th style="width:90px;">Unit</th><th style="width:100px;" class="text-right">Remain</th><th style="width:100px;" class="text-right">Stock</th><th style="width:110px;" class="text-right">Issue Qty</th><th style="width:120px;" class="text-right">Price</th></tr></thead>
                        <tbody id="mrDetailRows"><tr><td colspan="8" class="text-center text-muted">Select MR</td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer py-2"><button type="button" id="btnFromMrOk" class="btn btn-sm btn-primary"><i class="fas fa-check"></i> OK</button><button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button></div>
