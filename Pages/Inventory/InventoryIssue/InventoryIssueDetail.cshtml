            $('#btnConfirmVoucherAction').on('click', function () {
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                if (mode === 'add') {
                    isSubmittingConfirmAfterSave = true;
                    $('#confirmInventoryIssueModal').modal('hide');
                    $('#InventoryIssueDetailForm').attr('action', '?handler=SaveAndConfirm');
                    $('#InventoryIssueDetailForm').trigger('submit');
                    return;
                }

                $('#confirmInventoryIssueForm').trigger('submit');
            });

            $('#confirmInventoryIssueModal').on('hidden.bs.modal', function () {
                if (isSubmittingConfirmAfterSave) {
                    return;
                }
                $('#ConfirmAfterSave').val('false');
                $('#InventoryIssueDetailForm').attr('action', '');
            });

            const openAddDetailModal = function () {
                $('#btnConfirmResetDetails').show();
                $('#addDetailPoPanel').addClass('d-none');
                $('#addDetailManualPanel').removeClass('d-none');
                renderManualAddDetailOptions();
                syncManualItemInfo();
                hideDuplicatePanel();
                $('#IssueAddDetailModal').modal('show');
            };

            $('#btnOpenAddDetail, #btnOpenAddNewAction').on('click', function () {
                openAddDetailModal();
            });


            $('#btnAddDetailConfirm').on('click', function () {
                showAddDetailModalValidation('');
                clearManualAddFieldErrors();
                const itemId = Number($('#manualAddItemId').val() || 0);
                const item = itemCatalog.find(x => Number(x.id) === itemId);
                if (!item) {
                    showAddDetailModalValidation('Please select item.');
                    return;
                }

                const docQty = parseNumber($('#manualAddDocQty').val());
                const actQty = parseNumber($('#manualAddActQty').val());
                const unitPrice = parseNumber($('#manualAddUnitPrice').val());
                const locationIdRaw = $('#manualAddLocationId').val();
                const location = locationCatalog.find(x => x.id === locationIdRaw);

                if (actQty <= 0) {
                    setManualAddFieldError('#manualAddActQty', '#manualAddActQtyError', 'Act. Qty must be greater than 0.');
                    showAddDetailModalValidation(`Item '${item.itemCode || ''}' must have Act. Qty > 0.`);
                    return;
                }
const incomingRow = {
                    itemId: Number(item.id),
                    chekingID: null,
                    chekingDTID: null,
                    mrDetailID: null,
                    itemCode: item.itemCode || '',
                    itemName: item.itemName || '',
                    unit: item.unit || '',
                    docQty: docQty,
                    actQty: actQty,
                    unitPrice: unitPrice,
                    amount: actQty * unitPrice,
                    locationId: locationIdRaw ? Number(locationIdRaw) : null,
                    locationName: location?.text || ''
                };

                if (!confirmReplaceExistingDetail(incomingRow)) {
                    return;
                }

                upsertDetailRow(incomingRow);

                renderRows();
                $('#IssueAddDetailModal').modal('hide');
                return;
            });

            $('#btnDuplicateReplace').on('click', function () {
                if (!pendingDuplicateIncomingRow) {
                    hideDuplicatePanel();
                    return;
                }

                upsertDetailRow(pendingDuplicateIncomingRow);
                renderRows();
                hideDuplicatePanel();
                $('#IssueAddDetailModal').modal('hide');
            });

            $('#btnDuplicateKeep').on('click', function () {
                hideDuplicatePanel();
            });

            $(document).on('input change', '.add-actqty, .add-docqty', function () {
                const itemId = Number($(this).data('itemid'));
                const item = itemCatalog.find(x => Number(x.id) === itemId);
                if (!item) return;
                const actQty = parseNumber($(`.add-actqty[data-itemid='${itemId}']`).val());
                const docQty = parseNumber($(`.add-docqty[data-itemid='${itemId}']`).val());
                const maxQty = getAvailableQty(item);
                if (actQty > maxQty || actQty <= 0 || docQty < actQty) {
                    $(this).addClass('is-invalid');
                } else {
                    $(`.add-actqty[data-itemid='${itemId}'], .add-docqty[data-itemid='${itemId}']`).removeClass('is-invalid');
                    showClientValidation('');
                }
            });

            $(document).on('change', '.add-detail-check', function () {
                $('#btnAddDetailConfirm').prop('disabled', $('.add-detail-check:checked').length === 0);
                syncAddDetailCheckAll();
            });

            $(document).on('change', '#manualAddItemId', function () {
                syncManualItemInfo();
            });

            $('#checkAllAddDetail').on('change', function () {
                const checked = $(this).is(':checked');
                $('.add-detail-check').prop('checked', checked);
                $('#btnAddDetailConfirm').prop('disabled', $('.add-detail-check:checked').length === 0);
                syncAddDetailCheckAll();
            });

            $(document).on('input change', '.detail-docqty, .detail-actqty, .detail-unitprice, .detail-location', function () {
                const idx = Number($(this).data('index'));
                const row = details[idx];
                if (!row) return;

                row.docQty = parseNumber($(`.detail-docqty[data-index='${idx}']`).val());
                row.actQty = parseNumber($(`.detail-actqty[data-index='${idx}']`).val());
                if (row.actQty <= 0) {
                    showClientValidation(`Item '${row.itemCode || ''}' must have Act. Qty > 0.`);
                } else {
                    showClientValidation('');
                }

                row.unitPrice = parseNumber($(`.detail-unitprice[data-index='${idx}']`).val());
                row.amount = row.actQty * row.unitPrice;

                const locationIdRaw = $(`.detail-location[data-index='${idx}']`).val();
                const location = locationCatalog.find(x => x.id === locationIdRaw);
                row.locationId = locationIdRaw ? Number(locationIdRaw) : null;
                row.locationName = location?.text || '';

                $(`.detail-amount[data-index='${idx}']`).text(formatNumber(row.amount));
                syncDetailsJson();
            });
            $(document).on('focus', '.number-format', function () {
                $(this).val(parseNumber($(this).val()));
            });

            $(document).on('blur', '.number-format', function () {
                $(this).val(formatNumber(parseNumber($(this).val())));
            });

            $(document).on('click', '.btn-delete-detail', function () {
                details.splice(Number($(this).data('index')), 1);
                renderRows();
            });

            $('#detailAttachmentUpload').on('change', function () {
                const files = Array.from(this.files || []);
                if (files.length === 0) return;
                const existingKeys = new Set(pendingAttachments.map(attachmentKey));
                files.forEach(file => {
                    const key = attachmentKey(file);
                    if (!existingKeys.has(key)) {
                        pendingAttachments.push(file);
                        existingKeys.add(key);
                    }
                });
                stagedAttachments = [...pendingAttachments];
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
                this.value = '';
            });

            $(document).on('click', '.btn-remove-pending-attachment', function () {
                const idx = Number($(this).data('index'));
                pendingAttachments.splice(idx, 1);
                stagedAttachments = [...pendingAttachments];
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
            });

            $(document).on('click', '.btn-remove-existing-attachment', function () {
                const docId = Number($(this).data('docid'));
                if (docId > 0 && !deletedAttachmentDocIds.includes(docId)) {
                    deletedAttachmentDocIds.push(docId);
                    syncDeletedAttachmentDocIds();
                    renderAttachmentStaging();
                }
            });

            $('#btnAttachmentAgree').on('click', function () {
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
            });

            $('#prqAttachmentModal').on('show.bs.modal', function () {
                renderAttachmentStaging();
            });

            $('#prqAttachmentModal').on('hidden.bs.modal', function () {
                syncAttachmentInputFromStaging();
                renderAttachmentStaging();
            });


            $('#btnOpenIssueFromIssue').on('click', function () {
                if ($(this).prop('disabled')) {
                    return;
                }
                if (Number($('#Header_FlowSubType').val() || 0) !== 6) {
                    showClientValidation('Issue From Inventory Issue is only available for Issue From Company Main Store.');
                    return;
                }

                showIssueIssueValidation('');
                loadIssueIssueList().then(function () {
                    if (selectedIssueFlowId > 0) {
                        loadIssueIssueetails(selectedIssueFlowId);
                    } else {
                        issueIssueetails = [];
                        renderIssueIssueetails();
                    }
                    $('#FromMrModal').modal('show');
                });
            });

            $('#btnSearchIssueIssue').on('click', function () {
                selectedIssueFlowId = 0;
                issueIssueetails = [];
                renderIssueIssueetails();
                loadIssueIssueList();
            });

            $(document).on('change', '.issue-Issue-select', function () {
                selectedIssueFlowId = Number($(this).val() || 0);
                $('#btnIssueFromIssueOk').prop('disabled', selectedIssueFlowId <= 0);
                showIssueIssueValidation('');
                loadIssueIssueetails(selectedIssueFlowId);
            });

            $(document).on('click', '#issueIssueRowsBody .issue-Issue-row', function (e) {
                if ($(e.target).is('.issue-Issue-select')) {
                    return;
                }

                const flowId = Number($(this).data('flow-id') || 0);
                if (!flowId) {
                    return;
                }

                $(this).find('.issue-Issue-select').prop('checked', true).trigger('change');
            });

            $('#btnIssueFromIssueOk').on('click', function () {
                if (selectedIssueFlowId <= 0) {
                    showIssueIssueValidation('Please select issue voucher.');
                    return;
                }
                if (!issueIssueetails.length) {
                    showIssueIssueValidation('Selected issue voucher has no details.');
                    return;
                }

                details = issueIssueetails.map(x => ({
                    itemId: Number(x.itemId || 0),
                    chekingID: null,
                    chekingDTID: null,
                    mrDetailID: null,
                    itemCode: x.itemCode || '',
                    itemName: x.itemName || '',
                    unit: x.unit || '',
                    docQty: Number(x.docQty || 0),
                    actQty: Number(x.actQty || 0),
                    unitPrice: Number(x.unitPrice || 0),
                    amount: Number(x.amount || 0),
                    locationId: null,
                    locationName: ''
                }));

                $('#SelectedIssueFlowId').val(selectedIssueFlowId);
                renderRows();
                $('#FromMrModal').modal('hide');
            });

            $('#btnConfirmResetDetails').on('click', function () {
                if (pendingField) {
                    clearDetails();
                    if (pendingAction === 'flow-subtype-change') {
                        applyFieldRuleByFlowSubType();
                        reloadIssueContext();
                    } else {
                        pendingOldValue = $(pendingField).val();
                    }
                    pendingField = null;
                    pendingAction = '';
                }
                $('#detailResetWarningModal').modal('hide');
            });

            $('#detailResetWarningModal').on('hidden.bs.modal', function () {
                if (pendingField) {
                    $(pendingField).val(pendingOldValue).trigger('change.select2');
                    pendingField = null;
                    pendingAction = '';
                }
                $('#btnConfirmResetDetails').show();
            });

            $('#Header_FlowSubType').on('change', function () {
                if (details.length > 0) {
                    pendingField = this;
                    pendingOldValue = $(this).data('old') || '';
                    pendingAction = 'flow-subtype-change';
                    $('#btnConfirmResetDetails').show();
                    $('#detailResetWarningModal .modal-body').text('Changing Issue Type will reset PO No and current detail list. Do you want to continue?');
                    $('#detailResetWarningModal').modal('show');
                    return;
                }
                $(this).data('old', $(this).val());
                applyFieldRuleByFlowSubType();
                reloadIssueContext();
            });

            $('#Header_FlowSubType').on('focus', function () {
                $(this).data('old', $(this).val());
            });

            initSelect2();
            applyFieldRuleByFlowSubType();
            syncConfirmButtonState();
            let selectedMrNo = 0;
            let mrDetails = [];

            function setMrAlert(message) {
                if (message) {
                    $('#mrAlert').removeClass('d-none').text(message);
                } else {
                    $('#mrAlert').addClass('d-none').text('');
                }
            }

            function showMrMessage(message) {
                if ($('#FromMrModal').hasClass('show')) {
                    setMrAlert(message);
                    return;
                }

                $('#fromMrWarningText').text(message || '');
                $('#fromMrWarningModal').modal('show');
            }

            function renderMrRows(items) {
                const $b = $('#mrRows'); $b.empty();
                if (!items.length) { $b.html('<tr><td colspan="6" class="text-center text-muted">No data</td></tr>'); return; }
                items.forEach(x => {
                    const rowClass = x.allItemsOutOfStock ? 'mr-row mr-row-out-of-stock' : 'mr-row';
                    $b.append(`<tr class="${rowClass}" data-request-no="${x.requestNo}" style="cursor:pointer;"><td class="text-center"><input type="radio" name="mrSelect" class="mr-select" value="${x.requestNo}" /></td><td>${x.requestNo}</td><td>${x.dateCreate || ''}</td><td>${x.according || ''}</td><td>${x.deptName || ''}</td><td>${x.materialStatusName || ''}</td></tr>`);
                });
            }

            function renderMrDetailRows(items) {
                const $b = $('#mrDetailRows');
                $b.empty();
                $('#mrCheckAll').prop('checked', false);
                if (!items.length) {
                    $b.html('<tr><td colspan="8" class="text-center text-muted">No data</td></tr>');
                    setMrAlert('');
                    return;
                }
                items.forEach(x => {
                    const hasStockQty = x.stockQty !== null && x.stockQty !== undefined;
                    const defaultIssueQty = hasStockQty ? Math.min(Number(x.remainQty || 0), Number(x.stockQty || 0)) : Number(x.remainQty || 0);
                    const outOfStock = hasStockQty && Number(x.stockQty || 0) <= 0;
                    const rowClass = outOfStock ? 'mr-item-out-of-stock' : '';
                    const disabledAttr = outOfStock ? 'disabled' : '';
                    $b.append(`<tr class="${rowClass}"><td class="text-center"><input type="checkbox" class="mr-detail-check" data-id="${x.id}" ${disabledAttr} /></td><td>${x.itemCode || ''}</td><td class="tcvn3-font">${toTcvn3WebText(x.itemName || '')}</td><td>${x.unit || ''}</td><td class="text-right">${Number(x.remainQty || 0).toLocaleString()}</td><td class="text-right">${hasStockQty ? Number(x.stockQty || 0).toLocaleString() : ''}</td><td><input type="text" class="form-control form-control-sm text-right mr-issue-qty" data-id="${x.id}" value="${formatNumber(defaultIssueQty)}" disabled /></td><td><input type="text" class="form-control form-control-sm text-right mr-price" data-id="${x.id}" value="0" disabled /></td></tr>`);
                });
                const missing = items.filter(x => x.missingItemName);
                if (missing.length) {
                    setMrAlert(`Missing Item Name master data for ${missing.length} item(s). Please update item master.`);
                } else {
                    setMrAlert('');
                }
            }

            function loadMrDepartments() {
                return fetch(`?handler=MrDepartments`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : null)
                    .then(items => {
                        if (!Array.isArray(items) || items.length === 0) {
                            return;
                        }

                        const $dept = $('#mrDept');
                        const current = $dept.val() || '';
                        $dept.empty();
                        $dept.append('<option value="">All</option>');
                        items.forEach(x => {
                            $dept.append(`<option value="${x.value || ''}">${x.text || ''}</option>`);
                        });
                        if (current && items.some(x => String(x.value || '') === String(current))) {
                            $dept.val(current);
                        }
                        if ($dept.data('select2')) {
                            $dept.trigger('change.select2');
                        }
                    })
                    .catch(() => { });
            }

            function loadMrList() {
                const requestNo = $('#mrRequestNo').val() || '';
                const itemCode = $('#mrItemCode').val() || '';
                const according = $('#mrAccording').val() || '';
                const deptId = $('#mrDept').val() || '';
                const fromDate = $('#mrFromDate').val() || '';
                const toDate = $('#mrToDate').val() || '';
                const fromStore = $('#Header_FromStore').val() || '';
                return fetch(`?handler=MrList&requestNo=${encodeURIComponent(requestNo)}&itemCode=${encodeURIComponent(itemCode)}&according=${encodeURIComponent(according)}&deptId=${encodeURIComponent(deptId)}&fromDate=${encodeURIComponent(fromDate)}&toDate=${encodeURIComponent(toDate)}&fromStore=${encodeURIComponent(fromStore)}`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : []).then(renderMrRows);
            }

            function loadMrDetails(requestNo) {
                const fromStore = $('#Header_FromStore').val() || '';
                return fetch(`?handler=MrDetails&requestNo=${encodeURIComponent(requestNo)}&fromStore=${encodeURIComponent(fromStore)}`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : []).then(list => {
                        mrDetails = Array.isArray(list) ? list : [];
                        renderMrDetailRows(mrDetails);
                    });
            }

            $('#btnOpenFromMr, #btnOpenFromMrAction').on('click', function () {
                if (hasAdjustedApartmentItems) return;
                const fromStore = Number($('#Header_FromStore').val() || 0);
                if (fromStore <= 0) {
                    showMrMessage('Please select Issue House before choosing Material Request.');
                    return;
                }
                const today = new Date();
                const from = new Date();
                from.setDate(today.getDate() - 60);
                $('#mrFromDate').val(from.toISOString().slice(0, 10));
                $('#mrToDate').val(today.toISOString().slice(0, 10));
                selectedMrNo = 0;
                mrDetails = [];
                setMrAlert('');
                renderMrDetailRows([]);
                loadMrDepartments().then(() => loadMrList());
                $('#FromMrModal').modal('show');
            });

            $('#btnSearchMr').on('click', function () { loadMrList(); });

            $('#FromMrModal').on('hidden.bs.modal', function () {
                selectedMrNo = 0;
                mrDetails = [];
                $('#mrRows .mr-row').removeClass('table-primary');
                $('input[name="mrSelect"]').prop('checked', false);
                $('#mrCheckAll').prop('checked', false);
                setMrAlert('');
                renderMrDetailRows([]);
            });

            $(document).on('click', '.mr-row', function (e) {
                if (!$(e.target).is('.mr-select')) {
                    $(this).find('.mr-select').prop('checked', true);
                }
                selectedMrNo = Number($(this).data('request-no') || 0);
                $('#mrRows .mr-row').removeClass('table-primary');
                $(this).addClass('table-primary');
                $('#mrCheckAll').prop('checked', false);
                setMrAlert('');
                loadMrDetails(selectedMrNo);
            });

            $('#mrCheckAll').on('change', function () {
                const checked = $(this).is(':checked');
                $('.mr-detail-check:not(:disabled)').prop('checked', checked);
                $('.mr-detail-check').each(function () {
                    const id = Number($(this).data('id') || 0);
                    const isChecked = $(this).is(':checked');
                    $(`.mr-issue-qty[data-id='${id}'], .mr-price[data-id='${id}']`).prop('disabled', !isChecked);
                });
                if (checked) {
                    mrDetails.forEach(item => {
                        const hasStockQty = item.stockQty !== null && item.stockQty !== undefined;
                        const defaultIssueQty = hasStockQty ? Math.min(Number(item.remainQty || 0), Number(item.stockQty || 0)) : Number(item.remainQty || 0);
                        $(`.mr-issue-qty[data-id='${item.id}']`).val(formatNumber(defaultIssueQty));
                    });
                } else {
                    $('.mr-issue-qty, .mr-price').val('0');
                }
            });

            $('#Header_RecDept').on('change', function () {
                reloadReceiverOptions('');
            });

            $(document).on('change', '.mr-detail-check', function () {
                const total = $('.mr-detail-check').length;
                const checked = $('.mr-detail-check:checked').length;
                $('#mrCheckAll').prop('checked', total > 0 && total === checked);
                const id = Number($(this).data('id') || 0);
                const isChecked = $(this).is(':checked');
                const qtySelector = ".mr-issue-qty[data-id='" + id + "']";
                const priceSelector = ".mr-price[data-id='" + id + "']";
                $(qtySelector).prop('disabled', !isChecked);
                $(priceSelector).prop('disabled', !isChecked);
                if (isChecked) {
                    const item = mrDetails.find(x => Number(x.id) === id);
                    const hasStockQty = item && item.stockQty !== null && item.stockQty !== undefined;
                    const defaultIssueQty = hasStockQty ? Math.min(Number(item?.remainQty || 0), Number(item?.stockQty || 0)) : Number(item?.remainQty || 0);
                    $(qtySelector).val(formatNumber(defaultIssueQty));
                } else {
                    $(qtySelector).val('0');
                    $(priceSelector).val('0');
                }
            });

            $(document).on('change', '.mr-issue-qty', function () {
                const id = Number($(this).data('id') || 0);
                const item = mrDetails.find(x => Number(x.id) === id);
                if (!item) return;

                const qty = parseNumber($(this).val());
                const hasStockQty = item.stockQty !== null && item.stockQty !== undefined;
                const stockQty = Number(item.stockQty || 0);
                if (hasStockQty && qty > stockQty) {
                    showMrMessage(`Item stock quantity is ${Number(stockQty || 0).toLocaleString()}.`);
                    $(this).val(formatNumber(stockQty));
                    return;
                }

                $(this).val(formatNumber(qty));
            });

            $('#btnFromMrOk').on('click', function () {
                const selected = [];
                const invalidItems = [];
                const checkedRows = $('.mr-detail-check:checked');

                checkedRows.each(function () {
                    const id = Number($(this).data('id') || 0);
                    const item = mrDetails.find(x => Number(x.id) === id);
                    if (!item) return;

                    const qty = parseNumber($(`.mr-issue-qty[data-id='${id}']`).val());
                    const price = parseNumber($(`.mr-price[data-id='${id}']`).val());

                    if (qty <= 0) {
                        invalidItems.push(`${item.itemCode || id}: Issue Qty must be greater than 0`);
                        return;
                    }
                    if (qty > Number(item.remainQty || 0)) {
                        invalidItems.push(`${item.itemCode || id}: Issue Qty (${qty}) cannot exceed Remain (${Number(item.remainQty || 0)})`);
                        return;
                    }
                    if (item.stockQty !== null && item.stockQty !== undefined && qty > Number(item.stockQty || 0)) {
                        invalidItems.push(`${item.itemCode || id}: Item stock quantity is ${Number(item.stockQty || 0).toLocaleString()}`);
                        return;
                    }

                    selected.push({
                        itemId: Number(item.itemId || 0),
                        requestNo: Number(item.requestNo || selectedMrNo || 0),
                        mrDetailID: id,
                        itemCode: item.itemCode || '',
                        itemName: item.itemName || '',
                        unit: item.unit || '',
                        docQty: Number(item.remainQty || 0),
                        actQty: qty,
                        unitPrice: price,
                        amount: qty * price,
                        locationId: null,
                        locationName: ''
                    });
                });

                if (!checkedRows.length) {
                    setMrAlert('Please select at least one MR item.');
                    return;
                }
                if (invalidItems.length) {
                    setMrAlert(invalidItems.join(' | '));
                    return;
                }
                if (!selected.length) {
                    setMrAlert('Please input valid Issue Qty.');
                    return;
                }

                setMrAlert('');
                selected.forEach(x => upsertDetailRow(x));
                renderRows();
                $('#FromMrModal').modal('hide');
            });

            syncAttachmentInputFromStaging();
            syncDeletedAttachmentDocIds();
            renderRows();
        })();
    </script>
}

























