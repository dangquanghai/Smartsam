@page
@using System.Text.Json
@model SmartSam.Pages.Inventory.InventoryIssue.InventoryIssueDetailModel
@{
    ViewData["Title"] = "Item Issue Detail";
    var initialDetailsJson = JsonSerializer.Serialize(Model.Details, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    var alertClass = (Model.MessageType ?? "info").ToLowerInvariant() switch
    {
        "success" => "alert-success",
        "warning" => "alert-warning",
        "error" => "alert-danger",
        _ => "alert-info"
    };
}

<section class="content vni-font">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header py-2">
                <h3 class="card-title prq-detail-title">Item Issue Detail</h3>
            </div>

            <form method="post" enctype="multipart/form-data" id="InventoryIssueDetailForm" class="mb-0">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="mode" value="@Model.Mode" />
                <input asp-for="DetailsJson" type="hidden" id="DetailsJson" />
                <input asp-for="SelectedIssueFlowId" type="hidden" id="SelectedIssueFlowId" />
                <input asp-for="DeletedAttachmentDocIdsJson" type="hidden" id="DeletedAttachmentDocIdsJson" />
                <input asp-for="ConfirmAfterSave" type="hidden" id="ConfirmAfterSave" value="false" />

                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.Message))
                    {
                        <div class="alert @alertClass mb-2 py-2">@Model.Message</div>
                    }
                    <div id="clientValidationAlert" class="alert alert-danger mb-2 py-2 d-none"></div>

                    <div class="inventory-issue-header-section mb-3">
                        <div class="row inventory-issue-header-grid-row">
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Issue No.<span class="required-mark">*</span></label><div class="inventory-issue-header-control-wrap"><input asp-for="Header.FlowNo" class="form-control form-control-sm vni-font" readonly="@(Model.IsAddMode && Model.CanEditVoucherBusiness ? null : "readonly")" /><span asp-validation-for="Header.FlowNo" class="text-danger small"></span></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Issue Date</label><div class="inventory-issue-header-control-wrap"><input id="Header_FlowDateDisplay" type="text" class="form-control form-control-sm @(Model.CanEditVoucherBusiness ? "app-date-picker" : string.Empty)" value="@Model.Header.FlowDate.ToString("dd/MM/yyyy")" data-hidden-target="#Header_FlowDate" autocomplete="off" readonly />
                                <input id="Header_FlowDate" name="Header.FlowDate" type="hidden" value="@Model.Header.FlowDate.ToString("yyyy-MM-dd")" /></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Issue Type<span class="required-mark">*</span></label><div class="inventory-issue-header-control-wrap"><small id="issueType2Hint" class="d-none inventory-issue-type-hint">Save first to open Adjust Item in Apmt, then Confirm in edit mode.</small><select asp-for="Header.FlowSubType" asp-items="Model.IssueTypes" class="form-control form-control-sm select2" disabled="@((Model.CanEditVoucherBusiness && !Model.HasAdjustedApartmentItems) ? null : "disabled")"></select>@if (Model.HasAdjustedApartmentItems){<input type="hidden" name="Header.FlowSubType" value="@Model.Header.FlowSubType" />}<span asp-validation-for="Header.FlowSubType" class="text-danger small"></span></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Issue House<span class="required-mark">*</span></label><div class="inventory-issue-header-control-wrap"><select asp-for="Header.FromStore" asp-items="Model.Stores" class="form-control form-control-sm select2" disabled="@((Model.CanEditVoucherBusiness && !Model.IsIssueHouseLocked) ? null : "disabled")"></select>@if (Model.IsIssueHouseLocked)
                                        {
                                            <input type="hidden" name="Header.FromStore" value="@Model.Header.FromStore" />
                                        }<span asp-validation-for="Header.FromStore" class="text-danger small"></span></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">According To</label><div class="inventory-issue-header-control-wrap"><input asp-for="Header.According" class="form-control form-control-sm vni-font" readonly="@(Model.CanEditVoucherBusiness ? null : "readonly")" /></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Received Department</label><div class="inventory-issue-header-control-wrap"><select asp-for="Header.RecDept" asp-items="Model.Departments" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select><span asp-validation-for="Header.RecDept" class="text-danger small"></span></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Receiver By</label><div class="inventory-issue-header-control-wrap"><select asp-for="Header.ReceivedBy" asp-items="Model.ReceiverBys" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select><span asp-validation-for="Header.ReceivedBy" class="text-danger small"></span></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Location</label><div class="inventory-issue-header-control-wrap"><select asp-for="Header.AssetLocation" asp-items="Model.Locations" class="form-control form-control-sm select2" disabled="@(Model.CanEditVoucherBusiness ? null : "disabled")"></select></div></div></div>
                            <div class="col-xl-4 col-md-6 col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Status</label><div class="inventory-issue-header-control-wrap inventory-issue-status-text-wrap"><input id="statusTextStrong" class="form-control form-control-sm font-weight-bold" value="@Model.Header.StatusName" disabled /></div></div></div>
                        </div>
                        <div class="row inventory-issue-header-grid-row">
                            <div class="col-12"><div class="inventory-issue-header-field prq-detail-form-col"><label class="prq-detail-label inventory-issue-header-label">Reason</label><div class="inventory-issue-header-control-wrap"><input asp-for="Header.Reason" class="form-control form-control-sm vni-font" readonly="@(Model.CanEditVoucherBusiness ? null : "readonly")" /></div></div></div>
                        </div>
                        <input type="hidden" asp-for="Header.StatusID" />
                        <input type="hidden" asp-for="Header.StatusName" />
                    </div>

                    <div class="row prq-detail-form-row mb-3 align-items-end">
                        <div class="col-12 prq-detail-form-col d-flex justify-content-start align-items-center flex-wrap">
                            @if (Model.CanEditVoucherBusiness)
                            {
                                <button type="button" id="btnOpenAddNewAction" class="btn btn-sm btn-action-close border mr-2 mb-1" disabled="@(Model.HasAdjustedApartmentItems ? "disabled" : null)"><i class="fas fa-plus"></i> Add new</button>
                                <button type="button" id="btnOpenFromMrAction" class="btn btn-sm btn-info border mr-2 mb-1" disabled="@(Model.HasAdjustedApartmentItems ? "disabled" : null)"><i class="fas fa-list"></i> From MR</button>
                                <button type="button" id="btnAdjustItemInApmt" class="btn btn-sm btn-warning border mr-2 mb-1" disabled="@((Model.Id.HasValue && (Model.IsEditMode || Model.IsApprovedMode) && Model.Header.FlowSubType == 2 && !Model.HasAdjustedApartmentItems) ? null : "disabled")"><i class="fas fa-building"></i> Adjust Item in Apmt</button>
                                @* <button type="button" id="btnOpenFromMr" class="btn btn-sm btn-info border ml-2"><i class="fas fa-list"></i> From MR</button> *@
                            }
                            @if (Model.PagePerm.HasPermission(2) || Model.CanEditVoucherBusiness)
                            {
                                <button type="button" id="btnOpenAttachmentModal" class="btn btn-sm btn-action-close border mr-2 mb-1" data-toggle="modal" data-target="#prqAttachmentModal"><i class="fas fa-folder-open"></i> Liquidation File(<span id="attachmentCountText">@Model.AttachmentList.Count</span>)</button>
                            }
                        </div>
                    </div>

                    <div class="row prq-detail-form-row mb-0">
                        <div class="col-12 prq-detail-form-col">
                            <div class="table-responsive prq-table-wrap border rounded-sm inventory-Issue-detail-scroll inventory-Issue-detail-scroll-x">
                                <table class="table table-hover table-bordered mb-0 text-nowrap prq-table inventory-Issue-main-table">
                                    <thead class="thead-light">
                                        <tr>
                                            <th style="width:70px;" class="text-center">Action</th>
                                            <th style="width:220px;">Item Code</th>
                                            <th style="min-width:360px;">Item Name</th>
                                            <th style="width:90px;">Unit</th>
                                            <th class="text-right" style="width:100px;">Doc. Qty</th>
                                            <th class="text-right" style="width:100px;">Act. Qty</th>
                                            <th class="text-right" style="width:110px;">Price</th>
                                            <th class="text-right" style="width:120px; min-width:120px; max-width:120px;">Amount</th>
                                            <th style="width:260px;">Location</th>
                                        </tr>
                                    </thead>
                                    <tbody id="detailRowsBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer p-2 text-left module-action-bar prq-action-bar">
                    @if (Model.CanEditVoucherBusiness)
                    {
                        <button type="submit" class="btn btn-sm btn-action-save btn-success border mx-1 my-1"><i class="fas fa-save"></i> Save</button>
                    }
                    @{ var userHasConfirmAccess = Model.HasIssueApprovalAccess(); }
                    @if ((Model.IsAddMode && Model.CanEditVoucherBusiness) || (!Model.IsAddMode && Model.CanConfirmVoucherBusiness))
                    {
                        var disableConfirmForApartmentAdd = Model.IsAddMode && Model.Header.FlowSubType == 2;
                        var disableConfirmForNoAccess = Model.IsAddMode && !userHasConfirmAccess;
                        var confirmButtonText = Model.IsApprovedMode ? "Sign" : "Confirm";
                        <button type="button" id="btnOpenConfirmVoucher" class="btn btn-sm btn-success border mx-1 my-1" data-toggle="modal" data-target="#confirmInventoryIssueModal" data-has-confirm-access="@(userHasConfirmAccess ? "true" : "false")" disabled="@((disableConfirmForApartmentAdd || disableConfirmForNoAccess) ? "disabled" : null)"><i class="fas fa-check"></i> @confirmButtonText</button>
                    }
                    @if (Model.Id.HasValue)
                    {
                        <button type="button" id="btnPrintInventoryIssueDetail" class="btn btn-sm btn-info border mx-1 my-1"><i class="fas fa-print"></i> Print</button>
                    }
                    <a class="btn btn-sm btn-action-close border mx-1 my-1" asp-page="./Index"><i class="fas fa-arrow-left"></i> Back to List</a>
                </div>
            </form>

            @if (Model.Id.HasValue)
            {
                <form method="post" asp-page-handler="AdjustItemInApartment" id="adjustInventoryIssueForm" class="d-none">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="mode" value="@Model.Mode" />
                    <input type="hidden" name="ApplyAllApartment" id="ApplyAllApartmentInput" value="false" />
                </form>
            }
            @if (Model.Id.HasValue && Model.HasIssueApprovalAccess())
            {
                <form method="post" asp-page-handler="@(Model.IsApprovedMode ? "Sign" : "Confirm")" id="confirmInventoryIssueForm" class="d-none">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="mode" value="@Model.Mode" />
                </form>
            }
        </div>
    </div>
</section>
<div class="modal fade vni-font" id="inventoryIssueDetailReportPreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog inventory-issue-report-preview-modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header py-2"><h5 class="modal-title">Print Preview</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body p-0"><iframe id="inventoryIssueDetailPrintFrame" class="inventory-issue-report-preview-frame" title="Inventory Issue Detail Report Preview"></iframe></div>
            <div class="modal-footer py-2 justify-content-end"><button type="button" id="btnPrintInventoryIssueDetailFrame" class="btn btn-sm btn-info border"><i class="fas fa-print"></i> Print</button><button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button></div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="IssueAddDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-xl-down modal-xl" style="max-width: 96vw;" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Add Detail</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body pb-2">
                <div id="addDetailModalValidationAlert" class="alert alert-danger mb-2 py-2 d-none"></div>
                <div id="addDetailDuplicatePanel" class="alert alert-info mb-2 py-2 d-none" style="background-color:#f3f8ff;border-color:#d7e8ff;color:#2f4f6f;">
                    <div class="font-weight-bold mb-1">Item already exists in current voucher.</div>
                    <div id="addDetailDuplicateMessage" class="small mb-2"></div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-2">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Item Code</th>
                                    <th class="text-right">Qty</th>
                                    <th class="text-right">Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Current</strong></td>
                                    <td id="duplicateCurrentItemCode"></td>
                                    <td id="duplicateCurrentQty" class="text-right"></td>
                                    <td id="duplicateCurrentPrice" class="text-right"></td>
                                </tr>
                                <tr>
                                    <td><strong>New</strong></td>
                                    <td id="duplicateNewItemCode"></td>
                                    <td id="duplicateNewQty" class="text-right"></td>
                                    <td id="duplicateNewPrice" class="text-right"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-right">
                        <button type="button" id="btnDuplicateReplace" class="btn btn-sm btn-info mr-2"><i class="fas fa-sync"></i> Replace</button>
                        <button type="button" id="btnDuplicateKeep" class="btn btn-sm btn-action-close border">Keep Current</button>
                    </div>
                </div>
                <div id="addDetailManualPanel" class="d-none">
                    <div class="row inventory-issue-header-grid-row inventory-issue-add-detail-form-row">
                        <div class="col-xl-4 col-md-6 col-12">
                            <div class="inventory-issue-header-field prq-detail-form-col">
                                <label class="prq-detail-label inventory-issue-header-label">Item<span class="required-mark">*</span></label>
                                <div class="inventory-issue-header-control-wrap"><select id="manualAddItemId" class="form-control form-control-sm select2"></select></div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 col-12">
                            <div class="inventory-issue-header-field prq-detail-form-col">
                                <label class="prq-detail-label inventory-issue-header-label">Unit</label>
                                <div class="inventory-issue-header-control-wrap"><input type="text" id="manualAddUnit" class="form-control form-control-sm" readonly /></div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 col-12">
                            <div class="inventory-issue-header-field prq-detail-form-col">
                                <label class="prq-detail-label inventory-issue-header-label">Location</label>
                                <div class="inventory-issue-header-control-wrap"><select id="manualAddLocationId" class="form-control form-control-sm select2"></select></div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 col-12">
                            <div class="inventory-issue-header-field prq-detail-form-col">
                                <label class="prq-detail-label inventory-issue-header-label">Act. Qty<span class="required-mark">*</span></label>
                                <div class="inventory-issue-header-control-wrap"><input type="text" id="manualAddActQty" class="form-control form-control-sm text-right number-format" value="0" /><small id="manualAddActQtyError" class="text-danger d-none"></small></div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 col-12">
                            <div class="inventory-issue-header-field prq-detail-form-col">
                                <label class="prq-detail-label inventory-issue-header-label">Doc. Qty</label>
                                <div class="inventory-issue-header-control-wrap"><input type="text" id="manualAddDocQty" class="form-control form-control-sm text-right number-format" value="0" /><small id="manualAddDocQtyError" class="text-danger d-none"></small></div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 col-12">
                            <div class="inventory-issue-header-field prq-detail-form-col">
                                <label class="prq-detail-label inventory-issue-header-label">Price</label>
                                <div class="inventory-issue-header-control-wrap"><input type="text" id="manualAddUnitPrice" class="form-control form-control-sm text-right number-format" value="0" /><small id="manualAddUnitPriceError" class="text-danger d-none"></small></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="addDetailPoPanel" class="table-responsive inventory-received-add-detail-scroll">
                    <table class="table table-bordered table-hover table-sm mb-0">
                        <thead>
                            <tr>
                                <th style="width:45px;" class="text-center"><input type="checkbox" id="checkAllAddDetail" /></th>
                                <th style="width:220px;">Item Code</th>
                                <th style="min-width:360px;">Item Name</th>
                                <th style="width:90px;">Unit</th>
                                <th style="width:130px;" class="text-right">Doc. Qty</th>
                                <th style="width:130px;" class="text-right">Act. Qty</th>
                                <th style="width:110px;" class="text-right">Price</th>
                                <th style="width:160px;">Location</th>
                            </tr>
                        </thead>
                        <tbody id="addDetailRowsBody">
                            <tr><td colspan="8" class="text-center text-muted py-3">No data</td></tr>
                        </tbody>
                        </table>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" id="btnAddDetailConfirm" class="btn btn-sm btn-primary" disabled><i class="fas fa-save"></i> Add</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade vni-font" id="confirmInventoryIssueModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog @(Model.IsApprovedMode ? "inventory-issue-sign-preview-modal-dialog" : "modal-dialog-centered")" role="document">
        <div class="modal-content @(Model.IsApprovedMode ? "" : "border-primary")">
            <div class="modal-header @(Model.IsApprovedMode ? "py-2" : "bg-primary py-2")">
                <h5 class="modal-title @(Model.IsApprovedMode ? "" : "text-white")">@(Model.IsApprovedMode ? "Sign Voucher" : "Confirm Voucher")</h5>
                <button type="button" class="close @(Model.IsApprovedMode ? "" : "text-white")" data-dismiss="modal"><span>&times;</span></button>
            </div>
            @if (Model.IsApprovedMode && Model.Id.HasValue)
            {
                <div class="modal-body p-0">
                    <iframe id="issueSignReportPreviewFrame" class="inventory-issue-report-preview-frame" title="Inventory Issue Sign Preview"></iframe>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" id="btnConfirmVoucherAction" class="btn btn-sm btn-primary border mr-2"><i class="fas fa-check"></i> Sign</button>
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal"><i class="fas fa-times"></i> Close</button>
                </div>
            }
            else
            {
                <div class="modal-body">
                    Are you sure you want to confirm this Inventory Issue voucher?
                </div>
                <div class="modal-footer py-2 justify-content-end">
                    <button type="button" id="btnConfirmVoucherAction" class="btn btn-sm btn-primary"><i class="fas fa-check"></i> Confirm</button>
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button>
                </div>
            }
        </div>
    </div>
</div>



<div class="modal fade vni-font" id="adjustItemInApmtModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning py-2">
                <h5 class="modal-title text-dark">Adjust Item In Apartment</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                Do you want to create adjust item data for apartment?
                <div class="text-danger mt-2">After this action, item lines can no longer be added, removed or edited for this voucher.</div>
            </div>
            <div class="modal-footer py-2 justify-content-end">
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Close</button>
                <button type="button" id="btnConfirmAdjustItemInApmt" class="btn btn-sm btn-warning"><i class="fas fa-building"></i> Confirm</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade vni-font" id="detailResetWarningModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning py-2">
                <h5 class="modal-title text-dark">Warning</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">Changing this header field will reset the current detail list. Do you want to continue?</div>
            <div class="modal-footer py-2">
                <button type="button" id="btnConfirmResetDetails" class="btn btn-sm btn-warning">Continue</button>
                <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="FromMrModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 96vw; width: 96vw;" role="document">
        <div class="modal-content">
            <div class="modal-header py-2"><h5 class="modal-title">Select Material Request</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
            <div class="modal-body">
                <div class="inventory-issue-mr-filter-grid mb-3">
                    <div class="inventory-issue-mr-filter-item"><label>Request No.</label><input id="mrRequestNo" class="form-control form-control-sm" /></div>
                    <div class="inventory-issue-mr-filter-item"><label>Item Code</label><input id="mrItemCode" class="form-control form-control-sm" /></div>
                    <div class="inventory-issue-mr-filter-item"><label>According To</label><input id="mrAccording" class="form-control form-control-sm" /></div>
                    <div class="inventory-issue-mr-filter-item"><label>Dept</label><select id="mrDept" class="form-control form-control-sm select2"><option value="">All</option>@foreach (var dept in Model.MrDepartments.Where(x => !string.IsNullOrWhiteSpace(x.Value))) {<option value="@dept.Value">@dept.Text</option>}</select></div>
                    <div class="inventory-issue-mr-filter-item"><label>From</label><input id="mrFromDate" type="date" class="form-control form-control-sm" /></div>
                    <div class="inventory-issue-mr-filter-item inventory-issue-mr-filter-item-search"><label>To</label><div class="inventory-issue-mr-search-wrap"><input id="mrToDate" type="date" class="form-control form-control-sm" /><button id="btnSearchMr" type="button" class="btn btn-sm btn-primary ml-2 flex-shrink-0"><i class="fas fa-search"></i> Search</button></div></div>
                </div>
                <div class="border-top pt-3 pb-2 mt-2 mb-2 font-weight-bold text-left">Material Request</div>
                <div class="table-responsive" style="max-height:220px;overflow:auto;">
                    <table class="table table-sm table-bordered table-hover mb-2 text-nowrap align-middle inventory-issue-mr-scroll-table">
                        <thead class="thead-light"><tr><th style="width:40px;" class="text-center"></th><th style="width:120px;">Request No.</th><th style="width:120px;">Date</th><th>According To</th><th style="width:180px;">Dept</th><th style="width:160px;">Status</th></tr></thead>
