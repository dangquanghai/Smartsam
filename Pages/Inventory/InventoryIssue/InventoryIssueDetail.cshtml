@section Scripts {
    <script src="~/adminlte/plugins/jquery-ui/jquery-ui.min.js" asp-append-version="true"></script>
    <script src="~/js/common/app-datepicker.js" asp-append-version="true"></script>
    <script>
        (function () {
            if (window.AppDatePicker) {
                window.AppDatePicker.init(document);
            }
            const detailPrintFrame = document.getElementById('inventoryIssueDetailPrintFrame');
            const detailIssueId = @(Model.Id.HasValue ? Model.Id.Value.ToString() : "null");
            const detailPrintButton = document.getElementById('btnPrintInventoryIssueDetail');
            if (detailPrintButton) {
                detailPrintButton.addEventListener('click', function () {
                    if (!detailPrintFrame || !detailIssueId) return;
                    const reportUrl = '?id=' + encodeURIComponent(detailIssueId) + '&handler=Report&inline=true';
                    detailPrintFrame.src = reportUrl;
                    $('#inventoryIssueDetailReportPreviewModal').modal('show');
                });
            }
            $("#btnPrintInventoryIssueDetailFrame").on('click', function () {
                try {
                    if (detailPrintFrame && detailPrintFrame.contentWindow) {
                        detailPrintFrame.contentWindow.focus();
                        detailPrintFrame.contentWindow.print();
                    }
                } catch (e) { }
            });

            const TCVN3_WEB_LOWER_U = '\uE001';
            const TCVN3_WEB_UPPER_U = '\uE002';

            function toTcvn3WebText(value) {
                return String(value || '')
                    .replace(/\u00AD/g, TCVN3_WEB_LOWER_U)
                    .replace(/\u01B0/g, TCVN3_WEB_LOWER_U)
                    .replace(/\u00A6/g, TCVN3_WEB_UPPER_U)
                    .replace(/\u01AF/g, TCVN3_WEB_UPPER_U);
            }

            const itemCatalog = @Html.Raw(JsonSerializer.Serialize(Model.ItemCatalog.Select(x => new {
                id = x.ItemId,
                itemCode = x.ItemCode,
                itemName = x.ItemName,
                unit = x.Unit,
                price = x.Price,
                remainQty = x.RemainingQty,
                checkingId = x.ChekingID,
                checkingDtId = x.ChekingDTID,
                mrDetailId = x.MRDetailID,
                itemId = x.ItemId
            })));
            const locationCatalog = @Html.Raw(JsonSerializer.Serialize(Model.Locations.Where(x => !string.IsNullOrWhiteSpace(x.Value)).Select(x => new { id = x.Value, text = x.Text })));
            const existingAttachments = @Html.Raw(JsonSerializer.Serialize(Model.AttachmentList.Select(x => new {
                docId = x.DocId,
                filePath = x.FilePath,
                uploadDate = x.UploadDate?.ToString("dd/MM/yyyy HH:mm") ?? "",
                employeeCode = x.EmployeeCode,
                downloadUrl = Url.Page("./InventoryIssueDetail", "DownloadAttachment", new { id = Model.Id, docId = x.DocId }),
                deleteUrl = Url.Page("./InventoryIssueDetail", "DeleteAttachment", new { id = Model.Id, docId = x.DocId })
            })));
            const currentEmployeeCode = '@Model.CurrentEmployeeCode';
            const currentUserName = '@(User?.Identity?.Name ?? string.Empty)';
            const hasAdjustedApartmentItems = @Model.HasAdjustedApartmentItems.ToString().ToLowerInvariant();
            let details = @Html.Raw(initialDetailsJson);
            let pendingField = null;
            let pendingOldValue = null;
            let pendingAction = '';
            const $addDetailModal = $('#IssueAddDetailModal');
            let stagedAttachments = [];
            let pendingAttachments = [];
            let deletedAttachmentDocIds = [];
            let isSubmittingConfirmAfterSave = false;
            let pendingDuplicateIncomingRow = null;

            function formatBytes(bytes) {
                const value = Number(bytes || 0);
                if (value < 1024) return `${value} B`;
                if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
                return `${(value / (1024 * 1024)).toFixed(2)} MB`;
            }

            function formatDateTimeDdMmYyyyHm(date) {
                const d = date instanceof Date ? date : new Date(date);
                const dd = String(d.getDate()).padStart(2, '0');
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const yyyy = d.getFullYear();
                const hh = String(d.getHours()).padStart(2, '0');
                const min = String(d.getMinutes()).padStart(2, '0');
                return `${dd}/${mm}/${yyyy} ${hh}:${min}`;
            }

            function attachmentKey(file) {
                return `${file.name || ''}__${file.size || 0}__${file.lastModified || 0}`;
            }

            function syncAttachmentInputFromStaging() {
                const dt = new DataTransfer();
                stagedAttachments.forEach(file => dt.items.add(file));
                const input = document.getElementById('detailAttachmentUpload');
                if (!input) {
                    return;
                }
                input.files = dt.files;
            }

            function renderAttachmentStaging() {
                const $body = $('#attachmentListBody');
                $body.empty();
                const canEdit = @Model.CanEditVoucherBusiness.ToString().ToLowerInvariant() && !hasAdjustedApartmentItems;

                existingAttachments.filter(file => !deletedAttachmentDocIds.includes(Number(file.docId))).forEach(file => {
                    const deleteAction = canEdit
                        ? `<button type="button" class="btn btn-xs btn-danger btn-remove-existing-attachment" data-docid="${file.docId}"><i class="fas fa-trash"></i></button>`
                        : '';
                    $body.append(`<tr>
                        <td class="text-center">${deleteAction}</td>
                        <td><a href="${file.downloadUrl}">${file.filePath || ''}</a></td>
                        <td>${file.uploadDate || ''}</td>
                        <td>${file.employeeCode || ''}</td>
                    </tr>`);
                });

                pendingAttachments.forEach((file, index) => {
                    const removeAction = canEdit
                        ? `<button type="button" class="btn btn-xs btn-danger btn-remove-pending-attachment" data-index="${index}"><i class="fas fa-trash"></i></button>`
                        : '';
                    const nowText = formatDateTimeDdMmYyyyHm(new Date());
                    const displayUser = (currentEmployeeCode || currentUserName || 'Current User');
                    $body.append(`<tr>
                        <td class="text-center">${removeAction}</td>
                        <td>${file.name || ''}</td>
                        <td>${nowText}</td>
                        <td>${displayUser}</td>
                    </tr>`);
                });

                const visibleExistingCount = existingAttachments.filter(file => !deletedAttachmentDocIds.includes(Number(file.docId))).length;
                $('#attachmentCountText').text(visibleExistingCount + pendingAttachments.length);
                if (visibleExistingCount === 0 && pendingAttachments.length === 0) {
                    $body.append('<tr><td colspan="4" class="text-center text-muted py-3">No files selected</td></tr>');
                    return;
                }
            }

            function syncDeletedAttachmentDocIds() {
                $('#DeletedAttachmentDocIdsJson').val(JSON.stringify(deletedAttachmentDocIds));
            }

            function initSelect2() {
                if (!$.fn.select2) return;
                const $modal = $addDetailModal;
                $('select.select2').not($modal.find('select.select2')).select2({ width: '100%' });
                $modal.find('select.select2').select2({ width: '100%', dropdownParent: $modal });
            }

            function reloadIssueContext() {
                const flowSubType = $('#Header_FlowSubType').val() || '';
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                const url = `?handler=IssueContext&flowSubType=${encodeURIComponent(flowSubType)}`;

                return fetch(url, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : null)
                    .then(data => {
                        if (!data) return;
                        $('#Header_StatusID').val(data.statusId || '');
                        $('#Header_StatusName').val(data.statusName || '');
                        $('#statusTextStrong').val(data.statusName || '');
                        if (mode === 'add' && data.flowNo) {
                            $('#Header_FlowNo').val(data.flowNo);
                        } else if (mode === 'add' && !flowSubType) {
                            $('#Header_FlowNo').val('');
                        }
                    })
                    .catch(() => {
                        $('#Header_StatusName').val('');
                    });
            }

            function reloadReceiverOptions(selectedValue) {
                const deptId = $('#Header_RecDept').val() || '';
                const $receiver = $('#Header_ReceivedBy');

                $receiver.empty().append(new Option('--- Select ---', '', true, false));

                if (!deptId) {
                    $receiver.val('').trigger('change.select2');
                    return Promise.resolve();
                }

                const url = `?handler=ReceiverOptions&deptId=${encodeURIComponent(deptId)}`;
                return fetch(url, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : [])
                    .then(list => {
                        const items = Array.isArray(list) ? list : [];
                        items.forEach(item => {
                            $receiver.append(new Option(item.text || '', item.value || '', false, false));
                        });

                        const nextValue = selectedValue || '';
                        $receiver.val(nextValue).trigger('change.select2');
                    })
                    .catch(() => {
                        $receiver.val('').trigger('change.select2');
                    });
            }
            function setFieldEnabled($field, enabled, clearWhenDisabled) {
                if (!$field || $field.length === 0) return;
                const tagName = ($field.prop('tagName') || '').toLowerCase();
                if (tagName === 'select') {
                    if (!enabled && clearWhenDisabled) {
                        $field.val('').trigger('change.select2');
                    }
                    $field.prop('disabled', !enabled).trigger('change.select2');
                    return;
                }

                if (!enabled && clearWhenDisabled) {
                    $field.val('');
                }
                $field.prop('readonly', !enabled);
            }

            function syncIssueFromIssueButton() { }

            function syncConfirmButtonState() {
                const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                const flowSubType = Number($('#Header_FlowSubType').val() || 0);
                const hasConfirmAccess = ($('#btnOpenConfirmVoucher').attr('data-has-confirm-access') || '').toLowerCase() === 'true';
                const disable = mode === 'add' && (!hasConfirmAccess || flowSubType === 2);
                $('#btnOpenConfirmVoucher').prop('disabled', disable);
                $('#issueType2Hint').toggleClass('d-none', !(mode === 'add' && flowSubType === 2));
            }

            function applyFieldRuleByFlowSubType() {
                const flowSubType = Number($('#Header_FlowSubType').val() || 0);
                const isManualIssueType = flowSubType >= 4;
                const canAddNew = isManualIssueType && !hasAdjustedApartmentItems;

                setFieldEnabled($('#Header_RecDept'), !isManualIssueType, isManualIssueType);
                setFieldEnabled($('#Header_ReceivedBy'), !isManualIssueType, isManualIssueType);
                setFieldEnabled($('#Header_AssetLocation'), !isManualIssueType, isManualIssueType);
                $('#btnOpenAddDetail, #btnOpenAddNewAction').prop('disabled', !canAddNew);

                syncIssueFromIssueButton();
                syncConfirmButtonState();
            }

            function syncDetailsJson() {
                $('#DetailsJson').val(JSON.stringify(details));
            }

            function renderRows() {
                const $body = $('#detailRowsBody');
                const canEdit = @Model.CanEditVoucherBusiness.ToString().ToLowerInvariant() && !hasAdjustedApartmentItems;
                $body.empty();
                if (details.length === 0) {
                    $body.append('<tr><td colspan="10" class="text-center text-muted py-3">No data</td></tr>');
                    syncDetailsJson();
                    return;
                }
                details.forEach((d, index) => {
                    const itemCode = d.itemCode ?? d.ItemCode ?? '';
                    const itemName = toTcvn3WebText(d.itemName ?? d.ItemName ?? '');
                    const unit = d.unit ?? d.Unit ?? '';
                    const docQty = Number(d.docQty ?? d.DocQty ?? 0);
                    const actQty = Number(d.actQty ?? d.ActQty ?? 0);
                    const unitPrice = Number(d.unitPrice ?? d.UnitPrice ?? 0);
                    const amount = Number(d.amount ?? d.Amount ?? 0);
                    const locationId = Number(d.locationId ?? d.LocationId ?? 0);
                    const locationOptions = locationCatalog.map(l => {
                        const selected = locationId === Number(l.id) ? 'selected' : '';
                        return `<option value="${l.id}" ${selected}>${l.text}</option>`;
                    }).join('');

                    const deleteAction = canEdit
                        ? `<button type="button" class="btn btn-xs btn-danger stage-remove btn-delete-detail" data-index="${index}" title="Remove"><i class="fas fa-trash"></i></button>`
                        : '';
                    const readOnlyText = canEdit ? '' : 'readonly';
                    const disabledSelect = canEdit ? '' : 'disabled';
                    $body.append(`<tr>
                        <td class="text-center align-middle">${deleteAction}</td>
                        <td class="text-bold">${itemCode}</td>
                        <td class="tcvn3-font">${itemName}</td>
                        <td>${unit}</td>
                        <td><input type="text" inputmode="numeric" class="form-control form-control-sm text-right detail-docqty number-format" data-index="${index}" value="${docQty.toLocaleString(undefined,{maximumFractionDigits:0})}" ${readOnlyText} /></td>
                        <td><input type="text" inputmode="numeric" class="form-control form-control-sm text-right detail-actqty number-format" data-index="${index}" value="${actQty.toLocaleString(undefined,{maximumFractionDigits:0})}" ${readOnlyText} /></td>
                        <td><input type="text" inputmode="numeric" class="form-control form-control-sm text-right detail-unitprice number-format" data-index="${index}" value="${unitPrice.toLocaleString(undefined,{maximumFractionDigits:0})}" ${readOnlyText} /></td>
                        <td class="text-right detail-amount" data-index="${index}">${amount.toLocaleString(undefined,{maximumFractionDigits:0})}</td>
                        <td>
                            <select class="form-control form-control-sm detail-location" data-index="${index}" ${disabledSelect}>
                                <option value=""></option>
                                ${locationOptions}
                            </select>
                        </td>
                    </tr>`);
                });
                syncDetailsJson();
            }

            function clearDetails() { details = []; renderRows(); }
            function parseNumber(v) {
                if (v === null || v === undefined) return 0;
                const s = String(v).replace(/,/g, '').trim();
                const n = Number(s);
                return isNaN(n) ? 0 : n;
            }
            function formatNumber(v) {
                return Number(v || 0).toLocaleString(undefined, { maximumFractionDigits: 0 });
            }
            function syncAddDetailCheckAll() {
                const total = $('.add-detail-check').length;
                const checked = $('.add-detail-check:checked').length;
                $('#checkAllAddDetail').prop('checked', total > 0 && checked === total);
            }

            function detailKey(row) {
                const checkingDtId = Number(row.chekingDTID || row.ChekingDTID || row.checkingDtId || 0);
                if (checkingDtId > 0) return `checking:${checkingDtId}`;
                return `item:${Number(row.itemId || row.id || 0)}`;
            }

            function getSelectedDetailKeys() {
                return new Set(details.map(detailKey));
            }

            function upsertDetailRow(newRow) {
                const newKey = detailKey(newRow);
                details = details.filter(existing => detailKey(existing) !== newKey);
                details.push(newRow);
            }

            function findExistingDetailByKey(row) {
                const key = detailKey(row);
                return details.find(existing => detailKey(existing) === key) || null;
            }

            function hideDuplicatePanel() {
                $('#addDetailDuplicatePanel').addClass('d-none');
                $('#addDetailDuplicateMessage').text('');
                pendingDuplicateIncomingRow = null;
            }

            function showDuplicatePanel(existing, incoming) {
                $('#duplicateCurrentItemCode').text(existing.itemCode || incoming.itemCode || '');
                $('#duplicateCurrentQty').text(formatNumber(Number(existing.actQty || 0)));
                $('#duplicateCurrentPrice').text(formatNumber(Number(existing.unitPrice || 0)));
                $('#duplicateNewItemCode').text(incoming.itemCode || existing.itemCode || '');
                $('#duplicateNewQty').text(formatNumber(Number(incoming.actQty || 0)));
                $('#duplicateNewPrice').text(formatNumber(Number(incoming.unitPrice || 0)));
                $('#addDetailDuplicateMessage').text('Do you want to replace current values with new values?');
                $('#addDetailDuplicatePanel').removeClass('d-none');
            }

            function confirmReplaceExistingDetail(newRow) {
                const existing = findExistingDetailByKey(newRow);
                if (!existing) {
                    return true;
                }

                pendingDuplicateIncomingRow = newRow;
                showDuplicatePanel(existing, newRow);
                return false;
            }

            function getAvailableQty(item) {
                return Math.max(0, Number(item.remainingQty || 0));
            }

            function getAvailableAddItems() {
                const selectedKeys = getSelectedDetailKeys();
                return itemCatalog.filter(x => getAvailableQty(x) > 0 && !selectedKeys.has(detailKey(x)));
            }

            function getManualAddItems() {
                const selectedKeys = getSelectedDetailKeys();
                return itemCatalog.filter(x => !selectedKeys.has(detailKey(x)));
            }

            function showClientValidation(message) {
                const $alert = $('#clientValidationAlert');
                $alert.text(message || '').toggleClass('d-none', !message);
            }

            function showIssueIssueValidation(message) {
                const $alert = $('#IssueFromIssueAlert');
                $alert.text(message || '').toggleClass('d-none', !message);
            }

            function renderIssueIssueRows() {
                const $body = $('#issueIssueRowsBody');
                $body.empty();
                if (!issueIssueList.length) {
                    $body.append('<tr><td colspan="7" class="text-center text-muted py-3">No data</td></tr>');
                    $('#btnIssueFromIssueOk').prop('disabled', true);
                    return;
                }
                issueIssueList.forEach(issue => {
                    const checked = selectedIssueFlowId === Number(issue.flowId) ? 'checked' : '';
                    $body.append(`<tr class="issue-Issue-row" data-flow-id="${issue.flowId}" style="cursor:pointer;">
                        <td class="text-center"><input type="radio" name="issueIssueSelect" class="issue-Issue-select" value="${issue.flowId}" ${checked} /></td>
                        <td>${issue.flowNo || ''}</td>
                        <td>${issue.flowDate || ''}</td>
                        <td>${issue.according || ''}</td>
                        <td>${issue.storeName || ''}</td>
                        <td>${issue.deptName || ''}</td>
                        <td>${issue.locationName || ''}</td>
                    </tr>`);
                });
                $('#btnIssueFromIssueOk').prop('disabled', selectedIssueFlowId <= 0);
            }

            function renderIssueIssueetails() {
                const $body = $('#issueIssueetailRowsBody');
                $body.empty();
                if (!issueIssueetails.length) {
                    $body.append('<tr><td colspan="7" class="text-center text-muted py-3">No data</td></tr>');
                    return;
                }
                issueIssueetails.forEach(d => {
                    $body.append(`<tr>
                        <td>${d.itemCode || ''}</td>
                        <td class="tcvn3-font">${toTcvn3WebText(d.itemName || '')}</td>
                        <td>${d.unit || ''}</td>
                        <td class="text-right">${Number(d.docQty || 0).toLocaleString()}</td>
                        <td class="text-right">${Number(d.actQty || 0).toLocaleString()}</td>
                        <td class="text-right">${Number(d.unitPrice || 0).toLocaleString()}</td>
                        <td class="text-right">${Number(d.amount || 0).toLocaleString()}</td>
                    </tr>`);
                });
            }

            function loadIssueIssueList() {
                const fromDate = $('#issueFromDate').val() || '';
                const toDate = $('#issueToDate').val() || '';
                const url = `?handler=IssueIssueList&fromDate=${encodeURIComponent(fromDate)}&toDate=${encodeURIComponent(toDate)}`;
                return fetch(url, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : [])
                    .then(list => {
                        issueIssueList = Array.isArray(list) ? list : [];
                        renderIssueIssueRows();
                    })
                    .catch(() => {
                        issueIssueList = [];
                        renderIssueIssueRows();
                    });
            }

            function loadIssueIssueetails(flowId) {
                if (!flowId) {
                    issueIssueetails = [];
                    renderIssueIssueetails();
                    return Promise.resolve();
                }
                const url = `?handler=IssueIssueetails&flowId=${encodeURIComponent(flowId)}`;
                return fetch(url, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : [])
                    .then(list => {
                        issueIssueetails = Array.isArray(list) ? list : [];
                        renderIssueIssueetails();
                    })
                    .catch(() => {
                        issueIssueetails = [];
                        renderIssueIssueetails();
                    });
            }

            function showAddDetailModalValidation(message) {
                const $alert = $('#addDetailModalValidationAlert');
                $alert.text(message || '').toggleClass('d-none', !message);
            }

            function clearManualAddFieldErrors() {
                $('#manualAddDocQty, #manualAddActQty, #manualAddUnitPrice').removeClass('is-invalid');
                $('#manualAddDocQtyError, #manualAddActQtyError, #manualAddUnitPriceError').text('').addClass('d-none');
            }

            function setManualAddFieldError(selector, errorSelector, message) {
                $(selector).addClass('is-invalid');
                $(errorSelector).text(message).removeClass('d-none');
            }

            function clearPoAddFieldErrors() {
                $('.add-docqty, .add-actqty, .add-unitprice').removeClass('is-invalid');
                $('.add-docqty-error, .add-actqty-error, .add-unitprice-error').remove();
            }

            function setPoAddFieldError(itemId, cls, message) {
                const $input = $(`.${cls}[data-itemid='${itemId}']`);
                $input.addClass('is-invalid');
                const $existing = $input.parent().find(`.${cls}-error`);
                if ($existing.length > 0) {
                    $existing.text(message);
                } else {
                    $input.parent().append(`<small class="text-danger ${cls}-error">${message}</small>`);
                }
            }

            function renderAddDetailRows() {
                const $body = $('#addDetailRowsBody');
                $body.empty();

                if (!itemCatalog || itemCatalog.length === 0) {
                    $body.append('<tr><td colspan="8" class="text-center text-muted py-3">No data</td></tr>');
                    $('#btnAddDetailConfirm').prop('disabled', true);
                    return;
                }

                const availableItems = getAvailableAddItems();

                if (availableItems.length === 0) {
                    $body.append('<tr><td colspan="8" class="text-center text-muted py-3">No data</td></tr>');
                    $('#btnAddDetailConfirm').prop('disabled', true);
                    return;
                }

                availableItems.forEach((item, index) => {
                    const availableQty = getAvailableQty(item);
                    const locationOptions = locationCatalog.map(l => `<option value="${l.id}">${l.text}</option>`).join('');
                    $body.append(`<tr>
                        <td class="text-center"><input type="checkbox" class="add-detail-check" data-itemid="${item.id}" data-checkingdtid="${item.checkingDtId || ''}" /></td>
                        <td class="text-bold">${item.itemCode || ''}</td>
                        <td class="tcvn3-font">${toTcvn3WebText(item.itemName || '')}</td>
                        <td>${item.unit || ''}</td>
                        <td><input type="text" inputmode="numeric" class="form-control form-control-sm text-right add-docqty number-format" data-itemid="${item.id}" value="${Number(availableQty || 0).toLocaleString(undefined,{maximumFractionDigits:0})}" /></td>
                        <td><input type="text" inputmode="numeric" class="form-control form-control-sm text-right add-actqty number-format" data-itemid="${item.id}" data-maxqty="${availableQty}" value="${Number(availableQty || 0).toLocaleString(undefined,{maximumFractionDigits:0})}" /></td>
                        <td><input type="text" inputmode="numeric" class="form-control form-control-sm text-right add-unitprice number-format" data-itemid="${item.id}" value="${Number(item.price || 0).toLocaleString(undefined,{maximumFractionDigits:0})}" /></td>
                        <td><select class="form-control form-control-sm add-location" data-itemid="${item.id}"><option value=""></option>${locationOptions}</select></td>
                    </tr>`);
                });

                $('#checkAllAddDetail').prop('checked', false);
                $('#btnAddDetailConfirm').prop('disabled', true);
                showClientValidation('');
            }

            function resetAddDetailModalInputs() {
                renderAddDetailRows();
                clearPoAddFieldErrors();
                showAddDetailModalValidation('');
            }

            function buildItemOptionText(item) {
                const code = item.itemCode || '';
                const name = toTcvn3WebText(item.itemName || '');
                return (code + ' - ' + name).trim();
            }

            function renderManualAddDetailOptions() {
                const availableItems = getManualAddItems();
                const $item = $('#manualAddItemId');
                const locationOptions = ['<option value=""></option>'].concat(locationCatalog.map(l => `<option value="${l.id}">${l.text}</option>`));
                $('#manualAddLocationId').html(locationOptions.join(''));
                $item.html('<option value=""></option>' + availableItems.map(x => `<option value="${x.id}">${buildItemOptionText(x)}</option>`).join(''));
                $('#manualAddUnit').val('');
                $('#manualAddDocQty').val('0');
                $('#manualAddActQty').val('0');
                $('#manualAddUnitPrice').val('0');
                $('#btnAddDetailConfirm').prop('disabled', availableItems.length === 0);
                clearManualAddFieldErrors();
                showAddDetailModalValidation('');
                initModalSelect2($('#IssueAddDetailModal'));
            }

            function syncManualItemInfo() {
                const itemId = Number($('#manualAddItemId').val() || 0);
                const item = itemCatalog.find(x => Number(x.id) === itemId);
                $('#manualAddUnit').val(item?.unit || '');
                if (item) {
                    $('#manualAddUnitPrice').val(formatNumber(item.price || 0));
                }
            }

            function reloadDetailItemsByPo() {
                const poId = '';
                const flowId = $('input[name="id"]').val() || '';
                const url = `?handler=PoItems&poId=${encodeURIComponent(poId)}&flowId=${encodeURIComponent(flowId)}`;

                return fetch(url, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.ok ? r.json() : [])
                    .then(list => {
                        itemCatalog.length = 0;
                        list.forEach(x => itemCatalog.push({
                            id: String(x.id),
                            checkingId: x.checkingId || null,
                            checkingDtId: x.checkingDtId || null,
                            mrDetailId: x.mrDetailId || null,
                            itemCode: x.itemCode || '',
                            itemName: x.itemName || '',
                            unit: x.unit || '',
                            remainingQty: Number(x.remainingQty || 0),
                            price: Number(x.price || 0)
                        }));

                        renderAddDetailRows();
                    })
                    .catch(() => {
                        itemCatalog.length = 0;
                        renderAddDetailRows();
                    });
            }

            function destroyBackgroundSelect2() {
                $('#InventoryIssueDetailForm select.select2').each(function () {
                    const $select = $(this);
                    if ($select.closest('.modal').length > 0) {
                        return;
                    }

                    if ($select.data('select2')) {
                        $select.select2('close');
                        $select.select2('destroy');
                    }
                });

                $('body').addClass('inventory-Issue-modal-open');
            }

            function initBackgroundSelect2() {
                $('#InventoryIssueDetailForm select.select2').each(function () {
                    const $select = $(this);
                    if ($select.closest('.modal').length > 0) {
                        return;
                    }

                    if (!$select.data('select2')) {
                        $select.select2({ width: '100%' });
                    }
                });

                $('body').removeClass('inventory-Issue-modal-open');
            }

            function initModalSelect2($modal) {
                $modal.find('select.select2').each(function () {
                    const $select = $(this);

                    if ($select.data('select2')) {
                        $select.select2('destroy');
                    }

                    const config = {
                        width: '100%',
                        dropdownParent: $modal
                    };

                    if ($select.attr('id') === 'mrDept') {
                        config.minimumResultsForSearch = 0;
                        config.dropdownCssClass = 'inventory-issue-mr-dept-dropdown';
                    }

                    if ($select.attr('id') === 'detailItemId' || $select.attr('id') === 'manualAddItemId') {
                        config.templateResult = function (state) {
                            if (!state.id) return state.text;
                            const text = state.text || '';
                            const idx = text.indexOf(' - ');
                            if (idx < 0) {
                                return $('<span></span>').text(text);
                            }
                            const code = text.substring(0, idx);
                            const name = text.substring(idx + 3);
                            const $result = $('<span><span class="item-code"></span> - <span class="tcvn3-font item-name"></span></span>');
                            $result.find('.item-code').text(code);
                            $result.find('.item-name').text(toTcvn3WebText(name));
                            return $result;
                        };

                        config.templateSelection = function (state) {
                            if (!state.id) return state.text;
                            const text = state.text || '';
                            const idx = text.indexOf(' - ');
                            if (idx < 0) {
                                return $('<span class="tcvn3-font"></span>').text(text);
                            }
                            const code = text.substring(0, idx);
                            const name = text.substring(idx + 3);
                            const $result = $('<span><span class="item-code"></span> - <span class="tcvn3-font item-name"></span></span>');
                            $result.find('.item-code').text(code);
                            $result.find('.item-name').text(toTcvn3WebText(name));
                            return $result;
                        };

                        config.escapeMarkup = function (markup) { return markup; };
                    }

                    $select.select2(config);
                });
            }

            const InventoryIssueModalSelector = '#IssueAddDetailModal, #detailResetWarningModal, #prqAttachmentModal, #confirmInventoryIssueModal, #adjustItemInApmtModal, #FromMrModal';

            $('.modal').filter(InventoryIssueModalSelector).on('show.bs.modal', function () {
                const $modal = $(this);
                destroyBackgroundSelect2();
                if ($modal.is('#confirmInventoryIssueModal')) {
                    $('body').addClass('inventory-Issue-confirm-open');
                    const mode = ($('input[name="mode"]').val() || '').toLowerCase();
                    const issueId = $('input[name="id"]').val() || '';
                    if (mode === 'approved' && issueId) {
                        const reportUrl = `?id=${encodeURIComponent(issueId)}&handler=Report&inline=true&previewSign=true`;
                        $('#issueSignReportPreviewFrame').attr('src', reportUrl);
                    }
                }
                initModalSelect2($modal);
            });
            $('.modal').filter(InventoryIssueModalSelector).on('shown.bs.modal', function () {
                const $modal = $(this);
                if ($modal.is('#FromMrModal')) {
                    const $dept = $('#mrDept');
                    if ($dept.data('select2')) {
                        $dept.select2('destroy');
                    }
                    $dept.select2({ width: '100%', dropdownParent: $modal, minimumResultsForSearch: 0, dropdownCssClass: 'inventory-issue-mr-dept-dropdown' });
                }
            });
            $('.modal').filter(InventoryIssueModalSelector).on('hidden.bs.modal', function () {
                if ($(this).is('#confirmInventoryIssueModal')) {
                    $('body').removeClass('inventory-Issue-confirm-open');
                    $('#issueSignReportPreviewFrame').attr('src', '');
                }
                if ($('.modal.show').filter(InventoryIssueModalSelector).length === 0) {
                    initBackgroundSelect2();
                }
            });

            $(document).on('select2:opening', 'select.select2', function (e) {
                const isModalOpen = $('.modal.show').filter(InventoryIssueModalSelector).length > 0;
                const isInsideModal = $(this).closest('.modal.show').filter(InventoryIssueModalSelector).length > 0;
                if (isModalOpen && !isInsideModal) {
                    e.preventDefault();
                    return false;
                }
            });

            $('#btnAdjustItemInApmt').on('click', function () {
                $('#adjustItemInApmtModal').modal('show');
            });

            $('#btnConfirmAdjustItemInApmt').on('click', function () {
                $('#adjustItemInApmtModal').modal('hide');
                syncDetailsJson();
                let $applyAll = $('#InventoryIssueDetailForm input[name="ApplyAllApartment"]');
                if ($applyAll.length === 0) {
                    $applyAll = $('<input type="hidden" name="ApplyAllApartment" />').appendTo('#InventoryIssueDetailForm');
                }
                $applyAll.val($('#ApplyAllApartmentInput').val() || 'false');
                $('#InventoryIssueDetailForm').attr('action', '?handler=AdjustItemInApartment');
                $('#InventoryIssueDetailForm').trigger('submit');
