@page
@model SmartSam.Pages.Inventory.InventoryParameters.InventoryParametersMemberModel
@{
    ViewData["Title"] = "Inventory Parameters Member";
    var currentPage = Model.Filter.Page <= 0 ? 1 : Model.Filter.Page;
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
    var pageItems = new List<int?>();
    var message = TempData["Message"]?.ToString();
    var messageType = TempData["MessageType"]?.ToString() ?? "info";
    var alertClass = messageType == "success"
        ? "alert-success"
        : messageType == "warning"
            ? "alert-warning"
            : "alert-info";

    for (var p = 1; p <= totalPages; p++)
    {
        if (p == 1 || p == totalPages || (p >= currentPage - 2 && p <= currentPage + 2))
        {
            pageItems.Add(p);
        }
        else if (pageItems.Count == 0 || pageItems[^1].HasValue)
        {
            pageItems.Add(null);
        }
    }

    Func<int, string> pageUrl = (page) => Url.Page("./InventoryParametersMember", new
    {
        GroupId = Model.Filter.GroupId,
        DepartmentId = Model.Filter.DepartmentId,
        EmployeeKeyword = Model.Filter.EmployeeKeyword,
        ActiveStatus = Model.Filter.ActiveStatus,
        PageNumber = page,
        PageSize = Model.Filter.PageSize
    }) ?? "#";
}

<section class="content vni-font">
    <div class="container-fluid">
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert @alertClass alert-dismissible fade show py-2" role="alert">
                <strong><i class="fas fa-info-circle"></i></strong> @message
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="row">
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-search"></i> Search</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="inventoryParametersMemberSearchForm">
                            <input type="hidden" name="GroupId" value="@Model.Filter.GroupId" />
                            <input type="hidden" name="PageNumber" value="1" />
                            <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />

                            <div class="form-group mb-2">
                                <label>Employee</label>
                                <input id="Filter_EmployeeKeyword" name="EmployeeKeyword" value="@Model.Filter.EmployeeKeyword" class="form-control form-control-sm vni-font" />
                            </div>

                            <div class="form-group mb-2">
                                <label>Department</label>
                                <select id="Filter_DepartmentId" name="DepartmentId" class="form-control form-control-sm select2 vni-font" data-placeholder="--- All ---">
                                    @foreach (var department in Model.DepartmentList)
                                    {
                                        var selectedDepartment = string.IsNullOrWhiteSpace(department.Value)
                                            ? !Model.Filter.DepartmentId.HasValue
                                            : Model.Filter.DepartmentId?.ToString() == department.Value;
                                        <option value="@department.Value" selected="@(selectedDepartment ? "selected" : null)">@department.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label>Active</label>
                                <select id="Filter_ActiveStatus" name="ActiveStatus" class="form-control form-control-sm">
                                    <option value="" selected="@(!Model.Filter.ActiveStatus.HasValue ? "selected" : null)">--- All ---</option>
                                    <option value="1" selected="@(Model.Filter.ActiveStatus == 1 ? "selected" : null)">Active</option>
                                    <option value="0" selected="@(Model.Filter.ActiveStatus == 0 ? "selected" : null)">Inactive</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-block btn-sm border mb-2">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-10">
                <div class="card card-primary">
                    <div class="card-header ipm-table-header">
                        <div class="ipm-table-header-left">
                            <h3 class="card-title">Inventory Group Member</h3>
                            <span class="badge badge-light ml-2">@Model.TotalRecords records</span>
                            @if (!string.IsNullOrWhiteSpace(Model.SelectedGroupName))
                            {
                                <span class="badge badge-info ml-2">@Model.SelectedGroupName</span>
                            }
                        </div>
                        <div class="ipm-table-header-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div class="d-inline-block mr-2 ipm-pagination-info">
                                    @if (Model.TotalRecords == 0)
                                    {
                                        <small>No records</small>
                                    }
                                    else
                                    {
                                        <small>Showing @Model.PageStart to @Model.PageEnd of @Model.TotalRecords entries</small>
                                    }
                                </div>
                                <div class="ipm-page-size-form d-inline-flex mr-2">
                                    <label class="mb-0 ipm-page-size-label" for="inventoryParametersMemberPageSize">Show</label>
                                    <select id="inventoryParametersMemberPageSize" class="form-control form-control-sm ipm-page-size-select">
                                        @foreach (var pageSizeOption in Model.PageSizeOptions)
                                        {
                                            <option value="@pageSizeOption" selected="@(Model.Filter.PageSize == pageSizeOption ? "selected" : null)">@pageSizeOption</option>
                                        }
                                    </select>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex">
                                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                        <a class="page-link ipm-pager-link" href="@(Model.HasPreviousPage ? pageUrl(currentPage - 1) : "#")">Prev</a>
                                    </li>
                                    @foreach (var pageItem in pageItems)
                                    {
                                        if (pageItem.HasValue)
                                        {
                                            <li class="page-item @(pageItem.Value == currentPage ? "active" : "")">
                                                <a class="page-link ipm-pager-link" href="@pageUrl(pageItem.Value)">@pageItem.Value</a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                        }
                                    }
                                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                        <a class="page-link ipm-pager-link" href="@(Model.HasNextPage ? pageUrl(currentPage + 1) : "#")">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive ipm-table-wrap">
                            <table class="table table-hover table-bordered mb-0 text-nowrap ipm-table" id="inventoryParametersMemberTable">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 32px;"></th>
                                        <th class="ipm-col-employee">Employee Name</th>
                                        <th style="width: 125px;">Employee Code</th>
                                        <th class="ipm-col-group">Store Group</th>
                                        <th class="ipm-col-department">Department</th>
                                        @* <th style="width: 80px;" class="ipm-center">Active</th> *@
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Rows.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No data</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var row in Model.Rows)
                                        {
                                            <tr class="ipm-row"
                                                data-detail-id="@row.DetailID"
                                                data-employee-id="@row.EmployeeId"
                                                data-employee-code="@row.EmployeeCode"
                                                data-employee-name="@row.EmployeeName"
                                                data-store-group-id="@row.StoreGroupId"
                                                data-store-group-name="@row.StoreGroupName">
                                                <td>
                                                    <input type="radio" class="ipm-selector" name="selectedInventoryGroupMember" aria-label="Select row" />
                                                </td>
                                                <td class="ipm-col-employee">
                                                    <span class="ipm-ellipsis vni-font" title="@row.EmployeeName">@row.EmployeeName</span>
                                                </td>
                                                <td class="font-weight-bold">@row.EmployeeCode</td>
                                                <td class="ipm-col-group">
                                                    <span class="ipm-ellipsis vni-font" title="@row.StoreGroupName">@row.StoreGroupName</span>
                                                </td>
                                                <td class="ipm-col-department">
                                                    <span class="ipm-ellipsis vni-font" title="@row.DepartmentText">@row.DepartmentText</span>
                                                </td>
                                                @* <td class="ipm-center">
                                                    <span class="badge @(row.IsActive ? "badge-success" : "badge-secondary")">@(row.IsActive ? "Yes" : "No")</span>
                                                </td> *@
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center module-action-bar ipm-action-bar">
                        @if (Model.CanAdd)
                        {
                            <button type="button" id="ipmAddBtn" class="btn btn-sm btn-action-add border mx-1 my-1" disabled="@(!Model.Filter.GroupId.HasValue)">
                                <i class="fas fa-plus"></i> Add
                            </button>
                        }
                        @if (Model.CanDelete)
                        {
                            <button type="button" id="ipmDeleteBtn" class="btn btn-sm btn-action-delete border mx-1 my-1" disabled>
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        }
                        <a href="@Url.Page("/Inventory/InventoryParameters/Index")" class="btn btn-sm btn-action-close border mx-1 my-1">
                            <i class="fas fa-arrow-left"></i> Back to list
                        </a>
                        @* <a href="@Url.Page("./InventoryParametersMember", "ExportExcel", new {
                               GroupId = Model.Filter.GroupId,
                               DepartmentId = Model.Filter.DepartmentId,
                               EmployeeKeyword = Model.Filter.EmployeeKeyword,
                               ActiveStatus = Model.Filter.ActiveStatus
                           })"
                           class="btn btn-sm btn-action-export border mx-1 my-1">
                            <i class="fas fa-file-excel"></i> Export Excel
                        </a> *@
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade vni-font" id="inventoryParameterMemberModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg ipm-member-modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" asp-page-handler="SaveMember" class="ipm-member-form" id="inventoryParameterMemberForm" data-current-group-id="@Model.Filter.GroupId">
                <div class="modal-header py-2">
                    <h5 class="modal-title font-weight-bold" id="inventoryParameterMemberModalTitle">Inventory Group Member</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pb-2">
                    <input asp-for="MemberInput.DetailID" type="hidden" />
                    <input type="hidden" name="Filter.GroupId" value="@Model.Filter.GroupId" />
                    <input type="hidden" name="Filter.DepartmentId" value="@Model.Filter.DepartmentId" />
                    <input type="hidden" name="Filter.EmployeeKeyword" value="@Model.Filter.EmployeeKeyword" />
                    <input type="hidden" name="Filter.ActiveStatus" value="@Model.Filter.ActiveStatus" />
                    <input type="hidden" name="Filter.Page" value="@Model.Filter.Page" />
                    <input type="hidden" name="Filter.PageSize" value="@Model.Filter.PageSize" />

                    <div class="form-row">
                        <div class="form-group col-md-12 mb-2" id="ipmEmployeeSelectGroup">
                            <label>Employee<span class="text-danger">*</span></label>
                            <select asp-for="MemberInput.EmployeeID" asp-items="Model.EmployeeList" class="form-control form-control-sm select2 vni-font" data-placeholder="Select employee" required>
                                <option value="">---</option>
                            </select>
                        </div>
                        <div class="form-group col-md-12 mb-2 d-none" id="ipmStoreGroupSelectGroup">
                            <label>Store Group<span class="text-danger">*</span></label>
                            <select asp-for="MemberInput.KPGroupID" asp-items="Model.StoreGroupList" class="form-control form-control-sm select2 vni-font" data-placeholder="Select group" required>
                                <option value="">---</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    @if (Model.CanAdd)
                    {
                        <button type="submit" class="btn btn-sm btn-action-save border">
                            <i class="fas fa-save"></i> Save
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade vni-font" id="inventoryParameterMemberDeleteModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form method="post" asp-page-handler="DeleteMember" id="inventoryParameterMemberDeleteForm">
                <div class="modal-header bg-danger text-white py-2">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="MemberInput.DetailID" id="DeleteMemberInput_DetailID" />
                    <input type="hidden" name="MemberInput.KPGroupID" id="DeleteMemberInput_KPGroupID" />
                    <input type="hidden" name="Filter.GroupId" value="@Model.Filter.GroupId" />
                    <input type="hidden" name="Filter.DepartmentId" value="@Model.Filter.DepartmentId" />
                    <input type="hidden" name="Filter.EmployeeKeyword" value="@Model.Filter.EmployeeKeyword" />
                    <input type="hidden" name="Filter.ActiveStatus" value="@Model.Filter.ActiveStatus" />
                    <input type="hidden" name="Filter.Page" value="@Model.Filter.Page" />
                    <input type="hidden" name="Filter.PageSize" value="@Model.Filter.PageSize" />
                    <div>Are you sure to delete member <strong id="inventoryParameterMemberDeleteName"></strong>?</div>
                </div>
                <div class="modal-footer py-2">
                    @if (Model.CanDelete)
                    {
                        <button type="submit" class="btn btn-sm btn-action-delete border">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-action-close border" data-dismiss="modal">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/common/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Inventory/InventoryParameters/InventoryParametersMember.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Inventory/InventoryParameters/InventoryParametersMember.js" asp-append-version="true"></script>
}
