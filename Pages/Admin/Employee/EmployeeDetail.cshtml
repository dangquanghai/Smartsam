
@page 
@model SmartSam.Pages.Admin.Employee.EmployeeDetailModel
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "Employee Detail";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                @* Dùng toán tử null-conditional để tránh lỗi nếu Employee chưa load kịp *@
                <h1>Profile: @Model.Employee?.EmployeeName</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-page="./Index">Nhân viên</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">Basic information n</h3>
                <div class="card-tools">
                    @* Sửa lại tên property cho khớp với ViewModel: EmployeeID thay vì Id *@
                    <a asp-page="./Detail" asp-route-id="@Model.Employee?.EmployeeID" asp-route-mode="edit" class="btn btn-tool">
                        <i class="fas fa-edit"></i> Chỉnh sửa
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Emp Code</label>
                            <input type="text" class="form-control" asp-for="Employee.EmployeeCode" />
                            <input type="hidden" asp-for="Employee.EmployeeID" />
                            <input type="hidden" asp-for="Mode" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Emp Name</label>
                            <input type="text" class="form-control" asp-for="Employee.EmployeeName" readonly="@(Model.Mode == "view")" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Title</label>
                            <input type="text" class="form-control" asp-for="Employee.Title" readonly="@(Model.Mode == "view")" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Password</label>
                            <div class="input-group">
                                <input type="password" class="form-control" asp-for="Employee.NewPassword"
                                       readonly="@(Model.Mode == "view")" placeholder="Nhập mật khẩu mới..." />
                                <div class="input-group-append">
                                    <span class="input-group-text" style="cursor:pointer" onclick="togglePassword()">
                                        <i class="fas fa-eye" id="eyeIcon"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>TheEmail</label>
                            <input type="email" class="form-control" asp-for="Employee.TheEmail" readonly="@(Model.Mode == "view")" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Department</label>
                            @if (Model.Mode == "edit" || Model.Mode == "add")
                            {
                                <select asp-for="Employee.DeptID" asp-items="Model.DepartmentList" class="form-control">
                                    <option value="">-- Không phân nhóm --</option>
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control" value="@(Model.DepartmentList.FirstOrDefault(x => x.Value == Model.Employee.DeptID?.ToString())?.Text ?? "N/A")" readonly />
                            }
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>StoreGR</label>
                            @if (Model.Mode == "edit" || Model.Mode == "add")
                            {
                                <select asp-for="Employee.StoreGR" asp-items="Model.StoreGroupList" class="form-control">
                                    <option value="">-- Không phân nhóm --</option>
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control" value="@(Model.StoreGroupList.FirstOrDefault(x => x.Value == Model.Employee.StoreGR?.ToString())?.Text ?? "N/A")" readonly />
                            }
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>ISO Approve Level</label>
                            <input type="number" class="form-control" asp-for="Employee.ISOLevel" readonly="@(Model.Mode == "view")" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Level Check Supplier</label>
                            <input type="number" class="form-control" asp-for="Employee.LevelCheckSupplier" readonly="@(Model.Mode == "view")" />
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <div class="col-md-12">
                        <h5 class="text-primary"><i class="fas fa-user-shield"></i> Others</h5>
                        <div class="row mt-3">
                            <div class="col-md-3">
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsActive" id="chkActive" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkActive">Is Active</label>
                                </div>
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsSystemUser" id="chkSys" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkSys">Is System User </label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.HeadDept" id="chkHead" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkHead">Is Head Dept</label>
                                </div>
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsSupervisor" id="chkSuper" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkSuper">Is Supervisort</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsCTReceiver" id="chkCT" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkCT">Receiver Contract</label>
                                </div>
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.Approval" id="chkApprove" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkApprove">Approve PO Level</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsPurchaser" id="chkPur" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkPur">Is Purchaser</label>
                                </div>
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsCFO" id="chkCFO" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkCFO">Is CFO</label>
                                </div>
                                <div class="custom-control custom-checkbox mb-2">
                                    <input class="custom-control-input" type="checkbox" asp-for="Employee.IsBOD" id="chkBOD" disabled="@(Model.Mode == "view")">
                                    <label class="custom-control-label" for="chkBOD">Is BOD</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="row">
                    <div class="col-md-12">
                        <h5 class="text-primary"><i class="fas fa-signature"></i> Sign</h5>
                        <div class="row mt-2">
                            <div class="col-md-6 text-center">
                                <label>Normal Sign</label>
                                <div class="mb-2">
                                    @* Sửa src: Gọi handler GetImg và truyền path từ DB vào *@
                                    <img id="previewNormal"
                                         src="@(string.IsNullOrEmpty(Model.Employee.UrlNomalSign) ? "/img/no-signature.png" : Url.Page("EmployeeDetail", "GetImg", new { path = Model.Employee.UrlNomalSign }))"
                                         style="height: 100px; border: 1px dashed #ddd; cursor: pointer;"
                                         onclick="document.getElementById('fileNormal').click();" title="Click to change" />
                                </div>
                                <input type="file" id="fileNormal" style="display:none" accept="image/*" onchange="previewImage(this, 'previewNormal', 'urlNormal')">
                                <input type="hidden" asp-for="Employee.UrlNomalSign" id="urlNormal" />
                                <small class="text-muted">Click to change</small>
                            </div>

                            <div class="col-md-6 text-center">
                                <label>Small Sign</label>
                                <div class="mb-2">
                                    @* Tương tự cho Small Sign *@
                                    <img id="previewSmall"
                                         src="@(string.IsNullOrEmpty(Model.Employee.UrlSmallSign) ? "/img/no-signature.png" : Url.Page("EmployeeDetail", "GetImg", new { path = Model.Employee.UrlSmallSign }))"
                                         style="height: 60px; border: 1px dashed #ddd; cursor: pointer;"
                                         onclick="document.getElementById('fileSmall').click();" title="Click to change" />
                                </div>
                                <input type="file" id="fileSmall" style="display:none" accept="image/*" onchange="previewImage(this, 'previewSmall', 'urlSmall')">
                                <input type="hidden" asp-for="Employee.UrlSmallSign" id="urlSmall" />
                                <small class="text-muted">Click to change</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer text-center">
                    @if (Model.Mode != "view")
                    {
                        <button type="button" id="btnSaveEmployee" class="btn btn-primary">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    }
                    <a asp-page="./Index" class="btn btn-default">
                        <i class="fas fa-undo"></i> Back to List
                    </a>
                </div>
              
        </div>
    </div>
</section>
@section Scripts {
    @* Gọi file JS riêng của anh *@
    <script src="~/js/Admin/Employee/EmployeeDetail.js" asp-append-version="true"></script>
}