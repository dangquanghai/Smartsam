@page
@model SmartSam.Pages.Cus.DailyServiceBill.DailyServiceBillDetailModel
@{
    ViewData["Title"] = "Daily Service Bill Detail";
    var isView = Model.IsViewMode;
    var canSaveDescription = Model.CanSaveDescription;
    var isPopup = Model.IsPopup;
    if (isPopup)
    {
        Layout = "_PopupLayout";
        ViewData["PopupBodyClass"] = "daily-service-bill-popup-body";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Cus/DailyServiceBill/DailyServiceBillDetail.css" asp-append-version="true" />
}

<section class="content @(isPopup ? "daily-service-bill-popup" : string.Empty)">
    <div class="container-fluid">
        <form method="post" asp-page-handler="Save" id="dailyServiceBillDetailForm">
            <input type="hidden" asp-for="Bill.BillID" />
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="Popup" />

            @if ((isPopup && Model.Saved) || TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show py-2 mb-2" role="alert">
                    @(isPopup && Model.Saved ? "Saved successfully." : TempData["SuccessMessage"])
                    <button type="button" class="close py-1" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="card card-outline card-primary">
                @if (!isPopup)
                {
                    <div class="card-header py-2">
                        <h3 class="card-title">Add/Edit Service Bill</h3>
                    </div>
                }
                <div class="card-body daily-service-bill-header-body">
                    <div class="daily-service-bill-vb-form">
                        <div class="daily-service-bill-vb-row">
                            <div class="daily-service-bill-vb-field">
                                <label>Bill ID:</label>
                                <input class="form-control form-control-sm" value="@Model.Bill.BillID" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field">
                                <label>Bill Date:</label>
                                @if (isPopup && canSaveDescription)
                                {
                                    <input asp-for="Bill.BillDate" type="date" class="form-control form-control-sm" />
                                }
                                else
                                {
                                    <input class="form-control form-control-sm" value="@Model.Bill.BillDate.ToString("MM/dd/yyyy")" readonly />
                                }
                            </div>
                            <div class="daily-service-bill-vb-field">
                                <label>Status:</label>
                                <input class="form-control form-control-sm" value="@Model.Bill.BillStatusName" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-vat-column daily-service-bill-vb-half-control">
                                <label>Before VAT</label>
                                <input id="billBeforeVat" class="form-control form-control-sm text-right" value="@Model.Bill.VNDAmountBefVAT.ToString("#,0.##")" readonly />
                            </div>
                        </div>
                        <div class="daily-service-bill-vb-row">
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-span-2">
                                <label>Sale point:</label>
                                <input class="form-control form-control-sm vni-font" value="@Model.Bill.SalePointName" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field">
                                <label>Ex. Rate:</label>
                                <input class="form-control form-control-sm text-right" value="@Model.Bill.ExRate.ToString("#,0.##")" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-vat-column daily-service-bill-vb-half-control">
                                <label>%VAT</label>
                                <input id="billPctTax" class="form-control form-control-sm text-right" value="@Model.Bill.PctTax.ToString("#,0.##")" readonly />
                            </div>
                        </div>
                        <div class="daily-service-bill-vb-row">
                            <div class="daily-service-bill-vb-field">
                                <label>Cust ID:</label>
                                <input class="form-control form-control-sm" value="@Model.Bill.CustomerID" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field">
                                <label>Apmt No.</label>
                                <input class="form-control form-control-sm" value="@Model.Bill.ApartmentNo" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field">
                                <label>For From</label>
                                @if (isView)
                                {
                                    <input class="form-control form-control-sm" value="@(Model.Bill.ForFromDate?.ToString("MM/dd/yyyy") ?? string.Empty)" readonly />
                                }
                                else
                                {
                                    <input asp-for="Bill.ForFromDate" type="date" class="form-control form-control-sm" />
                                }
                            </div>
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-vat-column daily-service-bill-vb-half-control">
                                <label>VAT</label>
                                <input id="billVat" class="form-control form-control-sm text-right" value="@Model.Bill.DisplayVNDAmountVAT.ToString("#,0.##")" readonly />
                            </div>
                        </div>
                        <div class="daily-service-bill-vb-row">
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-span-2">
                                <label>Cust Name:</label>
                                <input class="form-control form-control-sm vni-font" value="@Model.Bill.CustomerName" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field">
                                <label>To Date</label>
                                @if (isView)
                                {
                                    <input class="form-control form-control-sm" value="@(Model.Bill.ForToDate?.ToString("MM/dd/yyyy") ?? string.Empty)" readonly />
                                }
                                else
                                {
                                    <input asp-for="Bill.ForToDate" type="date" class="form-control form-control-sm" />
                                }
                            </div>
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-vat-column daily-service-bill-vb-half-control">
                                <label>After VAT</label>
                                <input id="billAfterVat" class="form-control form-control-sm text-right" value="@Model.Bill.DisplayVNDAmount.ToString("#,0.##")" readonly />
                            </div>
                        </div>
                        <div class="daily-service-bill-vb-row">
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-span-2">
                                <label>Company</label>
                                <input class="form-control form-control-sm vni-font" value="@Model.Bill.CompanyName" readonly />
                            </div>
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-right-span daily-service-bill-vb-wide-control">
                                <label>Description</label>
                                @if (canSaveDescription)
                                {
                                    <input asp-for="Bill.Description" class="form-control form-control-sm vni-font" />
                                }
                                else
                                {
                                    <input asp-for="Bill.Description" class="form-control form-control-sm vni-font" readonly />
                                }
                            </div>
                        </div>
                        <div class="daily-service-bill-vb-row">
                            <div class="daily-service-bill-vb-field">
                                <label>Paid Date:</label>
                                <input class="form-control form-control-sm" value="@(Model.Bill.PaidDate?.ToString("MM/dd/yyyy") ?? string.Empty)" readonly />
                            </div>
                            <div class="daily-service-bill-vb-checks">
                                <div class="custom-control custom-checkbox">
                                    <input asp-for="Bill.IsPersonalPayment" class="custom-control-input" disabled="@isView" />
                                    <label class="custom-control-label" asp-for="Bill.IsPersonalPayment">Is Personal</label>
                                </div>
                            </div>
                            <div class="daily-service-bill-vb-field daily-service-bill-vb-right-span daily-service-bill-vb-wide-control">
                                <label>Note:</label>
                                <input asp-for="Bill.Note" class="form-control form-control-sm vni-font" readonly="@isView" />
                            </div>
                        </div>
                        <div class="daily-service-bill-vb-row daily-service-bill-vb-row-last">
                            <div class="daily-service-bill-vb-text daily-service-bill-vb-operator-text">
                                <span>Created Operator:</span>
                                <strong>@Model.Bill.CreatedOperatorCode</strong>
                                <span>@Model.Bill.CreatedOperatorName</span>
                            </div>
                        </div>
                    </div>
                </div>
                @if (isPopup && canSaveDescription)
                {
                    <div class="card-footer py-2 text-right">
                        <button type="submit" asp-page-handler="Save" class="btn btn-primary btn-sm">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
                }
                else if (!isPopup)
                {
                    <div class="card-footer py-2">
                        @if (!isView)
                        {
                            <button type="submit" asp-page-handler="Save" class="btn btn-primary btn-sm">
                                <i class="fas fa-save"></i> Save
                            </button>
                        }
                        <a class="btn btn-secondary btn-sm" href="@Model.SafeReturnUrl">
                            <i class="fas fa-arrow-left"></i> Back
                        </a>
                    </div>
                }
            </div>

            <div class="card">
                <div class="card-header py-2">
                    <h3 class="card-title">Service Bill Detail</h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0" id="dailyServiceBillDetailTable">
                            <thead class="thead-light">
                                <tr>
                                    <th class="daily-service-bill-row-number" style="width: 36px;">#</th>
                                    <th>Item Name</th>
                                    <th style="width: 100px;">Unit</th>
                                    <th style="width: 100px;">Quantity</th>
                                    <th style="width: 110px;">Price</th>
                                    <th style="width: 120px;">Amount</th>
                                    <th style="width: 380px;">Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < Model.DetailRows.Count; i++)
                                {
                                    <tr>
                                        <td class="daily-service-bill-row-number">@(i + 1)</td>
                                        <td class="vni-font">
                                            @Model.DetailRows[i].ServiceName
                                            <input type="hidden" asp-for="DetailRows[i].DetailID" />
                                            <input type="hidden" asp-for="DetailRows[i].BillNumber" />
                                            <input type="hidden" asp-for="DetailRows[i].ServiceItem" />
                                        </td>
                                        <td class="vni-font">
                                            @Model.DetailRows[i].Unit
                                            <input type="hidden" asp-for="DetailRows[i].Unit" />
                                        </td>
                                        <td>
                                            <input asp-for="DetailRows[i].Quantity" asp-format="{0:#,0.##}" inputmode="decimal" class="form-control form-control-sm text-right js-bill-qty" readonly="@isView" />
                                        </td>
                                        <td>
                                            <input asp-for="DetailRows[i].Price" asp-format="{0:#,0.##}" inputmode="decimal" class="form-control form-control-sm text-right js-bill-price" readonly="@isView" />
                                        </td>
                                        <td>
                                            <input asp-for="DetailRows[i].Amount" asp-format="{0:#,0.##}" inputmode="decimal" class="form-control form-control-sm text-right js-bill-amount" readonly />
                                        </td>
                                        <td class="daily-service-bill-detail-note-cell">
                                            <input asp-for="DetailRows[i].Notes" class="form-control form-control-sm vni-font daily-service-bill-detail-note" readonly="@isView" />
                                        </td>
                                    </tr>
                                }
                                @if (Model.DetailRows.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-3">No detail</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer py-2 text-right">
                    Total Record(s): @Model.DetailRows.Count
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        window.dailyServiceBillPage = {
            pctTax: @Model.Bill.PctTax.ToString(System.Globalization.CultureInfo.InvariantCulture),
            isView: @Model.IsViewMode.ToString().ToLowerInvariant(),
            isPopup: @(isPopup ? "true" : "false")
        };
    </script>
    <script src="~/js/Cus/DailyServiceBill/DailyServiceBillDetail.js" asp-append-version="true"></script>
}
