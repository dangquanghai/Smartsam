@page
@model SmartSam.Pages.Sales.STContract.STContractDetailModel
@{
    ViewData["Title"] = "Add Short Term Contract";
}
<style>
    /* 1. Khi Modal đang mở, ép tất cả container Select2 ở trang chính xuống dưới lớp backdrop */
    body.modal-open .select2-container {
        z-index: 1030 !important; /* Thấp hơn z-index mặc định của backdrop là 1040 */
    }

    /* 2. Ép lớp nền đen của Modal phải che phủ toàn bộ */
    .modal-backdrop {
        z-index: 1040 !important;
    }

    /* 3. Đảm bảo cửa sổ Modal phải nằm trên lớp nền đen */
    .modal {
        z-index: 1050 !important;
    }

    /* 4. CỰC KỲ QUAN TRỌNG: Đảm bảo các Select2 nằm TRONG Modal (như svc_ServiceID)
           phải hiện lên trên cùng để có thể chọn được */
    body.modal-open .modal .select2-container,
    body.modal-open .select2-container--open {
        z-index: 9999 !important;
        pointer-events: auto !important;
    }

    /* 5. Khóa tương tác chuột của vùng trang chính khi Modal đang hiện */
    body.modal-open .card {
        pointer-events: none;
    }

    body.modal-open .modal {
        pointer-events: auto;
    }

    /* Ép modal rộng ra */
    #modalTenantDetail .modal-xl {
        max-width: 98% !important;
        margin: 10px auto;
    }

    /* Tùy chỉnh vùng cuộn */
    .col-left {
        scrollbar-width: thin;
    }

        .col-left::-webkit-scrollbar {
            width: 6px;
        }

        .col-left::-webkit-scrollbar-thumb {
            background: #bbb;
            border-radius: 10px;
        }

    /* Hiệu ứng focus input */
    .form-control-sm:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.15);
    }

    /* Vùng hiển thị ảnh */
    .bg-black {
        background-color: #000;
    }

    #thumb_strip img {
        height: 50px;
        cursor: pointer;
        margin-right: 5px;
        opacity: 0.6;
    }

        #thumb_strip img.active {
            opacity: 1;
            border: 2px solid #ffc107;
        }

</style>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <strong><i class="fas fa-check-circle"></i> Thông báo:</strong> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        }
        <form method="post">
            <div class="row d-flex align-items-stretch">
                <div class="col-md-5">
                    <div class="card card-primary card-outline card-outline-tabs h-100 mb-0">
                        <div class="card-header p-0 border-bottom-0">
                            <ul class="nav nav-tabs" id="custom-tabs-four-tab" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active" id="tabs-general-tab" data-toggle="pill" href="#tabs-general" role="tab" aria-controls="tabs-general" aria-selected="true">General Information</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" id="tabs-other-tab" data-toggle="pill" href="#tabs-other" role="tab" aria-controls="tabs-other" aria-selected="false">Other Details</a>
                                </li>
                            </ul>
                        </div>
                        <div class="card-body p-2">
                            <div class="tab-content" id="custom-tabs-four-tabContent">
                                <div class="tab-pane fade show active" id="tabs-general" role="tabpanel" aria-labelledby="tabs-general-tab">
                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">ContractNo(*)</label></div>
                                        <div class="col-3">
                                            <input type="hidden" id="hfContractID" asp-for="Contract.ContractID" />
                                            <input type="text" asp-for="Contract.ContractNo" id="ContractNo" class="form-control form-control-sm" readonly tabindex="-1">
                                            <input type="hidden" id="ContractId" value="@Model.SavedContractID" />
                                        </div>

                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Status(*)</label></div>
                                        <div class="col-4">
                                            <select asp-for="Contract.ContractStatus" id="ContractStatus" asp-items="Model.StatusList" class="form-control form-control-sm" tabindex="5">
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">C.Date(*)</label></div>
                                        <div class="col-3">
                                            <input type="date" asp-for="Contract.ContractDate" id="ContractDate" class="form-control form-control-sm" tabindex="1">
                                        </div>
                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Company</label></div>
                                        <div class="col-4">
                                            <select asp-for="Contract.CompanyID"
                                                    id="CompanyId"
                                                    class="form-control select2-ajax" tabindex="6"
                                                    style="width: 100%;">
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">Apartment(*)</label></div>
                                        <div class="col-3">
                                            <select asp-for="Contract.ApmtID" id="ApmtId" asp-items="Model.ApmtList" class="form-control form-control-sm" tabindex="2">
                                               <option value="">-- Select Apartment --</option>
                                            </select>
                                        </div>
                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Representator</label></div>
                                        <div class="col-4">
                                            <select asp-for="Contract.Representator" id="Representator" asp-items="Model.RepresentatorList" class="form-control form-control-sm" tabindex="7">
                                            </select>

                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">RentIncVAT(*)</label></div>
                                        <div class="col-3">
                                            <input type="text" asp-for="Contract.CurrentRentRateNVD" id="CurrentRentRate" asp-items="Model.ApmtList" class="form-control form-control-sm" tabindex="3">
                                        </div>
                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Period(*)</label></div>
                                        <div class="col-4">
                                            <div class="input-group">
                                                <input type="text" class="form-control form-control-sm" id="contractDuration" tabindex="8">
                                                <input type="hidden" asp-for="Contract.ContractFromDate"
                                                       value="@Model.Contract.ContractFromDate?.ToString("yyyy-MM-dd")" id="ContractFromDate" />
                                                <input type="hidden" asp-for="Contract.ContractToDate"
                                                       value="@Model.Contract.ContractToDate?.ToString("yyyy-MM-dd")" id="ContractToDate" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">%VAT</label></div>
                                        <div class="col-3">
                                            <input type="text" asp-for="Contract.PerVAT" id="PerVAT" class="form-control form-control-sm text-right" tabindex="-1">
                                        </div>
                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Is Repeater</label></div>
                                        <div class="col-1">
                                            <div class="custom-control custom-checkbox">
                                                <input type="checkbox" class="custom-control-input" id="IsRepeater" asp-for="Contract.IsRepeater" tabindex="9">
                                                <label class="custom-control-label" for="IsRepeater"></label>
                                            </div>
                                        </div>

                                        <div class="col-1 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Occ</label></div>
                                        <div class="col-2">
                                            <input type="text" asp-for="Contract.Occupy" id="Occupy" class="form-control form-control-sm text-right" tabindex="10">
                                        </div>
                                    </div>
    
                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">Exl.VAT</label></div>
                                        <div class="col-3">
                                            <input type="text" asp-for="Contract.TotalPriceExcVATVND" id="TotalPriceExcVAT" class="form-control form-control-sm text-right" readonly tabindex="-1">
                                        </div>


                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Source(*)</label></div>
                                        <div class="col-4">
                                            <select asp-for="Contract.ContractSourceID" id="ContractSourceID" asp-items="Model.SourceList" class="form-control form-control-sm" tabindex="11">
                                                <option value="">--Select--</option>
                                            </select>
                                        </div>

                                    </div>

                                     <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">Display VAT</label></div>
                                        <div class="col-3">
                                            <select asp-for="Contract.DisPlayVATFromID" id="DisPlayVATFromID" asp-items="Model.VATFromList" class="form-control form-control-sm" tabindex="4">
                                                <option value="">--Select--</option>
                                            </select>
                                        </div>

                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Received By(*)</label></div>
                                        <div class="col-4">
                                            <select asp-for="Contract.ReceivedByID" id="ReceivedByID" asp-items="Model.ReceiverList" class="form-control form-control-sm" tabindex="12">
                                                <option value="">--Select--</option>
                                            </select>
                                        </div>

                                    </div>
                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">Remark</label></div>
                                        <div class="col-10">
                                            <textarea asp-for="Contract.Remarks" id="Remarks" class="form-control form-control-sm" rows="2" tabindex="13"></textarea>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="tabs-other" role="tabpanel" aria-labelledby="tabs-other-tab">
                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">AgentCompany</label></div>
                                        <div class="col-3">
                                            <select asp-for="STInfor.AgentCompany"
                                                    id="AgentCompanyId"
                                                    class="form-control select2-ajax" tabindex="14"
                                                    style="width: 100%;">
                                                <option value="">-- Select--</option>
                                            </select>
                                            <input type="hidden" id="Contract_AgentPersonId" value="@Model.STInfor.AgentPersonId" />
                                        </div>
                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Payment By(*)</label></div>
                                        <div class="col-4">
                                            <select asp-for="STInfor.PaidBy" id="PaymentByID" asp-items="Model.PaymnetByList" class="form-control form-control-sm" tabindex="15">
                                             <option value="">-- Select --</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-center mb-2">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mb-0">Agent Person </label></div>
                                        <div class="col-3">
                                                <select id="AgentPersonId"
                                                        name="STInfor.AgentPersonId"
                                                        class="form-control"
                                                        style="width: 100%;">
                                                </select>
                                        </div>
                                        <div class="col-3 text-left pl-4 pr-2"><label class="col-form-label-sm mb-0">Apmt Note</label></div>
                                        <div class="col-4">
                                            <input type="text" asp-for="STInfor.ApmtNote" id="ApmtNote" class="form-control form-control-sm" tabindex="17">
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">PaymentInfor</label></div>
                                        <div class="col-10">
                                            <input type="text" asp-for="STInfor.PaymentInfor" id="PaymentInfor" class="form-control form-control-sm" tabindex="18">
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">Rental Charge</label></div>
                                        <div class="col-10">
                                            <input type="text" asp-for="STInfor.RentalCharge" id="RentalCharge" class="form-control form-control-sm" tabindex="19">
                                        </div>
                                    </div>
                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">DepositInfor</label></div>
                                        <div class="col-10">
                                            <input type="text" asp-for="STInfor.DepositInfor" id="DepositInfor" class="form-control form-control-sm" tabindex="20">
                                        </div>
                                    </div>
                                    
                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">CancelCharge</label></div>
                                        <div class="col-10">
                                            <input asp-for="STInfor.CancellationCharge"
                                                   list="dtlCancellationCharge" 
                                                   class="form-control form-control-sm" 
                                                   autocomplete="off" />
                                            <datalist id="dtlCancellationCharge" tabindex="21">
                                                <option value="24 hours prior to 14:00 of the check-in date. Later than this time, one night room rental will be levied."></option>
                                                <option value="24 hours prior to 14:00 of the check-in date. Later than this time, one night room rental will be levied."></option>
                                                <option value="three days prior to the check-in date. Later than this time, 10% of total room rental of the reserved stay will be levied."></option>
                                                <option value="three days prior to the check-in date. Later than this time, 10% of total room rental of the reserved stay will be levied."></option>
                                                <option value="two weeks prior to the check-in date. Later than this time,15% of total room rental of the reserved stay will be levied."></option>
                                                <option value="No cancellation is accepted prior to the check-in date. If cancel, 15% of total room rental of the reserved stay will be levied."></option>
                                                <option value="A cancellation should be informed to SSG 07 days prior to the check-in date. Later than this time, full charge of room rental will be applied."></option>
                                            </datalist>
                                        </div>
                                    </div>

                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">OutSuddenly</label></div>
                                        <div class="col-10">
                                            <input asp-for="STInfor.CheckoutSuddenly"
                                                   list="dtlCheckoutSuddenly"
                                                   class="form-control form-control-sm" 
                                                   autocomplete="off" />
                                            <datalist id="dtlCheckoutSuddenly" tabindex="22">
                                                <option value="24 hours prior to 12:00 of the actual checkout date. Later than this time, one night room rental will be levied."></option>
                                                <option value="three days prior to the actual checkout date. Later than this time, 10% room rental of the remainder of reserved stay will be levied."></option>
                                                <option value="15% room rental of the remainder of reserved stay."></option>
                                            </datalist>
                                        </div>
                                    </div>



                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">DepositRP DRP</label></div>
                                        <div class="col-10">
                                            <input asp-for="STInfor.DRP"
                                                   list="dtlDRP"
                                                   class="form-control form-control-sm"
                                                   autocomplete="off" />
                                            <datalist id="dtlDRP" tabindex="23">
                                                <option value="Deposit is not refunded in case of (late cancellation) or (no-show) "></option>
                                                <option value="10% of total room rental of the reserved stay is not refunded in case of (late cancellation) or (no-show)."></option>
                                                <option value="15% of total room rental of the reserved stay is not refunded in case of (late cancellation) or (no-show)."></option>
                                            </datalist>
                                        </div>
                                    </div>
                                    <div class="row no-gutters align-items-start mb-0">
                                        <div class="col-2 text-left pr-2"><label class="col-form-label-sm mt-1">SpecialReq</label></div>
                                        <div class="col-10">
                                            <textarea asp-for="STInfor.SpecialReq" id="SpecialReq" class="form-control form-control-sm" rows="1" tabindex="24"></textarea>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div class="card-footer py-2">
                            <div class="float-left">
                                <button type="button" class="btn btn-info" onclick="loadHistory(@Model.Contract.ContractID)">
                                    <i class="fa fa-history"></i> History
                                </button>
                                <button type="submit" class="btn btn-primary btn-sm px-4"><i class="fas fa-save"></i> Save Contract</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <div class="card card-success card-outline h-100 mb-0 d-flex flex-column">
                        <div class="card-header p-2 d-flex justify-content-between align-items-center">
                            <h3 class="card-title text-bold text-success">Contract Services</h3>
                            <div class="card-tools">
                                <button type="button" class="btn btn-tool" onclick="loadServiceGrid()"><i class="fas fa-sync"></i></button>
                            </div>
                        </div>

                        <div class="card-body p-0 flex-grow-1" style="min-height: 400px; overflow-y: auto;">
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered table-striped m-0" id="tableServices">
                                    <thead class="bg-light sticky-top">
                                        <tr>
                                            <th style="width: 40px;" class="text-center"></th>
                                            <th style="width: 20%">Service Name</th>
                                            <th class="text-center">From Date</th>
                                            <th class="text-center">To Date</th>
                                            <th class="text-center">Interval</th>
                                            <th class="text-center">Type</th>
                                            <th class="text-right">Charge Amount</th>
                                            <th class="text-center">Max Qty</th>
                                            <th>Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.ContractServices != null && Model.ContractServices.Any())
                                        {
                                            foreach (var item in Model.ContractServices)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="radio" name="selectedService" value="@item.ContractServiceID" />
                                                    </td>
                                                    <td class="vni-font">@item.ServiceName</td>
                                                    <td class="text-center">@item.ServiceFromDate?.ToString("dd/MM/yyyy")</td>
                                                    <td class="text-center">@item.ServiceToDate?.ToString("dd/MM/yyyy")</td>
                                                    <td class="text-center">@item.ChargeIntervalName</td>
                                                    <td class="text-center">@item.ChargeTypeName</td>
                                                    <td class="text-right">@item.ChargeAmount.ToString("N0")</td>
                                                    <td class="text-center">@item.MaxQuantity</td>
                                                    <td><small>@item.Notes</small></td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr id="no-data-row">
                                                <td colspan="9" class="text-center text-muted">No services found.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="card-footer py-2">
                            <button type="button" class="btn btn-success btn-sm px-4" onclick="openServiceModal()">
                                <i class="fas fa-plus"></i> Add Service
                            </button>
                            <button type="button" class="btn btn-danger btn-sm px-4 ml-2" onclick="removeSelectedService()">
                                <i class="fas fa-trash-alt"></i> Remove Service
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-md-12">
                    <div class="card card-secondary card-outline">
                        <div class="card-header p-2">
                            <h3 class="card-title">Tenants Information</h3>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="min-height: 200px;">
                                <table class="table table-sm table-bordered table-hover mb-0" id="tableTenants">
                                    <thead class="bg-gray-light">
                                        <tr>
                                            <th style="width: 30px;"></th>
                                            <th>Title</th>
                                            <th>Full Name</th>
                                            <th>Birthday</th>
                                            <th>Nationality</th>
                                            <th>Passport/ID</th>
                                            <th>Position</th>
                                            <th>Move-in</th>
                                            <th>Exp. Date</th>
                                            <th>Visa No</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer py-2">
                            <button id="btnAddFromList" type="button" class="btn btn-primary btn-sm px-3" onclick="openAddFromList()">
                                <i class="fas fa-user-plus"></i> Add From List
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" onclick="openTenantModal('add')">
                                <i class="fas fa-plus"></i> Add New Tenant
                            </button>

                            <button type="button" class="btn btn-info btn-sm" onclick="openTenantModal('view')">View</button>
                            <button type="button" class="btn btn-primary btn-sm" onclick="openTenantModal('edit')">Edit</button>
                            <button type="button" class="btn btn-danger btn-sm px-3">Remove</button>
                            <a asp-page="./Index" class="btn btn-default btn-sm float-right">Back to List</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

<div class="modal fade" id="modalService" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-concierge-bell"></i> Add Contract Service</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="formService">
                    <input type="hidden" id="svc_ContractID" />

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label class="font-weight-bold">Service Name (*)</label>
                                <select id="svc_ServiceID" class="form-control select2 vni-font" style="width: 100%;">
                                    <option value="">-- Select Service --</option>
                                    @if (Model.ServiceList != null)
                                    {
                                        foreach (var item in Model.ServiceList)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">From Date</label>
                                <input type="date" id="svc_FromDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">To Date</label>
                                <input type="date" id="svc_ToDate" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Charge Interval</label>
                                <select id="svc_Interval" class="form-control">
                                    @foreach (var item in Model.ChargeIntervalList ?? new List<SelectListItem>())
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Charge Type</label>
                                <select id="svc_Type" class="form-control">
                                    @foreach (var item in Model.ChargeTypeList ?? new List<SelectListItem>())
                                    {
                                        // Tự động bỏ qua Type = 2 nếu cần ở đây hoặc xử lý ở Backend
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Charge Amount</label>
                                <input type="text" id="svc_ChargeAmount" class="form-control text-right" placeholder="0" onkeyup="formatCurrency(this)" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Max Quantity</label>
                                <input type="number" id="svc_Qty" class="form-control" value="1" step="0.01" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Notes</label>
                        <textarea id="svc_Notes" class="form-control" rows="2" placeholder="Enter service notes..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success px-4" onclick="saveContractService()">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="historyModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Contract History Log</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <table class="table table-sm table-striped" id="historyTable">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>User</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSearchTenant" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-search"></i> Search Tenant from History</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input type="text" id="txtSearchName" class="form-control" placeholder="Enter customer name to search..."
                           onkeyup="if(event.keyCode==13) searchTenant()">
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="button" onclick="searchTenant()">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>

                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-hover table-bordered" id="tableResult">
                        <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>Tenant Name</th>
                                <th>Gender</th>
                                <th>ID/Passport</th>
                                <th>Birthday</th>
                                <th>Nation</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyResult">
                            <tr>
                                <td colspan="5" class="text-center text-muted">Enter name and click search...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <small class="text-muted mr-auto">* Double-click on a row to select and add to contract.</small>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalTenantDetail" tabindex="-1" role="dialog" aria-labelledby="tenantModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document" style="max-width: 98%;">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white p-2">
                <h5 class="modal-title" id="tenantModalTitle">
                    <i class="fas fa-user-edit mr-2"></i>Tenant Detailed Information
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0">
                <form id="formTenantDetail">
                    <div class="d-flex" style="height: 82vh;">

                        <div class="col-left p-3 border-right" style="flex: 0 0 55%; overflow-y: auto; background: #f8f9fa;">
                            <input type="hidden" id="txtContractTenantID" value="0" />
                            <input type="hidden" id="txtCustomerID" />

                            <h6 class="text-primary font-weight-bold mb-3 border-bottom pb-1"><i class="fas fa-id-card"></i> 1. Customer Identity</h6>
                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Name / Title</label>
                                <div class="col-sm-3">
                                    <input type="text" id="txtTitle" class="form-control form-control-sm" placeholder="Title">
                                </div>
                                <div class="col-sm-6">
                                    <input type="text" id="txtCustomerName" class="form-control form-control-sm border-primary" placeholder="Full Name">
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Gender / B-Day</label>
                                <div class="col-sm-3">
                                    <select id="ddlMale" class="form-control form-control-sm">
                                        <option value="true">Male</option>
                                        <option value="false">Female</option>
                                    </select>
                                </div>
                                <div class="col-sm-6">
                                    <input type="date" id="txtBirthday" class="form-control form-control-sm">
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Tenant Type / Nation</label>
                                <div class="col-sm-4">
                                    <select id="ddlTenantType" class="form-control form-control-sm select2">
                                        @foreach (var t in Model.ListTenantTypes)
                                        {
                                            <option value="@t.Value">@t.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-sm-5">
                                    <select id="ddlNationality" class="form-control form-control-sm select2">
                                        @foreach (var n in Model.ListNations)
                                        {
                                            <option value="@n.Value">@n.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Passport / Expire</label>
                                <div class="col-sm-4">
                                    <input type="text" id="txtIDPassportNo" class="form-control form-control-sm border-primary">
                                </div>
                                <div class="col-sm-5">
                                    <input type="date" id="txtPassportUntilDate" class="form-control form-control-sm">
                                </div>
                            </div>
                            <h6 class="text-success font-weight-bold mt-4 mb-3 border-bottom pb-1"><i class="fas fa-plane-arrival"></i> 2. Passport, Visa & Others</h6>
                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Position / Move-Out</label>
                                <div class="col-sm-3">
                                    <select id="ddlFamilyPos" class="form-control form-control-sm">
                                        @foreach (var p in Model.ListPositions)
                                        {
                                            <option value="@p.Value">@p.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-sm-4">
                                    <div class="custom-control custom-switch mt-1">
                                        <input type="checkbox" class="custom-control-input" id="chkIsMoveOut">
                                        <label class="custom-control-label" for="chkIsMoveOut">Moved Out?</label>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Visa No / Date / Exp</label>
                                <div class="col-sm-3">
                                    <input type="text" id="txtVisaNo" class="form-control form-control-sm">
                                </div>
                                <div class="col-sm-3">
                                    <input type="date" id="txtVisaDate" class="form-control form-control-sm">
                                </div>
                                <div class="col-sm-3">
                                    <input type="date" id="txtVisaExpDate" class="form-control form-control-sm">
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Entry Date / Port</label>
                                <div class="col-sm-4">
                                    <input type="date" id="txtEntryDate" class="form-control form-control-sm">
                                </div>
                                <div class="col-sm-5">
                                    <select id="ddlArrivalPort" class="form-control form-control-sm">
                                        @foreach (var port in Model.ListArrivalPorts)
                                        {
                                            <option value="@port.Value">@port.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Permit / Propose Exp</label>
                                <div class="col-sm-4">
                                    <input type="date" id="txtPermitExpDate" class="form-control form-control-sm">
                                </div>
                                <div class="col-sm-5">
                                    <input type="date" id="txtProposeExpDate" class="form-control form-control-sm">
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">A/D Card / Last Reg</label>
                                <div class="col-sm-4">
                                    <input type="text" id="txtADCardNo" class="form-control form-control-sm">
                                </div>
                                <div class="col-sm-5">
                                    <input type="date" id="txtLastRegDate" class="form-control form-control-sm">
                                </div>
                            </div>

                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Sponsor / Notes</label>
                                <div class="col-sm-4">
                                    <input type="text" id="txtSponsor" class="form-control form-control-sm" placeholder="Sponsor">
                                </div>
                                <div class="col-sm-5">
                                    <textarea id="txtNotes" class="form-control form-control-sm" rows="1" placeholder="Notes"></textarea>
                                </div>
                            </div>
                            <h6 class="text-info font-weight-bold mt-4 mb-3 border-bottom pb-1"><i class="fas fa-building"></i> 3. VAT Information</h6>
                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Company/Vat Code</label>
                                <div class="col-sm-6">
                                    <input type="text" id="txtCompany" class="form-control form-control-sm">
                                </div>
                                <div class="col-sm-3">
                                    <input type="text" id="txtVATCode" class="form-control form-control-sm" placeholder="VAT Code">
                                </div>
                            </div>
                            <div class="form-group row mb-2">
                                <label class="col-sm-3 col-form-label-sm">Address</label>
                                <div class="col-sm-9">
                                    <textarea id="txtAddress" class="form-control form-control-sm" placeholder="Address"></textarea>
                                </div>
                            </div>

                        </div>

                       

                        

                        <div class="col-right p-2 bg-dark d-flex flex-column" style="flex: 0 0 45%; overflow: hidden;">
                            <div class="d-flex align-items-center justify-content-between mb-2 p-2 bg-white rounded">
                                <div class="d-flex align-items-center">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="moveImg(-1)"><i class="fas fa-chevron-left"></i></button>
                                    <span id="img_index_label" class="badge badge-dark mx-2">0/0</span>
                                    <button type="button" class="btn btn-outline-secondary btn-sm mr-2" onclick="moveImg(1)"><i class="fas fa-chevron-right"></i></button>

                                    <select id="ddlDocTypeID" class="form-control form-control-sm font-weight-bold border-primary" style="width: 130px;">
                                        <option value="1">Passport</option>
                                        <option value="2">Visa/Entry</option>
                                        <option value="3">Polish Register</option>
                                        <option value="4">Other</option>
                                    </select>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-warning btn-sm" onclick="recognizeOCR()"><i class="fas fa-magic"></i> OCR</button>
                                    <button type="button" class="btn btn-info btn-sm" onclick="$('#fileUpload').click()"><i class="fas fa-camera"></i> Scan</button>
                                    <input type="file" id="fileUpload" class="d-none" multiple onchange="handleFileUpload(this)">
                                </div>
                            </div>

                            <div class="flex-grow-1 d-flex align-items-center justify-content-center bg-black rounded" style="position: relative; overflow: hidden; background: #1a1a1a; border: 1px solid #444;">
                                <img src="" id="current_img_display" class="img-fluid" style="max-height: 100%; display:none;">
                                <div id="no_img_overlay" class="text-white-50 text-center">
                                    <i class="fas fa-images fa-3x d-block mb-2"></i>
                                    No image scanned
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mt-2">
                                <button type="button" class="btn btn-outline-light btn-sm" onclick="downloadCurrentImg()">
                                    <i class="fas fa-download"></i> Tải về máy
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteCurrentImg()">
                                    <i class="fas fa-trash-alt"></i> Xóa ảnh
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light p-2">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                <button type="button" id="btnSaveTenantDetail" class="btn btn-success btn-sm px-4 shadow">
                    <i class="fas fa-save mr-1"></i> SAVE ALL DATA & IMAGES
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {

    <script src="~/js/Sales/STContract/STContractDetail.js" asp-append-version="true"></script>
}

