@page
@model Sales.STContract.IndexModel
@{
    ViewData["Title"] = "Short Term Contract";
}
@section Styles {
    <style>
        /* 1. Ép Select2 và nút bấm nằm trên cùng 1 hàng */
        .input-group > .select2-container--default {
            flex: 1 1 auto; /* Chiếm toàn bộ không gian còn lại */
            width: 1% !important; /* Mẹo để không bị nhảy xuống dòng */
        }

        /* 2. Fix chiều cao và bo góc cho Select2 khi đi cùng Group */
        .input-group .select2-container--default .select2-selection--single {
            height: 38px !important; /* Chiều cao chuẩn Bootstrap 4 */
            border-top-right-radius: 0 !important;
            border-bottom-right-radius: 0 !important;
            display: flex;
            align-items: center;
            border-color: #ced4da;
        }

        /* 3. Tùy chỉnh nút Xóa (nút x) */
        .btn-clear-select2 {
            border-top-left-radius: 0 !important;
            border-bottom-left-radius: 0 !important;
            border-left: none !important; /* Bỏ viền giữa để trông như một khối */
            background-color: #fff;
            color: #999;
            border-color: #ced4da;
            z-index: 10; /* Đảm bảo nút luôn nằm trên cùng để click */
        }

            .btn-clear-select2:hover {
                color: #dc3545; /* Di chuột vào hiện màu đỏ xóa */
                background-color: #f8f9fa;
            }

        /* 4. Tránh bôi đen văn bản khi click chọn dòng liên tục */
        .contract-row {
            user-select: none;
        }
    </style>
}
<section class="content">
    <div class="container-fluid">
        <div class="row">

            <!-- SEARCH PANEL (LEFT) -->
            <div class="col-md-2">
                <div class="card card-info">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-search"></i> Search
                        </h3>
                    </div>

                    <div class="card-body">
                        <form method="get">

                            <!-- Row 1 -->
                            <div class="form-group">
                                <label>Contract Status</label>
                                <select class="form-control"
                                        asp-for="Filter.StatusID"
                                        asp-items="Model.ContractStatusList">
                                </select>
                            </div>
                            <!-- Row 2 -->
                            <div class="form-group">
                                <label>Apartment</label>
                                <select class="form-control"
                                        asp-for="Filter.ApartmentId"
                                        asp-items="Model.ApartmentList">
                                </select>
                            </div>

                            <!-- Row 3 -->
                            <div class="form-group">
                                <label>Check In Period</label>
                                <div class="input-group input-group-sm" id="date-group-wrapper">
                                    <input type="text" asp-for="Filter.DateRangeIn" class="form-control form-control-sm" id="DateRangeIn" readonly>
                                </div>

                            </div>

                            <!-- Row 4 -->
                            <div class="form-group">
                                <label>Check Out Period</label>
                                <div class="d-flex align-items-center">
                                    <input type="text" asp-for="Filter.DateRangeOut" class="form-control form-control-sm" id="DateRangeOut" readonly>
                                </div>
                            </div>

                            <!-- Row 5 -->
                            <div class="form-group">
                                <label>Company</label>
                                <div class="input-group">
                                    <select id="CompanyId" name="Filter.CompanyId" class="form-control select2"></select>
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-secondary btn-clear-select2" type="button" data-target="#CompanyId">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <!-- Row 6 -->
                            <div class="form-group">
                                <label>Agent Company</label>
                                <div class="input-group">
                                    <select id="AgentCompanyId" name="Filter.AgentCompanyId" class="form-control select2"></select>
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-secondary btn-clear-select2" type="button" data-target="#AgentCompanyId">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Row 7 -->
                            <div class="form-group">
                                <label>Contract No</label>
                                <input class="form-control" asp-for="Filter.ContractNo">
                            </div>

                            <div class="form-group">
                                <label>Customer Name</label>
                                <input class="form-control" asp-for="Filter.CustomerName">
                            </div>

                            <!-- Row 8 -->
                            <button class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Search
                            </button>

                        </form>
                    </div>
                </div>
            </div>

            <!-- RESULT + ACTION (RIGHT) -->
            <div class="col-md-10">
                <!-- RESULT GRID -->
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Contracts</h3>
                        <span class="badge badge-light ml-2" id="total-records-badge">0 records</span>
                        <!-- Pagination info trong header (bên phải) -->
                        <div class="card-tools float-right app-paging-white">
                            <nav aria-label="Page navigation">
                                <div id="pagination-info" class="d-inline-block mr-2" style="padding-top: 0.3rem;">
                                    <small>No records</small>
                                </div>
                                <ul class="pagination pagination-sm mb-0 d-inline-flex" id="pagination">
                                    <!-- Pagination buttons sẽ được thêm bằng JS -->
                                </ul>
                            </nav>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered">
                                <thead class="thead-light">
                                    <tr>
                                        <th></th>
                                        <th>Contract No</th>
                                        <th>Apartment</th>
                                        <th>Customer</th>
                                        <th>Company</th>
                                        <th>From</th>
                                        <th>To</th>
                                        <th>Status</th>
                                        <th class="d-none">Contract Status ID</th> <!-- Header cho cột ẩn -->
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in Model.Contracts)
                                    {
                                        <tr data-id="@c.ContractID">
                                            <td>
                                                <input type="radio" name="selectedContract">
                                            </td>
                                            <td style="white-space: nowrap;">
                                                <a href="javascript:void(0)" class="contract-no-link text-bold" style="text-decoration: underline;">
                                                    @c.ContractNo
                                                </a>
                                            </td>

                                            <td>@c.ApartmentNo</td>
                                            <td style="white-space: nowrap;">@c.CustomerName</td> <!-- Không xuống dòng -->
                                            <td class="vni-font"  style="white-space: nowrap;">@c.CompanyName</td> <!-- Không xuống dòng -->
                                            <td>@c.ContractFromDate</td>
                                            <td>@c.ContractToDate</td>
                                            <td>@c.StatusName </td>
                                            <td style="display: none;">@c.StatusID</td> <!-- Cột ẩn chứa ContractStatus -->
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- ACTION PANEL -->
                <div class="card card-outline card-primary">
                    <div class="card-footer p-2 text-center">
                        @* Nút Add: Quyền 3 - Chỉ hiện nếu có quyền từ lúc Load trang *@
                        @if (Model.PagePerm.HasPermission(3))
                        {
                            <button class="btn btn-success btn-sm" id="btnAdd">
                                <i class="fas fa-plus"></i> Add New
                            </button>
                        }

                        @* Các nút nghiệp vụ khác: Luôn ẩn (d-none) mặc định *@
                        <button class="btn btn-info btn-sm d-none" id="btnDeposit">
                            <i class="fas fa-money-bill-wave"></i> Deposit
                        </button>

                        <button class="btn btn-outline-primary btn-sm d-none" id="btnCheckIn">
                            <i class="fas fa-sign-in-alt"></i> Check In
                        </button>

                        <button class="btn btn-warning btn-sm d-none" id="btnEditMember">
                            <i class="fas fa-users-cog"></i> Members
                        </button>

                        <button class="btn btn-primary btn-sm d-none" id="btnCopy">
                            <i class="fas fa-copy"></i> Copy
                        </button>

                        <button class="btn btn-dark btn-sm d-none" id="btnChangeStatus">
                            <i class="fas fa-exchange-alt"></i> Status
                        </button>

                        <button class="btn btn-secondary btn-sm d-none" id="btnAdjustDate">
                            <i class="fas fa-calendar-alt"></i> Adjust Date
                        </button>

                        <button class="btn btn-outline-danger btn-sm d-none" id="btnCheckOut">
                            <i class="fas fa-sign-out-alt"></i> Check Out
                        </button>

                        <button class="btn btn-danger btn-sm d-none" id="btnCancel">
                            <i class="fas fa-ban"></i> Cancel
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<div class="modal fade" id="changeStatusModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Lý do thay đổi trạng thái</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="targetContractId" />
                <input type="hidden" id="targetStatus" />
                <textarea id="changeReason" class="form-control" rows="3" placeholder="Vui lòng nhập lý do..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="submitStatusChange()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
    <script src="~/js/Sales/STContract/index.js" asp-append-version="true"></script>
    <script>
        $(function () {
            // Global variable từ server
            const defaultPageSize = @Model.DefaultPageSize; // Lấy trực tiếp từ Model

            // Khởi tạo daterange theo common.js. Nếu muốn từ ngày đến ngày liên hệ với nhau thì khởi tạo
            window.initSimpleDateRange('DateRangeIn', null, null, {
                linkedCalendars: false
            });

            window.initSimpleDateRange('DateRangeOut', null, null, {
                linkedCalendars: false
            });


        });
    </script>

}
