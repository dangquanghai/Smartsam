@model List<SmartSam.Models.UserMenuDto>
@using System.Linq

@{
    var currentPath = ViewContext.HttpContext.Request.Path.Value ?? "";
}

<ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

    @foreach (var moduleGroup in Model.GroupBy(x => x.ModuleName))
    {
        // Lấy thông tin module từ bản ghi đầu tiên trong nhóm
        var firstItem = moduleGroup.First();

        // Nếu database trống ModuleIcon, dùng mặc định 'fas fa-folder'
        var mIcon = string.IsNullOrEmpty(firstItem.ModuleIcon) ? "fas fa-folder" : firstItem.ModuleIcon;

        var isModuleActive = moduleGroup.Any(f => currentPath.StartsWith(f.Url, StringComparison.OrdinalIgnoreCase));

        <li class="nav-item @(isModuleActive ? "menu-open" : "")">
            <a href="#" class="nav-link @(isModuleActive ? "active" : "")">
                @* Hiển thị Icon của Module từ DB *@
                <i class="nav-icon @mIcon"></i>
                <p>
                    @moduleGroup.Key
                    <i class="right fas fa-angle-left"></i>
                </p>
            </a>

            <ul class="nav nav-treeview">
                @foreach (var function in moduleGroup)
                {
                    var isFunctionActive = currentPath.Equals(function.Url, StringComparison.OrdinalIgnoreCase);

                    // Nếu database trống FunctionIcon, dùng mặc định 'far fa-circle' cho thanh thoát
                    var fIcon = string.IsNullOrEmpty(function.FunctionIcon) ? "far fa-circle" : function.FunctionIcon;

                    <li class="nav-item">
                        <a href="@function.Url" class="nav-link @(isFunctionActive ? "active" : "")">
                            @* Hiển thị Icon của Function từ DB *@
                            <i class="@fIcon nav-icon"></i>
                            <p>@function.FunctionName</p>
                        </a>
                    </li>
                }
            </ul>
        </li>
    }
</ul>